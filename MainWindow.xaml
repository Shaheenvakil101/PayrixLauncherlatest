                            <!-- A5: Common API Patterns -->
                            <Border Background="{DynamicResource CardBg}" CornerRadius="14" Padding="22,18" Margin="0,0,0,20" BorderBrush="{DynamicResource CardBorder}" BorderThickness="1">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                        <Border Width="32" Height="32" CornerRadius="8" Margin="0,0,12,0">
                                            <Border.Background><SolidColorBrush Color="#7C3AED" Opacity="0.2"/></Border.Background>
