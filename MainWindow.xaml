                                        <TextBlock Grid.Column="1" FontSize="12" Foreground="{DynamicResource SubText}" TextWrapping="Wrap">POST .../RecordCount — returns total row count matching the filter. Same body as list endpoint.</TextBlock>
                                    </Grid>
                                    <Grid Margin="0,0,0,10">
                                        <Grid.ColumnDefinitions><ColumnDefinition Width="160"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                        <TextBlock Text="RecordCountWithLimit" FontWeight="SemiBold" Foreground="#4ADE80" FontSize="12" VerticalAlignment="Top"/>
