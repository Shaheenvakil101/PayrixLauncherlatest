                                        <TextBlock Grid.Column="1" FontSize="12" Foreground="{DynamicResource SubText}" TextWrapping="Wrap"><Run FontWeight="SemiBold" Foreground="{DynamicResource PrimaryText}">Set an environment.</Run>  Click the environment selector (top-right of HTTP Client). Set baseUrl to your target server.</TextBlock>
                                    </Grid>
                                    <Grid Margin="0,0,0,8"><Grid.ColumnDefinitions><ColumnDefinition Width="28"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
