                                        <Grid Margin="0,0,0,8"><Grid.ColumnDefinitions><ColumnDefinition Width="40"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><TextBlock Text="7" FontWeight="Bold" Foreground="#A78BFA" FontSize="13"/><TextBlock Grid.Column="1" Text="ACH Debit (pull)" FontSize="12" Foreground="{DynamicResource SubText}"/></Grid>
                                        <Grid Margin="0,0,0,8"><Grid.ColumnDefinitions><ColumnDefinition Width="40"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><TextBlock Text="8" FontWeight="Bold" Foreground="#A78BFA" FontSize="13"/><TextBlock Grid.Column="1" Text="ACH Credit (push)" FontSize="12" Foreground="{DynamicResource SubText}"/></Grid>
                                        <Grid Margin="0,0,0,8"><Grid.ColumnDefinitions><ColumnDefinition Width="40"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><TextBlock Text="9" FontWeight="Bold" Foreground="#4ADE80" FontSize="13"/><TextBlock Grid.Column="1" Text="Void" FontSize="12" Foreground="{DynamicResource SubText}"/></Grid>
                                    </UniformGrid>
                                </StackPanel>
                            </Border>

                            <!-- Section 4: ACH / Card Flows -->
                            <Border Background="{DynamicResource CardBg}" CornerRadius="14" Padding="22,18" Margin="0,0,0,14" BorderBrush="{DynamicResource CardBorder}" BorderThickness="1">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                                        <Border Width="32" Height="32" CornerRadius="8" Margin="0,0,12,0">
                                            <Border.Background><SolidColorBrush Color="#7C3AED" Opacity="0.2"/></Border.Background>
                                            <TextBlock Text="⇄" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#A78BFA"/>
                                        </Border>
                                        <TextBlock Text="ACH / Card Payment Flows" FontSize="15" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryText}" VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <Border Height="1" Background="{DynamicResource CardBorder}" Margin="0,0,0,14"/>
                                    <Grid Margin="0,0,20,12"><Grid.ColumnDefinitions><ColumnDefinition Width="100"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                        <TextBlock Text="ACH Flow" FontWeight="SemiBold" Foreground="#A78BFA" FontSize="12.5" VerticalAlignment="Top"/>
                                        <TextBlock Grid.Column="1" FontSize="12" Foreground="{DynamicResource SubText}" TextWrapping="Wrap">Customer submits bank account → Payrix initiates NACHA file → Bank processes (1–3 business days) → Status: Pending → Settled (4) or Returned (5). Use webhook type ACH Return to test return scenarios.</TextBlock>
                                    </Grid>
                                    <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="100"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                        <TextBlock Text="Card Flow" FontWeight="SemiBold" Foreground="#4ADE80" FontSize="12.5" VerticalAlignment="Top"/>
                                        <TextBlock Grid.Column="1" FontSize="12" Foreground="{DynamicResource SubText}" TextWrapping="Wrap">Customer submits card → Auth request to card network (Visa/MC) → Capture triggers settlement batch → Status: Pending (1) → Captured (3) → Settled. Refunds create a new transaction (type 5) linked via Fortxn.</TextBlock>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <!-- Section 5: Testing Instructions -->
                            <Border Background="{DynamicResource CardBg}" CornerRadius="14" Padding="22,18" Margin="0,0,0,14" BorderBrush="{DynamicResource CardBorder}" BorderThickness="1">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                                        <Border Width="32" Height="32" CornerRadius="8" Margin="0,0,12,0">
                                            <Border.Background><SolidColorBrush Color="#FBBF24" Opacity="0.2"/></Border.Background>
                                            <TextBlock Text="🧪" FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <TextBlock Text="Testing Instructions" FontSize="15" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryText}" VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <Border Height="1" Background="{DynamicResource CardBorder}" Margin="0,0,0,14"/>
                                    <StackPanel>
                                        <TextBlock FontSize="12.5" Foreground="{DynamicResource PrimaryText}" FontWeight="SemiBold" Margin="0,0,0,6">Webhook Test Setup:</TextBlock>
                                        <TextBlock FontSize="12" Foreground="{DynamicResource SubText}" TextWrapping="Wrap" Margin="0,0,0,10">1. Navigate to Webhook Tests tab and configure the target URL (Local/Staging/Sprint).&#x0a;2. Set the Entity Custom field: AccountID,CompanyID (use Fetch from DB button to auto-populate).&#x0a;3. Select the webhook type (ACH Return, ACH Refund, Card Refund, Settlement, Withdrawal).&#x0a;4. Fill in the Transaction ID and Amount fields.&#x0a;5. Click Run to send the POST and view the response.</TextBlock>
                                        <TextBlock FontSize="12.5" Foreground="{DynamicResource PrimaryText}" FontWeight="SemiBold" Margin="0,6,0,6">Sandbox Credentials:</TextBlock>
                                        <Border Background="{DynamicResource DbConfigBg}" CornerRadius="8" Padding="14,10" BorderBrush="{DynamicResource DbConfigBorder}" BorderThickness="1">
                                            <StackPanel>
                                                <TextBlock FontSize="11.5" Foreground="{DynamicResource SubText}"><Run FontWeight="SemiBold" Foreground="{DynamicResource PrimaryText}">API:</Run>  test.api.payrix.com</TextBlock>
                                                <TextBlock FontSize="11.5" Foreground="{DynamicResource SubText}" Margin="0,4,0,0"><Run FontWeight="SemiBold" Foreground="{DynamicResource PrimaryText}">Portal:</Run>  test-portal.payrix.com</TextBlock>
                                                <TextBlock FontSize="11.5" Foreground="{DynamicResource SubText}" Margin="0,4,0,0"><Run FontWeight="SemiBold" Foreground="{DynamicResource PrimaryText}">Test Card:</Run>  4111 1111 1111 1111  Exp: 12/26  CVV: 999</TextBlock>
                                                <TextBlock FontSize="11.5" Foreground="{DynamicResource SubText}" Margin="0,4,0,0"><Run FontWeight="SemiBold" Foreground="{DynamicResource PrimaryText}">Test ACH:</Run>  Routing: 021000021  Account: 9900000002</TextBlock>
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <!-- Section 6: QA / Dev Guide -->
                            <Border Background="{DynamicResource CardBg}" CornerRadius="14" Padding="22,18" Margin="0,0,0,0" BorderBrush="{DynamicResource CardBorder}" BorderThickness="1">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                                        <Border Width="32" Height="32" CornerRadius="8" Margin="0,0,12,0">
                                            <Border.Background><SolidColorBrush Color="#F87171" Opacity="0.2"/></Border.Background>
                                            <TextBlock Text="🛠" FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <TextBlock Text="Internal QA / Dev Guide" FontSize="15" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryText}" VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <Border Height="1" Background="{DynamicResource CardBorder}" Margin="0,0,0,14"/>
                                    <Grid Margin="0,0,0,10"><Grid.ColumnDefinitions><ColumnDefinition Width="130"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                        <TextBlock Text="Find CompanyID" FontWeight="SemiBold" Foreground="#F87171" FontSize="12.5"/>
                                        <TextBlock Grid.Column="1" FontSize="12" Foreground="{DynamicResource SubText}" TextWrapping="Wrap">Enter a Payrix transaction ID in the DB Config panel → click Fetch. Queries ServiceEntity → Company in the payment-service DB.</TextBlock>
                                    </Grid>
                                    <Grid Margin="0,0,0,10"><Grid.ColumnDefinitions><ColumnDefinition Width="130"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                        <TextBlock Text="Find AccountID" FontWeight="SemiBold" Foreground="#F87171" FontSize="12.5"/>
                                        <TextBlock Grid.Column="1" FontSize="12" Foreground="{DynamicResource SubText}" TextWrapping="Wrap">Enter the user email in the Email field → click ▶ Fetch button next to it. Queries Account.Email in the BQECoreHost main DB.</TextBlock>
                                    </Grid>
                                    <Grid Margin="0,0,0,10"><Grid.ColumnDefinitions><ColumnDefinition Width="130"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                        <TextBlock Text="Decrypt IDs" FontWeight="SemiBold" Foreground="#F87171" FontSize="12.5"/>
                                        <TextBlock Grid.Column="1" FontSize="12" Foreground="{DynamicResource SubText}" TextWrapping="Wrap">Use Crypto tab to decode encrypted AccountID/CompanyID tokens from BQE Core URLs or webhook payloads.</TextBlock>
                                    </Grid>
                                    <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="130"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                        <TextBlock Text="Discrepancies" FontWeight="SemiBold" Foreground="#F87171" FontSize="12.5"/>
                                        <TextBlock Grid.Column="1" FontSize="12" Foreground="{DynamicResource SubText}" TextWrapping="Wrap">Red discrepancy badges in the Transactions grid indicate Total ≠ Approved+Tax. Click the row to inspect the raw JSON for the full breakdown.</TextBlock>
                                    </Grid>
                                </StackPanel>
                            </Border>

                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <!-- Tab 10: Dashboard -->
                <TabItem x:Name="TabItem10" Header="📊  Dashboard"      Visibility="Collapsed">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>  <!-- header -->
                            <RowDefinition Height="*"/>     <!-- body -->
                            <RowDefinition Height="Auto"/>  <!-- footer -->
                        </Grid.RowDefinitions>

                        <!-- ── Header bar ── -->
                        <Border Grid.Row="0" Padding="20,14"
                                BorderBrush="{DynamicResource CardBorder}" BorderThickness="0,0,0,1"
                                Background="{DynamicResource CardBg}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <!-- Left: purple icon pill + title -->
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <Border Width="42" Height="42" CornerRadius="10"
                                            Background="#F5F3FF" Margin="0,0,12,0">
                                        <TextBlock Text="📊" FontSize="20"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="Dashboard" FontSize="16" FontWeight="Bold"
                                                   Foreground="{DynamicResource PrimaryText}"/>
                                        <TextBlock Text="Live overview of your Payrix payment activity"
                                                   FontSize="11.5" Foreground="{DynamicResource SubText}"/>
                                    </StackPanel>
                                </StackPanel>
                                <!-- Right: env badge + export button -->
                                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                    <Border CornerRadius="6" Padding="10,5" Margin="0,0,10,0"
                                            Background="#1A4F46E5" BorderBrush="#7C3AED" BorderThickness="1">
                                        <TextBlock x:Name="DashEnvLabel" Text="Sandbox"
                                                   FontSize="11" FontWeight="SemiBold" Foreground="#4ADE80"/>
                                    </Border>
                                    <Button Content="⬇  Export Report" FontSize="12" Padding="12,6"
                                            Background="#7C3AED" Foreground="White" BorderThickness="0"
                                            Cursor="Hand" Click="ExportDashboardCsv_Click">
                                        <Button.Resources>
                                            <Style TargetType="Border">
                                                <Setter Property="CornerRadius" Value="6"/>
                                            </Style>
                                        </Button.Resources>
                                    </Button>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- ── Body ── -->
                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                            <StackPanel Margin="24,20" DataContext="{Binding RelativeSource={RelativeSource AncestorType=Window}}">

                                <!-- ── KPI Row (4 cards) ── -->
                                <UniformGrid Columns="4" Margin="0,0,0,20">

                                    <!-- Total Transactions -->
                                    <Border Background="{DynamicResource CardBg}" CornerRadius="12"
                                            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                                            Margin="0,0,12,0" Padding="18,16">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel>
                                                <TextBlock Text="Total Transactions" FontSize="11"
                                                           Foreground="{DynamicResource SubText}" Margin="0,0,0,8"/>
                                                <TextBlock Text="{Binding OverviewTxnCount}" FontSize="28"
                                                           FontWeight="Bold" Foreground="{DynamicResource FgDefault}"/>
                                                <TextBlock Margin="0,6,0,0" FontSize="11"
                                                           Foreground="{DynamicResource SubText}">
                                                    <Run Text="{Binding OverviewAchCount, Mode=OneWay}"/>
                                                    <Run Text=" ACH · "/>
                                                    <Run Text="{Binding OverviewCardCount, Mode=OneWay}"/>
                                                    <Run Text=" Card"/>
                                                </TextBlock>
                                            </StackPanel>
                                            <Border Grid.Column="1" Width="44" Height="44" CornerRadius="10"
                                                    Background="{DynamicResource GreenIconBadgeBg}" VerticalAlignment="Top">
                                                <TextBlock Text="💳" FontSize="20"
                                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                        </Grid>
                                    </Border>

                                    <!-- Total Volume -->
                                    <Border Background="{DynamicResource CardBg}" CornerRadius="12"
                                            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                                            Margin="0,0,12,0" Padding="18,16">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel>
                                                <TextBlock Text="Total Volume" FontSize="11"
                                                           Foreground="{DynamicResource SubText}" Margin="0,0,0,8"/>
                                                <TextBlock Text="{Binding DashTotalVolume}" FontSize="28"
                                                           FontWeight="Bold" Foreground="#A78BFA"/>
                                                <TextBlock Margin="0,6,0,0" FontSize="11"
                                                           Foreground="{DynamicResource SubText}">
                                                    <Run Text="Avg "/>
                                                    <Run Text="{Binding DashAvgAmount, Mode=OneWay}"/>
                                                    <Run Text=" per txn"/>
                                                </TextBlock>
                                            </StackPanel>
                                            <Border Grid.Column="1" Width="44" Height="44" CornerRadius="10"
                                                    Background="{DynamicResource GreenIconBadgeBg}" VerticalAlignment="Top">
                                                <TextBlock Text="💰" FontSize="20"
                                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                        </Grid>
                                    </Border>

                                    <!-- Settlement Rate -->
                                    <Border Background="{DynamicResource CardBg}" CornerRadius="12"
                                            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                                            Margin="0,0,12,0" Padding="18,16">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel>
                                                <TextBlock Text="Settlement Rate" FontSize="11"
                                                           Foreground="{DynamicResource SubText}" Margin="0,0,0,8"/>
                                                <TextBlock Text="{Binding DashSettlementRate}" FontSize="28"
                                                           FontWeight="Bold" Foreground="#7C3AED"/>
                                                <!-- progress bar -->
                                                <Grid Margin="0,8,0,0" Height="6">
                                                    <Border CornerRadius="3" Background="{DynamicResource BorderBrush}"/>
                                                    <Border CornerRadius="3" Background="#7C3AED" HorizontalAlignment="Left">
                                                        <Border.Width>
                                                            <MultiBinding Converter="{StaticResource PctToWidthConverter}">
                                                                <Binding Path="DashSettlementRateDouble"/>
                                                                <Binding RelativeSource="{RelativeSource AncestorType=Grid}" Path="ActualWidth"/>
                                                            </MultiBinding>
                                                        </Border.Width>
                                                    </Border>
                                                </Grid>
                                                <TextBlock Margin="0,6,0,0" FontSize="11"
                                                           Foreground="{DynamicResource SubText}">
                                                    <Run Text="{Binding OverviewSettledCount, Mode=OneWay}"/>
                                                    <Run Text=" settled · "/>
                                                    <Run Text="{Binding DashInProgressCount, Mode=OneWay}"/>
                                                    <Run Text=" in progress"/>
                                                </TextBlock>
                                            </StackPanel>
                                            <Border Grid.Column="1" Width="44" Height="44" CornerRadius="10"
                                                    Background="{DynamicResource GreenIconBadgeBg}" VerticalAlignment="Top">
                                                <TextBlock Text="📈" FontSize="20"
                                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                        </Grid>
                                    </Border>

                                    <!-- Active Merchants -->
                                    <Border Background="{DynamicResource CardBg}" CornerRadius="12"
                                            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                                            Padding="18,16">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel>
                                                <TextBlock Text="Active Merchants" FontSize="11"
                                                           Foreground="{DynamicResource SubText}" Margin="0,0,0,8"/>
                                                <TextBlock Text="{Binding DashActiveMerchants}" FontSize="28"
                                                           FontWeight="Bold" Foreground="#FCD34D"/>
                                                <TextBlock Margin="0,6,0,0" FontSize="11"
                                                           Foreground="{DynamicResource SubText}">
                                                    <Run Text="{Binding DashTotalMerchants, Mode=OneWay}"/>
                                                    <Run Text=" total merchants"/>
                                                </TextBlock>
                                            </StackPanel>
                                            <Border Grid.Column="1" Width="44" Height="44" CornerRadius="10"
                                                    Background="#FFFBEB" VerticalAlignment="Top">
                                                <TextBlock Text="🏪" FontSize="20"
                                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                        </Grid>
                                    </Border>

                                </UniformGrid>

                                <!-- ── Middle row: Status Breakdown | Payment Methods | Volume Trend ── -->
                                <Grid Margin="0,0,0,20">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="14"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="14"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Status Breakdown -->
                                    <Border Grid.Column="0" Background="{DynamicResource CardBg}" CornerRadius="12"
                                            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Padding="18,16">
                                        <StackPanel>
                                            <TextBlock Text="Transaction Status Breakdown" FontSize="13"
                                                       FontWeight="SemiBold" Foreground="{DynamicResource FgDefault}"
                                                       Margin="0,0,0,14"/>
                                            <!-- Donut chart -->
                                            <Grid HorizontalAlignment="Center" Margin="0,0,0,16" Width="130" Height="130"
                                                  Loaded="DashDonutChart_Loaded">
                                                <Ellipse Width="130" Height="130" Stroke="#E2E8F0" StrokeThickness="22" Fill="Transparent"/>
                                                <Path x:Name="DashDonutGreenArc"  Stroke="#A78BFA" StrokeThickness="22" Fill="Transparent" StrokeStartLineCap="Flat" StrokeEndLineCap="Flat"/>
                                                <Path x:Name="DashDonutBlueArc"   Stroke="#7C3AED" StrokeThickness="22" Fill="Transparent" StrokeStartLineCap="Flat" StrokeEndLineCap="Flat"/>
                                                <Path x:Name="DashDonutAmberArc"  Stroke="#F59E0B" StrokeThickness="22" Fill="Transparent" StrokeStartLineCap="Flat" StrokeEndLineCap="Flat"/>
                                                <Path x:Name="DashDonutRedArc"    Stroke="#EF4444" StrokeThickness="22" Fill="Transparent" StrokeStartLineCap="Flat" StrokeEndLineCap="Flat"/>
                                                <Path x:Name="DashDonutOrangeArc" Stroke="#F97316" StrokeThickness="22" Fill="Transparent" StrokeStartLineCap="Flat" StrokeEndLineCap="Flat"/>
                                                <Path x:Name="DashDonutPurpleArc" Stroke="#8B5CF6" StrokeThickness="22" Fill="Transparent" StrokeStartLineCap="Flat" StrokeEndLineCap="Flat"/>
                                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                                    <TextBlock x:Name="DashDonutCenterLabel" Text="{Binding DashTotalCount}"
                                                               FontSize="22" FontWeight="Bold"
                                                               Foreground="{DynamicResource FgDefault}"
                                                               HorizontalAlignment="Center"/>
                                                    <TextBlock Text="total" FontSize="10"
                                                               Foreground="{DynamicResource SubText}"
                                                               HorizontalAlignment="Center"/>
                                                </StackPanel>
                                            </Grid>
                                            <!-- Approved -->
                                            <Grid Margin="0,0,0,10">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="56"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                    <Border Width="8" Height="8" CornerRadius="4" Background="#A78BFA" Margin="0,0,8,0"/>
                                                    <TextBlock Text="Approved" FontSize="12" Foreground="{DynamicResource FgDefault}"/>
                                                </StackPanel>
                                                <TextBlock Grid.Column="1" Text="{Binding DashApprovedCount}"
                                                           FontSize="13" FontWeight="SemiBold"
                                                           Foreground="#A78BFA" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                                <TextBlock Grid.Column="2" Text="{Binding DashApprovedPct}"
                                                           FontSize="11" Foreground="{DynamicResource SubText}" VerticalAlignment="Center"/>
                                            </Grid>
                                            <!-- Captured -->
                                            <Grid Margin="0,0,0,10">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="56"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                    <Border Width="8" Height="8" CornerRadius="4" Background="#7C3AED" Margin="0,0,8,0"/>
                                                    <TextBlock Text="Captured" FontSize="12" Foreground="{DynamicResource FgDefault}"/>
                                                </StackPanel>
                                                <TextBlock Grid.Column="1" Text="{Binding DashCapturedCount}"
                                                           FontSize="13" FontWeight="SemiBold"
                                                           Foreground="#7C3AED" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                                <TextBlock Grid.Column="2" Text="{Binding DashCapturedPct}"
                                                           FontSize="11" Foreground="{DynamicResource SubText}" VerticalAlignment="Center"/>
                                            </Grid>
                                            <!-- Pending -->
                                            <Grid Margin="0,0,0,10">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="56"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                    <Border Width="8" Height="8" CornerRadius="4" Background="#F59E0B" Margin="0,0,8,0"/>
                                                    <TextBlock Text="Pending" FontSize="12" Foreground="{DynamicResource FgDefault}"/>
                                                </StackPanel>
                                                <TextBlock Grid.Column="1" Text="{Binding OverviewPendingCount}"
                                                           FontSize="13" FontWeight="SemiBold"
                                                           Foreground="#FCD34D" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                                <TextBlock Grid.Column="2" Text="{Binding DashPendingPct}"
                                                           FontSize="11" Foreground="{DynamicResource SubText}" VerticalAlignment="Center"/>
                                            </Grid>
                                            <!-- Declined -->
                                            <Grid Margin="0,0,0,10">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="56"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                    <Border Width="8" Height="8" CornerRadius="4" Background="#EF4444" Margin="0,0,8,0"/>
                                                    <TextBlock Text="Declined" FontSize="12" Foreground="{DynamicResource FgDefault}"/>
                                                </StackPanel>
                                                <TextBlock Grid.Column="1" Text="{Binding DashDeclinedCount}"
                                                           FontSize="13" FontWeight="SemiBold"
                                                           Foreground="#EF4444" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                                <TextBlock Grid.Column="2" Text="{Binding DashDeclinedPct}"
                                                           FontSize="11" Foreground="{DynamicResource SubText}" VerticalAlignment="Center"/>
                                            </Grid>
                                            <!-- Error / Failed -->
                                            <Grid Margin="0,0,0,10">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="56"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                    <Border Width="8" Height="8" CornerRadius="4" Background="#F97316" Margin="0,0,8,0"/>
                                                    <TextBlock Text="Error / Failed" FontSize="12" Foreground="{DynamicResource FgDefault}"/>
                                                </StackPanel>
                                                <TextBlock Grid.Column="1" Text="{Binding DashErrorCount}"
                                                           FontSize="13" FontWeight="SemiBold"
                                                           Foreground="#F97316" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                                <TextBlock Grid.Column="2" Text="{Binding DashErrorPct}"
                                                           FontSize="11" Foreground="{DynamicResource SubText}" VerticalAlignment="Center"/>
                                            </Grid>
                                            <!-- ACH Settled / Returned -->
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="56"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                    <Border Width="8" Height="8" CornerRadius="4" Background="#8B5CF6" Margin="0,0,8,0"/>
                                                    <TextBlock Text="ACH Settled / Returned" FontSize="12" Foreground="{DynamicResource FgDefault}"/>
                                                </StackPanel>
                                                <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="0,0,8,0">
                                                    <TextBlock Text="{Binding DashSettledAchCount}" FontSize="13"
                                                               FontWeight="SemiBold" Foreground="#8B5CF6" VerticalAlignment="Center"/>
                                                    <TextBlock Text=" / " FontSize="13" Foreground="{DynamicResource SubText}" VerticalAlignment="Center"/>
                                                    <TextBlock Text="{Binding DashReturnedCount}" FontSize="13"
                                                               FontWeight="SemiBold" Foreground="#8B5CF6" VerticalAlignment="Center"/>
                                                </StackPanel>
                                                <TextBlock Grid.Column="2" Text="{Binding DashAchPct}"
                                                           FontSize="11" Foreground="{DynamicResource SubText}" VerticalAlignment="Center"/>
                                            </Grid>
                                        </StackPanel>
                                    </Border>

                                    <!-- Payment Method Split -->
                                    <Border Grid.Column="2" Background="{DynamicResource CardBg}" CornerRadius="12"
                                            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Padding="18,16">
                                        <StackPanel>
                                            <TextBlock Text="Payment Method Split" FontSize="13" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource FgDefault}" Margin="0,0,0,14"/>
                                            <!-- Card row -->
                                            <Grid Margin="0,0,0,14">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel>
                                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                                        <Border Width="8" Height="8" CornerRadius="4" Background="#7C3AED" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                                        <TextBlock Text="Card" FontSize="12.5" FontWeight="SemiBold" Foreground="{DynamicResource FgDefault}"/>
                                                    </StackPanel>
                                                    <TextBlock FontSize="22" FontWeight="Bold" Foreground="#7C3AED">
                                                        <Run Text="{Binding OverviewCardCount, Mode=OneWay}"/>
                                                        <Run Text=" txns" FontSize="12" Foreground="{DynamicResource SubText}"/>
                                                    </TextBlock>
                                                    <TextBlock Text="{Binding DashCardPct}" FontSize="11"
                                                               Foreground="{DynamicResource SubText}" Margin="0,2,0,0"/>
                                                </StackPanel>
                                                <Border Grid.Column="1" CornerRadius="6" Padding="10,4"
                                                        Background="#1A3B82F6" BorderBrush="#7C3AED" BorderThickness="1"
                                                        VerticalAlignment="Center">
                                                    <TextBlock Text="Credit / Debit" FontSize="10.5" Foreground="#7C3AED"/>
                                                </Border>
                                            </Grid>
                                            <Border Height="1" Background="{DynamicResource BorderBrush}" Margin="0,0,0,14"/>
                                            <!-- ACH row -->
                                            <Grid Margin="0,0,0,14">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel>
                                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                                        <Border Width="8" Height="8" CornerRadius="4" Background="#8B5CF6" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                                        <TextBlock Text="ACH / eCheck" FontSize="12.5" FontWeight="SemiBold" Foreground="{DynamicResource FgDefault}"/>
                                                    </StackPanel>
                                                    <TextBlock FontSize="22" FontWeight="Bold" Foreground="#8B5CF6">
                                                        <Run Text="{Binding OverviewAchCount, Mode=OneWay}"/>
                                                        <Run Text=" txns" FontSize="12" Foreground="{DynamicResource SubText}"/>
                                                    </TextBlock>
                                                    <TextBlock Text="{Binding DashAchMethodPct}" FontSize="11"
                                                               Foreground="{DynamicResource SubText}" Margin="0,2,0,0"/>
                                                </StackPanel>
                                                <Border Grid.Column="1" CornerRadius="6" Padding="10,4"
                                                        Background="#1A8B5CF6" BorderBrush="#8B5CF6" BorderThickness="1"
                                                        VerticalAlignment="Center">
                                                    <TextBlock Text="Bank Transfer" FontSize="10.5" Foreground="#8B5CF6"/>
                                                </Border>
                                            </Grid>
                                            <Border Height="1" Background="{DynamicResource BorderBrush}" Margin="0,0,0,14"/>
                                            <!-- Volume mini-summary -->
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel>
                                                    <TextBlock Text="Approved Volume" FontSize="10.5"
                                                               Foreground="{DynamicResource SubText}" Margin="0,0,0,3"/>
                                                    <TextBlock Text="{Binding DashApprovedAmount}" FontSize="14"
                                                               FontWeight="Bold" Foreground="#A78BFA"/>
                                                </StackPanel>
                                                <StackPanel Grid.Column="1">
                                                    <TextBlock Text="Avg per Transaction" FontSize="10.5"
                                                               Foreground="{DynamicResource SubText}" Margin="0,0,0,3"/>
                                                    <TextBlock Text="{Binding DashAvgAmount}" FontSize="14"
                                                               FontWeight="Bold" Foreground="{DynamicResource FgDefault}"/>
                                                </StackPanel>
                                            </Grid>
                                        </StackPanel>
                                    </Border>

                                    <!-- Volume Trend placeholder -->
                                    <Border Grid.Column="4" Background="{DynamicResource CardBg}" CornerRadius="12"
                                            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Padding="18,16">
                                        <StackPanel>
                                            <Grid Margin="0,0,0,14">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="Volume Trend" FontSize="13" FontWeight="SemiBold"
                                                           Foreground="{DynamicResource FgDefault}" VerticalAlignment="Center"/>
                                                <Button Grid.Column="1" Content="View Transactions →"
                                                        FontSize="11" Background="Transparent"
                                                        Foreground="#7C3AED" BorderThickness="0" Cursor="Hand"
                                                        VerticalAlignment="Center" Click="NavToTransactions_Click"/>
                                            </Grid>
                                            <!-- settled volume highlight -->
                                            <Border CornerRadius="10" Padding="14,12" Margin="0,0,0,12"
                                                    Background="{DynamicResource GreenHighlightBg}" BorderBrush="{DynamicResource GreenHighlightBorder}" BorderThickness="1">
                                                <StackPanel>
                                                    <TextBlock Text="Settled Volume" FontSize="11"
                                                               Foreground="{DynamicResource GreenHighlightFg}" Margin="0,0,0,4"/>
                                                    <TextBlock Text="{Binding OverviewSettledAmount}" FontSize="20"
                                                               FontWeight="Bold" Foreground="{DynamicResource GreenHighlightFg}"/>
                                                    <TextBlock Text="{Binding DashSettledVolumePct}" FontSize="11"
                                                               Foreground="{DynamicResource GreenHighlightFg}" Margin="0,2,0,0"/>
                                                </StackPanel>
                                            </Border>
                                            <!-- refunded highlight -->
                                            <Border CornerRadius="10" Padding="14,12"
                                                    Background="{DynamicResource RedHighlightBg}" BorderBrush="{DynamicResource RedHighlightBorder}" BorderThickness="1">
                                                <StackPanel>
                                                    <TextBlock Text="Refunded Amount" FontSize="11"
                                                               Foreground="{DynamicResource RedHighlightFg}" Margin="0,0,0,4"/>
                                                    <TextBlock Text="{Binding DashRefundedAmount}" FontSize="20"
                                                               FontWeight="Bold" Foreground="{DynamicResource RedHighlightFg}"/>
                                                </StackPanel>
                                            </Border>
                                        </StackPanel>
                                    </Border>

                                </Grid>

                                <!-- ── Bottom 6-card stat row ── -->
                                <UniformGrid Columns="6" Margin="0,0,0,20">
                                    <!-- Settled Transactions -->
                                    <Border Background="{DynamicResource CardBg}" CornerRadius="10"
                                            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                                            Margin="0,0,10,0" Padding="14,12">
                                        <StackPanel>
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                                <Border Width="28" Height="28" CornerRadius="6" Background="{DynamicResource GreenIconBadgeBg}" Margin="0,0,8,0">
                                                    <TextBlock Text="✓" FontSize="13" FontWeight="Bold"
                                                               Foreground="#7C3AED" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <TextBlock Text="Settled Txns" FontSize="10.5"
                                                           Foreground="{DynamicResource SubText}" VerticalAlignment="Center"/>
                                            </StackPanel>
                                            <TextBlock Text="{Binding OverviewSettledCount}" FontSize="22"
                                                       FontWeight="Bold" Foreground="#7C3AED"/>
                                            <TextBlock Text="{Binding DashSettledPct}" FontSize="10.5"
                                                       Foreground="{DynamicResource SubText}" Margin="0,3,0,0"/>
                                        </StackPanel>
                                    </Border>
                                    <!-- Settled Volume -->
                                    <Border Background="{DynamicResource CardBg}" CornerRadius="10"
                                            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                                            Margin="0,0,10,0" Padding="14,12">
                                        <StackPanel>
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                                <Border Width="28" Height="28" CornerRadius="6" Background="{DynamicResource GreenIconBadgeBg}" Margin="0,0,8,0">
                                                    <TextBlock Text="$" FontSize="13" FontWeight="Bold"
                                                               Foreground="#7C3AED" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <TextBlock Text="Settled Vol." FontSize="10.5"
                                                           Foreground="{DynamicResource SubText}" VerticalAlignment="Center"/>
                                            </StackPanel>
                                            <TextBlock Text="{Binding OverviewSettledAmount}" FontSize="16"
                                                       FontWeight="Bold" Foreground="#7C3AED"/>
                                            <TextBlock Text="{Binding DashSettledVolumePct}" FontSize="10.5"
                                                       Foreground="{DynamicResource SubText}" Margin="0,3,0,0"/>
                                        </StackPanel>
                                    </Border>
                                    <!-- Void Transactions -->
                                    <Border Background="{DynamicResource CardBg}" CornerRadius="10"
                                            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                                            Margin="0,0,10,0" Padding="14,12">
                                        <StackPanel>
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                                <Border Width="28" Height="28" CornerRadius="6" Background="#F8FAFC" Margin="0,0,8,0">
                                                    <TextBlock Text="⊘" FontSize="13"
                                                               Foreground="#64748B" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <TextBlock Text="Void Txns" FontSize="10.5"
                                                           Foreground="{DynamicResource SubText}" VerticalAlignment="Center"/>
                                            </StackPanel>
                                            <TextBlock Text="{Binding DashVoidCount}" FontSize="22"
                                                       FontWeight="Bold" Foreground="{DynamicResource FgDefault}"/>
                                            <TextBlock Text="{Binding DashVoidPct}" FontSize="10.5"
                                                       Foreground="{DynamicResource SubText}" Margin="0,3,0,0"/>
                                        </StackPanel>
                                    </Border>
                                    <!-- Pending Transactions -->
                                    <Border Background="{DynamicResource CardBg}" CornerRadius="10"
                                            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                                            Margin="0,0,10,0" Padding="14,12">
                                        <StackPanel>
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                                <Border Width="28" Height="28" CornerRadius="6" Background="#FFFBEB" Margin="0,0,8,0">
                                                    <TextBlock Text="⏳" FontSize="13"
                                                               Foreground="#D97706" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <TextBlock Text="Pending Txns" FontSize="10.5"
                                                           Foreground="{DynamicResource SubText}" VerticalAlignment="Center"/>
                                            </StackPanel>
                                            <TextBlock Text="{Binding OverviewPendingCount}" FontSize="22"
                                                       FontWeight="Bold" Foreground="#D97706"/>
                                            <TextBlock Text="{Binding DashPendingPct2}" FontSize="10.5"
                                                       Foreground="{DynamicResource SubText}" Margin="0,3,0,0"/>
                                        </StackPanel>
                                    </Border>
                                    <!-- Failed Transactions -->
                                    <Border Background="{DynamicResource CardBg}" CornerRadius="10"
                                            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                                            Margin="0,0,10,0" Padding="14,12">
                                        <StackPanel>
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                                <Border Width="28" Height="28" CornerRadius="6" Background="#FEF2F2" Margin="0,0,8,0">
                                                    <TextBlock Text="✕" FontSize="13" FontWeight="Bold"
                                                               Foreground="#DC2626" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <TextBlock Text="Failed Txns" FontSize="10.5"
                                                           Foreground="{DynamicResource SubText}" VerticalAlignment="Center"/>
                                            </StackPanel>
                                            <TextBlock Text="{Binding OverviewFailedCount}" FontSize="22"
                                                       FontWeight="Bold" Foreground="#DC2626"/>
                                            <TextBlock Text="{Binding DashFailedPct}" FontSize="10.5"
                                                       Foreground="{DynamicResource SubText}" Margin="0,3,0,0"/>
                                        </StackPanel>
                                    </Border>
                                    <!-- Refunded Amount -->
                                    <Border Background="{DynamicResource CardBg}" CornerRadius="10"
                                            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                                            Padding="14,12">
                                        <StackPanel>
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                                <Border Width="28" Height="28" CornerRadius="6" Background="#FEF2F2" Margin="0,0,8,0">
                                                    <TextBlock Text="↩" FontSize="13" FontWeight="Bold"
                                                               Foreground="#DC2626" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <TextBlock Text="Refunded" FontSize="10.5"
                                                           Foreground="{DynamicResource SubText}" VerticalAlignment="Center"/>
                                            </StackPanel>
                                            <TextBlock Text="{Binding DashRefundedAmount}" FontSize="16"
                                                       FontWeight="Bold" Foreground="#DC2626"/>
                                            <TextBlock Text="refund total" FontSize="10.5"
                                                       Foreground="{DynamicResource SubText}" Margin="0,3,0,0"/>
                                        </StackPanel>
                                    </Border>
                                </UniformGrid>

                                <!-- ── Bottom split row: Recent Transactions | Top Merchants ── -->
                                <Grid Margin="0,0,0,4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="14"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Recent Transactions -->
                                    <Border Grid.Column="0" Background="{DynamicResource CardBg}" CornerRadius="12"
                                            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Padding="18,16">
                                        <StackPanel>
                                            <!-- Card header -->
                                            <Grid Margin="0,0,0,12">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="Recent Transactions" FontSize="13" FontWeight="SemiBold"
                                                           Foreground="{DynamicResource FgDefault}" VerticalAlignment="Center"/>
                                                <Button Grid.Column="1" Content="View all →" FontSize="11"
                                                        Background="Transparent" Foreground="#7C3AED"
                                                        BorderThickness="0" Cursor="Hand" Padding="4,2"
                                                        VerticalAlignment="Center" Click="NavToTransactions_Click"/>
                                            </Grid>
                                            <!-- DataGrid -->
                                            <DataGrid ItemsSource="{Binding DashRecentTransactions}"
                                                      AutoGenerateColumns="False" IsReadOnly="True"
                                                      CanUserResizeRows="False" CanUserReorderColumns="False"
                                                      CanUserSortColumns="False" RowHeight="40"
                                                      GridLinesVisibility="None" HeadersVisibility="Column"
                                                      FontSize="12" Background="Transparent"
                                                      BorderThickness="0" SelectionMode="Single"
                                                      RowBackground="Transparent"
                                                      AlternatingRowBackground="Transparent">
                                                <DataGrid.ColumnHeaderStyle>
                                                    <Style TargetType="DataGridColumnHeader">
                                                        <Setter Property="FontSize" Value="11"/>
                                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                                        <Setter Property="Foreground" Value="{DynamicResource SubText}"/>
                                                        <Setter Property="Background" Value="Transparent"/>
                                                        <Setter Property="Padding" Value="4,6"/>
                                                        <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                                        <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
                                                    </Style>
                                                </DataGrid.ColumnHeaderStyle>
                                                <DataGrid.CellStyle>
                                                    <Style TargetType="DataGridCell">
                                                        <Setter Property="BorderThickness" Value="0"/>
                                                        <Setter Property="Padding" Value="4,0"/>
                                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                                        <Setter Property="Background" Value="Transparent"/>
                                                        <Setter Property="Foreground" Value="{DynamicResource FgDefault}"/>
                                                    </Style>
                                                </DataGrid.CellStyle>
                                                <DataGrid.Columns>
                                                    <DataGridTextColumn Header="Transaction ID" Binding="{Binding Id}" Width="*">
                                                        <DataGridTextColumn.ElementStyle>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="FontFamily" Value="Consolas"/>
                                                                <Setter Property="FontSize" Value="11"/>
                                                                <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                                                                <Setter Property="ToolTip" Value="{Binding Id}"/>
                                                                <Setter Property="VerticalAlignment" Value="Center"/>
                                                            </Style>
                                                        </DataGridTextColumn.ElementStyle>
                                                    </DataGridTextColumn>
                                                    <DataGridTextColumn Header="Date &amp; Time" Binding="{Binding Created}" Width="130">
                                                        <DataGridTextColumn.ElementStyle>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="FontSize" Value="11"/>
                                                                <Setter Property="Foreground" Value="{DynamicResource SubText}"/>
                                                                <Setter Property="VerticalAlignment" Value="Center"/>
                                                            </Style>
                                                        </DataGridTextColumn.ElementStyle>
                                                    </DataGridTextColumn>
                                                    <DataGridTextColumn Header="Merchant" Binding="{Binding MerchantDisplayName}" Width="120">
                                                        <DataGridTextColumn.ElementStyle>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                                                                <Setter Property="VerticalAlignment" Value="Center"/>
                                                            </Style>
                                                        </DataGridTextColumn.ElementStyle>
                                                    </DataGridTextColumn>
                                                    <DataGridTextColumn Header="Amount" Binding="{Binding ApprovedFormatted}" Width="90">
                                                        <DataGridTextColumn.ElementStyle>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="FontWeight" Value="SemiBold"/>
                                                                <Setter Property="Foreground" Value="#A78BFA"/>
                                                                <Setter Property="VerticalAlignment" Value="Center"/>
                                                            </Style>
                                                        </DataGridTextColumn.ElementStyle>
                                                    </DataGridTextColumn>
                                                    <DataGridTextColumn Header="Method" Binding="{Binding GatewayDisplay}" Width="90">
                                                        <DataGridTextColumn.ElementStyle>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="FontSize" Value="11"/>
                                                                <Setter Property="Foreground" Value="{DynamicResource SubText}"/>
                                                                <Setter Property="VerticalAlignment" Value="Center"/>
                                                            </Style>
                                                        </DataGridTextColumn.ElementStyle>
                                                    </DataGridTextColumn>
                                                    <DataGridTemplateColumn Header="Status" Width="100">
                                                        <DataGridTemplateColumn.CellTemplate>
                                                            <DataTemplate>
                                                                <Border CornerRadius="4" Padding="6,3" Margin="2,6"
                                                                        HorizontalAlignment="Left" VerticalAlignment="Center"
                                                                        Background="{Binding StatusColor, Converter={StaticResource StringToBrushConverter}}">
                                                                    <TextBlock Text="{Binding StatusLabel}"
                                                                               FontSize="10.5" FontWeight="SemiBold"
                                                                               Foreground="White"/>
                                                                </Border>
                                                            </DataTemplate>
                                                        </DataGridTemplateColumn.CellTemplate>
                                                    </DataGridTemplateColumn>
                                                </DataGrid.Columns>
                                            </DataGrid>
                                        </StackPanel>
                                    </Border>

                                    <!-- Top Merchants by Volume -->
                                    <Border Grid.Column="2" Background="{DynamicResource CardBg}" CornerRadius="12"
                                            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Padding="18,16">
                                        <StackPanel>
                                            <!-- Card header -->
                                            <Grid Margin="0,0,0,12">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="Top Merchants by Volume" FontSize="13" FontWeight="SemiBold"
                                                           Foreground="{DynamicResource FgDefault}" VerticalAlignment="Center"/>
                                                <Button Grid.Column="1" Content="View all →" FontSize="11"
                                                        Background="Transparent" Foreground="#7C3AED"
                                                        BorderThickness="0" Cursor="Hand" Padding="4,2"
                                                        VerticalAlignment="Center" Click="NavToTransactions_Click"/>
                                            </Grid>
                                            <!-- DataGrid -->
                                            <DataGrid ItemsSource="{Binding DashTopMerchants}"
                                                      AutoGenerateColumns="False" IsReadOnly="True"
                                                      CanUserResizeRows="False" CanUserReorderColumns="False"
                                                      CanUserSortColumns="False" RowHeight="40"
                                                      GridLinesVisibility="None" HeadersVisibility="Column"
                                                      FontSize="12" Background="Transparent"
                                                      BorderThickness="0" SelectionMode="Single"
                                                      RowBackground="Transparent"
                                                      AlternatingRowBackground="Transparent">
                                                <DataGrid.ColumnHeaderStyle>
                                                    <Style TargetType="DataGridColumnHeader">
                                                        <Setter Property="FontSize" Value="11"/>
                                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                                        <Setter Property="Foreground" Value="{DynamicResource SubText}"/>
                                                        <Setter Property="Background" Value="Transparent"/>
                                                        <Setter Property="Padding" Value="4,6"/>
                                                        <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                                        <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
                                                    </Style>
                                                </DataGrid.ColumnHeaderStyle>
                                                <DataGrid.CellStyle>
                                                    <Style TargetType="DataGridCell">
                                                        <Setter Property="BorderThickness" Value="0"/>
                                                        <Setter Property="Padding" Value="4,0"/>
                                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                                        <Setter Property="Background" Value="Transparent"/>
                                                        <Setter Property="Foreground" Value="{DynamicResource FgDefault}"/>
                                                    </Style>
                                                </DataGrid.CellStyle>
                                                <DataGrid.Columns>
                                                    <DataGridTemplateColumn Header="Merchant" Width="*">
                                                        <DataGridTemplateColumn.CellTemplate>
                                                            <DataTemplate>
                                                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="2,0">
                                                                    <Border Width="28" Height="28" CornerRadius="14"
                                                                            Background="{DynamicResource GreenIconBadgeBg}" Margin="0,0,8,0">
                                                                        <TextBlock FontSize="10" FontWeight="Bold"
                                                                                   Foreground="#7C3AED"
                                                                                   HorizontalAlignment="Center"
                                                                                   VerticalAlignment="Center">
                                                                            <TextBlock.Text>
                                                                                <Binding Path="Name">
                                                                                    <Binding.Converter>
                                                                                        <local:InitialsConverter/>
                                                                                    </Binding.Converter>
                                                                                </Binding>
                                                                            </TextBlock.Text>
                                                                        </TextBlock>
                                                                    </Border>
                                                                    <TextBlock Text="{Binding Name}"
                                                                               VerticalAlignment="Center"
                                                                               TextTrimming="CharacterEllipsis"
                                                                               ToolTip="{Binding Name}"/>
                                                                </StackPanel>
                                                            </DataTemplate>
                                                        </DataGridTemplateColumn.CellTemplate>
                                                    </DataGridTemplateColumn>
                                                    <DataGridTextColumn Header="Volume (USD)" Binding="{Binding Volume}" Width="110">
                                                        <DataGridTextColumn.ElementStyle>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="FontWeight" Value="SemiBold"/>
                                                                <Setter Property="Foreground" Value="#A78BFA"/>
                                                                <Setter Property="VerticalAlignment" Value="Center"/>
                                                            </Style>
                                                        </DataGridTextColumn.ElementStyle>
                                                    </DataGridTextColumn>
                                                    <DataGridTextColumn Header="Transactions" Binding="{Binding Count}" Width="90">
                                                        <DataGridTextColumn.ElementStyle>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Foreground" Value="{DynamicResource SubText}"/>
                                                                <Setter Property="VerticalAlignment" Value="Center"/>
                                                            </Style>
                                                        </DataGridTextColumn.ElementStyle>
                                                    </DataGridTextColumn>
                                                </DataGrid.Columns>
                                            </DataGrid>
                                        </StackPanel>
                                    </Border>

                                </Grid>

                            </StackPanel>
                        </ScrollViewer>

                        <!-- ── Footer bar ── -->
                        <Border Grid.Row="2" Padding="20,8"
                                BorderBrush="{DynamicResource CardBorder}" BorderThickness="0,1,0,0"
                                Background="{DynamicResource CardBg}">
                            <Grid DataContext="{Binding RelativeSource={RelativeSource AncestorType=Window}}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="All dates and times are in UTC"
                                           FontSize="11" Foreground="{DynamicResource SubText}"
                                           VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1" Text="{Binding DashLastUpdated}"
                                           FontSize="11" Foreground="{DynamicResource SubText}"
                                           VerticalAlignment="Center"/>
                            </Grid>
                        </Border>

                    </Grid>
                </TabItem>

                <!-- Tab 11: Disbursements -->
                <TabItem x:Name="TabItem11" Header="💸  Disbursements"   Visibility="Collapsed">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>  <!-- header -->
                            <RowDefinition Height="*"/>     <!-- body -->
                            <RowDefinition Height="Auto"/>  <!-- footer -->
                        </Grid.RowDefinitions>

                        <!-- ── Header ── -->
                        <Border Grid.Row="0" Padding="20,12"
                                BorderBrush="{DynamicResource CardBorder}" BorderThickness="0,0,0,1"
                                Background="{DynamicResource CardBg}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <!-- Left: green icon pill + title -->
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <Border Width="40" Height="40" CornerRadius="10"
                                            Background="{DynamicResource GreenIconBadgeBg}" Margin="0,0,12,0">
                                        <TextBlock Text="💸" FontSize="19"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="Disbursements" FontSize="16" FontWeight="Bold"
                                                   Foreground="{DynamicResource PrimaryText}"/>
                                        <TextBlock x:Name="DisbSubtitle"
                                                   Text="Track payouts and disbursement batches"
                                                   FontSize="11.5" Foreground="{DynamicResource SubText}"/>
                                    </StackPanel>
                                </StackPanel>
                                <!-- Sandbox badge -->
                                <Border Grid.Column="1" CornerRadius="6" Margin="0,0,10,0"
                                        Background="{DynamicResource TabHoverBg}" Padding="12,5"
                                        VerticalAlignment="Center">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="⊙ " FontSize="11" Foreground="{DynamicResource SubText}"/>
                                        <TextBlock x:Name="DisbEnvLabel" Text="Sandbox"
                                                   FontSize="11" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource SubText}"/>
                                    </StackPanel>
                                </Border>
                                <!-- Merchant filter -->
                                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,10,0">
                                    <TextBlock Text="🏢 " FontSize="12" VerticalAlignment="Center"/>
                                    <TextBlock Text="Merchant:" FontSize="12" Foreground="{DynamicResource SubText}"
                                               VerticalAlignment="Center" Margin="0,0,6,0"/>
                                    <TextBox x:Name="DisbMerchantBox" Width="200" Height="32" Padding="8,0"
                                             VerticalContentAlignment="Center" FontSize="12"
                                             BorderBrush="{DynamicResource InputBorder}" BorderThickness="1"
                                             ToolTip="Filter by merchant name, DBA, email, or merchant ID"/>
                                </StackPanel>
                                <!-- Limit ComboBox -->
                                <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,10,0">
                                    <TextBlock Text="Limit:" FontSize="12" Foreground="{DynamicResource SubText}"
                                               VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <ComboBox x:Name="DisbTabLimitBox" Width="72" Height="32" FontSize="12"
                                              SelectedIndex="0" SelectionChanged="DisbLimitBox_SelectionChanged">
                                        <ComboBoxItem Content="20"/>
                                        <ComboBoxItem Content="50"/>
                                        <ComboBoxItem Content="100"/>
                                        <ComboBoxItem Content="200"/>
                                    </ComboBox>
                                </StackPanel>
                                <!-- Load button -->
                                <Button Grid.Column="4" x:Name="DisbLoadBtn"
                                        Content="⟳  Load Disbursements"
                                        Height="34" Padding="16,0" FontSize="12.5"
                                        Style="{StaticResource PrimaryButton}"
                                        Background="#7C3AED"
                                        Click="LoadDisbursements_Click"/>
                            </Grid>
                        </Border>

                        <!-- ── Body ── -->
                        <Grid Grid.Row="1">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>  <!-- pagination footer -->
                                <RowDefinition x:Name="DisbEntryRow" Height="0"/>
                            </Grid.RowDefinitions>

                            <!-- Disbursements table -->
                            <Grid Grid.Row="0">
                                <!-- Empty state -->
                                <Border x:Name="DisbEmptyState" Padding="20,64"
                                        Background="{DynamicResource CardBg}" CornerRadius="0"
                                        HorizontalAlignment="Stretch" VerticalAlignment="Top"
                                        Margin="24,24,24,0">
                                    <StackPanel HorizontalAlignment="Center">
                                        <TextBlock Text="💸" FontSize="40" HorizontalAlignment="Center" Margin="0,0,0,12"/>
                                        <TextBlock Text="Click  ⟳ Load Disbursements  to fetch payout batches."
                                                   FontSize="13" Foreground="{DynamicResource SubText}"
                                                   HorizontalAlignment="Center" TextAlignment="Center"/>
                                    </StackPanel>
                                </Border>

                                <!-- DataGrid -->
                                <DataGrid x:Name="DisbGrid"
                                          Visibility="Collapsed"
                                          AutoGenerateColumns="False"
                                          IsReadOnly="True"
                                          HeadersVisibility="Column"
                                          GridLinesVisibility="Horizontal"
                                          HorizontalGridLinesBrush="{DynamicResource BorderBrush}"
                                          SelectionMode="Single"
                                          SelectionUnit="FullRow"
                                          CanUserResizeRows="False"
                                          RowHeight="40"
                                          FontSize="12.5"
                                          Background="Transparent"
                                          RowBackground="Transparent"
                                          AlternatingRowBackground="{DynamicResource GridAltRowBg}"
                                          BorderThickness="0"
                                          SelectionChanged="DisbGrid_SelectionChanged"
                                          Margin="0">
                                    <DataGrid.ColumnHeaderStyle>
                                        <Style TargetType="DataGridColumnHeader">
                                            <Setter Property="Background"  Value="{DynamicResource CardBg}"/>
                                            <Setter Property="Foreground"  Value="{DynamicResource SubText}"/>
                                            <Setter Property="FontSize"    Value="10.5"/>
                                            <Setter Property="FontWeight"  Value="Bold"/>
                                            <Setter Property="Padding"     Value="12,10"/>
                                            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
                                            <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                        </Style>
                                    </DataGrid.ColumnHeaderStyle>
                                    <DataGrid.RowStyle>
                                        <Style TargetType="DataGridRow">
                                            <Setter Property="Cursor" Value="Hand"/>
                                            <Style.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="{DynamicResource TabHoverBg}"/>
                                                </Trigger>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter Property="Background" Value="#26007AFF"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </DataGrid.RowStyle>
                                    <DataGrid.Columns>
                                        <!-- ID with copy -->
                                        <DataGridTemplateColumn Header="DISBURSEMENT ID" Width="240" SortMemberPath="Id">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="12,0">
                                                        <TextBlock Text="{Binding ShortId}" FontFamily="Cascadia Code, Consolas"
                                                                   FontSize="11.5" Foreground="{DynamicResource PrimaryText}"
                                                                   VerticalAlignment="Center"/>
                                                        <Button Content="📋" FontSize="10" Background="Transparent"
                                                                BorderThickness="0" Padding="4,0" Margin="4,0,0,0"
                                                                ToolTip="Copy full ID"
                                                                Tag="{Binding Id}"
                                                                Click="CopyDisbField_Click"/>
                                                    </StackPanel>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                        <!-- Company Name -->
                                        <DataGridTextColumn Header="COMPANY" Width="180"
                                                            Binding="{Binding CompanyName}"
                                                            SortMemberPath="CompanyName">
                                            <DataGridTextColumn.ElementStyle>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Padding" Value="12,0"/>
                                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                                </Style>
                                            </DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>
                                        <!-- Created date -->
                                        <DataGridTextColumn Header="CREATED" Width="160"
                                                            Binding="{Binding CreatedFormatted}"
                                                            SortMemberPath="Created">
                                            <DataGridTextColumn.ElementStyle>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Padding" Value="12,0"/>
                                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                                </Style>
                                            </DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>
                                        <!-- Processed date -->
                                        <DataGridTextColumn Header="PROCESSED" Width="160"
                                                            Binding="{Binding ProcessedFormatted}"
                                                            SortMemberPath="Processed">
                                            <DataGridTextColumn.ElementStyle>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Padding" Value="12,0"/>
                                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                                </Style>
                                            </DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>
                                        <!-- Amount -->
                                        <DataGridTextColumn Header="AMOUNT" Width="110"
                                                            Binding="{Binding AmountAlertFormatted}"
                                                            SortMemberPath="Amount">
                                            <DataGridTextColumn.ElementStyle>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Padding" Value="12,0"/>
                                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                                </Style>
                                            </DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>
                                        <!-- Status badge -->
                                        <DataGridTemplateColumn Header="STATUS" Width="110" SortMemberPath="StatusLabel">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <Border CornerRadius="4" Padding="8,3"
                                                            Background="{Binding StatusBg}"
                                                            HorizontalAlignment="Left"
                                                            VerticalAlignment="Center" Margin="12,0">
                                                        <TextBlock Text="{Binding StatusLabel}"
                                                                   FontSize="11" FontWeight="SemiBold"
                                                                   Foreground="{Binding StatusColor}"/>
                                                    </Border>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                        <!-- Settlement -->
                                        <DataGridTextColumn Header="SETTLEMENT" Width="220"
                                                            Binding="{Binding Settlement}"
                                                            SortMemberPath="Settlement">
                                            <DataGridTextColumn.ElementStyle>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Padding" Value="12,0"/>
                                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                                    <Setter Property="FontFamily" Value="Cascadia Code, Consolas"/>
                                                    <Setter Property="FontSize" Value="11"/>
                                                </Style>
                                            </DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>
                                        <!-- Payout -->
                                        <DataGridTextColumn Header="PAYOUT" Width="220"
                                                            Binding="{Binding Payout}"
                                                            SortMemberPath="Payout">
                                            <DataGridTextColumn.ElementStyle>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Padding" Value="12,0"/>
                                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                                    <Setter Property="FontFamily" Value="Cascadia Code, Consolas"/>
                                                    <Setter Property="FontSize" Value="11"/>
                                                </Style>
                                            </DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>
                                        <!-- Description -->
                                        <DataGridTextColumn Header="DESCRIPTION" Width="*"
                                                            Binding="{Binding Description}"
                                                            SortMemberPath="Description">
                                            <DataGridTextColumn.ElementStyle>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Padding" Value="12,0"/>
                                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                                    <Setter Property="Foreground" Value="{DynamicResource SubText}"/>
                                                </Style>
                                            </DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Grid>

                            <!-- ── Pagination footer ── -->
                            <Border Grid.Row="1"
                                    Background="{DynamicResource CardBg}"
                                    BorderBrush="{DynamicResource CardBorder}" BorderThickness="0,1,0,0"
                                    Padding="16,8">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>  <!-- paging text -->
                                        <ColumnDefinition Width="*"/>     <!-- page buttons (center) -->
                                        <ColumnDefinition Width="Auto"/>  <!-- rows per page -->
                                    </Grid.ColumnDefinitions>
                                    <!-- Count label -->
                                    <TextBlock x:Name="DisbPagingText" Grid.Column="0"
                                               Text="No disbursements loaded" FontSize="12"
                                               Foreground="{DynamicResource SubText}"
                                               VerticalAlignment="Center"/>
                                    <!-- Page buttons -->
                                    <StackPanel Grid.Column="1" Orientation="Horizontal"
                                                HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <Button x:Name="DisbPrevPageBtn" Content="‹"
                                                Width="32" Height="32" FontSize="14" FontWeight="SemiBold"
                                                Background="Transparent" BorderBrush="{DynamicResource CardBorder}" BorderThickness="1"
                                                Foreground="{DynamicResource SubText}" Margin="2,0"
                                                IsEnabled="False" Cursor="Hand"
                                                Click="DisbPrevPageBtn_Click">
                                            <Button.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="6"/></Style></Button.Resources>
                                        </Button>
                                        <Border x:Name="DisbPageNumBadge" CornerRadius="6" Margin="2,0"
                                                Background="#7C3AED" MinWidth="32" Height="32" Padding="6,0">
                                            <TextBlock x:Name="DisbPageNumText" Text="1" FontSize="13"
                                                       FontWeight="SemiBold" Foreground="White"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <Button x:Name="DisbNextPageBtn" Content="›"
                                                Width="32" Height="32" FontSize="14" FontWeight="SemiBold"
                                                Background="Transparent" BorderBrush="{DynamicResource CardBorder}" BorderThickness="1"
                                                Foreground="{DynamicResource SubText}" Margin="2,0"
                                                IsEnabled="False" Cursor="Hand"
                                                Click="DisbNextPageBtn_Click">
                                            <Button.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="6"/></Style></Button.Resources>
                                        </Button>
                                    </StackPanel>
                                    <!-- Rows per page -->
                                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                        <TextBlock Text="Rows per page" FontSize="12"
                                                   Foreground="{DynamicResource SubText}"
                                                   VerticalAlignment="Center" Margin="0,0,8,0"/>
                                        <ComboBox x:Name="DisbPageSizeBox" Width="64" Height="30" FontSize="12"
                                                  SelectedIndex="0" SelectionChanged="DisbPageSizeBox_SelectionChanged">
                                            <ComboBoxItem Content="20"/>
                                            <ComboBoxItem Content="50"/>
                                            <ComboBoxItem Content="100"/>
                                        </ComboBox>
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <!-- ── Entry sub-panel ── -->
                            <Border Grid.Row="2" x:Name="DisbEntryPanel"
                                    Visibility="Collapsed"
                                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0"
                                    Background="{DynamicResource CardBg}">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>
                                    <!-- Sub-panel header -->
                                    <Grid Grid.Row="0" Margin="16,10,16,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                            <TextBlock Text="ENTRIES FOR " FontSize="10.5" FontWeight="Bold"
                                                       Foreground="{DynamicResource SubText}" VerticalAlignment="Center"/>
                                            <TextBlock x:Name="DisbEntryHeader" FontSize="10.5" FontWeight="Bold"
                                                       FontFamily="Cascadia Code, Consolas"
                                                       Foreground="{DynamicResource PrimaryText}" VerticalAlignment="Center"/>
                                        </StackPanel>
                                        <Button Grid.Column="1" Content="✕  Close"
                                                Height="28" Padding="10,0" FontSize="11.5"
                                                Background="Transparent" BorderThickness="1"
                                                BorderBrush="{DynamicResource BorderBrush}"
                                                Foreground="{DynamicResource SubText}"
                                                Click="CloseDisbEntries_Click"/>
                                    </Grid>
                                    <!-- Entry DataGrid -->
                                    <DataGrid Grid.Row="1" x:Name="DisbEntryDetailGrid"
                                              AutoGenerateColumns="False"
                                              IsReadOnly="True"
                                              HeadersVisibility="Column"
                                              GridLinesVisibility="Horizontal"
                                              HorizontalGridLinesBrush="{DynamicResource BorderBrush}"
                                              SelectionMode="Single"
                                              CanUserResizeRows="False"
                                              RowHeight="36"
                                              FontSize="12"
                                              Background="Transparent"
                                              RowBackground="Transparent"
                                              AlternatingRowBackground="{DynamicResource GridAltRowBg}"
                                              BorderThickness="0">
                                        <DataGrid.ColumnHeaderStyle>
                                            <Style TargetType="DataGridColumnHeader">
                                                <Setter Property="Background"  Value="{DynamicResource CardBg}"/>
                                                <Setter Property="Foreground"  Value="{DynamicResource SubText}"/>
                                                <Setter Property="FontSize"    Value="10"/>
                                                <Setter Property="FontWeight"  Value="Bold"/>
                                                <Setter Property="Padding"     Value="12,8"/>
                                                <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
                                                <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                            </Style>
                                        </DataGrid.ColumnHeaderStyle>
                                        <DataGrid.Columns>
                                            <DataGridTemplateColumn Header="ENTRY ID" Width="220">
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="12,0">
                                                            <TextBlock Text="{Binding ShortEntryId}"
                                                                       FontFamily="Cascadia Code, Consolas"
                                                                       FontSize="11" Foreground="{DynamicResource PrimaryText}"
                                                                       VerticalAlignment="Center"/>
                                                            <Button Content="📋" FontSize="10" Background="Transparent"
                                                                    BorderThickness="0" Padding="4,0" Margin="4,0,0,0"
                                                                    ToolTip="Copy entry ID"
                                                                    Tag="{Binding Id}"
                                                                    Click="CopyDisbField_Click"/>
                                                        </StackPanel>
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                            </DataGridTemplateColumn>
                                            <DataGridTextColumn Header="AMOUNT" Width="110"
                                                                Binding="{Binding AmountFormatted}">
                                                <DataGridTextColumn.ElementStyle>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Padding" Value="12,0"/>
                                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                                    </Style>
                                                </DataGridTextColumn.ElementStyle>
                                            </DataGridTextColumn>
                                            <DataGridTemplateColumn Header="EVENT" Width="100">
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <TextBlock Text="{Binding EventLabel}"
                                                                   Padding="12,0" VerticalAlignment="Center"
                                                                   FontSize="11.5" Foreground="{DynamicResource SubText}"/>
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                            </DataGridTemplateColumn>
                                            <DataGridTemplateColumn Header="TXN ID" Width="220">
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="12,0">
                                                            <TextBlock Text="{Binding EventId}"
                                                                       FontFamily="Cascadia Code, Consolas"
                                                                       FontSize="11" Foreground="{DynamicResource PrimaryText}"
                                                                       VerticalAlignment="Center"/>
                                                            <Button Content="📋" FontSize="10" Background="Transparent"
                                                                    BorderThickness="0" Padding="4,0" Margin="4,0,0,0"
                                                                    ToolTip="Copy txn ID"
                                                                    Tag="{Binding EventId}"
                                                                    Click="CopyDisbField_Click"/>
                                                        </StackPanel>
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                            </DataGridTemplateColumn>
                                            <DataGridTextColumn Header="DESCRIPTION" Width="*"
                                                                Binding="{Binding Description}">
                                                <DataGridTextColumn.ElementStyle>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Padding" Value="12,0"/>
                                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                                        <Setter Property="Foreground" Value="{DynamicResource SubText}"/>
                                                    </Style>
                                                </DataGridTextColumn.ElementStyle>
                                            </DataGridTextColumn>
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </Grid>
                            </Border>
                        </Grid>

                        <!-- ── Footer bar ── -->
                        <Border Grid.Row="2" Padding="20,10"
                                BorderBrush="{DynamicResource CardBorder}" BorderThickness="0,1,0,0"
                                Background="{DynamicResource CardBg}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Orientation="Horizontal">
                                    <Button Content="⬇  Export JSON" FontSize="11" Padding="12,5" Margin="0,0,8,0"
                                            Background="Transparent" Foreground="{DynamicResource FgDefault}"
                                            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                                            Cursor="Hand" Click="ExportDisbJson_Click">
                                        <Button.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="6"/></Style></Button.Resources>
                                    </Button>
                                    <Button Content="⬇  Export CSV" FontSize="11" Padding="12,5"
                                            Background="Transparent" Foreground="{DynamicResource FgDefault}"
                                            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                                            Cursor="Hand" Click="ExportDisbCsv_Click">
                                        <Button.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="6"/></Style></Button.Resources>
                                    </Button>
                                </StackPanel>
                                <TextBlock Grid.Column="1" Text="All dates and times are in UTC"
                                           FontSize="11" Foreground="{DynamicResource SubText}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Grid>
                        </Border>

                    </Grid>
                </TabItem>

                <!-- Tab 12: Accounts -->
                <TabItem x:Name="TabItem12" Header="👤  Accounts"        Visibility="Collapsed">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- ── Toolbar ── -->
                        <Border Grid.Row="0" Padding="20,12"
                                BorderBrush="{DynamicResource CardBorder}" BorderThickness="0,0,0,1"
                                Background="{DynamicResource CardBg}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="Accounts" FontSize="18" FontWeight="Bold"
                                               Foreground="{DynamicResource PrimaryText}"/>
                                    <TextBlock x:Name="AccountSubtitle"
                                               Text="Entity info and connected merchant accounts"
                                               FontSize="11.5" Foreground="{DynamicResource SubText}"/>
                                </StackPanel>
                                <!-- Limit input -->
                                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,8,0">
                                    <TextBlock Text="Limit:" FontSize="12" Foreground="{DynamicResource SubText}"
                                               VerticalAlignment="Center" Margin="0,0,6,0"/>
                                    <TextBox x:Name="AccLimitBox" Width="60" Height="32" Padding="8,0"
                                             VerticalContentAlignment="Center" FontSize="12"
                                             BorderBrush="{DynamicResource InputBorder}" BorderThickness="1"
                                             Text="0" ToolTip="Max accounts to load. Enter 0 to load all."/>
                                </StackPanel>
                                <Border Grid.Column="2" CornerRadius="6" Margin="0,0,8,0"
                                        Background="{DynamicResource TabHoverBg}" Padding="10,4"
                                        VerticalAlignment="Center">
                                    <TextBlock x:Name="AccountEnvLabel" Text="Sandbox"
                                               FontSize="11" FontWeight="SemiBold"
                                               Foreground="{DynamicResource SubText}"/>
                                </Border>
                                <Button Grid.Column="3" x:Name="LoadAccountsBtn"
                                        Content="⟳  Load Accounts"
                                        Height="34" Padding="14,0" FontSize="12.5"
                                        Style="{StaticResource PrimaryButton}"
                                        Click="LoadAccounts_Click"/>
                            </Grid>
                        </Border>

                        <!-- ── Body ── -->
                        <Grid Grid.Row="1">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <StackPanel Grid.Row="0" Margin="24,20,24,0">

                                <!-- Empty state -->
                                <Border x:Name="AccountEmptyState" Padding="20,48"
                                        Background="{DynamicResource CardBg}" CornerRadius="12"
                                        BorderBrush="{DynamicResource CardBorder}" BorderThickness="1">
                                    <StackPanel HorizontalAlignment="Center">
                                        <TextBlock Text="🏦" FontSize="36" HorizontalAlignment="Center" Margin="0,0,0,12"/>
                                        <TextBlock x:Name="AccountEmptyText"
                                                   Text="Click  ⟳ Load Accounts  to fetch entity and merchant account data."
                                                   FontSize="13" Foreground="{DynamicResource SubText}"
                                                   HorizontalAlignment="Center" TextAlignment="Center"/>
                                    </StackPanel>
                                </Border>

                                <!-- ── Entity card (horizontal) ── -->
                                <Border x:Name="AccountEntityCard"
                                        Background="{DynamicResource CardBg}" CornerRadius="10"
                                        BorderBrush="{DynamicResource CardBorder}" BorderThickness="1"
                                        Padding="16,12" Margin="0,0,0,12" Visibility="Collapsed">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <!-- Section label -->
                                        <TextBlock Grid.Column="0" Text="ENTITY / API KEY OWNER"
                                                   FontSize="9.5" FontWeight="Bold"
                                                   Foreground="{DynamicResource SubText}"
                                                   VerticalAlignment="Center" Margin="0,0,24,0"/>
                                        <!-- Entity ID -->
                                        <StackPanel Grid.Column="1" Margin="0,0,24,0" VerticalAlignment="Center">
                                            <TextBlock Text="ENTITY ID" FontSize="9" FontWeight="Bold"
                                                       Foreground="{DynamicResource SubText}" Margin="0,0,0,1"/>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock x:Name="AccEntityId"
                                                           FontSize="11" FontFamily="Cascadia Code, Consolas"
                                                           Foreground="{DynamicResource PrimaryText}"/>
                                                <Button Content="📋" FontSize="10"
                                                        Background="Transparent" BorderThickness="0" Padding="3,0"
                                                        ToolTip="Copy Entity ID"
                                                        Tag="{Binding ElementName=AccEntityId, Path=Text}"
                                                        Click="CopyAccField_Click"/>
                                            </StackPanel>
                                        </StackPanel>
                                        <!-- Name -->
                                        <StackPanel Grid.Column="2" Margin="0,0,24,0" VerticalAlignment="Center">
                                            <TextBlock Text="NAME" FontSize="9" FontWeight="Bold"
                                                       Foreground="{DynamicResource SubText}" Margin="0,0,0,1"/>
                                            <TextBlock x:Name="AccEntityName"
                                                       FontSize="12" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource PrimaryText}"/>
                                        </StackPanel>
                                        <!-- Login -->
                                        <StackPanel Grid.Column="3" Margin="0,0,24,0" VerticalAlignment="Center">
                                            <TextBlock Text="LOGIN" FontSize="9" FontWeight="Bold"
                                                       Foreground="{DynamicResource SubText}" Margin="0,0,0,1"/>
                                            <TextBlock x:Name="AccEntityLogin"
                                                       FontSize="11" FontFamily="Cascadia Code, Consolas"
                                                       Foreground="{DynamicResource PrimaryText}"/>
                                        </StackPanel>
                                        <!-- BQE Ref -->
                                        <StackPanel Grid.Column="4" Margin="0,0,16,0" VerticalAlignment="Center" MaxWidth="280">
                                            <TextBlock Text="BQE REF" FontSize="9" FontWeight="Bold"
                                                       Foreground="{DynamicResource SubText}" Margin="0,0,0,1"/>
                                            <TextBlock x:Name="AccEntityCustom"
                                                       FontSize="10" FontFamily="Cascadia Code, Consolas"
                                                       Foreground="{DynamicResource SubText}"
                                                       TextTrimming="CharacterEllipsis"/>
                                        </StackPanel>
                                        <!-- Spacer pushes Verify badge to right -->
                                        <!-- Verify badge -->
                                        <Border x:Name="VerifiedBadge" Grid.Column="6" CornerRadius="6" Padding="10,4"
                                                Background="{DynamicResource VerifiedBadgeBg}"
                                                BorderBrush="{DynamicResource VerifiedBadgeBorder}" BorderThickness="1"
                                                VerticalAlignment="Center">
                                            <TextBlock FontSize="11" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource VerifiedBadgeFg}">
                                                <Run Text="✓ Verified"/>
                                            </TextBlock>
                                        </Border>
                                    </Grid>
                                </Border>

                                <!-- ── KPI tiles ── -->
                                <Border x:Name="AccKpiPanel" Visibility="Collapsed" Margin="0,0,0,12">
                                    <UniformGrid Rows="1" Columns="4">
                                        <!-- Total — blue -->
                                        <Border Background="{DynamicResource CardBg}"
                                                BorderBrush="{DynamicResource CardBorder}" BorderThickness="1"
                                                CornerRadius="8" Margin="0,0,6,0" ClipToBounds="True">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="3"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <Rectangle Grid.Column="0" Fill="#2563EB"/>
                                                <StackPanel Grid.Column="1" Margin="12,10">
                                                    <TextBlock Text="🏢  TOTAL" FontSize="10" FontWeight="Bold"
                                                               Foreground="{DynamicResource SubText}" Margin="0,0,0,4"/>
                                                    <TextBlock x:Name="AccKpiTotal" Text="—" FontSize="20" FontWeight="Bold"
                                                               Foreground="#2563EB"/>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                        <!-- Active — green -->
                                        <Border Background="{DynamicResource CardBg}"
                                                BorderBrush="{DynamicResource CardBorder}" BorderThickness="1"
                                                CornerRadius="8" Margin="0,0,6,0" ClipToBounds="True">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="3"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <Rectangle Grid.Column="0" Fill="#16A34A"/>
                                                <StackPanel Grid.Column="1" Margin="12,10">
                                                    <TextBlock Text="✅  ACTIVE" FontSize="10" FontWeight="Bold"
                                                               Foreground="{DynamicResource SubText}" Margin="0,0,0,4"/>
                                                    <TextBlock x:Name="AccKpiActive" Text="—" FontSize="20" FontWeight="Bold"
                                                               Foreground="#16A34A"/>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                        <!-- Inactive — gray -->
                                        <Border Background="{DynamicResource CardBg}"
                                                BorderBrush="{DynamicResource CardBorder}" BorderThickness="1"
                                                CornerRadius="8" Margin="0,0,6,0" ClipToBounds="True">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="3"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <Rectangle Grid.Column="0" Fill="#9CA3AF"/>
                                                <StackPanel Grid.Column="1" Margin="12,10">
                                                    <TextBlock Text="⏸  INACTIVE" FontSize="10" FontWeight="Bold"
                                                               Foreground="{DynamicResource SubText}" Margin="0,0,0,4"/>
                                                    <TextBlock x:Name="AccKpiInactive" Text="—" FontSize="20" FontWeight="Bold"
                                                               Foreground="#9CA3AF"/>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                        <!-- KYC Approved — green -->
                                        <Border Background="{DynamicResource CardBg}"
                                                BorderBrush="{DynamicResource CardBorder}" BorderThickness="1"
                                                CornerRadius="8" ClipToBounds="True">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="3"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <Rectangle Grid.Column="0" Fill="#16A34A"/>
                                                <StackPanel Grid.Column="1" Margin="12,10">
                                                    <TextBlock Text="🔍  KYC APPROVED" FontSize="10" FontWeight="Bold"
                                                               Foreground="{DynamicResource SubText}" Margin="0,0,0,4"/>
                                                    <TextBlock x:Name="AccKpiKyc" Text="—" FontSize="20" FontWeight="Bold"
                                                               Foreground="#16A34A"/>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </UniformGrid>
                                </Border>

                            </StackPanel>
                            <!-- ── Merchant Accounts table ── -->
                            <Border x:Name="AccountMerchantCard" Grid.Row="1"
                                    Background="{DynamicResource CardBg}" CornerRadius="12"
                                    BorderBrush="{DynamicResource CardBorder}" BorderThickness="1"
                                    Margin="24,8,24,20" Visibility="Collapsed">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <!-- ── Card header: title + search + count + exports ── -->
                                    <Border Grid.Row="0" Padding="14,10"
                                            BorderBrush="{DynamicResource CardBorder}" BorderThickness="0,0,0,1"
                                            Background="{DynamicResource CardBg}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="Merchants"
                                                       FontSize="13" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource PrimaryText}"
                                                       VerticalAlignment="Center" Margin="0,0,10,0"/>
                                            <!-- Search box -->
                                            <Border Grid.Column="1" CornerRadius="7" Margin="0,0,8,0"
                                                    Background="{DynamicResource InputBg}"
                                                    BorderBrush="{DynamicResource CardBorder}" BorderThickness="1"
                                                    Padding="8,0" Height="30" Width="210" VerticalAlignment="Center">
                                                <TextBox x:Name="AccSearchBox"
                                                         Background="Transparent" BorderThickness="0"
                                                         VerticalAlignment="Center" FontSize="11.5"
                                                         Foreground="{DynamicResource PrimaryText}"
                                                         TextChanged="AccSearch_Changed">
                                                    <TextBox.Style>
                                                        <Style TargetType="TextBox">
                                                            <Style.Resources>
                                                                <VisualBrush x:Key="AccHint2" TileMode="None" Stretch="None" AlignmentX="Left">
                                                                    <VisualBrush.Visual>
                                                                        <TextBlock Text="🔍  Search by ID or name…" Foreground="{DynamicResource SubText}" FontSize="11"/>
                                                                    </VisualBrush.Visual>
                                                                </VisualBrush>
                                                            </Style.Resources>
                                                            <Style.Triggers>
                                                                <Trigger Property="Text" Value="">
                                                                    <Setter Property="Background" Value="{StaticResource AccHint2}"/>
                                                                </Trigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBox.Style>
                                                </TextBox>
                                            </Border>
                                            <!-- Count badge -->
                                            <Border Grid.Column="2" CornerRadius="5" Padding="8,2" Margin="0,0,0,0"
                                                    Background="{DynamicResource TabHoverBg}"
                                                    VerticalAlignment="Center">
                                                <TextBlock x:Name="AccCountBadge" Text="0"
                                                           FontSize="11" FontWeight="SemiBold"
                                                           Foreground="{DynamicResource SubText}"/>
                                            </Border>
                                            <!-- Delete Selected (hidden until rows are checked) -->
                                            <Button x:Name="AccDeleteSelectedBtn" Grid.Column="3"
                                                    Content="🗑  Delete Selected (0)"
                                                    Height="28" Padding="10,0" FontSize="11" Margin="0,0,6,0"
                                                    Style="{StaticResource DangerButton}"
                                                    Visibility="Collapsed" VerticalAlignment="Center"
                                                    Click="AccDeleteSelected_Click"/>
                                            <!-- Export buttons -->
                                            <StackPanel Grid.Column="4" Orientation="Horizontal" VerticalAlignment="Center">
                                                <Button x:Name="AccExportJsonBtn"
                                                        Content="📤  Export JSON" Height="28" Padding="10,0" FontSize="11"
                                                        Background="Transparent" BorderThickness="1"
                                                        BorderBrush="{DynamicResource CardBorder}"
                                                        Foreground="{DynamicResource PrimaryText}"
                                                        Margin="0,0,6,0" ToolTip="Export as JSON"
                                                        Click="AccExportJson_Click" Cursor="Hand"/>
                                                <Button x:Name="AccExportCsvBtn"
                                                        Content="📊  Export CSV" Height="28" Padding="10,0" FontSize="11"
                                                        Background="Transparent" BorderThickness="1"
                                                        BorderBrush="{DynamicResource CardBorder}"
                                                        Foreground="{DynamicResource PrimaryText}"
                                                        ToolTip="Export as CSV"
                                                        Click="AccExportCsv_Click" Cursor="Hand"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                    <!-- Column headers (clickable sort buttons) -->
                                    <Border Grid.Row="1" Padding="4,0"
                                            BorderBrush="{DynamicResource CardBorder}" BorderThickness="0,0,0,1"
                                            Background="{DynamicResource TabHoverBg}">
                                            <Grid x:Name="AccHeaderGrid">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" MaxWidth="300"/>
                                                    <ColumnDefinition Width="4"/>
                                                    <ColumnDefinition Width="65"/>
                                                    <ColumnDefinition Width="4"/>
                                                    <ColumnDefinition Width="70"/>
                                                    <ColumnDefinition Width="4"/>
                                                    <ColumnDefinition Width="50"/>
                                                    <ColumnDefinition Width="4"/>
                                                    <ColumnDefinition Width="60"/>
                                                    <ColumnDefinition Width="4"/>
                                                    <ColumnDefinition Width="70"/>
                                                    <ColumnDefinition Width="4"/>
                                                    <ColumnDefinition Width="90"/>
                                                    <ColumnDefinition Width="4"/>
                                                    <ColumnDefinition Width="70"/>
                                                    <ColumnDefinition Width="4"/>
                                                    <ColumnDefinition Width="130"/>
                                                    <ColumnDefinition Width="4"/>
                                                    <ColumnDefinition Width="*" MinWidth="140"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                                    <CheckBox x:Name="AccSelectAllChk" Margin="10,0,6,0"
                                                              VerticalAlignment="Center" Click="AccSelectAll_Click"
                                                              ToolTip="Select / deselect all"/>
                                                    <Button Content="MERCHANT" Tag="DisplayName" x:Name="AccSortMerchant"
                                                            Style="{StaticResource SortHeaderButton}"
                                                            Click="AccSort_Click"/>
                                                </StackPanel>
                                                <GridSplitter Grid.Column="1" Width="4" HorizontalAlignment="Stretch"
                                                              Background="Transparent" Cursor="SizeWE"
                                                              ResizeDirection="Columns" ResizeBehavior="PreviousAndNext"
                                                              DragDelta="AccSplitter_DragDelta"/>
                                                <Button Grid.Column="2" Content="STATUS" Tag="StatusCode"
                                                        x:Name="AccSortStatus"
                                                        Style="{StaticResource SortHeaderButton}"
                                                        Click="AccSort_Click"/>
                                                <GridSplitter Grid.Column="3" Width="4" HorizontalAlignment="Stretch"
                                                              Background="Transparent" Cursor="SizeWE"
                                                              ResizeDirection="Columns" ResizeBehavior="PreviousAndNext"
                                                              DragDelta="AccSplitter_DragDelta"/>
                                                <Button Grid.Column="4" Content="KYC" Tag="KycCode"
                                                        x:Name="AccSortKyc"
                                                        Style="{StaticResource SortHeaderButton}"
                                                        Click="AccSort_Click"/>
                                                <GridSplitter Grid.Column="5" Width="4" HorizontalAlignment="Stretch"
                                                              Background="Transparent" Cursor="SizeWE"
                                                              ResizeDirection="Columns" ResizeBehavior="PreviousAndNext"
                                                              DragDelta="AccSplitter_DragDelta"/>
                                                <Button Grid.Column="6" Content="TXNS" Tag="TxnCount"
                                                        x:Name="AccSortTxns"
                                                        Style="{StaticResource SortHeaderButton}"
                                                        Click="AccSort_Click"/>
                                                <GridSplitter Grid.Column="7" Width="4" HorizontalAlignment="Stretch"
                                                              Background="Transparent" Cursor="SizeWE"
                                                              ResizeDirection="Columns" ResizeBehavior="PreviousAndNext"
                                                              DragDelta="AccSplitter_DragDelta"/>
                                                <Button Grid.Column="8" Content="VOL" Tag="VolumeRaw"
                                                        x:Name="AccSortVolume"
                                                        Style="{StaticResource SortHeaderButton}"
                                                        Click="AccSort_Click"/>
                                                <GridSplitter Grid.Column="9" Width="4" HorizontalAlignment="Stretch"
                                                              Background="Transparent" Cursor="SizeWE"
                                                              ResizeDirection="Columns" ResizeBehavior="PreviousAndNext"
                                                              DragDelta="AccSplitter_DragDelta"/>
                                                <Button Grid.Column="10" Content="CURRENCY" Tag="Currency"
                                                        x:Name="AccSortCurrency"
                                                        Style="{StaticResource SortHeaderButton}"
                                                        Click="AccSort_Click"/>
                                                <GridSplitter Grid.Column="11" Width="4" HorizontalAlignment="Stretch"
                                                              Background="Transparent" Cursor="SizeWE"
                                                              ResizeDirection="Columns" ResizeBehavior="PreviousAndNext"
                                                              DragDelta="AccSplitter_DragDelta"/>
                                                <Button Grid.Column="12" Content="CREATED" Tag="CreatedRaw"
                                                        x:Name="AccSortCreated"
                                                        Style="{StaticResource SortHeaderButton}"
                                                        Click="AccSort_Click"/>
                                                <GridSplitter Grid.Column="13" Width="4" HorizontalAlignment="Stretch"
                                                              Background="Transparent" Cursor="SizeWE"
                                                              ResizeDirection="Columns" ResizeBehavior="PreviousAndNext"
                                                              DragDelta="AccSplitter_DragDelta"/>
                                                <TextBlock Grid.Column="14" Text="CORE" FontSize="10"
                                                           FontWeight="SemiBold" Foreground="{DynamicResource SubText}"
                                                           VerticalAlignment="Center" Margin="4,0,0,0"/>
                                                <GridSplitter Grid.Column="15" Width="4" HorizontalAlignment="Stretch"
                                                              Background="Transparent" Cursor="SizeWE"
                                                              ResizeDirection="Columns" ResizeBehavior="PreviousAndNext"
                                                              DragDelta="AccSplitter_DragDelta"/>
                                                <Button Grid.Column="16" Content="ENTITY" Tag="EntityName"
                                                        x:Name="AccSortEntity"
                                                        Style="{StaticResource SortHeaderButton}"
                                                        Click="AccSort_Click"/>
                                                <GridSplitter Grid.Column="17" Width="4" HorizontalAlignment="Stretch"
                                                              Background="Transparent" Cursor="SizeWE"
                                                              ResizeDirection="Columns" ResizeBehavior="PreviousAndNext"
                                                              DragDelta="AccSplitter_DragDelta"/>
<StackPanel Grid.Column="18" Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,8,0">
                                                    <TextBlock Text="ACTION" FontSize="10" FontWeight="SemiBold"
                                                               Foreground="{DynamicResource SubText}" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                                    <Button x:Name="AccColChooserBtn" Content="⊞" Click="AccColumnChooser_Click"
                                                            FontSize="11" Padding="3,1" VerticalAlignment="Center"
                                                            Background="Transparent" BorderThickness="1"
                                                            BorderBrush="{DynamicResource CardBorder}"
                                                            Foreground="{DynamicResource SubText}" Cursor="Hand"/>
                                                    <Popup x:Name="AccColChooserPopup" StaysOpen="False" Placement="Bottom"
                                                           PlacementTarget="{Binding ElementName=AccColChooserBtn}">
                                                        <Border Background="{DynamicResource CardBg}"
                                                                BorderBrush="{DynamicResource CardBorder}"
                                                                BorderThickness="1" CornerRadius="6" Padding="10">
                                                            <StackPanel>
                                                                <TextBlock Text="Show columns" FontSize="10" FontWeight="SemiBold"
                                                                           Foreground="{DynamicResource SubText}" Margin="0,0,0,6"/>
                                                                <CheckBox Content="Status"   IsChecked="True" Tag="2:65:3"   Click="AccColCheck_Click" Margin="0,2"/>
                                                                <CheckBox Content="KYC"      IsChecked="True" Tag="4:70:5"   Click="AccColCheck_Click" Margin="0,2"/>
                                                                <CheckBox Content="Txns"     IsChecked="True" Tag="6:50:7"   Click="AccColCheck_Click" Margin="0,2"/>
                                                                <CheckBox Content="Volume"   IsChecked="True" Tag="8:60:9"   Click="AccColCheck_Click" Margin="0,2"/>
                                                                <CheckBox Content="Currency" IsChecked="True" Tag="10:70:11" Click="AccColCheck_Click" Margin="0,2"/>
                                                                <CheckBox Content="Created"  IsChecked="True" Tag="12:90:13" Click="AccColCheck_Click" Margin="0,2"/>
                                                                <CheckBox Content="Core"     IsChecked="True" Tag="14:70:15" Click="AccColCheck_Click" Margin="0,2"/>
                                                                <CheckBox Content="Entity"   IsChecked="True" Tag="16:130:17" Click="AccColCheck_Click" Margin="0,2"/>
                                                            </StackPanel>
                                                        </Border>
                                                    </Popup>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    <!-- Rows -->
                                    <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                                        <ItemsControl x:Name="AccountMerchantList" HorizontalContentAlignment="Stretch">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate DataType="{x:Type local:AccountMerchantRow}">
                                                    <Border Padding="4,9"
                                                            BorderBrush="{DynamicResource CardBorder}"
                                                            BorderThickness="0,0,0,1">
                                                        <!-- Pinned-row left accent -->
                                                        <Border.Style>
                                                            <Style TargetType="Border">
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsPinned}" Value="True">
                                                                        <Setter Property="Background" Value="{DynamicResource PinnedRowBg}"/>
                                                                        <Setter Property="BorderBrush" Value="{DynamicResource PinnedRowBorder}"/>
                                                                        <Setter Property="BorderThickness" Value="3,0,0,1"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Border.Style>
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*" MaxWidth="300"/>
                                                                <ColumnDefinition Width="4"/>    <!-- spacer -->
                                                                <ColumnDefinition Width="65"/>
                                                                <ColumnDefinition Width="4"/>    <!-- spacer -->
                                                                <ColumnDefinition Width="70"/>
                                                                <ColumnDefinition Width="4"/>    <!-- spacer -->
                                                                <ColumnDefinition Width="50"/>
                                                                <ColumnDefinition Width="4"/>    <!-- spacer -->
                                                                <ColumnDefinition Width="60"/>
                                                                <ColumnDefinition Width="4"/>    <!-- spacer -->
                                                                <ColumnDefinition Width="70"/>
                                                                <ColumnDefinition Width="4"/>    <!-- spacer -->
                                                                <ColumnDefinition Width="90"/>
                                                                <ColumnDefinition Width="4"/>    <!-- spacer -->
                                                                <ColumnDefinition Width="70"/>
                                                                <ColumnDefinition Width="4"/>    <!-- spacer -->
                                                                <ColumnDefinition Width="130"/>
                                                                <ColumnDefinition Width="4"/>    <!-- spacer -->
                                                                <ColumnDefinition Width="*" MinWidth="140"/>
                                                            </Grid.ColumnDefinitions>
                                                            <!-- Checkbox + Name + ID + pin chip -->
                                                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                                <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                                                          Margin="10,0,6,0" VerticalAlignment="Center"
                                                                          Click="AccRowCheck_Click"/>
                                                            <StackPanel Margin="0,0,0,0">
                                                                <StackPanel Orientation="Horizontal">
                                                                    <TextBlock Text="{Binding DisplayName}"
                                                                               FontSize="13" FontWeight="SemiBold"
                                                                               Foreground="{DynamicResource PrimaryText}"
                                                                               TextTrimming="CharacterEllipsis"/>
                                                                    <!-- "📌 Pinned" chip -->
                                                                    <Border CornerRadius="4" Padding="5,1" Margin="6,0,0,0"
                                                                            Background="{DynamicResource PinnedChipBg}" VerticalAlignment="Center">
                                                                        <Border.Style>
                                                                            <Style TargetType="Border">
                                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                                                <Style.Triggers>
                                                                                    <DataTrigger Binding="{Binding IsPinned}" Value="True">
                                                                                        <Setter Property="Visibility" Value="Visible"/>
                                                                                    </DataTrigger>
                                                                                </Style.Triggers>
                                                                            </Style>
                                                                        </Border.Style>
                                                                        <TextBlock Text="📌 Pinned" FontSize="9" FontWeight="SemiBold" Foreground="{DynamicResource PinnedChipFg}"/>
                                                                    </Border>
                                                                </StackPanel>
                                                                <StackPanel Orientation="Horizontal">
                                                                    <TextBlock Text="{Binding MerchantId}"
                                                                               FontSize="10" Foreground="{DynamicResource SubText}"
                                                                               FontFamily="Cascadia Code, Consolas"
                                                                               TextTrimming="CharacterEllipsis"/>
                                                                    <Button Content="📋" FontSize="11"
                                                                            Background="Transparent" BorderThickness="0"
                                                                            Padding="4,0" Margin="4,0,0,0"
                                                                            ToolTip="Copy Merchant ID"
                                                                            Tag="{Binding MerchantId}"
                                                                            Click="CopyAccMerchantId_Click"/>
                                                                </StackPanel>
                                                            </StackPanel>
                                                            </StackPanel>
                                                            <!-- Status badge -->
                                                            <Border Grid.Column="2" CornerRadius="5" Padding="6,2"
                                                                    Background="{Binding StatusBg}"
                                                                    HorizontalAlignment="Left" VerticalAlignment="Center">
                                                                <TextBlock Text="{Binding StatusLabel}"
                                                                           FontSize="10.5" FontWeight="SemiBold"
                                                                           Foreground="{Binding StatusColor}"/>
                                                            </Border>
                                                            <!-- KYC badge -->
                                                            <Border Grid.Column="4" CornerRadius="5" Padding="6,2"
                                                                    Background="{Binding KycBg}"
                                                                    HorizontalAlignment="Left" VerticalAlignment="Center">
                                                                <TextBlock Text="{Binding KycLabel}"
                                                                           FontSize="10.5" FontWeight="SemiBold"
                                                                           Foreground="{Binding KycColor}"/>
                                                            </Border>
                                                            <!-- Txn count -->
                                                            <TextBlock Grid.Column="6"
                                                                       Text="{Binding TxnCount}"
                                                                       FontSize="13" FontWeight="SemiBold"
                                                                       Foreground="{DynamicResource PrimaryText}"
                                                                       VerticalAlignment="Center" Margin="8,0,0,0"/>
                                                            <!-- Volume -->
                                                            <TextBlock Grid.Column="8"
                                                                       Text="{Binding Volume}"
                                                                       FontSize="12" FontWeight="SemiBold"
                                                                       Foreground="{DynamicResource VolumeValueFg}"
                                                                       VerticalAlignment="Center"/>
                                                            <!-- Currency -->
                                                            <TextBlock Grid.Column="10"
                                                                       Text="{Binding Currency}"
                                                                       FontSize="12" Foreground="{DynamicResource SubText}"
                                                                       VerticalAlignment="Center"/>
                                                            <!-- Created -->
                                                            <TextBlock Grid.Column="12"
                                                                       Text="{Binding CreatedFormatted}"
                                                                       FontSize="11" Foreground="{DynamicResource SubText}"
                                                                       VerticalAlignment="Center"/>
                                                            <!-- Linked to Core badge -->
                                                            <Border Grid.Column="14" CornerRadius="5" Padding="6,2"
                                                                    HorizontalAlignment="Left" VerticalAlignment="Center">
                                                                <Border.Style>
                                                                    <Style TargetType="Border">
                                                                        <Setter Property="Background" Value="{DynamicResource CoreNotLinkedBg}"/>
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding LinkedToCore}" Value="True">
                                                                                <Setter Property="Background" Value="{DynamicResource CoreLinkedBg}"/>
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </Border.Style>
                                                                <TextBlock FontSize="10" FontWeight="SemiBold">
                                                                    <TextBlock.Style>
                                                                        <Style TargetType="TextBlock">
                                                                            <Setter Property="Text" Value="—"/>
                                                                            <Setter Property="Foreground" Value="{DynamicResource CoreNotLinkedFg}"/>
                                                                            <Style.Triggers>
                                                                                <DataTrigger Binding="{Binding LinkedToCore}" Value="True">
                                                                                    <Setter Property="Text" Value="✓ Linked"/>
                                                                                    <Setter Property="Foreground" Value="{DynamicResource CoreLinkedFg}"/>
                                                                                </DataTrigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </TextBlock.Style>
                                                                </TextBlock>
                                                            </Border>
                                                            <!-- Entity Name -->
                                                            <TextBlock Grid.Column="16"
                                                                       Text="{Binding EntityName}"
                                                                       FontSize="11" Foreground="{DynamicResource SubText}"
                                                                       VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                                            <!-- Toggle Active / Inactive + Delete -->
                                                            <StackPanel Grid.Column="18" Orientation="Horizontal"
                                                                        VerticalAlignment="Center" HorizontalAlignment="Right"
                                                                        Margin="2,0,8,0">
                                                            <Button Content="{Binding ToggleStatusLabel}"
                                                                    IsEnabled="{Binding ToggleEnabled}"
                                                                    Tag="{Binding MerchantId}"
                                                                    Click="ToggleMerchantStatus_Click"
                                                                    Height="26" Width="96" Padding="8,0" FontSize="11">
                                                                <Button.Style>
                                                                    <Style TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
                                                                        <Setter Property="Background" Value="#7C3AED"/>
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding StatusCode}" Value="1">
                                                                                <Setter Property="Background" Value="{DynamicResource ToggleBtnActiveBg}"/>
                                                                            </DataTrigger>
                                                                            <DataTrigger Binding="{Binding StatusCode}" Value="2">
                                                                                <Setter Property="Background" Value="{DynamicResource ToggleBtnActiveBg}"/>
                                                                            </DataTrigger>
                                                                            <DataTrigger Binding="{Binding ToggleBusy}" Value="True">
                                                                                <Setter Property="Background" Value="{DynamicResource ToggleBtnBusyBg}"/>
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </Button.Style>
                                                            </Button>
                                                            <Button Content="🗑"
                                                                    Tag="{Binding MerchantId}"
                                                                    Click="DeleteAccount_Click"
                                                                    Height="26" Width="30" FontSize="12"
                                                                    Margin="4,0,0,0"
                                                                    Style="{StaticResource DangerButton}"
                                                                    ToolTip="Delete this account's Payrix link and merchant"/>
                                                            </StackPanel>
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </ScrollViewer>
                                    <!-- Paging footer -->
                                    <Border Grid.Row="3" BorderBrush="{DynamicResource CardBorder}" BorderThickness="0,1,0,0"
                                            Padding="12,8" Background="{DynamicResource TabHoverBg}">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <!-- Per-page selector -->
                                                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                                    <TextBlock Text="Show" FontSize="11" Foreground="{DynamicResource SubText}"
                                                               VerticalAlignment="Center" Margin="0,0,6,0"/>
                                                    <ComboBox x:Name="AccPageSizeBox" FontSize="11" Height="26" Width="72"
                                                              SelectedIndex="0"
                                                              SelectionChanged="AccPageSizeBox_SelectionChanged">
                                                        <ComboBoxItem Content="20 / page"/>
                                                        <ComboBoxItem Content="50 / page"/>
                                                        <ComboBoxItem Content="100 / page"/>
                                                    </ComboBox>
                                                </StackPanel>
                                                <!-- Paging text + nav -->
                                                <StackPanel Grid.Column="1" Orientation="Horizontal"
                                                            HorizontalAlignment="Center" VerticalAlignment="Center">
                                                    <TextBlock x:Name="AccPagingText"
                                                               Text="No accounts loaded"
                                                               FontSize="11" Foreground="{DynamicResource SubText}"
                                                               VerticalAlignment="Center" Margin="0,0,12,0"/>
                                                    <Button x:Name="AccPrevPageBtn"
                                                            Content="‹" FontSize="14" Width="28" Height="28"
                                                            Background="Transparent" BorderThickness="1"
                                                            BorderBrush="{DynamicResource CardBorder}"
                                                            Foreground="{DynamicResource PrimaryText}"
                                                            IsEnabled="False"
                                                            Click="AccPrevPageBtn_Click" Cursor="Hand" Margin="0,0,4,0"/>
                                                    <Border CornerRadius="6" Background="{DynamicResource PagePillBg}" Padding="8,2" VerticalAlignment="Center" Margin="0,0,4,0">
                                                        <TextBlock x:Name="AccPageNumText" Text="1"
                                                                   FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource PagePillFg}"/>
                                                    </Border>
                                                    <Button x:Name="AccNextPageBtn"
                                                            Content="›" FontSize="14" Width="28" Height="28"
                                                            Background="Transparent" BorderThickness="1"
                                                            BorderBrush="{DynamicResource CardBorder}"
                                                            Foreground="{DynamicResource PrimaryText}"
                                                            IsEnabled="False"
                                                            Click="AccNextPageBtn_Click" Cursor="Hand"/>
                                                </StackPanel>
                                            </Grid>
                                    </Border>
                                </Grid>
                            </Border>

                        </Grid>
                    </Grid>
                </TabItem>

                <!-- Tab 13: Merchants -->
                <TabItem x:Name="TabItem13" Header="🏪  Merchants"       Visibility="Collapsed">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>  <!-- toolbar -->
                            <RowDefinition Height="*"/>     <!-- list + detail split -->
                        </Grid.RowDefinitions>

                        <!-- ── Toolbar ── -->
                        <Border Grid.Row="0" Padding="20,12"
                                BorderBrush="{DynamicResource CardBorder}" BorderThickness="0,0,0,1"
                                Background="{DynamicResource CardBg}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <!-- Title -->
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="Merchants" FontSize="18" FontWeight="Bold"
                                               Foreground="{DynamicResource PrimaryText}"/>
                                    <TextBlock x:Name="MerchantSubtitle"
                                               Text="Load merchants from the active environment"
                                               FontSize="11.5" Foreground="{DynamicResource SubText}"/>
                                </StackPanel>
                                <!-- Search box -->
                                <Border Grid.Column="1" CornerRadius="8" Margin="0,0,8,0"
                                        Background="{DynamicResource InputBg}"
                                        BorderBrush="{DynamicResource CardBorder}" BorderThickness="1"
                                        Padding="10,0" Height="32" Width="200" VerticalAlignment="Center">
                                    <TextBox x:Name="MerchantSearchBox"
                                             Background="Transparent" BorderThickness="0"
                                             VerticalAlignment="Center" FontSize="12"
                                             Foreground="{DynamicResource PrimaryText}"
                                             TextChanged="MerchantSearch_Changed">
                                        <TextBox.Style>
                                            <Style TargetType="TextBox">
                                                <Style.Resources>
                                                    <VisualBrush x:Key="Hint" TileMode="None" Stretch="None" AlignmentX="Left">
                                                        <VisualBrush.Visual>
                                                            <TextBlock Text="🔍  Search merchants…" Foreground="{DynamicResource SubText}" FontSize="11.5"/>
                                                        </VisualBrush.Visual>
                                                    </VisualBrush>
                                                </Style.Resources>
                                                <Style.Triggers>
                                                    <Trigger Property="Text" Value="">
                                                        <Setter Property="Background" Value="{StaticResource Hint}"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBox.Style>
                                    </TextBox>
                                </Border>
                                <!-- Status filter pills + Latest Boarded -->
                                <StackPanel Grid.Column="2" Orientation="Horizontal" Margin="0,0,8,0" VerticalAlignment="Center">
                                    <Border x:Name="MerchantFilterAllBorder" CornerRadius="6" Margin="0,0,4,0"
                                            Background="#7C3AED" BorderBrush="#7C3AED" BorderThickness="1"
                                            Padding="10,4" Cursor="Hand" MouseLeftButtonDown="MerchantFilter_Click" Tag="All">
                                        <TextBlock Text="All" FontSize="11" FontWeight="SemiBold" Foreground="White"/>
                                    </Border>
                                    <Border x:Name="MerchantFilterActiveBorder" CornerRadius="6" Margin="0,0,4,0"
                                            Background="{DynamicResource InputBg}" BorderBrush="{DynamicResource CardBorder}" BorderThickness="1"
                                            Padding="10,4" Cursor="Hand" MouseLeftButtonDown="MerchantFilter_Click" Tag="Active">
                                        <TextBlock Text="Active" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource SubText}"/>
                                    </Border>
                                    <Border x:Name="MerchantFilterInactiveBorder" CornerRadius="6" Margin="0,0,4,0"
                                            Background="{DynamicResource InputBg}" BorderBrush="{DynamicResource CardBorder}" BorderThickness="1"
                                            Padding="10,4" Cursor="Hand" MouseLeftButtonDown="MerchantFilter_Click" Tag="Inactive">
                                        <TextBlock Text="Inactive" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource SubText}"/>
                                    </Border>
                                    <Border x:Name="MerchantFilterBoardedBorder" CornerRadius="6"
                                            Background="{DynamicResource InputBg}" BorderBrush="{DynamicResource CardBorder}" BorderThickness="1"
                                            Padding="10,4" Cursor="Hand" MouseLeftButtonDown="MerchantFilter_Click" Tag="Boarded">
                                        <TextBlock Text="🆕 Latest Boarded" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource SubText}"/>
                                    </Border>
                                </StackPanel>
                                <!-- Limit input -->
                                <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,8,0">
                                    <TextBlock Text="Limit:" FontSize="12" Foreground="{DynamicResource SubText}"
                                               VerticalAlignment="Center" Margin="0,0,6,0"/>
                                    <TextBox x:Name="MerchantLimitBox" Width="60" Height="32" Padding="8,0"
                                             VerticalContentAlignment="Center" FontSize="12"
                                             BorderBrush="{DynamicResource InputBorder}" BorderThickness="1"
                                             Text="0" ToolTip="Max merchants to load. Enter 0 to load all."/>
                                </StackPanel>
                                <!-- Environment badge -->
                                <Border Grid.Column="4" CornerRadius="6" Margin="0,0,8,0"
                                        Background="{DynamicResource TabHoverBg}" Padding="10,4"
                                        VerticalAlignment="Center">
                                    <TextBlock x:Name="MerchantEnvLabel" Text="Sandbox"
                                               FontSize="11" FontWeight="SemiBold"
                                               Foreground="{DynamicResource SubText}"/>
                                </Border>
                                <!-- Load button -->
                                <Button Grid.Column="5" x:Name="LoadMerchantsBtn"
                                        Content="⟳  Load Merchants"
                                        Height="34" Padding="14,0" FontSize="12.5"
                                        Style="{StaticResource PrimaryButton}"
                                        Background="#7C3AED"
                                        Click="LoadMerchants_Click"/>
                                <Button Grid.Column="6" x:Name="MerchDeleteSelectedBtn"
                                        Content="🗑  Delete Selected (0)"
                                        Height="34" Padding="14,0" FontSize="12.5" Margin="8,0,0,0"
                                        Style="{StaticResource PrimaryButton}"
                                        Background="#DC2626" Visibility="Collapsed"
                                        Click="MerchDeleteSelected_Click"/>
                            </Grid>
                        </Border>

                        <!-- ── Content: list (left) + detail (right) ── -->
                        <Grid Grid.Row="1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="4"/>
                                <ColumnDefinition Width="360" MinWidth="280"/>
                            </Grid.ColumnDefinitions>

                            <!-- ── Merchant list ── -->
                            <Grid Grid.Column="0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <!-- Column headers — clickable sort buttons -->
                                <Border Grid.Row="0" Padding="0,0"
                                        Background="{DynamicResource TabHoverBg}"
                                        BorderBrush="{DynamicResource CardBorder}" BorderThickness="0,0,0,1">
                                    <Grid x:Name="MerchantHeaderGrid">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="30"/>    <!-- pin -->
                                            <ColumnDefinition Width="*"/>     <!-- name -->
                                            <ColumnDefinition Width="4"/>
                                            <ColumnDefinition Width="160"/>   <!-- entity -->
                                            <ColumnDefinition Width="4"/>
                                            <ColumnDefinition Width="100"/>   <!-- descriptor -->
                                            <ColumnDefinition Width="4"/>
                                            <ColumnDefinition Width="90"/>    <!-- status -->
                                            <ColumnDefinition Width="4"/>
                                            <ColumnDefinition Width="80"/>    <!-- kyc -->
                                            <ColumnDefinition Width="4"/>
                                            <ColumnDefinition Width="100"/>   <!-- created -->
                                            <ColumnDefinition Width="4"/>
                                            <ColumnDefinition Width="80"/>    <!-- core -->
                                            <ColumnDefinition Width="4"/>
                                            <ColumnDefinition Width="100"/>   <!-- avail bal -->
                                            <ColumnDefinition Width="4"/>
                                            <ColumnDefinition Width="102"/>   <!-- action -->
                                        </Grid.ColumnDefinitions>
                                        <!-- blank pin col -->
                                        <TextBlock Grid.Column="0"/>
                                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                            <CheckBox x:Name="MerchSelectAllChk" Margin="4,0,6,0"
                                                      VerticalAlignment="Center" Click="MerchSelectAll_Click"
                                                      ToolTip="Select / deselect all"/>
                                            <Button Content="NAME" Tag="DisplayName" x:Name="MSortName"
                                                    Style="{StaticResource SortHeaderButton}" Click="MSort_Click"/>
                                        </StackPanel>
                                        <GridSplitter Grid.Column="2" Width="4" HorizontalAlignment="Stretch"
                                                      Background="Transparent" Cursor="SizeWE"
                                                      ResizeDirection="Columns" ResizeBehavior="PreviousAndNext"
                                                      DragDelta="MerchantSplitter_DragDelta"/>
                                        <TextBlock Grid.Column="3" Text="ENTITY" FontSize="10" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource SubText}" VerticalAlignment="Center" Margin="4,0,0,0"/>
                                        <GridSplitter Grid.Column="4" Width="4" HorizontalAlignment="Stretch"
                                                      Background="Transparent" Cursor="SizeWE"
                                                      ResizeDirection="Columns" ResizeBehavior="PreviousAndNext"
                                                      DragDelta="MerchantSplitter_DragDelta"/>
                                        <Button Grid.Column="5" x:Name="MSortDescriptor" Content="DESCRIPTION"  Tag="Descriptor"  Style="{StaticResource SortHeaderButton}" Click="MSort_Click"/>
                                        <GridSplitter Grid.Column="6" Width="4" HorizontalAlignment="Stretch"
                                                      Background="Transparent" Cursor="SizeWE"
                                                      ResizeDirection="Columns" ResizeBehavior="PreviousAndNext"
                                                      DragDelta="MerchantSplitter_DragDelta"/>
                                        <Button Grid.Column="7" x:Name="MSortStatus"     Content="STATUS"       Tag="Status"      Style="{StaticResource SortHeaderButton}" Click="MSort_Click"/>
                                        <GridSplitter Grid.Column="8" Width="4" HorizontalAlignment="Stretch"
                                                      Background="Transparent" Cursor="SizeWE"
                                                      ResizeDirection="Columns" ResizeBehavior="PreviousAndNext"
                                                      DragDelta="MerchantSplitter_DragDelta"/>
                                        <Button Grid.Column="9" x:Name="MSortKyc"        Content="KYC"          Tag="KycCode"     Style="{StaticResource SortHeaderButton}" Click="MSort_Click"/>
                                        <GridSplitter Grid.Column="10" Width="4" HorizontalAlignment="Stretch"
                                                      Background="Transparent" Cursor="SizeWE"
                                                      ResizeDirection="Columns" ResizeBehavior="PreviousAndNext"
                                                      DragDelta="MerchantSplitter_DragDelta"/>
                                        <Button Grid.Column="11" x:Name="MSortCreated"   Content="CREATED"      Tag="Created"     Style="{StaticResource SortHeaderButton}" Click="MSort_Click"/>
                                        <GridSplitter Grid.Column="12" Width="4" HorizontalAlignment="Stretch"
                                                      Background="Transparent" Cursor="SizeWE"
                                                      ResizeDirection="Columns" ResizeBehavior="PreviousAndNext"
                                                      DragDelta="MerchantSplitter_DragDelta"/>
                                        <TextBlock Grid.Column="13" Text="CORE" FontSize="10" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource SubText}" VerticalAlignment="Center" Margin="4,0,0,0"/>
                                        <GridSplitter Grid.Column="14" Width="4" HorizontalAlignment="Stretch"
                                                      Background="Transparent" Cursor="SizeWE"
                                                      ResizeDirection="Columns" ResizeBehavior="PreviousAndNext"
                                                      DragDelta="MerchantSplitter_DragDelta"/>
                                        <TextBlock Grid.Column="15" Text="AVAIL. BAL" FontSize="10" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource SubText}" VerticalAlignment="Center" Margin="4,0,0,0"/>
                                        <GridSplitter Grid.Column="16" Width="4" HorizontalAlignment="Stretch"
                                                      Background="Transparent" Cursor="SizeWE"
                                                      ResizeDirection="Columns" ResizeBehavior="PreviousAndNext"
                                                      DragDelta="MerchantSplitter_DragDelta"/>
                                        <StackPanel Grid.Column="17" Orientation="Horizontal" VerticalAlignment="Center" Margin="4,0,0,0">
                                            <TextBlock Text="ACTION" FontSize="10" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource SubText}" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                            <Button x:Name="MerchColChooserBtn" Content="⊞" Click="MerchColumnChooser_Click"
                                                    FontSize="11" Padding="3,1" VerticalAlignment="Center"
                                                    Background="Transparent" BorderThickness="1"
                                                    BorderBrush="{DynamicResource CardBorder}"
                                                    Foreground="{DynamicResource SubText}" Cursor="Hand"/>
                                            <Popup x:Name="MerchColChooserPopup" StaysOpen="False" Placement="Bottom"
                                                   PlacementTarget="{Binding ElementName=MerchColChooserBtn}">
                                                <Border Background="{DynamicResource CardBg}"
                                                        BorderBrush="{DynamicResource CardBorder}"
                                                        BorderThickness="1" CornerRadius="6" Padding="10">
                                                    <StackPanel>
                                                        <TextBlock Text="Show columns" FontSize="10" FontWeight="SemiBold"
                                                                   Foreground="{DynamicResource SubText}" Margin="0,0,0,6"/>
                                                        <CheckBox Content="Entity"      IsChecked="True" Tag="3:160:4"  Click="MerchColCheck_Click" Margin="0,2"/>
                                                        <CheckBox Content="Description" IsChecked="True" Tag="5:100:6"  Click="MerchColCheck_Click" Margin="0,2"/>
                                                        <CheckBox Content="Status"      IsChecked="True" Tag="7:90:8"   Click="MerchColCheck_Click" Margin="0,2"/>
                                                        <CheckBox Content="KYC"         IsChecked="True" Tag="9:80:10"  Click="MerchColCheck_Click" Margin="0,2"/>
                                                        <CheckBox Content="Created"     IsChecked="True" Tag="11:100:12" Click="MerchColCheck_Click" Margin="0,2"/>
                                                        <CheckBox Content="Core"        IsChecked="True" Tag="13:80:14"  Click="MerchColCheck_Click" Margin="0,2"/>
                                                        <CheckBox Content="Avail. Bal"  IsChecked="True" Tag="15:100:16" Click="MerchColCheck_Click" Margin="0,2"/>
                                                    </StackPanel>
                                                </Border>
                                            </Popup>
                                        </StackPanel>
                                    </Grid>
                                </Border>

                                <!-- Merchant rows -->
                                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                                    <StackPanel>
                                        <!-- Placeholder / empty state -->
                                        <Border x:Name="MerchantEmptyState" Padding="20,48"
                                                Visibility="Visible">
                                            <StackPanel HorizontalAlignment="Center">
                                                <TextBlock Text="🏪" FontSize="36" HorizontalAlignment="Center" Margin="0,0,0,12"/>
                                                <TextBlock x:Name="MerchantEmptyText"
                                                           Text="Click  ⟳ Load Merchants  to fetch merchant data."
                                                           FontSize="13" Foreground="{DynamicResource SubText}"
                                                           HorizontalAlignment="Center" TextAlignment="Center"/>
                                            </StackPanel>
                                        </Border>
                                        <!-- Live rows (paged) -->
                                        <ItemsControl x:Name="MerchantList">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate DataType="{x:Type local:Merchant}">
                                                    <Border Cursor="Hand"
                                                            BorderBrush="{DynamicResource CardBorder}"
                                                            BorderThickness="0,0,0,1"
                                                            Tag="{Binding}"
                                                            MouseLeftButtonDown="MerchantRow_Click">
                                                        <Border.Style>
                                                            <Style TargetType="Border">
                                                                <Setter Property="Background" Value="Transparent"/>
                                                                <Setter Property="Padding" Value="0,8"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                                        <Setter Property="Background" Value="{DynamicResource TabHoverBg}"/>
                                                                    </DataTrigger>
                                                                    <Trigger Property="IsMouseOver" Value="True">
                                                                        <Setter Property="Background" Value="{DynamicResource TabHoverBg}"/>
                                                                    </Trigger>
                                                                    <DataTrigger Binding="{Binding IsPinned}" Value="True">
                                                                        <Setter Property="Background" Value="{DynamicResource PinnedRowBg}"/>
                                                                        <Setter Property="BorderBrush" Value="{DynamicResource PinnedRowBorder}"/>
                                                                        <Setter Property="BorderThickness" Value="3,0,0,1"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Border.Style>
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="30"/>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="4"/>    <!-- spacer -->
                                                                <ColumnDefinition Width="160"/>  <!-- Entity -->
                                                                <ColumnDefinition Width="4"/>    <!-- spacer -->
                                                                <ColumnDefinition Width="100"/>
                                                                <ColumnDefinition Width="4"/>    <!-- spacer -->
                                                                <ColumnDefinition Width="90"/>
                                                                <ColumnDefinition Width="4"/>    <!-- spacer -->
                                                                <ColumnDefinition Width="80"/>
                                                                <ColumnDefinition Width="4"/>    <!-- spacer -->
                                                                <ColumnDefinition Width="100"/>
                                                                <ColumnDefinition Width="4"/>    <!-- spacer -->
                                                                <ColumnDefinition Width="80"/>   <!-- Core -->
                                                                <ColumnDefinition Width="4"/>    <!-- spacer -->
                                                                <ColumnDefinition Width="100"/>  <!-- Avail Bal -->
                                                                <ColumnDefinition Width="4"/>    <!-- spacer -->
                                                                <ColumnDefinition Width="102"/>
                                                            </Grid.ColumnDefinitions>

                                                            <!-- Pin toggle button -->
                                                            <Button Grid.Column="0"
                                                                    Content="{Binding PinIcon}"
                                                                    FontSize="13" Background="Transparent" BorderThickness="0"
                                                                    Padding="4,0" VerticalAlignment="Center" Cursor="Hand"
                                                                    ToolTip="Pin / Unpin merchant"
                                                                    Tag="{Binding Id}"
                                                                    Click="PinMerchant_Click"/>

                                                            <!-- Checkbox + DisplayName + ID + copy + pinned chip -->
                                                            <Grid Grid.Column="1">
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="Auto"/>
                                                                    <ColumnDefinition Width="*"/>
                                                                    <ColumnDefinition Width="Auto"/>
                                                                </Grid.ColumnDefinitions>
                                                                <CheckBox Grid.Column="0"
                                                                          IsChecked="{Binding IsMarked, Mode=TwoWay}"
                                                                          Margin="4,0,8,0" VerticalAlignment="Center"
                                                                          Click="MerchRowCheck_Click"/>
                                                                <StackPanel Grid.Column="1">
                                                                    <StackPanel Orientation="Horizontal">
                                                                        <TextBlock Text="{Binding DisplayName}"
                                                                                   FontSize="13" FontWeight="SemiBold"
                                                                                   Foreground="{DynamicResource PrimaryText}"
                                                                                   TextTrimming="CharacterEllipsis"/>
                                                                        <Border CornerRadius="4" Padding="5,1" Margin="6,0,0,0"
                                                                                Background="#1A6366F1" VerticalAlignment="Center">
                                                                            <Border.Style>
                                                                                <Style TargetType="Border">
                                                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                                                    <Style.Triggers>
                                                                                        <DataTrigger Binding="{Binding IsPinned}" Value="True">
                                                                                            <Setter Property="Visibility" Value="Visible"/>
                                                                                        </DataTrigger>
                                                                                    </Style.Triggers>
                                                                                </Style>
                                                                            </Border.Style>
                                                                            <TextBlock Text="📌 Pinned" FontSize="9" FontWeight="SemiBold" Foreground="{DynamicResource PinnedChipFg}"/>
                                                                        </Border>
                                                                    </StackPanel>
                                                                    <TextBlock Text="{Binding Id}"
                                                                               FontSize="10" Foreground="{DynamicResource SubText}"
                                                                               FontFamily="Cascadia Code, Consolas"
                                                                               TextTrimming="CharacterEllipsis"/>
                                                                </StackPanel>
                                                                <Button Grid.Column="2"
                                                                        Content="📋" FontSize="13" Cursor="Hand"
                                                                        Background="Transparent" BorderThickness="0"
                                                                        Padding="6,0" VerticalAlignment="Center"
                                                                        ToolTip="Copy Merchant ID"
                                                                        Tag="{Binding Id}"
                                                                        Click="CopyMerchantId_Click"/>
                                                            </Grid>

                                                            <!-- Entity ID + Name -->
                                                            <StackPanel Grid.Column="3" VerticalAlignment="Center">
                                                                <TextBlock Text="{Binding EntityName, TargetNullValue='—'}"
                                                                           FontSize="11.5" FontWeight="SemiBold"
                                                                           Foreground="{DynamicResource PrimaryText}"
                                                                           TextTrimming="CharacterEllipsis"/>
                                                                <TextBlock Text="{Binding Entity, TargetNullValue=''}"
                                                                           FontSize="10" Foreground="{DynamicResource SubText}"
                                                                           FontFamily="Cascadia Code, Consolas"
                                                                           TextTrimming="CharacterEllipsis"/>
                                                            </StackPanel>
                                                            <!-- Descriptor -->
                                                            <TextBlock Grid.Column="5"
                                                                       Text="{Binding Descriptor, TargetNullValue='—'}"
                                                                       FontSize="12" Foreground="{DynamicResource SubText}"
                                                                       VerticalAlignment="Center"
                                                                       TextTrimming="CharacterEllipsis"/>
                                                            <!-- Status badge -->
                                                            <Border Grid.Column="7" CornerRadius="5" Padding="6,2"
                                                                    Background="{Binding StatusBg}"
                                                                    HorizontalAlignment="Left" VerticalAlignment="Center">
                                                                <TextBlock Text="{Binding StatusLabel}"
                                                                           FontSize="10.5" FontWeight="SemiBold"
                                                                           Foreground="{Binding StatusColor}"/>
                                                            </Border>
                                                            <!-- KYC badge -->
                                                            <Border Grid.Column="9" CornerRadius="5" Padding="6,2"
                                                                    Background="{Binding KycBg}"
                                                                    HorizontalAlignment="Left" VerticalAlignment="Center">
                                                                <TextBlock Text="{Binding KycLabel}"
                                                                           FontSize="10.5" FontWeight="SemiBold"
                                                                           Foreground="{Binding KycColor}"/>
                                                            </Border>
                                                            <!-- Created -->
                                                            <TextBlock Grid.Column="11"
                                                                       Text="{Binding CreatedFormatted}"
                                                                       FontSize="11" Foreground="{DynamicResource SubText}"
                                                                       VerticalAlignment="Center"/>
                                                            <!-- Linked to Core badge -->
                                                            <Border Grid.Column="13" CornerRadius="5" Padding="6,2"
                                                                    HorizontalAlignment="Left" VerticalAlignment="Center">
                                                                <Border.Style>
                                                                    <Style TargetType="Border">
                                                                        <Setter Property="Background" Value="#269CA3AF"/>
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding LinkedToCore}" Value="True">
                                                                                <Setter Property="Background" Value="#2622C55E"/>
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </Border.Style>
                                                                <TextBlock FontSize="10" FontWeight="SemiBold">
                                                                    <TextBlock.Style>
                                                                        <Style TargetType="TextBlock">
                                                                            <Setter Property="Text" Value="—"/>
                                                                            <Setter Property="Foreground" Value="{DynamicResource CoreNotLinkedFg}"/>
                                                                            <Style.Triggers>
                                                                                <DataTrigger Binding="{Binding LinkedToCore}" Value="True">
                                                                                    <Setter Property="Text" Value="✓ Linked"/>
                                                                                    <Setter Property="Foreground" Value="{DynamicResource CoreLinkedFg}"/>
                                                                                </DataTrigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </TextBlock.Style>
                                                                </TextBlock>
                                                            </Border>
                                                            <!-- Available Balance -->
                                                            <TextBlock Grid.Column="15"
                                                                       Text="{Binding AvailableBalanceDisplay}"
                                                                       FontSize="11.5" FontWeight="SemiBold"
                                                                       VerticalAlignment="Center" Margin="4,0,0,0">
                                                                <TextBlock.Style>
                                                                    <Style TargetType="TextBlock">
                                                                        <Setter Property="Foreground" Value="{DynamicResource SubText}"/>
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding HasBalance}" Value="True">
                                                                                <Setter Property="Foreground" Value="#22C55E"/>
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </TextBlock.Style>
                                                            </TextBlock>
                                                            <!-- Toggle Active/Inactive -->
                                                            <Button Grid.Column="17"
                                                                    Content="{Binding ToggleStatusLabel}"
                                                                    IsEnabled="{Binding ToggleEnabled}"
                                                                    Tag="{Binding Id}"
                                                                    Click="ToggleMerchantStatus_Merchants_Click"
                                                                    Height="26" Padding="10,0" FontSize="11"
                                                                    HorizontalAlignment="Left" VerticalAlignment="Center"
                                                                    Margin="4,0,4,0">
                                                                <Button.Style>
                                                                    <Style TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
                                                                        <Setter Property="Background" Value="#7C3AED"/>
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding Status}" Value="1">
                                                                                <Setter Property="Background" Value="#D97706"/>
                                                                            </DataTrigger>
                                                                            <DataTrigger Binding="{Binding Status}" Value="2">
                                                                                <Setter Property="Background" Value="#D97706"/>
                                                                            </DataTrigger>
                                                                            <DataTrigger Binding="{Binding ToggleBusy}" Value="True">
                                                                                <Setter Property="Background" Value="#6B7280"/>
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </Button.Style>
                                                            </Button>
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </ScrollViewer>

                                <!-- ── Pagination footer ── -->
                                <Border Grid.Row="2"
                                        Background="{DynamicResource CardBg}"
                                        BorderBrush="{DynamicResource CardBorder}" BorderThickness="0,1,0,0"
                                        Padding="12,8">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- Per-page selector -->
                                        <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                            <TextBlock Text="Show" FontSize="11" Foreground="{DynamicResource SubText}"
                                                       VerticalAlignment="Center" Margin="0,0,6,0"/>
                                            <ComboBox x:Name="MerchantPageSizeBox" FontSize="11" Height="26" Width="72"
                                                      SelectedIndex="0"
                                                      SelectionChanged="MerchantPageSizeBox_SelectionChanged">
                                                <ComboBoxItem Content="20 / page"/>
                                                <ComboBoxItem Content="50 / page"/>
                                                <ComboBoxItem Content="100 / page"/>
                                            </ComboBox>
                                        </StackPanel>

                                        <!-- Paging text + nav -->
                                        <StackPanel Grid.Column="1" Orientation="Horizontal"
                                                    HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <TextBlock x:Name="MerchantPagingText"
                                                       Text="No merchants loaded"
                                                       FontSize="11" Foreground="{DynamicResource SubText}"
                                                       VerticalAlignment="Center" Margin="0,0,12,0"/>
                                            <Button x:Name="MerchantPrevPageBtn"
                                                    Content="‹" FontSize="14" Width="28" Height="28"
                                                    Background="Transparent" BorderThickness="1"
                                                    BorderBrush="{DynamicResource CardBorder}"
                                                    Foreground="{DynamicResource PrimaryText}"
                                                    IsEnabled="False"
                                                    Click="MerchantPrevPageBtn_Click" Cursor="Hand" Margin="0,0,4,0"/>
                                            <Border CornerRadius="6" Background="#7C3AED" Padding="8,2" VerticalAlignment="Center" Margin="0,0,4,0">
                                                <TextBlock x:Name="MerchantPageNumText" Text="1"
                                                           FontSize="11" FontWeight="SemiBold" Foreground="White"/>
                                            </Border>
                                            <Button x:Name="MerchantNextPageBtn"
                                                    Content="›" FontSize="14" Width="28" Height="28"
                                                    Background="Transparent" BorderThickness="1"
                                                    BorderBrush="{DynamicResource CardBorder}"
                                                    Foreground="{DynamicResource PrimaryText}"
                                                    IsEnabled="False"
                                                    Click="MerchantNextPageBtn_Click" Cursor="Hand"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </Grid>

                            <!-- Splitter -->
                            <GridSplitter Grid.Column="1" Width="4" HorizontalAlignment="Stretch"
                                          Background="{DynamicResource CardBorder}" Cursor="SizeWE"/>

                            <!-- ── Detail panel ── -->
                            <Border Grid.Column="2"
                                    Background="{DynamicResource CardBg}"
                                    BorderBrush="{DynamicResource CardBorder}" BorderThickness="1,0,0,0">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>
                                    <!-- Detail header bar -->
                                    <Border Grid.Row="0" Padding="16,10"
                                            BorderBrush="{DynamicResource CardBorder}" BorderThickness="0,0,0,1"
                                            Background="{DynamicResource CardBg}">
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                            <TextBlock Text="←" FontSize="13" Foreground="{DynamicResource SubText}" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                            <TextBlock x:Name="MerchantDetailHeaderText"
                                                       Text="Select a merchant to view details"
                                                       FontSize="12" Foreground="{DynamicResource SubText}" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Border>
                                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                                    <Grid>
                                    <StackPanel x:Name="MerchantDetailPanel" Margin="20,16" Visibility="Collapsed">

                                        <!-- Name + copy + badges -->
                                        <Grid Margin="0,0,0,6">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock x:Name="MDetailName" Text="—"
                                                       FontSize="16" FontWeight="Bold"
                                                       Foreground="{DynamicResource PrimaryText}"
                                                       TextWrapping="Wrap"/>
                                            <Button Grid.Column="1" Content="📋" FontSize="14"
                                                    Background="Transparent" BorderThickness="0"
                                                    Padding="4,0" VerticalAlignment="Top" Cursor="Hand"
                                                    ToolTip="Copy display name"
                                                    Tag="{Binding ElementName=MDetailName, Path=Text}"
                                                    Click="CopyMDetailField_Click"/>
                                        </Grid>
                                        <Grid Margin="0,0,0,14">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Orientation="Horizontal">
                                                <Border x:Name="MDetailStatusBadge" CornerRadius="5" Padding="7,3" Margin="0,0,6,0">
                                                    <TextBlock x:Name="MDetailStatus" FontSize="11" FontWeight="SemiBold"/>
                                                </Border>
                                                <Border x:Name="MDetailKycBadge" CornerRadius="5" Padding="7,3">
                                                    <TextBlock x:Name="MDetailKyc" FontSize="11" FontWeight="SemiBold"/>
                                                </Border>
                                            </StackPanel>
                                            <!-- Activate / Deactivate + Delete -->
                                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                                <Button x:Name="MDetailToggleBtn"
                                                        Content="Deactivate"
                                                        Height="28" Padding="12,0" FontSize="11"
                                                        Style="{StaticResource PrimaryButton}"
                                                        Background="#D97706"
                                                        Click="ToggleMerchantDetail_Click"/>
                                                <Button x:Name="MDetailDeleteBtn"
                                                        Content="🗑 Delete"
                                                        Height="28" Padding="10,0" FontSize="11" Margin="8,0,0,0"
                                                        Style="{StaticResource DangerButton}"
                                                        ToolTip="Delete this merchant from Payrix and remove the Core DB link"
                                                        Click="DeleteMerchant_Click"/>
                                            </StackPanel>
                                        </Grid>

                                        <!-- Info rows -->
                                        <Border Background="{DynamicResource TabHoverBg}" CornerRadius="8" Padding="14,12" Margin="0,0,0,12">
                                            <StackPanel>
                                                <TextBlock Text="MERCHANT INFO" FontSize="10" FontWeight="Bold"
                                                           Foreground="{DynamicResource SubText}" Margin="0,0,0,10"/>
                                                <!-- ID -->
                                                <Grid Margin="0,0,0,6">
                                                    <Grid.ColumnDefinitions><ColumnDefinition Width="90"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                                    <TextBlock Text="ID" FontSize="11" Foreground="{DynamicResource SubText}" VerticalAlignment="Center"/>
                                                    <TextBlock x:Name="MDetailId" Grid.Column="1" FontSize="11"
                                                               Foreground="{DynamicResource PrimaryText}"
                                                               FontFamily="Cascadia Code, Consolas"
                                                               TextWrapping="Wrap" VerticalAlignment="Center"/>
                                                    <Button Grid.Column="2" x:Name="CopyMDetailIdBtn"
                                                            Content="📋" FontSize="12" Cursor="Hand"
                                                            Background="Transparent" BorderThickness="0"
                                                            Padding="4,0" ToolTip="Copy ID"
                                                            Tag="{Binding ElementName=MDetailId, Path=Text}"
                                                            Click="CopyMDetailField_Click"/>
                                                </Grid>
                                                <!-- Name -->
                                                <Grid Margin="0,0,0,6">
                                                    <Grid.ColumnDefinitions><ColumnDefinition Width="90"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                                    <TextBlock Text="Name" FontSize="11" Foreground="{DynamicResource SubText}" VerticalAlignment="Center"/>
                                                    <TextBlock x:Name="MDetailRawName" Grid.Column="1" FontSize="11"
                                                               Foreground="{DynamicResource PrimaryText}" TextWrapping="Wrap" VerticalAlignment="Center"/>
                                                    <Button Grid.Column="2" Content="📋" FontSize="12" Cursor="Hand"
                                                            Background="Transparent" BorderThickness="0" Padding="4,0"
                                                            ToolTip="Copy name"
                                                            Tag="{Binding ElementName=MDetailRawName, Path=Text}"
                                                            Click="CopyMDetailField_Click"/>
                                                </Grid>
                                                <!-- Descriptor -->
                                                <Grid Margin="0,0,0,6">
                                                    <Grid.ColumnDefinitions><ColumnDefinition Width="90"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                                    <TextBlock Text="Descriptor" FontSize="11" Foreground="{DynamicResource SubText}" VerticalAlignment="Center"/>
                                                    <TextBlock x:Name="MDetailDescriptor" Grid.Column="1" FontSize="11"
                                                               Foreground="{DynamicResource PrimaryText}" TextWrapping="Wrap" VerticalAlignment="Center"/>
                                                    <Button Grid.Column="2" Content="📋" FontSize="12" Cursor="Hand"
                                                            Background="Transparent" BorderThickness="0" Padding="4,0"
                                                            ToolTip="Copy descriptor"
                                                            Tag="{Binding ElementName=MDetailDescriptor, Path=Text}"
                                                            Click="CopyMDetailField_Click"/>
                                                </Grid>
                                                <!-- Email -->
                                                <Grid Margin="0,0,0,6">
                                                    <Grid.ColumnDefinitions><ColumnDefinition Width="90"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                                    <TextBlock Text="Email" FontSize="11" Foreground="{DynamicResource SubText}" VerticalAlignment="Center"/>
                                                    <TextBlock x:Name="MDetailEmail" Grid.Column="1" FontSize="11"
                                                               Foreground="{DynamicResource PrimaryText}" TextWrapping="Wrap" VerticalAlignment="Center"/>
                                                    <Button Grid.Column="2" Content="📋" FontSize="12" Cursor="Hand"
                                                            Background="Transparent" BorderThickness="0" Padding="4,0"
                                                            ToolTip="Copy email"
                                                            Tag="{Binding ElementName=MDetailEmail, Path=Text}"
                                                            Click="CopyMDetailField_Click"/>
                                                </Grid>
                                                <!-- Phone -->
                                                <Grid Margin="0,0,0,6">
                                                    <Grid.ColumnDefinitions><ColumnDefinition Width="90"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                                    <TextBlock Text="Phone" FontSize="11" Foreground="{DynamicResource SubText}" VerticalAlignment="Center"/>
                                                    <TextBlock x:Name="MDetailPhone" Grid.Column="1" FontSize="11"
                                                               Foreground="{DynamicResource PrimaryText}" VerticalAlignment="Center"/>
                                                    <Button Grid.Column="2" Content="📋" FontSize="12" Cursor="Hand"
                                                            Background="Transparent" BorderThickness="0" Padding="4,0"
                                                            ToolTip="Copy phone"
                                                            Tag="{Binding ElementName=MDetailPhone, Path=Text}"
                                                            Click="CopyMDetailField_Click"/>
                                                </Grid>
                                                <!-- Currency -->
                                                <Grid Margin="0,0,0,6">
                                                    <Grid.ColumnDefinitions><ColumnDefinition Width="90"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                                    <TextBlock Text="Currency" FontSize="11" Foreground="{DynamicResource SubText}" VerticalAlignment="Center"/>
                                                    <TextBlock x:Name="MDetailCurrency" Grid.Column="1" FontSize="11"
                                                               Foreground="{DynamicResource PrimaryText}" VerticalAlignment="Center"/>
                                                    <Button Grid.Column="2" Content="📋" FontSize="12" Cursor="Hand"
                                                            Background="Transparent" BorderThickness="0" Padding="4,0"
                                                            ToolTip="Copy currency"
                                                            Tag="{Binding ElementName=MDetailCurrency, Path=Text}"
                                                            Click="CopyMDetailField_Click"/>
                                                </Grid>
                                                <!-- Created -->
                                                <Grid>
                                                    <Grid.ColumnDefinitions><ColumnDefinition Width="90"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                                    <TextBlock Text="Created" FontSize="11" Foreground="{DynamicResource SubText}" VerticalAlignment="Center"/>
                                                    <TextBlock x:Name="MDetailCreated" Grid.Column="1" FontSize="11"
                                                               Foreground="{DynamicResource PrimaryText}" VerticalAlignment="Center"/>
                                                    <Button Grid.Column="2" Content="📋" FontSize="12" Cursor="Hand"
                                                            Background="Transparent" BorderThickness="0" Padding="4,0"
                                                            ToolTip="Copy created date"
                                                            Tag="{Binding ElementName=MDetailCreated, Path=Text}"
                                                            Click="CopyMDetailField_Click"/>
                                                </Grid>
                                            </StackPanel>
                                        </Border>

                                        <!-- Address card -->
                                        <Border Background="{DynamicResource TabHoverBg}" CornerRadius="8" Padding="14,12" Margin="0,0,0,12">
                                            <Grid>
                                                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                                <StackPanel>
                                                    <TextBlock Text="ADDRESS" FontSize="10" FontWeight="Bold"
                                                               Foreground="{DynamicResource SubText}" Margin="0,0,0,10"/>
                                                    <TextBlock x:Name="MDetailAddress" FontSize="12"
                                                               Foreground="{DynamicResource PrimaryText}"
                                                               TextWrapping="Wrap" LineHeight="20"/>
                                                </StackPanel>
                                                <Button Grid.Column="1" Content="📋" FontSize="12" Cursor="Hand"
                                                        Background="Transparent" BorderThickness="0" Padding="4,0"
                                                        VerticalAlignment="Top" ToolTip="Copy address"
                                                        Tag="{Binding ElementName=MDetailAddress, Path=Text}"
                                                        Click="CopyMDetailField_Click"/>
                                            </Grid>
                                        </Border>

                                        <!-- KYC card -->
                                        <Border x:Name="MDetailKycCard" Background="{DynamicResource TabHoverBg}" CornerRadius="8" Padding="14,12">
                                            <StackPanel>
                                                <TextBlock Text="KYC / COMPLIANCE" FontSize="10" FontWeight="Bold"
                                                           Foreground="{DynamicResource SubText}" Margin="0,0,0,10"
                                                          />
                                                <Grid Margin="0,0,0,6">
                                                    <Grid.ColumnDefinitions><ColumnDefinition Width="80"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                                    <TextBlock Text="Status" FontSize="11" Foreground="{DynamicResource SubText}"/>
                                                    <TextBlock x:Name="MDetailKycStatus" Grid.Column="1" FontSize="11" Foreground="{DynamicResource PrimaryText}" FontWeight="SemiBold"/>
                                                </Grid>
                                                <Grid>
                                                    <Grid.ColumnDefinitions><ColumnDefinition Width="80"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                                    <TextBlock Text="Message" FontSize="11" Foreground="{DynamicResource SubText}" VerticalAlignment="Top"/>
                                                    <TextBlock x:Name="MDetailKycMsg" Grid.Column="1" FontSize="11" Foreground="{DynamicResource SubText}" TextWrapping="Wrap"/>
                                                </Grid>
                                            </StackPanel>
                                        </Border>

                                        <!-- Recent transactions card -->
                                        <Border x:Name="MDetailTxnCard" Background="{DynamicResource TabHoverBg}" CornerRadius="8" Padding="14,12"
                                                Visibility="Collapsed">
                                            <StackPanel>
                                                <TextBlock Text="RECENT TRANSACTIONS" FontSize="10" FontWeight="Bold"
                                                           Foreground="{DynamicResource SubText}" Margin="0,0,0,10"/>
                                                <TextBlock x:Name="MDetailTxnEmpty" Text="No transactions found."
                                                           FontSize="11" Foreground="{DynamicResource SubText}"
                                                           Visibility="Collapsed"/>
                                                <ItemsControl x:Name="MDetailTxnList">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <Border BorderBrush="{DynamicResource BorderColor}" BorderThickness="0,0,0,1" Padding="0,5">
                                                                <Grid>
                                                                    <Grid.ColumnDefinitions>
                                                                        <ColumnDefinition Width="*"/>
                                                                        <ColumnDefinition Width="Auto"/>
                                                                    </Grid.ColumnDefinitions>
                                                                    <StackPanel>
                                                                        <TextBlock Text="{Binding TypeLabel}" FontSize="11" FontWeight="SemiBold"
                                                                                   Foreground="{DynamicResource PrimaryText}"/>
                                                                        <TextBlock Text="{Binding CreatedDisplay}" FontSize="10"
                                                                                   Foreground="{DynamicResource SubText}"/>
                                                                    </StackPanel>
                                                                    <StackPanel Grid.Column="1" HorizontalAlignment="Right">
                                                                        <TextBlock Text="{Binding ApprovedFormatted}" FontSize="11" FontWeight="SemiBold"
                                                                                   HorizontalAlignment="Right"
                                                                                   Foreground="{DynamicResource PrimaryText}"/>
                                                                        <TextBlock Text="{Binding StatusLabel}" FontSize="10" HorizontalAlignment="Right"
                                                                                   Foreground="{Binding StatusColor, Converter={StaticResource StringToBrushConverter}}"/>
                                                                    </StackPanel>
                                                                </Grid>
                                                            </Border>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </StackPanel>
                                        </Border>

                                    </StackPanel>

                                    <!-- Empty detail placeholder -->
                                    <StackPanel x:Name="MerchantDetailEmpty" Margin="20,48" HorizontalAlignment="Center">
                                        <!-- Store icon illustration -->
                                        <Border Width="80" Height="80" CornerRadius="40"
                                                Background="{DynamicResource GreenIconBadgeBg}" HorizontalAlignment="Center" Margin="0,0,0,16">
                                            <TextBlock Text="🏪" FontSize="34" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <TextBlock Text="No merchant selected"
                                                   FontSize="14" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource PrimaryText}"
                                                   HorizontalAlignment="Center" Margin="0,0,0,6"/>
                                        <TextBlock Text="Choose a merchant from the list&#x0a;to view details and manage&#x0a;their settings."
                                                   FontSize="12" Foreground="{DynamicResource SubText}"
                                                   HorizontalAlignment="Center" TextAlignment="Center"
                                                   TextWrapping="Wrap" MaxWidth="200"/>
                                    </StackPanel>
                                    </Grid>
                                </ScrollViewer>
                                </Grid>
                            </Border>
                        </Grid>
                    </Grid>
                </TabItem>

                <!-- Tab 14: Reports -->
                <TabItem x:Name="TabItem14" Header="📈  Reports"         Visibility="Collapsed">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- ── Toolbar ── -->
                        <Border Grid.Row="0"
                                Background="{DynamicResource CardBg}"
                                BorderBrush="{DynamicResource CardBorder}"
                                BorderThickness="0,0,0,1"
                                Padding="16,10">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <!-- Left: title + filters + generate -->
                                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="Reports" FontSize="15" FontWeight="SemiBold"
                                               Foreground="{DynamicResource FgDefault}"
                                               VerticalAlignment="Center" Margin="0,0,20,0"/>

                                    <TextBlock Text="From" FontSize="11"
                                               Foreground="{DynamicResource SubText}"
                                               VerticalAlignment="Center" Margin="0,0,6,0"/>
                                    <DatePicker x:Name="ReportFromPicker" Width="118" Margin="0,0,14,0"
                                                SelectedDateChanged="ReportDate_Changed"/>

                                    <TextBlock Text="To" FontSize="11"
                                               Foreground="{DynamicResource SubText}"
                                               VerticalAlignment="Center" Margin="0,0,6,0"/>
                                    <DatePicker x:Name="ReportToPicker" Width="118" Margin="0,0,16,0"
                                                SelectedDateChanged="ReportDate_Changed"/>

                                    <TextBlock Text="Merchant ID" FontSize="11"
                                               Foreground="{DynamicResource SubText}"
                                               VerticalAlignment="Center" Margin="0,0,6,0"/>
                                    <Border CornerRadius="6" Margin="0,0,16,0"
                                            Background="{DynamicResource InputBg}"
                                            BorderBrush="{DynamicResource CardBorder}" BorderThickness="1"
                                            Padding="8,0" Height="32" Width="180" VerticalAlignment="Center">
                                        <TextBox x:Name="ReportMerchantIdBox"
                                                 Background="Transparent" BorderThickness="0"
                                                 VerticalAlignment="Center" FontSize="12"
                                                 FontFamily="Cascadia Code, Consolas"
                                                 Foreground="{DynamicResource PrimaryText}">
                                            <TextBox.Style>
                                                <Style TargetType="TextBox">
                                                    <Style.Resources>
                                                        <VisualBrush x:Key="MerchHint" TileMode="None" Stretch="None" AlignmentX="Left">
                                                            <VisualBrush.Visual>
                                                                <TextBlock Text="t1_mer_… (optional)"
                                                                           Foreground="{DynamicResource SubText}" FontSize="11"
                                                                           FontFamily="Cascadia Code, Consolas"/>
                                                            </VisualBrush.Visual>
                                                        </VisualBrush>
                                                    </Style.Resources>
                                                    <Style.Triggers>
                                                        <Trigger Property="Text" Value="">
                                                            <Setter Property="Background" Value="{StaticResource MerchHint}"/>
                                                        </Trigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBox.Style>
                                        </TextBox>
                                    </Border>

                                    <ComboBox x:Name="ReportTypeBox" Width="150" Margin="0,0,12,0"
                                              SelectionChanged="ReportType_Changed">
                                        <ComboBoxItem Content="By Type" IsSelected="True"/>
                                        <ComboBoxItem Content="By Status"/>
                                        <ComboBoxItem Content="By Merchant"/>
                                        <ComboBoxItem Content="Summary"/>
                                        <ComboBoxItem Content="Failed / Declined"/>
                                    </ComboBox>

                                    <Button x:Name="GenerateReportBtn"
                                            Content="⟳  Generate"
                                            Height="32" Padding="14,0" FontSize="12.5"
                                            Style="{StaticResource PrimaryButton}"
                                            Click="GenerateReport_Click"/>
                                </StackPanel>

                                <!-- Right: export + env badge -->
                                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                    <Button x:Name="ExportReportBtn"
                                            Content="⬇  Export CSV"
                                            Height="32" Padding="12,0" FontSize="12.5"
                                            Style="{StaticResource SecondaryButton}"
                                            IsEnabled="False"
                                            Click="ExportReport_Click"
                                            Margin="0,0,10,0"/>
                                    <Border CornerRadius="6"
                                            Background="{DynamicResource TabHoverBg}"
                                            Padding="10,4" VerticalAlignment="Center">
                                        <TextBlock x:Name="ReportEnvLabel"
                                                   Text="Sandbox"
                                                   FontSize="11" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource SubText}"/>
                                    </Border>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- ── KPI Cards ── -->
                        <Grid Grid.Row="1" Margin="16,12,16,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0" Background="{DynamicResource CardBg}" CornerRadius="8"
                                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Padding="16,12">
                                <StackPanel>
                                    <TextBlock Text="Transactions" FontSize="11"
                                               Foreground="{DynamicResource SubText}" Margin="0,0,0,4"/>
                                    <TextBlock x:Name="ReportKpiTotal" Text="—"
                                               FontSize="22" FontWeight="Bold"
                                               Foreground="{DynamicResource FgDefault}"/>
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="2" Background="{DynamicResource CardBg}" CornerRadius="8"
                                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Padding="16,12">
                                <StackPanel>
                                    <TextBlock Text="Total Amount" FontSize="11"
                                               Foreground="{DynamicResource SubText}" Margin="0,0,0,4"/>
                                    <TextBlock x:Name="ReportKpiAmount" Text="—"
                                               FontSize="22" FontWeight="Bold"
                                               Foreground="{DynamicResource FgDefault}"/>
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="4" Background="{DynamicResource CardBg}" CornerRadius="8"
                                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Padding="16,12">
                                <StackPanel>
                                    <TextBlock Text="Approved" FontSize="11"
                                               Foreground="{DynamicResource SubText}" Margin="0,0,0,4"/>
                                    <TextBlock x:Name="ReportKpiApproved" Text="—"
                                               FontSize="22" FontWeight="Bold"
                                               Foreground="#A78BFA"/>
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="6" Background="{DynamicResource CardBg}" CornerRadius="8"
                                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Padding="16,12">
                                <StackPanel>
                                    <TextBlock Text="Failed / Declined" FontSize="11"
                                               Foreground="{DynamicResource SubText}" Margin="0,0,0,4"/>
                                    <TextBlock x:Name="ReportKpiFailed" Text="—"
                                               FontSize="22" FontWeight="Bold"
                                               Foreground="#EF4444"/>
                                </StackPanel>
                            </Border>
                        </Grid>

                        <!-- ── Report Body ── -->
                        <Border Grid.Row="2" Margin="16,12,16,16"
                                Background="{DynamicResource CardBg}" CornerRadius="8"
                                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                            <Grid>

                                <!-- Empty state -->
                                <StackPanel x:Name="ReportEmptyState"
                                            VerticalAlignment="Center" HorizontalAlignment="Center"
                                            Margin="0,40">
                                    <TextBlock Text="📊" FontSize="40" HorizontalAlignment="Center" Margin="0,0,0,12"/>
                                    <TextBlock Text="Set a date range and click Generate"
                                               FontSize="13" Foreground="{DynamicResource SubText}"
                                               HorizontalAlignment="Center"/>
                                    <TextBlock Text="Works on transactions already loaded in the Txn Viewer"
                                               FontSize="11" Foreground="{DynamicResource SubText}"
                                               HorizontalAlignment="Center" Margin="0,4,0,0" Opacity="0.6"/>
                                </StackPanel>

                                <!-- Aggregate table (By Type / By Status / Summary) -->
                                <Grid x:Name="ReportAggPanel" Visibility="Collapsed">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>
                                    <!-- Column headers -->
                                    <Border Grid.Row="0"
                                            BorderBrush="{DynamicResource CardBorder}"
                                            BorderThickness="0,0,0,1"
                                            Padding="16,10">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="90"/>
                                                <ColumnDefinition Width="130"/>
                                                <ColumnDefinition Width="130"/>
                                                <ColumnDefinition Width="80"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="GROUP"        FontSize="10" FontWeight="SemiBold" Foreground="{DynamicResource SubText}"/>
                                            <TextBlock Grid.Column="1" Text="COUNT"        FontSize="10" FontWeight="SemiBold" Foreground="{DynamicResource SubText}"/>
                                            <TextBlock Grid.Column="2" Text="TOTAL AMOUNT" FontSize="10" FontWeight="SemiBold" Foreground="{DynamicResource SubText}"/>
                                            <TextBlock Grid.Column="3" Text="AVG AMOUNT"   FontSize="10" FontWeight="SemiBold" Foreground="{DynamicResource SubText}"/>
                                            <TextBlock Grid.Column="4" Text="SHARE"        FontSize="10" FontWeight="SemiBold" Foreground="{DynamicResource SubText}"/>
                                        </Grid>
                                    </Border>
                                    <!-- Data rows -->
                                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                                        <ItemsControl x:Name="ReportAggList">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border BorderBrush="{DynamicResource CardBorder}"
                                                            BorderThickness="0,0,0,1"
                                                            Padding="16,10">
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="90"/>
                                                                <ColumnDefinition Width="130"/>
                                                                <ColumnDefinition Width="130"/>
                                                                <ColumnDefinition Width="80"/>
                                                            </Grid.ColumnDefinitions>
                                                            <Border Grid.Column="0" CornerRadius="4"
                                                                    Padding="8,3" HorizontalAlignment="Left"
                                                                    VerticalAlignment="Center"
                                                                    Background="{Binding BgColor}">
                                                                <TextBlock Text="{Binding Label}"
                                                                           FontSize="12" FontWeight="SemiBold"
                                                                           Foreground="{Binding Color}"/>
                                                            </Border>
                                                            <TextBlock Grid.Column="1" Text="{Binding CountStr}"
                                                                       FontSize="13" VerticalAlignment="Center"
                                                                       Foreground="{DynamicResource FgDefault}"/>
                                                            <TextBlock Grid.Column="2" Text="{Binding TotalFormatted}"
                                                                       FontSize="13" VerticalAlignment="Center"
                                                                       Foreground="{DynamicResource FgDefault}"/>
                                                            <TextBlock Grid.Column="3" Text="{Binding AvgFormatted}"
                                                                       FontSize="13" VerticalAlignment="Center"
                                                                       Foreground="{DynamicResource SubText}"/>
                                                            <TextBlock Grid.Column="4" Text="{Binding Share}"
                                                                       FontSize="13" VerticalAlignment="Center"
                                                                       Foreground="{DynamicResource SubText}"/>
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </ScrollViewer>
                                </Grid>

                                <!-- Failed / Declined table -->
                                <Grid x:Name="ReportFailedPanel" Visibility="Collapsed">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>
                                    <!-- Column headers -->
                                    <Border Grid.Row="0"
                                            BorderBrush="{DynamicResource CardBorder}"
                                            BorderThickness="0,0,0,1"
                                            Padding="16,10">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="110"/>
                                                <ColumnDefinition Width="120"/>
                                                <ColumnDefinition Width="150"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="80"/>
                                                <ColumnDefinition Width="100"/>
                                                <ColumnDefinition Width="100"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="DATE"     FontSize="10" FontWeight="SemiBold" Foreground="{DynamicResource SubText}"/>
                                            <TextBlock Grid.Column="1" Text="TXN ID"   FontSize="10" FontWeight="SemiBold" Foreground="{DynamicResource SubText}"/>
                                            <TextBlock Grid.Column="2" Text="MERCHANT" FontSize="10" FontWeight="SemiBold" Foreground="{DynamicResource SubText}"/>
                                            <TextBlock Grid.Column="3" Text="CUSTOMER" FontSize="10" FontWeight="SemiBold" Foreground="{DynamicResource SubText}"/>
                                            <TextBlock Grid.Column="4" Text="TYPE"     FontSize="10" FontWeight="SemiBold" Foreground="{DynamicResource SubText}"/>
                                            <TextBlock Grid.Column="5" Text="AMOUNT"   FontSize="10" FontWeight="SemiBold" Foreground="{DynamicResource SubText}"/>
                                            <TextBlock Grid.Column="6" Text="STATUS"   FontSize="10" FontWeight="SemiBold" Foreground="{DynamicResource SubText}"/>
                                        </Grid>
                                    </Border>
                                    <!-- Data rows -->
                                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                                        <ItemsControl x:Name="ReportFailedList">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border BorderBrush="{DynamicResource CardBorder}"
                                                            BorderThickness="0,0,0,1"
                                                            Padding="16,9">
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="110"/>
                                                                <ColumnDefinition Width="120"/>
                                                                <ColumnDefinition Width="150"/>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="80"/>
                                                                <ColumnDefinition Width="100"/>
                                                                <ColumnDefinition Width="100"/>
                                                            </Grid.ColumnDefinitions>
                                                            <TextBlock Grid.Column="0" Text="{Binding Date}"
                                                                       FontSize="12" VerticalAlignment="Center"
                                                                       Foreground="{DynamicResource SubText}"/>
                                                            <TextBlock Grid.Column="1" Text="{Binding ShortId}"
                                                                       FontSize="11.5" VerticalAlignment="Center"
                                                                       Foreground="{DynamicResource FgDefault}"
                                                                       FontFamily="Consolas"/>
                                                            <TextBlock Grid.Column="2" Text="{Binding MerchantName}"
                                                                       FontSize="12" VerticalAlignment="Center"
                                                                       Foreground="{DynamicResource FgDefault}"
                                                                       TextTrimming="CharacterEllipsis"/>
                                                            <TextBlock Grid.Column="3" Text="{Binding Customer}"
                                                                       FontSize="12" VerticalAlignment="Center"
                                                                       Foreground="{DynamicResource SubText}"
                                                                       TextTrimming="CharacterEllipsis"/>
                                                            <TextBlock Grid.Column="4" Text="{Binding TxnType}"
                                                                       FontSize="12" VerticalAlignment="Center"
                                                                       Foreground="{DynamicResource SubText}"/>
                                                            <TextBlock Grid.Column="5" Text="{Binding Amount}"
                                                                       FontSize="12" VerticalAlignment="Center"
                                                                       Foreground="{DynamicResource FgDefault}"/>
                                                            <Border Grid.Column="6" CornerRadius="4"
                                                                    Padding="7,2" VerticalAlignment="Center"
                                                                    HorizontalAlignment="Left"
                                                                    Background="{Binding StatusBg}">
                                                                <TextBlock Text="{Binding Status}"
                                                                           FontSize="11" FontWeight="SemiBold"
                                                                           Foreground="{Binding StatusColor}"/>
                                                            </Border>
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </ScrollViewer>
                                </Grid>

                            </Grid>
                        </Border>
                    </Grid>
                </TabItem>

                <!-- ═══════════════════════════════════════════════════════
                     TAB 15 — HTTP CLIENT (Postman-style)
                     ═══════════════════════════════════════════════════════ -->
                <TabItem x:Name="TabItem15" Header="📡 HTTP Client">
                    <!-- Outer 2-column split: Collections sidebar | Request+Response -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition x:Name="CollectionsPaneCol" Width="240" MinWidth="160" MaxWidth="420"/>
                            <ColumnDefinition Width="4"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- ════════════════════════════════════════════════
                             COLLECTIONS SIDEBAR  (col 0)
                             ════════════════════════════════════════════════ -->
                        <Border Grid.Column="0"
                                Background="{DynamicResource CardBg}"
                                BorderBrush="{DynamicResource CardBorder}"
                                BorderThickness="0,0,1,0">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <!-- Header + New Collection button -->
                                <Border Grid.Row="0" Padding="10,8"
                                        BorderBrush="{DynamicResource CardBorder}" BorderThickness="0,0,0,1">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <!-- Title + API count badge -->
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                            <TextBlock Text="Collections" FontSize="12" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource PrimaryText}"/>
                                            <Border x:Name="ApiCountBadge" CornerRadius="8" Margin="6,0,0,0"
                                                    Background="{DynamicResource TabHoverBg}"
                                                    Padding="5,1">
                                                <TextBlock x:Name="ApiCountLabel" Text="0"
                                                           FontSize="10" FontWeight="SemiBold"
                                                           Foreground="{DynamicResource SubText}"/>
                                            </Border>
                                        </StackPanel>
                                        <!-- Collapse All -->
                                        <Button Grid.Column="1" x:Name="CollapseAllBtn"
                                                Content="⊟" ToolTip="Collapse all"
                                                Width="26" Height="26" Margin="0,0,2,0"
                                                FontSize="13" Click="CollapseAll_Click"
                                                Background="Transparent" BorderThickness="0"
                                                Foreground="{DynamicResource SubText}" Cursor="Hand">
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <Border Background="{TemplateBinding Background}" CornerRadius="6"
                                                            Width="{TemplateBinding Width}" Height="{TemplateBinding Height}">
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="Background" Value="{DynamicResource TabHoverBg}"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Button.Template>
                                        </Button>
                                        <!-- Expand All -->
                                        <Button Grid.Column="2" x:Name="ExpandAllBtn"
                                                Content="⊞" ToolTip="Expand all"
                                                Width="26" Height="26" Margin="0,0,2,0"
                                                FontSize="13" Click="ExpandAll_Click"
                                                Background="Transparent" BorderThickness="0"
                                                Foreground="{DynamicResource SubText}" Cursor="Hand">
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <Border Background="{TemplateBinding Background}" CornerRadius="6"
                                                            Width="{TemplateBinding Width}" Height="{TemplateBinding Height}">
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="Background" Value="{DynamicResource TabHoverBg}"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Button.Template>
                                        </Button>
                                        <!-- Remove Duplicates button -->
                                        <Button Grid.Column="3" Content="⧉" ToolTip="Remove duplicate APIs (same Method + URL)"
                                                Width="26" Height="26" Margin="0,0,2,0"
                                                FontSize="12" Click="DeduplicateApis_Click"
                                                Background="Transparent" BorderThickness="0"
                                                Foreground="{DynamicResource SubText}" Cursor="Hand">
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <Border Background="{TemplateBinding Background}" CornerRadius="6"
                                                            Width="{TemplateBinding Width}" Height="{TemplateBinding Height}">
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="Background" Value="{DynamicResource TabHoverBg}"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Button.Template>
                                        </Button>
                                        <!-- Validate / scan dead endpoints button -->
                                        <Button Grid.Column="4" x:Name="ValidateApisBtn"
                                                Content="🔍" ToolTip="Scan for obsolete / dead endpoints (404)"
                                                Width="26" Height="26" Margin="0,0,2,0"
                                                FontSize="11" Click="ValidateApis_Click"
                                                Background="Transparent" BorderThickness="0"
                                                Foreground="{DynamicResource SubText}" Cursor="Hand">
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <Border Background="{TemplateBinding Background}" CornerRadius="6"
                                                            Width="{TemplateBinding Width}" Height="{TemplateBinding Height}">
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="Background" Value="{DynamicResource TabHoverBg}"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Button.Template>
                                        </Button>
                                        <!-- Import button -->
                                        <Button Grid.Column="5" Content="⬆" ToolTip="Import collection"
                                                Width="26" Height="26" Margin="0,0,2,0"
                                                FontSize="12" Click="CollectionImport_Click"
                                                Background="Transparent" BorderThickness="0"
                                                Foreground="{DynamicResource SubText}" Cursor="Hand">
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <Border Background="{TemplateBinding Background}" CornerRadius="6"
                                                            Width="{TemplateBinding Width}" Height="{TemplateBinding Height}">
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="Background" Value="{DynamicResource TabHoverBg}"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Button.Template>
                                        </Button>
                                        <!-- New Collection button -->
                                        <Button Grid.Column="6" Content="＋" ToolTip="New collection"
                                                Width="26" Height="26" FontSize="14"
                                                Click="NewCollection_Click"
                                                Background="Transparent" BorderThickness="0"
                                                Foreground="{DynamicResource SubText}" Cursor="Hand">
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <Border Background="{TemplateBinding Background}" CornerRadius="6"
                                                            Width="{TemplateBinding Width}" Height="{TemplateBinding Height}">
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="Background" Value="{DynamicResource TabHoverBg}"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Button.Template>
                                        </Button>
                                    </Grid>
                                </Border>

                                <!-- Search box -->
                                <Border Grid.Row="1" Padding="8,6"
                                        BorderBrush="{DynamicResource CardBorder}" BorderThickness="0,0,0,1">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="🔍" FontSize="11"
                                                   VerticalAlignment="Center" Margin="6,0,5,0"
                                                   Foreground="{DynamicResource SubText}"/>
                                        <TextBox x:Name="CollectionSearchBox"
                                                 Grid.Column="1"
                                                 Height="26" FontSize="12"
                                                 VerticalContentAlignment="Center"
                                                 Background="Transparent"
                                                 BorderThickness="0"
                                                 Foreground="{DynamicResource PrimaryText}"
                                                 CaretBrush="{DynamicResource PrimaryText}"
                                                 TextChanged="CollectionSearch_TextChanged"
                                                 ToolTip="Search requests (name, method, URL)">
                                            <TextBox.Style>
                                                <Style TargetType="TextBox">
                                                    <Setter Property="Template">
                                                        <Setter.Value>
                                                            <ControlTemplate TargetType="TextBox">
                                                                <Border Background="Transparent">
                                                                    <Grid>
                                                                        <TextBlock x:Name="Placeholder"
                                                                                   Text="Search requests…"
                                                                                   Foreground="{DynamicResource SubText}"
                                                                                   FontSize="12"
                                                                                   VerticalAlignment="Center"
                                                                                   IsHitTestVisible="False"
                                                                                   Visibility="Collapsed"/>
                                                                        <ScrollViewer x:Name="PART_ContentHost" VerticalAlignment="Center"/>
                                                                    </Grid>
                                                                </Border>
                                                                <ControlTemplate.Triggers>
                                                                    <MultiTrigger>
                                                                        <MultiTrigger.Conditions>
                                                                            <Condition Property="Text" Value=""/>
                                                                            <Condition Property="IsFocused" Value="False"/>
                                                                        </MultiTrigger.Conditions>
                                                                        <Setter TargetName="Placeholder" Property="Visibility" Value="Visible"/>
                                                                    </MultiTrigger>
                                                                </ControlTemplate.Triggers>
                                                            </ControlTemplate>
                                                        </Setter.Value>
                                                    </Setter>
                                                </Style>
                                            </TextBox.Style>
                                        </TextBox>
                                        <!-- Clear search button — only visible when text is present -->
                                        <Button x:Name="CollectionSearchClearBtn"
                                                Grid.Column="2"
                                                Content="✕" Width="20" Height="20"
                                                FontSize="10" Cursor="Hand"
                                                Visibility="Collapsed"
                                                Background="Transparent" BorderThickness="0"
                                                Foreground="{DynamicResource SubText}"
                                                Click="CollectionSearchClear_Click"
                                                ToolTip="Clear search">
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <Border Background="{TemplateBinding Background}" CornerRadius="4"
                                                            Width="{TemplateBinding Width}" Height="{TemplateBinding Height}">
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="Background" Value="{DynamicResource TabHoverBg}"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Button.Template>
                                        </Button>
                                    </Grid>
                                </Border>

                                <!-- ── Recent requests panel ── -->
                                <Border x:Name="RecentPanel" Grid.Row="2"
                                        BorderBrush="{DynamicResource CardBorder}" BorderThickness="0,0,0,1">
                                    <StackPanel>
                                        <!-- Recent header row -->
                                        <Border Padding="10,6" Background="Transparent" Cursor="Hand"
                                                MouseLeftButtonDown="RecentHeader_Click">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Style.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="Background" Value="{DynamicResource TabHoverBg}"/>
                                                        </Trigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="14"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock x:Name="RecentChevron" Text="▼" FontSize="7"
                                                           Foreground="{DynamicResource SubText}"
                                                           VerticalAlignment="Center"/>
                                                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                                    <TextBlock Text="🕐" FontSize="11" Margin="0,0,5,0"
                                                               Foreground="{DynamicResource SubText}"/>
                                                    <TextBlock Text="Recent" FontSize="11" FontWeight="SemiBold"
                                                               Foreground="{DynamicResource SubText}"/>
                                                    <Border x:Name="RecentCountBadge" CornerRadius="6" Margin="5,0,0,0"
                                                            Background="{DynamicResource TabHoverBg}" Padding="4,1">
                                                        <TextBlock x:Name="RecentCountLabel" Text="0"
                                                                   FontSize="10" FontWeight="SemiBold"
                                                                   Foreground="{DynamicResource SubText}"/>
                                                    </Border>
                                                </StackPanel>
                                                <!-- Clear recent button -->
                                                <Button x:Name="RecentClearBtn" Grid.Column="2"
                                                        Content="Clear" FontSize="10"
                                                        Height="20" Padding="6,0"
                                                        Background="Transparent" BorderThickness="0"
                                                        Foreground="{DynamicResource SubText}" Cursor="Hand"
                                                        Visibility="Collapsed"
                                                        Click="RecentClear_Click"
                                                        ToolTip="Clear recent history">
                                                    <Button.Template>
                                                        <ControlTemplate TargetType="Button">
                                                            <Border Background="{TemplateBinding Background}" CornerRadius="5"
                                                                    Padding="{TemplateBinding Padding}"
                                                                    Height="{TemplateBinding Height}">
                                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                            </Border>
                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter Property="Background" Value="{DynamicResource TabHoverBg}"/>
                                                                </Trigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Button.Template>
                                                </Button>
                                            </Grid>
                                        </Border>

                                        <!-- Recent items list -->
                                        <ItemsControl x:Name="RecentList" Margin="4,0,4,4">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border CornerRadius="6" Padding="6,5" Cursor="Hand"
                                                            Background="Transparent"
                                                            Tag="{Binding}"
                                                            MouseLeftButtonDown="RecentItem_Click">
                                                        <Border.Style>
                                                            <Style TargetType="Border">
                                                                <Style.Triggers>
                                                                    <Trigger Property="IsMouseOver" Value="True">
                                                                        <Setter Property="Background" Value="{DynamicResource TabHoverBg}"/>
                                                                    </Trigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Border.Style>
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="44"/>
                                                                <ColumnDefinition Width="*"/>
                                                            </Grid.ColumnDefinitions>
                                                            <!-- Method badge -->
                                                            <Border CornerRadius="4" Padding="3,2"
                                                                    Background="{Binding MethodBadgeBg}"
                                                                    HorizontalAlignment="Left" VerticalAlignment="Center">
                                                                <TextBlock Text="{Binding Method}" FontSize="9"
                                                                           FontWeight="Bold"
                                                                           Foreground="{Binding MethodColor}"/>
                                                            </Border>
                                                            <!-- URL -->
                                                            <TextBlock Grid.Column="1" Margin="6,0,0,0"
                                                                       Text="{Binding DisplayUrl}"
                                                                       FontSize="11"
                                                                       Foreground="{DynamicResource PrimaryText}"
                                                                       TextTrimming="CharacterEllipsis"
                                                                       VerticalAlignment="Center"
                                                                       ToolTip="{Binding Url}"/>
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </Border>

                                <!-- Collections tree -->
                                <ScrollViewer Grid.Row="3" VerticalScrollBarVisibility="Auto">
                                    <ItemsControl x:Name="CollectionsPanel" Margin="4,6">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate DataType="{x:Type local:HttpCollection}">
                                                <StackPanel Margin="0,0,0,4">
                                                    <!-- Collection header row -->
                                                    <Border CornerRadius="8" Padding="6,5"
                                                            Background="Transparent" Cursor="Hand"
                                                            Tag="{Binding}"
                                                            MouseLeftButtonDown="CollectionHeader_Click">
                                                        <Border.Style>
                                                            <Style TargetType="Border">
                                                                <Style.Triggers>
                                                                    <Trigger Property="IsMouseOver" Value="True">
                                                                        <Setter Property="Background" Value="{DynamicResource TabHoverBg}"/>
                                                                    </Trigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Border.Style>
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="16"/>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                            </Grid.ColumnDefinitions>
                                                            <TextBlock Text="▶" FontSize="8"
                                                                       Foreground="{DynamicResource SubText}"
                                                                       VerticalAlignment="Center">
                                                                <TextBlock.Style>
                                                                    <Style TargetType="TextBlock">
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding Expanded}" Value="True">
                                                                                <Setter Property="Text" Value="▼"/>
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </TextBlock.Style>
                                                            </TextBlock>
                                                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                                                <!-- Favourite star (filled when IsFavorite) -->
                                                                <TextBlock Text="{Binding FavoriteIcon}"
                                                                           FontSize="11" VerticalAlignment="Center"
                                                                           Margin="0,0,4,0">
                                                                    <TextBlock.Style>
                                                                        <Style TargetType="TextBlock">
                                                                            <Setter Property="Foreground" Value="{DynamicResource SubText}"/>
                                                                            <Style.Triggers>
                                                                                <DataTrigger Binding="{Binding IsFavorite}" Value="True">
                                                                                    <Setter Property="Foreground" Value="#F59E0B"/>
                                                                                </DataTrigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </TextBlock.Style>
                                                                </TextBlock>
                                                                <TextBlock Text="{Binding Name}"
                                                                           FontSize="12" FontWeight="SemiBold"
                                                                           Foreground="{DynamicResource PrimaryText}"
                                                                           TextTrimming="CharacterEllipsis"
                                                                           VerticalAlignment="Center"/>
                                                            </StackPanel>
                                                            <!-- Favourite toggle button (always visible, dim when not fav) -->
                                                            <Button Grid.Column="2"
                                                                    Content="{Binding FavoriteIcon}"
                                                                    FontSize="13" Width="22" Height="22"
                                                                    Background="Transparent" BorderThickness="0"
                                                                    ToolTip="{Binding FavoriteTip}"
                                                                    Tag="{Binding}"
                                                                    Click="FavoriteCollection_Click" Cursor="Hand">
                                                                <Button.Style>
                                                                    <Style TargetType="Button">
                                                                        <Setter Property="Foreground" Value="{DynamicResource SubText}"/>
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding IsFavorite}" Value="True">
                                                                                <Setter Property="Foreground" Value="#F59E0B"/>
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </Button.Style>
                                                                <Button.Template>
                                                                    <ControlTemplate TargetType="Button">
                                                                        <Border Background="{TemplateBinding Background}" CornerRadius="4">
                                                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                        </Border>
                                                                        <ControlTemplate.Triggers>
                                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                                <Setter Property="Background" Value="{DynamicResource TabSelectedBorder}"/>
                                                                            </Trigger>
                                                                        </ControlTemplate.Triggers>
                                                                    </ControlTemplate>
                                                                </Button.Template>
                                                            </Button>
                                                            <!-- Collection context menu button -->
                                                            <Button Grid.Column="3" Content="⋯" FontSize="13"
                                                                    Width="22" Height="22"
                                                                    Background="Transparent" BorderThickness="0"
                                                                    Foreground="{DynamicResource SubText}"
                                                                    Tag="{Binding}"
                                                                    Click="CollectionMenu_Click" Cursor="Hand">
                                                                <Button.Template>
                                                                    <ControlTemplate TargetType="Button">
                                                                        <Border Background="{TemplateBinding Background}" CornerRadius="5">
                                                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                        </Border>
                                                                        <ControlTemplate.Triggers>
                                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                                <Setter Property="Background" Value="{DynamicResource TabSelectedBorder}"/>
                                                                            </Trigger>
                                                                        </ControlTemplate.Triggers>
                                                                    </ControlTemplate>
                                                                </Button.Template>
                                                            </Button>
                                                        </Grid>
                                                    </Border>

                                                    <!-- Requests grouped by category (collapsible per collection) -->
                                                    <ItemsControl ItemsSource="{Binding GroupedRequests}"
                                                                  Margin="0,0,0,0">
                                                        <ItemsControl.Style>
                                                            <Style TargetType="ItemsControl">
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding Expanded}" Value="False">
                                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </ItemsControl.Style>
                                                        <!-- Each item is a RequestGroup -->
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate DataType="{x:Type local:RequestGroup}">
                                                                <StackPanel>
                                                                    <!-- Group header — only shown when Category is non-empty -->
                                                                    <Border Margin="8,4,4,1" CornerRadius="5" Padding="6,3"
                                                                            Background="{DynamicResource TabHoverBg}"
                                                                            Cursor="Hand"
                                                                            Tag="{Binding}"
                                                                            MouseLeftButtonDown="GroupHeader_Click">
                                                                        <Border.Style>
                                                                            <Style TargetType="Border">
                                                                                <Setter Property="Visibility" Value="Visible"/>
                                                                                <Style.Triggers>
                                                                                    <DataTrigger Binding="{Binding Category}" Value="">
                                                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                                                    </DataTrigger>
                                                                                </Style.Triggers>
                                                                            </Style>
                                                                        </Border.Style>
                                                                        <Grid>
                                                                            <Grid.ColumnDefinitions>
                                                                                <ColumnDefinition Width="14"/>
                                                                                <ColumnDefinition Width="*"/>
                                                                            </Grid.ColumnDefinitions>
                                                                            <!-- Expand arrow -->
                                                                            <TextBlock FontSize="9" VerticalAlignment="Center"
                                                                                       Foreground="{DynamicResource SubText}">
                                                                                <TextBlock.Style>
                                                                                    <Style TargetType="TextBlock">
                                                                                        <Setter Property="Text" Value="▶"/>
                                                                                        <Style.Triggers>
                                                                                            <DataTrigger Binding="{Binding Expanded}" Value="True">
                                                                                                <Setter Property="Text" Value="▼"/>
                                                                                            </DataTrigger>
                                                                                        </Style.Triggers>
                                                                                    </Style>
                                                                                </TextBlock.Style>
                                                                            </TextBlock>
                                                                            <TextBlock Grid.Column="1"
                                                                                       Text="{Binding Category}"
                                                                                       FontSize="11" FontWeight="SemiBold"
                                                                                       Foreground="{DynamicResource SubText}"
                                                                                       VerticalAlignment="Center"
                                                                                       Margin="2,0,0,0"/>
                                                                        </Grid>
                                                                    </Border>

                                                                    <!-- Requests inside this group -->
                                                                    <ItemsControl ItemsSource="{Binding Requests}"
                                                                                  Margin="14,0,0,0">
                                                                        <ItemsControl.Style>
                                                                            <Style TargetType="ItemsControl">
                                                                                <Setter Property="Visibility" Value="Visible"/>
                                                                                <Style.Triggers>
                                                                                    <DataTrigger Binding="{Binding Expanded}" Value="False">
                                                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                                                    </DataTrigger>
                                                                                </Style.Triggers>
                                                                            </Style>
                                                                        </ItemsControl.Style>
                                                                        <ItemsControl.ItemTemplate>
                                                                            <DataTemplate DataType="{x:Type local:SavedHttpRequest}">
                                                                                <Border CornerRadius="7" Padding="6,4"
                                                                                        Margin="0,1" Cursor="Hand"
                                                                                        Background="Transparent"
                                                                                        Tag="{Binding}"
                                                                                        MouseLeftButtonDown="RequestItem_Click">
                                                                                    <Border.Style>
                                                                                        <Style TargetType="Border">
                                                                                            <Style.Triggers>
                                                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                                                    <Setter Property="Background" Value="{DynamicResource TabHoverBg}"/>
                                                                                                </Trigger>
                                                                                            </Style.Triggers>
                                                                                        </Style>
                                                                                    </Border.Style>
                                                                                    <Grid>
                                                                                        <Grid.ColumnDefinitions>
                                                                                            <ColumnDefinition Width="40"/>
                                                                                            <ColumnDefinition Width="*"/>
                                                                                            <ColumnDefinition Width="Auto"/>
                                                                                        </Grid.ColumnDefinitions>
                                                                                        <!-- Method badge -->
                                                                                        <Border CornerRadius="4" Padding="3,1"
                                                                                                HorizontalAlignment="Left"
                                                                                                Background="{DynamicResource CardBg}">
                                                                                            <TextBlock Text="{Binding Method}"
                                                                                                       FontSize="9" FontWeight="Bold"
                                                                                                       Foreground="{Binding MethodColor}"/>
                                                                                        </Border>
                                                                                        <!-- Show ShortName (after "|") when grouped, full Name when ungrouped -->
                                                                                        <TextBlock Grid.Column="1" Text="{Binding ShortName}"
                                                                                                   FontSize="11.5"
                                                                                                   Foreground="{DynamicResource PrimaryText}"
                                                                                                   TextTrimming="CharacterEllipsis"
                                                                                                   VerticalAlignment="Center"
                                                                                                   Margin="4,0,0,0"/>
                                                                                        <!-- Request context menu -->
                                                                                        <Button Grid.Column="2" Content="⋯" FontSize="12"
                                                                                                Width="20" Height="20"
                                                                                                Background="Transparent" BorderThickness="0"
                                                                                                Foreground="{DynamicResource SubText}"
                                                                                                Tag="{Binding}"
                                                                                                Click="RequestMenu_Click" Cursor="Hand">
                                                                                            <Button.Template>
                                                                                                <ControlTemplate TargetType="Button">
                                                                                                    <Border Background="{TemplateBinding Background}" CornerRadius="4">
                                                                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                                                    </Border>
                                                                                                    <ControlTemplate.Triggers>
                                                                                                        <Trigger Property="IsMouseOver" Value="True">
                                                                                                            <Setter Property="Background" Value="{DynamicResource TabSelectedBorder}"/>
                                                                                                        </Trigger>
                                                                                                    </ControlTemplate.Triggers>
                                                                                                </ControlTemplate>
                                                                                            </Button.Template>
                                                                                        </Button>
                                                                                    </Grid>
                                                                                </Border>
                                                                            </DataTemplate>
                                                                        </ItemsControl.ItemTemplate>
                                                                    </ItemsControl>
                                                                </StackPanel>
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                                </StackPanel>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </Grid>
                        </Border>

                        <!-- Resize splitter -->
                        <GridSplitter Grid.Column="1" Width="4" HorizontalAlignment="Stretch"
                                      Background="{DynamicResource CardBorder}" Cursor="SizeWE"/>

                        <!-- ════════════════════════════════════════════════
                             REQUEST + RESPONSE PANEL  (col 2)
                             ════════════════════════════════════════════════ -->
                        <Grid Grid.Column="2">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>  <!-- toolbar: method + url + send -->
                            <RowDefinition Height="Auto"/>  <!-- sub-tabs: Params / Headers / Body / Auth -->
                            <RowDefinition Height="*"/>     <!-- request editor -->
                            <RowDefinition Height="5"/>     <!-- splitter -->
                            <RowDefinition Height="*"/>     <!-- response panel -->
                        </Grid.RowDefinitions>

                        <!-- ── Top toolbar ────────────────────────────────────────── -->
                        <Border Grid.Row="0" Background="{DynamicResource CardBg}"
                                BorderBrush="{DynamicResource CardBorder}" BorderThickness="0,0,0,1">
                            <StackPanel>

                                <!-- Row 1: Method + URL + Send + Cancel + Save -->
                                <Grid Margin="16,10,16,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Method selector -->
                                    <ComboBox x:Name="HttpMethodBox" Grid.Column="0"
                                              Width="100" Height="34" Margin="0,0,8,0"
                                              SelectedIndex="0"
                                              SelectionChanged="HttpMethod_Changed"
                                              VerticalContentAlignment="Center"
                                              FontWeight="SemiBold" FontSize="12.5">
                                        <ComboBoxItem Content="GET"     Foreground="#A78BFA"/>
                                        <ComboBoxItem Content="POST"    Foreground="#FCD34D"/>
                                        <ComboBoxItem Content="PUT"     Foreground="#7C3AED"/>
                                        <ComboBoxItem Content="PATCH"   Foreground="#8B5CF6"/>
                                        <ComboBoxItem Content="DELETE"  Foreground="#EF4444"/>
                                        <ComboBoxItem Content="HEAD"    Foreground="#6B7280"/>
                                        <ComboBoxItem Content="OPTIONS" Foreground="#6B7280"/>
                                    </ComboBox>

                                    <!-- URL bar with autocomplete -->
                                    <Grid Grid.Column="1">
                                        <TextBox x:Name="HttpUrlBox"
                                                 Height="34" Padding="12,0" FontSize="13"
                                                 VerticalContentAlignment="Center"
                                                 Text="https://test.api.payrix.com/"
                                                 KeyDown="HttpUrl_KeyDown"
                                                 GotFocus="HttpUrlBox_GotFocus"
                                                 TextChanged="HttpUrl_Changed"
                                                 LostFocus="HttpUrlBox_LostFocus"
                                                 ToolTip="Use {{variableName}} to insert environment variables. Type to search all APIs."/>

                                        <!-- Autocomplete dropdown popup -->
                                        <Popup x:Name="UrlSuggestPopup"
                                               PlacementTarget="{Binding ElementName=HttpUrlBox}"
                                               Placement="Bottom"
                                               StaysOpen="False"
                                               AllowsTransparency="True"
                                               PopupAnimation="Fade">
                                            <Border x:Name="UrlSuggestBorder"
                                                    MinWidth="{Binding ActualWidth, ElementName=HttpUrlBox}"
                                                    MaxWidth="900"
                                                    MaxHeight="320"
                                                    CornerRadius="8"
                                                    Background="{DynamicResource CardBg}"
                                                    BorderBrush="{DynamicResource CardBorder}"
                                                    BorderThickness="1"
                                                    Margin="0,2,0,0">
                                                <Border.Effect>
                                                    <DropShadowEffect BlurRadius="16" ShadowDepth="2" Opacity="0.18" Direction="270"/>
                                                </Border.Effect>
                                                <ListBox x:Name="UrlSuggestList"
                                                         Background="Transparent"
                                                         BorderThickness="0"
                                                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                                         PreviewKeyDown="UrlSuggest_KeyDown"
                                                         MouseLeftButtonUp="UrlSuggest_Select">
                                                    <ListBox.ItemTemplate>
                                                        <DataTemplate>
                                                            <Grid Margin="4,3">
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="52"/>
                                                                    <ColumnDefinition Width="*"/>
                                                                </Grid.ColumnDefinitions>
                                                                <!-- Method badge -->
                                                                <Border Grid.Column="0" CornerRadius="4"
                                                                        Background="{Binding MethodBadgeBg}"
                                                                        Padding="4,2" HorizontalAlignment="Left">
                                                                    <TextBlock Text="{Binding Method}"
                                                                               FontSize="10" FontWeight="Bold"
                                                                               Foreground="{Binding MethodColor}"/>
                                                                </Border>
                                                                <!-- Name + URL -->
                                                                <StackPanel Grid.Column="1" Margin="8,0,0,0">
                                                                    <TextBlock Text="{Binding Name}"
                                                                               FontSize="12" FontWeight="SemiBold"
                                                                               Foreground="{DynamicResource PrimaryText}"
                                                                               TextTrimming="CharacterEllipsis"/>
                                                                    <TextBlock Text="{Binding Url}"
                                                                               FontSize="11"
                                                                               Foreground="{DynamicResource SubText}"
                                                                               TextTrimming="CharacterEllipsis"/>
                                                                </StackPanel>
                                                            </Grid>
                                                        </DataTemplate>
                                                    </ListBox.ItemTemplate>
                                                    <ListBox.ItemContainerStyle>
                                                        <Style TargetType="ListBoxItem">
                                                            <Setter Property="Padding" Value="6,2"/>
                                                            <Setter Property="Cursor" Value="Hand"/>
                                                            <Style.Triggers>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter Property="Background" Value="{DynamicResource TabHoverBg}"/>
                                                                </Trigger>
                                                                <Trigger Property="IsSelected" Value="True">
                                                                    <Setter Property="Background" Value="{DynamicResource TabActiveBg}"/>
                                                                </Trigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </ListBox.ItemContainerStyle>
                                                </ListBox>
                                            </Border>
                                        </Popup>
                                    </Grid>

                                    <!-- Send -->
                                    <Button x:Name="HttpSendBtn" Grid.Column="2"
                                            Content="  Send  " Height="34" Margin="8,0,0,0"
                                            Padding="14,0" FontSize="13" FontWeight="SemiBold"
                                            Click="HttpSend_Click">
                                        <Button.Style>
                                            <Style TargetType="Button">
                                                <Setter Property="Background">
                                                    <Setter.Value>
                                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                            <GradientStop Color="#7C3AED" Offset="0"/>
                                                            <GradientStop Color="#8B5CF6" Offset="1"/>
                                                        </LinearGradientBrush>
                                                    </Setter.Value>
                                                </Setter>
                                                <Setter Property="Foreground" Value="White"/>
                                                <Setter Property="BorderThickness" Value="0"/>
                                                <Setter Property="Cursor" Value="Hand"/>
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="Button">
                                                            <Border Background="{TemplateBinding Background}"
                                                                    CornerRadius="10" Padding="{TemplateBinding Padding}">
                                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                            </Border>
                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter Property="Opacity" Value="0.85"/>
                                                                </Trigger>
                                                                <Trigger Property="IsEnabled" Value="False">
                                                                    <Setter Property="Opacity" Value="0.5"/>
                                                                </Trigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                            </Style>
                                        </Button.Style>
                                    </Button>

                                    <!-- Cancel -->
                                    <Button x:Name="HttpCancelBtn" Grid.Column="3"
                                            Content="Cancel" Height="34" Margin="6,0,0,0"
                                            Padding="10,0" FontSize="12.5" Visibility="Collapsed"
                                            Click="HttpCancel_Click"
                                            Background="{DynamicResource CardBg}"
                                            Foreground="{DynamicResource SubText}"
                                            BorderBrush="{DynamicResource CardBorder}" BorderThickness="1">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}" CornerRadius="10"
                                                        Padding="{TemplateBinding Padding}"
                                                        BorderBrush="{TemplateBinding BorderBrush}"
                                                        BorderThickness="{TemplateBinding BorderThickness}">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>

                                    <!-- Save to Collection -->
                                    <Button Grid.Column="4" Content="💾 Save" Height="34" Margin="6,0,0,0"
                                            Padding="10,0" FontSize="12.5"
                                            Click="HttpSaveToCollection_Click"
                                            Background="{DynamicResource CardBg}"
                                            Foreground="{DynamicResource SubText}"
                                            BorderBrush="{DynamicResource CardBorder}" BorderThickness="1">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}" CornerRadius="10"
                                                        Padding="{TemplateBinding Padding}"
                                                        BorderBrush="{TemplateBinding BorderBrush}"
                                                        BorderThickness="{TemplateBinding BorderThickness}">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                </Grid>

                                <!-- Row 2: Environment selector + import/export bar -->
                                <Grid Margin="16,0,16,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="200"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Column="0" Text="Environment:" FontSize="11.5"
                                               Foreground="{DynamicResource SubText}"
                                               VerticalAlignment="Center" Margin="0,0,8,0"/>

                                    <ComboBox x:Name="EnvSelectorBox" Grid.Column="1"
                                              Height="30" FontSize="12"
                                              SelectionChanged="EnvSelector_Changed"
                                              VerticalContentAlignment="Center">
                                        <ComboBoxItem Content="No Environment" FontStyle="Italic"/>
                                    </ComboBox>

                                    <Button Grid.Column="2" Content="⚙ Manage" Height="30" Margin="6,0,0,0"
                                            Padding="10,0" FontSize="11.5"
                                            Click="ManageEnvironments_Click"
                                            Background="{DynamicResource CardBg}"
                                            Foreground="{DynamicResource SubText}"
                                            BorderBrush="{DynamicResource CardBorder}" BorderThickness="1">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}" CornerRadius="8"
                                                        Padding="{TemplateBinding Padding}"
                                                        BorderBrush="{TemplateBinding BorderBrush}"
                                                        BorderThickness="{TemplateBinding BorderThickness}">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Opacity" Value="0.8"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>

                                    <!-- Spacer -->
                                    <Border Grid.Column="3"/>

                                    <!-- Import Collection -->
                                    <Button Grid.Column="4" Content="⬆ Import" Height="30" Margin="0,0,6,0"
                                            Padding="10,0" FontSize="11.5"
                                            Click="ImportCollection_Click"
                                            Background="{DynamicResource CardBg}"
                                            Foreground="{DynamicResource SubText}"
                                            BorderBrush="{DynamicResource CardBorder}" BorderThickness="1"
                                            ToolTip="Import a collection from JSON or Postman format">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}" CornerRadius="8"
                                                        Padding="{TemplateBinding Padding}"
                                                        BorderBrush="{TemplateBinding BorderBrush}"
                                                        BorderThickness="{TemplateBinding BorderThickness}">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Opacity" Value="0.8"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>

                                    <!-- Export All Collections -->
                                    <Button Grid.Column="5" Content="⬇ Export All" Height="30" Margin="0,0,6,0"
                                            Padding="10,0" FontSize="11.5"
                                            Click="ExportAllCollections_Click"
                                            Background="{DynamicResource CardBg}"
                                            Foreground="{DynamicResource SubText}"
                                            BorderBrush="{DynamicResource CardBorder}" BorderThickness="1"
                                            ToolTip="Export all collections to a single JSON file">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}" CornerRadius="8"
                                                        Padding="{TemplateBinding Padding}"
                                                        BorderBrush="{TemplateBinding BorderBrush}"
                                                        BorderThickness="{TemplateBinding BorderThickness}">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Opacity" Value="0.8"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>

                                    <!-- Active env variable preview chip -->
                                    <Border Grid.Column="6" x:Name="ActiveEnvChip"
                                            CornerRadius="6" Padding="8,3"
                                            Visibility="Collapsed">
                                        <Border.Background><SolidColorBrush Color="#7C3AED" Opacity="0.15"/></Border.Background>
                                        <TextBlock x:Name="ActiveEnvVarCount"
                                                   FontSize="11" Foreground="#A5B4FC"/>
                                    </Border>
                                </Grid>

                            </StackPanel>
                        </Border>

                        <!-- ── Request sub-tabs: Params / Headers / Body / Auth ───── -->
                        <TabControl x:Name="HttpReqTabs" Grid.Row="1"
                                    Background="Transparent" BorderThickness="0"
                                    Margin="0" Padding="0">
                            <TabControl.Resources>
                                <Style TargetType="TabItem">
                                    <Setter Property="Padding" Value="14,7"/>
                                    <Setter Property="FontSize" Value="12"/>
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="Foreground" Value="{DynamicResource SubText}"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="TabItem">
                                                <Border x:Name="Brd" Padding="{TemplateBinding Padding}"
                                                        BorderBrush="Transparent" BorderThickness="0,0,0,2">
                                                    <ContentPresenter ContentSource="Header"
                                                                      HorizontalAlignment="Center"
                                                                      VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsSelected" Value="True">
                                                        <Setter TargetName="Brd" Property="BorderBrush" Value="#7C3AED"/>
                                                        <Setter Property="Foreground" Value="{DynamicResource PrimaryText}"/>
                                                    </Trigger>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Foreground" Value="{DynamicResource PrimaryText}"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </TabControl.Resources>

                            <!-- Params -->
                            <TabItem Header="Params">
                                <Grid Margin="12,8">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <Grid Grid.Row="0" Margin="0,0,0,6">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="80"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Key" FontSize="11" Foreground="{DynamicResource SubText}" FontWeight="SemiBold" Margin="6,0"/>
                                        <TextBlock Grid.Column="1" Text="Value" FontSize="11" Foreground="{DynamicResource SubText}" FontWeight="SemiBold" Margin="6,0"/>
                                    </Grid>
                                    <DataGrid x:Name="HttpParamsGrid" Grid.Row="1"
                                              AutoGenerateColumns="False" CanUserAddRows="True"
                                              CanUserDeleteRows="True" HeadersVisibility="None"
                                              BorderThickness="1" BorderBrush="{DynamicResource CardBorder}"
                                              Background="{DynamicResource InputBg}"
                                              RowBackground="{DynamicResource InputBg}"
                                              AlternatingRowBackground="{DynamicResource CardBg}"
                                              GridLinesVisibility="None" MaxHeight="160"
                                              CellEditEnding="HttpParams_CellEditEnding">
                                        <DataGrid.Columns>
                                            <DataGridCheckBoxColumn Width="30" Binding="{Binding Enabled}"/>
                                            <DataGridTextColumn Width="*" Binding="{Binding Key}" Header="Key">
                                                <DataGridTextColumn.EditingElementStyle>
                                                    <Style TargetType="TextBox"><Setter Property="BorderThickness" Value="0"/></Style>
                                                </DataGridTextColumn.EditingElementStyle>
                                            </DataGridTextColumn>
                                            <DataGridTextColumn Width="*" Binding="{Binding Value}" Header="Value">
                                                <DataGridTextColumn.EditingElementStyle>
                                                    <Style TargetType="TextBox"><Setter Property="BorderThickness" Value="0"/></Style>
                                                </DataGridTextColumn.EditingElementStyle>
                                            </DataGridTextColumn>
                                            <DataGridTextColumn Width="2*" Binding="{Binding Description}" Header="Description">
                                                <DataGridTextColumn.EditingElementStyle>
                                                    <Style TargetType="TextBox"><Setter Property="BorderThickness" Value="0"/></Style>
                                                </DataGridTextColumn.EditingElementStyle>
                                            </DataGridTextColumn>
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </Grid>
                            </TabItem>

                            <!-- Headers -->
                            <TabItem Header="Headers">
                                <Grid Margin="12,8">
                                    <DataGrid x:Name="HttpHeadersGrid"
                                              AutoGenerateColumns="False" CanUserAddRows="True"
                                              CanUserDeleteRows="True" HeadersVisibility="None"
                                              BorderThickness="1" BorderBrush="{DynamicResource CardBorder}"
                                              Background="{DynamicResource InputBg}"
                                              RowBackground="{DynamicResource InputBg}"
                                              AlternatingRowBackground="{DynamicResource CardBg}"
                                              GridLinesVisibility="None" MaxHeight="160">
                                        <DataGrid.Columns>
                                            <DataGridCheckBoxColumn Width="30" Binding="{Binding Enabled}"/>
                                            <DataGridTextColumn Width="*" Binding="{Binding Key}" Header="Key">
                                                <DataGridTextColumn.EditingElementStyle>
                                                    <Style TargetType="TextBox"><Setter Property="BorderThickness" Value="0"/></Style>
                                                </DataGridTextColumn.EditingElementStyle>
                                            </DataGridTextColumn>
                                            <DataGridTextColumn Width="*" Binding="{Binding Value}" Header="Value">
                                                <DataGridTextColumn.EditingElementStyle>
                                                    <Style TargetType="TextBox"><Setter Property="BorderThickness" Value="0"/></Style>
                                                </DataGridTextColumn.EditingElementStyle>
                                            </DataGridTextColumn>
                                            <DataGridTextColumn Width="2*" Binding="{Binding Description}" Header="Description">
                                                <DataGridTextColumn.EditingElementStyle>
                                                    <Style TargetType="TextBox"><Setter Property="BorderThickness" Value="0"/></Style>
                                                </DataGridTextColumn.EditingElementStyle>
                                            </DataGridTextColumn>
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </Grid>
                            </TabItem>

                            <!-- Body -->
                            <TabItem Header="Body">
                                <Grid Margin="12,8,18,8">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>
                                    <!-- Body type picker + Clear button -->
                                    <Grid Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                            <RadioButton x:Name="BodyNoneRb"     Content="none"                  Margin="0,0,14,0" IsChecked="True"  GroupName="BodyType" Checked="BodyType_Changed" Foreground="{DynamicResource SubText}" FontSize="12"/>
                                            <RadioButton x:Name="BodyFormDataRb" Content="form-data"             Margin="0,0,14,0" GroupName="BodyType" Checked="BodyType_Changed" Foreground="{DynamicResource SubText}" FontSize="12"/>
                                            <RadioButton x:Name="BodyFormRb"     Content="x-www-form-urlencoded" Margin="0,0,14,0" GroupName="BodyType" Checked="BodyType_Changed" Foreground="{DynamicResource SubText}" FontSize="12"/>
                                            <RadioButton x:Name="BodyRawRb"      Content="raw"                   Margin="0,0,14,0" GroupName="BodyType" Checked="BodyType_Changed" Foreground="{DynamicResource SubText}" FontSize="12"/>
                                            <RadioButton x:Name="BodyBinaryRb"   Content="binary"                Margin="0,0,14,0" GroupName="BodyType" Checked="BodyType_Changed" Foreground="{DynamicResource SubText}" FontSize="12"/>
                                            <RadioButton x:Name="BodyGraphQLRb"  Content="GraphQL"               Margin="0,0,14,0" GroupName="BodyType" Checked="BodyType_Changed" Foreground="{DynamicResource SubText}" FontSize="12"/>
                                            <ComboBox x:Name="BodyRawFormatBox"  Width="90" Height="22" FontSize="11"
                                                      Visibility="Collapsed"
                                                      Background="{DynamicResource CardBg}"
                                                      BorderBrush="{DynamicResource CardBorder}"
                                                      Foreground="{DynamicResource SubText}">
                                                <ComboBoxItem Content="JSON"        IsSelected="True"/>
                                                <ComboBoxItem Content="Text"/>
                                                <ComboBoxItem Content="JavaScript"/>
                                                <ComboBoxItem Content="HTML"/>
                                                <ComboBoxItem Content="XML"/>
                                            </ComboBox>
                                        </StackPanel>
                                        <Button Grid.Column="1" Content="🗑 Clear Body"
                                                Click="ClearBody_Click"
                                                Height="26" FontSize="11"
                                                Padding="10,4" Margin="8,0,0,0"
                                                HorizontalAlignment="Right"
                                                Background="#FF3B30" Foreground="White"
                                                BorderThickness="0" Cursor="Hand">
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                                            CornerRadius="8" Padding="{TemplateBinding Padding}">
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="Bd" Property="Background" Value="#D62D22"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Button.Template>
                                        </Button>
                                    </Grid>
                                    <!-- Token-in-body warning (Row 1) -->
                                    <Border x:Name="TokenInBodyWarning" Grid.Row="1"
                                            Background="#7F1D1D" CornerRadius="6"
                                            Padding="10,8" Margin="0,0,0,6"
                                            Visibility="Collapsed">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="⛔  " FontSize="13" VerticalAlignment="Center"/>
                                            <TextBlock TextWrapping="Wrap" FontSize="12" Foreground="#FCA5A5" VerticalAlignment="Center">
                                                <Run FontWeight="Bold">Token detected in body — send blocked.</Run>
                                                <Run>Clear the body and paste your token in</Run>
                                                <Run FontWeight="Bold">Auth → Bearer Token</Run>
                                                <Run>tab instead.</Run>
                                            </TextBlock>
                                        </StackPanel>
                                    </Border>
                                    <!-- Raw JSON editor (Row 2) -->
                                    <TextBox x:Name="HttpBodyBox" Grid.Row="2"
                                             FontFamily="Cascadia Code, Consolas, Courier New"
                                             FontSize="12.5" AcceptsReturn="True"
                                             VerticalScrollBarVisibility="Auto"
                                             HorizontalScrollBarVisibility="Auto"
                                             TextWrapping="NoWrap"
                                             Padding="10" MinHeight="100"
                                             Text="" Visibility="Collapsed"
                                             TextChanged="HttpBodyBox_TextChanged"/>
                                    <!-- Form-encoded grid -->
                                    <DataGrid x:Name="HttpFormGrid" Grid.Row="2"
                                              AutoGenerateColumns="False" CanUserAddRows="True"
                                              CanUserDeleteRows="True" HeadersVisibility="None"
                                              BorderThickness="1" BorderBrush="{DynamicResource CardBorder}"
                                              Background="{DynamicResource InputBg}"
                                              RowBackground="{DynamicResource InputBg}"
                                              AlternatingRowBackground="{DynamicResource CardBg}"
                                              GridLinesVisibility="None" MaxHeight="160"
                                              Visibility="Collapsed">
                                        <DataGrid.Columns>
                                            <DataGridCheckBoxColumn Width="30" Binding="{Binding Enabled}"/>
                                            <DataGridTextColumn Width="*" Binding="{Binding Key}"/>
                                            <DataGridTextColumn Width="*" Binding="{Binding Value}"/>
                                            <DataGridTextColumn Width="2*" Binding="{Binding Description}"/>
                                        </DataGrid.Columns>
                                    </DataGrid>
                                    <!-- Binary file picker -->
                                    <StackPanel x:Name="HttpBinaryPanel" Grid.Row="2"
                                                Orientation="Horizontal" Visibility="Collapsed">
                                        <TextBox x:Name="HttpBinaryPathBox" Width="320" Height="34"
                                                 Padding="10,0" IsReadOnly="True"
                                                 VerticalContentAlignment="Center"/>
                                        <Button Content="Browse…" Margin="8,0,0,0" Height="34"
                                                Padding="12,0" Click="HttpBinaryBrowse_Click"
                                                Background="{DynamicResource CardBg}"
                                                BorderBrush="{DynamicResource CardBorder}" BorderThickness="1"
                                                Foreground="{DynamicResource SubText}">
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <Border Background="{TemplateBinding Background}"
                                                            CornerRadius="10" Padding="{TemplateBinding Padding}"
                                                            BorderBrush="{TemplateBinding BorderBrush}"
                                                            BorderThickness="{TemplateBinding BorderThickness}">
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                </ControlTemplate>
                                            </Button.Template>
                                        </Button>
                                    </StackPanel>
                                    <!-- form-data grid -->
                                    <DataGrid x:Name="HttpFormDataGrid" Grid.Row="2"
                                              AutoGenerateColumns="False" CanUserAddRows="True"
                                              CanUserDeleteRows="True" HeadersVisibility="Column"
                                              BorderThickness="1" BorderBrush="{DynamicResource CardBorder}"
                                              Background="{DynamicResource InputBg}"
                                              RowBackground="{DynamicResource InputBg}"
                                              AlternatingRowBackground="{DynamicResource CardBg}"
                                              GridLinesVisibility="None" MaxHeight="200"
                                              Visibility="Collapsed">
                                        <DataGrid.Columns>
                                            <DataGridCheckBoxColumn  Width="30"  Binding="{Binding Enabled}"     Header=""/>
                                            <DataGridTextColumn      Width="*"   Binding="{Binding Key}"         Header="Key"/>
                                            <DataGridTextColumn      Width="2*"  Binding="{Binding Value}"       Header="Value"/>
                                            <DataGridTextColumn      Width="*"   Binding="{Binding Description}" Header="Description"/>
                                        </DataGrid.Columns>
                                    </DataGrid>
                                    <!-- GraphQL editor -->
                                    <Grid x:Name="HttpGraphQLPanel" Grid.Row="2" Visibility="Collapsed">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="*"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="120"/>
                                        </Grid.RowDefinitions>
                                        <TextBox x:Name="HttpGraphQLQueryBox" Grid.Row="0"
                                                 FontFamily="Cascadia Code, Consolas, Courier New"
                                                 FontSize="12.5" AcceptsReturn="True"
                                                 VerticalScrollBarVisibility="Auto"
                                                 HorizontalScrollBarVisibility="Auto"
                                                 TextWrapping="NoWrap"
                                                 Padding="10" MinHeight="100"
                                                 Text=""/>
                                        <TextBlock Grid.Row="1" Text="Variables (JSON)"
                                                   FontSize="11" Foreground="{DynamicResource SubText}"
                                                   Margin="0,8,0,4"/>
                                        <TextBox x:Name="HttpGraphQLVariablesBox" Grid.Row="2"
                                                 FontFamily="Cascadia Code, Consolas, Courier New"
                                                 FontSize="12.5" AcceptsReturn="True"
                                                 VerticalScrollBarVisibility="Auto"
                                                 HorizontalScrollBarVisibility="Auto"
                                                 TextWrapping="NoWrap"
                                                 Padding="10"
                                                 Text="{}"/>
                                    </Grid>
                                </Grid>
                            </TabItem>

                            <!-- Auth -->
                            <TabItem Header="Auth">
                                <Grid Margin="12,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="160"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="Auth Type" FontSize="11" Foreground="{DynamicResource SubText}" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                        <ComboBox x:Name="HttpAuthTypeBox" SelectedIndex="0"
                                                  SelectionChanged="HttpAuthType_Changed"
                                                  FontSize="12.5" Height="32">
                                            <ComboBoxItem Content="No Auth"/>
                                            <ComboBoxItem Content="API Key"/>
                                            <ComboBoxItem Content="Bearer Token"/>
                                            <ComboBoxItem Content="Basic Auth"/>
                                        </ComboBox>
                                    </StackPanel>
                                    <!-- Auth detail panel -->
                                    <StackPanel x:Name="HttpAuthPanel" Grid.Column="1" Margin="16,0,0,0">
                                        <!-- API Key -->
                                        <StackPanel x:Name="AuthApiKeyPanel" Visibility="Collapsed">
                                            <Grid Margin="0,0,0,8">
                                                <Grid.ColumnDefinitions><ColumnDefinition Width="100"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                                <TextBlock Text="Key" FontSize="12" Foreground="{DynamicResource SubText}" VerticalAlignment="Center"/>
                                                <TextBox x:Name="AuthApiKeyNameBox" Grid.Column="1" Height="30" Padding="8,0"
                                                         VerticalContentAlignment="Center" Text="APIKEY"
                                                         TextChanged="HttpAuthField_Changed"/>
                                            </Grid>
                                            <Grid Margin="0,0,0,8">
                                                <Grid.ColumnDefinitions><ColumnDefinition Width="100"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                                <TextBlock Text="Value" FontSize="12" Foreground="{DynamicResource SubText}" VerticalAlignment="Center"/>
                                                <TextBox x:Name="AuthApiKeyValueBox" Grid.Column="1" Height="30" Padding="8,0"
                                                         VerticalContentAlignment="Center"
                                                         TextChanged="HttpAuthField_Changed"/>
                                            </Grid>
                                            <Grid>
                                                <Grid.ColumnDefinitions><ColumnDefinition Width="100"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                                <TextBlock Text="Add to" FontSize="12" Foreground="{DynamicResource SubText}" VerticalAlignment="Center"/>
                                                <ComboBox x:Name="AuthApiKeyLocationBox" Grid.Column="1" Height="30" SelectedIndex="0" FontSize="12"
                                                          SelectionChanged="HttpAuthLocation_Changed">
                                                    <ComboBoxItem Content="Header"/>
                                                    <ComboBoxItem Content="Query Params"/>
                                                </ComboBox>
                                            </Grid>
                                        </StackPanel>
                                        <!-- Bearer Token -->
                                        <StackPanel x:Name="AuthBearerPanel" Visibility="Collapsed">
                                            <Grid>
                                                <Grid.ColumnDefinitions><ColumnDefinition Width="100"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                                <TextBlock Text="Token" FontSize="12" Foreground="{DynamicResource SubText}" VerticalAlignment="Center"/>
                                                <TextBox x:Name="AuthBearerTokenBox" Grid.Column="1" Height="30" Padding="8,0"
                                                         VerticalContentAlignment="Center"
                                                         TextChanged="HttpAuthField_Changed"/>
                                            </Grid>
                                        </StackPanel>
                                        <!-- Basic Auth -->
                                        <StackPanel x:Name="AuthBasicPanel" Visibility="Collapsed">
                                            <Grid Margin="0,0,0,8">
                                                <Grid.ColumnDefinitions><ColumnDefinition Width="100"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                                <TextBlock Text="Username" FontSize="12" Foreground="{DynamicResource SubText}" VerticalAlignment="Center"/>
                                                <TextBox x:Name="AuthBasicUserBox" Grid.Column="1" Height="30" Padding="8,0"
                                                         VerticalContentAlignment="Center"
                                                         TextChanged="HttpAuthField_Changed"/>
                                            </Grid>
                                            <Grid>
                                                <Grid.ColumnDefinitions><ColumnDefinition Width="100"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                                <TextBlock Text="Password" FontSize="12" Foreground="{DynamicResource SubText}" VerticalAlignment="Center"/>
                                                <TextBox x:Name="AuthBasicPassBox" Grid.Column="1" Height="30" Padding="8,0"
                                                         VerticalContentAlignment="Center"
                                                         TextChanged="HttpAuthField_Changed"/>
                                            </Grid>
                                        </StackPanel>
                                    </StackPanel>
                                </Grid>
                            </TabItem>
                        </TabControl>

                        <!-- ── GridSplitter ───────────────────────────────────────── -->
                        <GridSplitter Grid.Row="3" Height="5" HorizontalAlignment="Stretch"
                                      Background="{DynamicResource CardBorder}" Cursor="SizeNS"/>

                        <!-- ── Response panel ─────────────────────────────────────── -->
                        <Grid Grid.Row="4">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <!-- Response status bar -->
                            <Border Grid.Row="0" Background="{DynamicResource CardBg}"
                                    BorderBrush="{DynamicResource CardBorder}" BorderThickness="0,1,0,1"
                                    Padding="16,6">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="Response" FontSize="12" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource PrimaryText}" VerticalAlignment="Center" Margin="0,0,20,0"/>
                                        <Border x:Name="HttpStatusBadge" CornerRadius="6" Padding="8,3" Visibility="Collapsed" Margin="0,0,12,0">
                                            <TextBlock x:Name="HttpStatusText" FontSize="12" FontWeight="SemiBold"/>
                                        </Border>
                                        <TextBlock x:Name="HttpTimingText" FontSize="11.5"
                                                   Foreground="{DynamicResource SubText}" VerticalAlignment="Center" Margin="0,0,12,0"/>
                                        <TextBlock x:Name="HttpSizeText" FontSize="11.5"
                                                   Foreground="{DynamicResource SubText}" VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                                        <Button Content="📋 Copy" Height="28" Padding="10,0" FontSize="11.5"
                                                Click="HttpCopyResponse_Click" Margin="0,0,6,0"
                                                Background="{DynamicResource CardBg}"
                                                Foreground="{DynamicResource SubText}"
                                                BorderBrush="{DynamicResource CardBorder}" BorderThickness="1">
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <Border Background="{TemplateBinding Background}" CornerRadius="8"
                                                            Padding="{TemplateBinding Padding}"
                                                            BorderBrush="{TemplateBinding BorderBrush}"
                                                            BorderThickness="{TemplateBinding BorderThickness}">
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                </ControlTemplate>
                                            </Button.Template>
                                        </Button>
                                        <Button Content="⬇ Save" Height="28" Padding="10,0" FontSize="11.5"
                                                Click="HttpSaveResponse_Click"
                                                Background="{DynamicResource CardBg}"
                                                Foreground="{DynamicResource SubText}"
                                                BorderBrush="{DynamicResource CardBorder}" BorderThickness="1">
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <Border Background="{TemplateBinding Background}" CornerRadius="8"
                                                            Padding="{TemplateBinding Padding}"
                                                            BorderBrush="{TemplateBinding BorderBrush}"
                                                            BorderThickness="{TemplateBinding BorderThickness}">
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                </ControlTemplate>
                                            </Button.Template>
                                        </Button>
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <!-- Response sub-tabs: Body / Headers / Cookies -->
                            <TabControl x:Name="HttpRespTabs" Grid.Row="1"
                                        Background="Transparent" BorderThickness="0" Padding="0">
                                <TabControl.Resources>
                                    <Style TargetType="TabItem">
                                        <Setter Property="Padding" Value="12,6"/>
                                        <Setter Property="FontSize" Value="12"/>
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="Foreground" Value="{DynamicResource SubText}"/>
                                        <Setter Property="BorderThickness" Value="0"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="TabItem">
                                                    <Border x:Name="Brd" Padding="{TemplateBinding Padding}"
                                                            BorderBrush="Transparent" BorderThickness="0,0,0,2">
                                                        <ContentPresenter ContentSource="Header"
                                                                          HorizontalAlignment="Center"
                                                                          VerticalAlignment="Center"/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsSelected" Value="True">
                                                            <Setter TargetName="Brd" Property="BorderBrush" Value="#7C3AED"/>
                                                            <Setter Property="Foreground" Value="{DynamicResource PrimaryText}"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </TabControl.Resources>

                                <!-- Body -->
                                <TabItem Header="Body">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                        </Grid.RowDefinitions>

                                        <!-- Toolbar: Pretty / Raw / Preview + language + wrap -->
                                        <Border BorderBrush="{DynamicResource CardBorder}" BorderThickness="0,0,0,1" Padding="12,5">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                    <RadioButton x:Name="RespPrettyRb" Content="Pretty" GroupName="RespView"
                                                                 IsChecked="True" Checked="RespView_Changed"
                                                                 Foreground="{DynamicResource SubText}" FontSize="12" Margin="0,0,14,0"/>
                                                    <RadioButton x:Name="RespRawRb" Content="Raw" GroupName="RespView"
                                                                 Checked="RespView_Changed"
                                                                 Foreground="{DynamicResource SubText}" FontSize="12" Margin="0,0,14,0"/>
                                                    <RadioButton x:Name="RespPreviewRb" Content="Preview" GroupName="RespView"
                                                                 Checked="RespView_Changed"
                                                                 Foreground="{DynamicResource SubText}" FontSize="12"/>
                                                </StackPanel>
                                                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                                    <TextBlock x:Name="RespLangLabel" FontSize="11"
                                                               Foreground="{DynamicResource SubLabelFg}"
                                                               VerticalAlignment="Center" Margin="0,0,16,0"/>
                                                    <CheckBox x:Name="RespWordWrapChk" Content="Wrap" FontSize="11"
                                                              Foreground="{DynamicResource SubText}" VerticalAlignment="Center"
                                                              Checked="RespWordWrap_Changed" Unchecked="RespWordWrap_Changed"/>
                                                </StackPanel>
                                            </Grid>
                                        </Border>

                                        <!-- Viewers (stacked, visibility-switched) -->
                                        <Grid Grid.Row="1">
                                            <!-- Pretty: WebView2 syntax-highlighted view -->
                                            <wv2:WebView2 x:Name="HttpPrettyView"
                                                          Visibility="Visible"
                                                          Loaded="HttpPrettyView_Loaded"/>
                                            <!-- Raw: plain monospace TextBox -->
                                            <TextBox x:Name="HttpResponseBox"
                                                     FontFamily="Cascadia Code, Consolas, Courier New"
                                                     FontSize="12.5" IsReadOnly="True"
                                                     AcceptsReturn="True"
                                                     VerticalScrollBarVisibility="Auto"
                                                     HorizontalScrollBarVisibility="Auto"
                                                     TextWrapping="NoWrap"
                                                     Padding="14"
                                                     Visibility="Collapsed"
                                                     Background="{DynamicResource InputBg}"
                                                     Text="— Send a request to see the response —"
                                                     Foreground="{DynamicResource SubText}"/>
                                            <!-- Preview: rendered HTML -->
                                            <wv2:WebView2 x:Name="HttpPreviewView"
                                                          Visibility="Collapsed"
                                                          Loaded="HttpPreviewView_Loaded"/>
                                        </Grid>
                                    </Grid>
                                </TabItem>

                                <!-- Response headers -->
                                <TabItem Header="Headers">
                                    <DataGrid x:Name="HttpRespHeadersGrid"
                                              AutoGenerateColumns="False" CanUserAddRows="False"
                                              IsReadOnly="True" HeadersVisibility="Column"
                                              BorderThickness="0"
                                              Background="{DynamicResource InputBg}"
                                              RowBackground="{DynamicResource InputBg}"
                                              AlternatingRowBackground="{DynamicResource CardBg}"
                                              GridLinesVisibility="None">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Width="*"  Header="Name"  Binding="{Binding Key}"/>
                                            <DataGridTextColumn Width="2*" Header="Value" Binding="{Binding Value}"/>
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </TabItem>
                            </TabControl>
                        </Grid>
                        </Grid><!-- /Grid.Column="2" request+response -->
                    </Grid><!-- /outer 2-col -->
                </TabItem>

                <!-- ═══════════════════════════════════════════════════════
                     TAB 16 — PERFORMANCE TESTER
                     ═══════════════════════════════════════════════════════ -->
                <TabItem x:Name="TabItem16" Header="⚡ Performance">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>   <!-- config panel -->
                            <RowDefinition Height="Auto"/>   <!-- run bar -->
                            <RowDefinition Height="Auto"/>   <!-- summary KPIs -->
                            <RowDefinition Height="*"/>      <!-- results grid + log -->
                        </Grid.RowDefinitions>

                        <!-- ── Config panel ───────────────────────────────────── -->
                        <Border Grid.Row="0" Background="{DynamicResource CardBg}"
                                BorderBrush="{DynamicResource CardBorder}" BorderThickness="0,0,0,1"
                                Padding="20,14">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="16"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <!-- Left column -->
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="⚡  Performance Test" FontSize="16" FontWeight="Bold"
                                               Foreground="{DynamicResource PrimaryText}" Margin="0,0,0,10"/>

                                    <!-- ── Mode selector ── -->
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                        <RadioButton x:Name="PerfModeCollection" Content="📦  Collection"
                                                     IsChecked="True" GroupName="PerfMode"
                                                     Checked="PerfMode_Changed"
                                                     FontSize="12" Foreground="{DynamicResource PrimaryText}"
                                                     VerticalContentAlignment="Center" Margin="0,0,18,0"/>
                                        <RadioButton x:Name="PerfModeSingleApi" Content="🔗  Single API"
                                                     GroupName="PerfMode" Checked="PerfMode_Changed"
                                                     FontSize="12" Foreground="{DynamicResource PrimaryText}"
                                                     VerticalContentAlignment="Center" Margin="0,0,18,0"/>
                                        <RadioButton x:Name="PerfModeWeb" Content="🌐  Web"
                                                     GroupName="PerfMode" Checked="PerfMode_Changed"
                                                     FontSize="12" Foreground="{DynamicResource PrimaryText}"
                                                     VerticalContentAlignment="Center"/>
                                    </StackPanel>

                                    <!-- ── Collection panel ── -->
                                    <StackPanel x:Name="PerfCollectionPanel">
                                        <Grid Margin="0,0,0,10">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="110"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="Collection" FontSize="12" Foreground="{DynamicResource SubText}" VerticalAlignment="Center"/>
                                            <ComboBox x:Name="PerfCollectionBox" Grid.Column="1" Height="32"
                                                      FontSize="12.5" VerticalContentAlignment="Center"
                                                      SelectionChanged="PerfCollection_Changed"/>
                                        </Grid>
                                    </StackPanel>

                                    <!-- ── Single API panel ── -->
                                    <StackPanel x:Name="PerfSingleApiPanel" Visibility="Collapsed">
                                        <!-- Method + URL -->
                                        <Grid Margin="0,0,0,8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="95"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <ComboBox x:Name="PerfSingleMethodBox" Height="32"
                                                      FontSize="12" FontWeight="SemiBold"
                                                      VerticalContentAlignment="Center" SelectedIndex="0">
                                                <ComboBoxItem Content="GET"    Foreground="#A78BFA"/>
                                                <ComboBoxItem Content="POST"   Foreground="#FCD34D"/>
                                                <ComboBoxItem Content="PUT"    Foreground="#7C3AED"/>
                                                <ComboBoxItem Content="PATCH"  Foreground="#8B5CF6"/>
                                                <ComboBoxItem Content="DELETE" Foreground="#EF4444"/>
                                            </ComboBox>
                                            <TextBox x:Name="PerfSingleUrlBox" Grid.Column="1"
                                                     Height="32" Padding="10,0" Margin="8,0,0,0"
                                                     FontSize="12.5" VerticalContentAlignment="Center"
                                                     Text="https://"
                                                     ToolTip="Use {{variableName}} for environment variables"/>
                                        </Grid>
                                        <!-- Body -->
                                        <Grid Margin="0,0,0,6">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="95"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="Body (JSON)" FontSize="12" Foreground="{DynamicResource SubText}"
                                                       VerticalAlignment="Top" Margin="0,6,0,0"/>
                                            <TextBox x:Name="PerfSingleBodyBox" Grid.Column="1"
                                                     Height="58" Padding="10,8" AcceptsReturn="True"
                                                     TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"
                                                     FontSize="12" FontFamily="Cascadia Code, Consolas, Courier New"
                                                     VerticalContentAlignment="Top"/>
                                        </Grid>
                                    </StackPanel>

                                    <!-- ── Web panel ── -->
                                    <StackPanel x:Name="PerfWebPanel" Visibility="Collapsed">
                                        <Grid Margin="0,0,0,8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="95"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="URL" FontSize="12" Foreground="{DynamicResource SubText}" VerticalAlignment="Center"/>
                                            <TextBox x:Name="PerfWebUrlBox" Grid.Column="1"
                                                     Height="32" Padding="10,0"
                                                     FontSize="12.5" VerticalContentAlignment="Center"
                                                     Text="https://"
                                                     ToolTip="Measures TTFB, download time, redirects and content size"/>
                                        </Grid>
                                        <Grid Margin="0,0,0,4">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="95"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <CheckBox x:Name="PerfWebFollowRedirects" Grid.Column="1"
                                                      Content="Follow redirects" IsChecked="True"
                                                      FontSize="12" Foreground="{DynamicResource PrimaryText}"/>
                                        </Grid>
                                        <TextBlock Text="Measures: TTFB · Download · Total time · Status · Content size · Redirects"
                                                   FontSize="10.5" Foreground="{DynamicResource SubText}"
                                                   Margin="0,4,0,0" TextWrapping="Wrap"/>
                                    </StackPanel>

                                    <!-- ── Environments (shared across all modes) ── -->
                                    <Grid Margin="0,10,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="110"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Environments" FontSize="12" Foreground="{DynamicResource SubText}" VerticalAlignment="Top" Margin="0,4,0,0"/>
                                        <Border Grid.Column="1" BorderBrush="{DynamicResource CardBorder}"
                                                BorderThickness="1" CornerRadius="8" Padding="8,6"
                                                Background="{DynamicResource InputBg}" MinHeight="60">
                                            <ItemsControl x:Name="PerfEnvCheckList">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <CheckBox Content="{Binding Name}" Margin="0,2"
                                                                  FontSize="12"
                                                                  Foreground="{DynamicResource PrimaryText}"
                                                                  IsChecked="{Binding Tag, RelativeSource={RelativeSource Self}, Mode=TwoWay}"
                                                                  Tag="False"/>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </Border>
                                    </Grid>
                                </StackPanel>

                                <!-- Right column -->
                                <StackPanel Grid.Column="2">

                                    <!-- Iterations -->
                                    <Grid Margin="0,30,0,10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="130"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Iterations" FontSize="12" Foreground="{DynamicResource SubText}" VerticalAlignment="Center"/>
                                        <TextBox x:Name="PerfIterBox" Grid.Column="1" Height="32" Padding="10,0"
                                                 VerticalContentAlignment="Center" Text="10" FontSize="12.5"/>
                                    </Grid>

                                    <!-- Concurrency -->
                                    <Grid Margin="0,0,0,10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="130"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Concurrency" FontSize="12" Foreground="{DynamicResource SubText}" VerticalAlignment="Center"/>
                                        <Grid Grid.Column="1">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBox x:Name="PerfConcurrencyBox" Height="32" Padding="10,0"
                                                     VerticalContentAlignment="Center" Text="1" FontSize="12.5"/>
                                            <TextBlock Grid.Column="1" Text="parallel users" FontSize="11"
                                                       Foreground="{DynamicResource SubText}" VerticalAlignment="Center" Margin="8,0,0,0"/>
                                        </Grid>
                                    </Grid>

                                    <!-- Delay -->
                                    <Grid Margin="0,0,0,10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="130"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Delay between" FontSize="12" Foreground="{DynamicResource SubText}" VerticalAlignment="Center"/>
                                        <Grid Grid.Column="1">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBox x:Name="PerfDelayBox" Height="32" Padding="10,0"
                                                     VerticalContentAlignment="Center" Text="0" FontSize="12.5"/>
                                            <TextBlock Grid.Column="1" Text="ms" FontSize="11"
                                                       Foreground="{DynamicResource SubText}" VerticalAlignment="Center" Margin="8,0,0,0"/>
                                        </Grid>
                                    </Grid>

                                    <!-- Timeout -->
                                    <Grid Margin="0,0,0,10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="130"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Request timeout" FontSize="12" Foreground="{DynamicResource SubText}" VerticalAlignment="Center"/>
                                        <Grid Grid.Column="1">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBox x:Name="PerfTimeoutBox" Height="32" Padding="10,0"
                                                     VerticalContentAlignment="Center" Text="10000" FontSize="12.5"/>
                                            <TextBlock Grid.Column="1" Text="ms" FontSize="11"
                                                       Foreground="{DynamicResource SubText}" VerticalAlignment="Center" Margin="8,0,0,0"/>
                                        </Grid>
                                    </Grid>

                                    <!-- Stop on first error -->
                                    <CheckBox x:Name="PerfStopOnErrorCb" Content="Stop on first error"
                                              FontSize="12" Foreground="{DynamicResource PrimaryText}" Margin="0,4,0,0"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- ── Run / Stop bar + progress ─────────────────────── -->
                        <Border Grid.Row="1" Background="{DynamicResource CardBg}"
                                BorderBrush="{DynamicResource CardBorder}" BorderThickness="0,0,0,1"
                                Padding="20,10">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <!-- Run -->
                                <Button x:Name="PerfRunBtn" Grid.Column="0"
                                        Content="▶  Run" Height="36" Padding="18,0"
                                        FontSize="13" FontWeight="SemiBold"
                                        Click="PerfRun_Click">
                                    <Button.Style>
                                        <Style TargetType="Button">
                                            <Setter Property="Background">
                                                <Setter.Value>
                                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                        <GradientStop Color="#059669" Offset="0"/>
                                                        <GradientStop Color="#10B981" Offset="1"/>
                                                    </LinearGradientBrush>
                                                </Setter.Value>
                                            </Setter>
                                            <Setter Property="Foreground" Value="White"/>
                                            <Setter Property="BorderThickness" Value="0"/>
                                            <Setter Property="Cursor" Value="Hand"/>
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border Background="{TemplateBinding Background}" CornerRadius="10" Padding="{TemplateBinding Padding}">
                                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True"><Setter Property="Opacity" Value="0.85"/></Trigger>
                                                            <Trigger Property="IsEnabled" Value="False"><Setter Property="Opacity" Value="0.5"/></Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </Button.Style>
                                </Button>

                                <!-- Stop -->
                                <Button x:Name="PerfStopBtn" Grid.Column="1"
                                        Content="■  Stop" Height="36" Padding="14,0" Margin="8,0,0,0"
                                        FontSize="13" FontWeight="SemiBold"
                                        IsEnabled="False" Click="PerfStop_Click"
                                        Background="#EF4444" Foreground="White" BorderThickness="0">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}" CornerRadius="10" Padding="{TemplateBinding Padding}">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsEnabled" Value="False"><Setter Property="Opacity" Value="0.4"/></Trigger>
                                                <Trigger Property="IsMouseOver" Value="True"><Setter Property="Opacity" Value="0.85"/></Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>

                                <!-- Progress bar -->
                                <ProgressBar x:Name="PerfProgressBar" Grid.Column="2"
                                             Height="10" Margin="16,0" VerticalAlignment="Center"
                                             Minimum="0" Maximum="100" Value="0"
                                             Background="{DynamicResource InputBg}"
                                             Foreground="#7C3AED"/>

                                <!-- Progress text -->
                                <TextBlock x:Name="PerfProgressText" Grid.Column="3"
                                           FontSize="12" Foreground="{DynamicResource SubText}"
                                           VerticalAlignment="Center" Margin="0,0,14,0"
                                           Text="0 / 0"/>

                                <!-- Export results -->
                                <Button Grid.Column="4" Content="⬇ Export CSV" Height="36"
                                        Padding="12,0" FontSize="12"
                                        Click="PerfExportCsv_Click"
                                        Background="{DynamicResource CardBg}"
                                        Foreground="{DynamicResource SubText}"
                                        BorderBrush="{DynamicResource CardBorder}" BorderThickness="1">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}" CornerRadius="9"
                                                    Padding="{TemplateBinding Padding}"
                                                    BorderBrush="{TemplateBinding BorderBrush}"
                                                    BorderThickness="{TemplateBinding BorderThickness}">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True"><Setter Property="Opacity" Value="0.8"/></Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                            </Grid>
                        </Border>

                        <!-- ── Summary KPI cards ─────────────────────────────── -->
                        <Border Grid.Row="2" Padding="16,10"
                                Background="{DynamicResource CardBg}"
                                BorderBrush="{DynamicResource CardBorder}" BorderThickness="0,0,0,1">
                            <UniformGrid Columns="6">
                                <!-- Total -->
                                <Border Margin="4,0" Padding="12,8" CornerRadius="10"
                                        Background="{DynamicResource SearchCardBg}"
                                        BorderBrush="{DynamicResource CardBorder}" BorderThickness="1">
                                    <StackPanel>
                                        <TextBlock Text="Total Requests" FontSize="10.5" Foreground="{DynamicResource SubText}"/>
                                        <TextBlock x:Name="KpiTotal" Text="—" FontSize="20" FontWeight="Bold"
                                                   Foreground="{DynamicResource PrimaryText}" Margin="0,2,0,0"/>
                                    </StackPanel>
                                </Border>
                                <!-- Passed -->
                                <Border Margin="4,0" Padding="12,8" CornerRadius="10"
                                        Background="{DynamicResource SearchCardBg}"
                                        BorderBrush="{DynamicResource CardBorder}" BorderThickness="1">
                                    <StackPanel>
                                        <TextBlock Text="Passed" FontSize="10.5" Foreground="{DynamicResource SubText}"/>
                                        <TextBlock x:Name="KpiPassed" Text="—" FontSize="20" FontWeight="Bold"
                                                   Foreground="#A78BFA" Margin="0,2,0,0"/>
                                    </StackPanel>
                                </Border>
                                <!-- Failed -->
                                <Border Margin="4,0" Padding="12,8" CornerRadius="10"
                                        Background="{DynamicResource SearchCardBg}"
                                        BorderBrush="{DynamicResource CardBorder}" BorderThickness="1">
                                    <StackPanel>
                                        <TextBlock Text="Failed" FontSize="10.5" Foreground="{DynamicResource SubText}"/>
                                        <TextBlock x:Name="KpiFailed" Text="—" FontSize="20" FontWeight="Bold"
                                                   Foreground="#EF4444" Margin="0,2,0,0"/>
                                    </StackPanel>
                                </Border>
                                <!-- Avg resp -->
                                <Border Margin="4,0" Padding="12,8" CornerRadius="10"
                                        Background="{DynamicResource SearchCardBg}"
                                        BorderBrush="{DynamicResource CardBorder}" BorderThickness="1">
                                    <StackPanel>
                                        <TextBlock Text="Avg Response" FontSize="10.5" Foreground="{DynamicResource SubText}"/>
                                        <TextBlock x:Name="KpiAvg" Text="—" FontSize="20" FontWeight="Bold"
                                                   Foreground="{DynamicResource PrimaryText}" Margin="0,2,0,0"/>
                                    </StackPanel>
                                </Border>
                                <!-- P95 -->
                                <Border Margin="4,0" Padding="12,8" CornerRadius="10"
                                        Background="{DynamicResource SearchCardBg}"
                                        BorderBrush="{DynamicResource CardBorder}" BorderThickness="1">
                                    <StackPanel>
                                        <TextBlock Text="P95" FontSize="10.5" Foreground="{DynamicResource SubText}"/>
                                        <TextBlock x:Name="KpiP95" Text="—" FontSize="20" FontWeight="Bold"
                                                   Foreground="{DynamicResource PrimaryText}" Margin="0,2,0,0"/>
                                    </StackPanel>
                                </Border>
                                <!-- RPS -->
                                <Border Margin="4,0" Padding="12,8" CornerRadius="10"
                                        Background="{DynamicResource SearchCardBg}"
                                        BorderBrush="{DynamicResource CardBorder}" BorderThickness="1">
                                    <StackPanel>
                                        <TextBlock Text="Throughput" FontSize="10.5" Foreground="{DynamicResource SubText}"/>
                                        <TextBlock x:Name="KpiRps" Text="—" FontSize="20" FontWeight="Bold"
                                                   Foreground="{DynamicResource PrimaryText}" Margin="0,2,0,0"/>
                                    </StackPanel>
                                </Border>
                            </UniformGrid>
                        </Border>

                        <!-- ── Results: aggregate stats + live log ────────────── -->
                        <Grid Grid.Row="3">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="5"/>
                                <ColumnDefinition Width="340"/>
                            </Grid.ColumnDefinitions>

                            <!-- Aggregate stats per request × environment -->
                            <Grid Grid.Column="0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <Border Padding="16,8,16,4">
                                    <TextBlock Text="Results by Request &amp; Environment"
                                               FontSize="12" FontWeight="SemiBold"
                                               Foreground="{DynamicResource PrimaryText}"/>
                                </Border>
                                <DataGrid x:Name="PerfStatsGrid" Grid.Row="1"
                                          AutoGenerateColumns="False"
                                          IsReadOnly="True"
                                          CanUserAddRows="False"
                                          HeadersVisibility="Column"
                                          BorderThickness="0"
                                          Background="{DynamicResource InputBg}"
                                          RowBackground="{DynamicResource InputBg}"
                                          AlternatingRowBackground="{DynamicResource CardBg}"
                                          GridLinesVisibility="Horizontal"
                                          FontSize="12">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Request"     Width="*"   Binding="{Binding RequestName}"/>
                                        <DataGridTextColumn Header="Env"         Width="90"  Binding="{Binding Environment}"/>
                                        <DataGridTextColumn Header="Iters"       Width="50"  Binding="{Binding Total}"/>
                                        <DataGridTemplateColumn Header="Pass %" Width="65">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding PassRate}"
                                                               Foreground="{Binding PassRateColor}"
                                                               FontWeight="SemiBold" VerticalAlignment="Center"/>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                        <DataGridTextColumn Header="Avg"   Width="65"  Binding="{Binding AvgDisplay}"/>
                                        <DataGridTextColumn Header="TTFB"  Width="65"  Binding="{Binding AvgTtfbDisplay}"/>
                                        <DataGridTextColumn Header="Min"   Width="65"  Binding="{Binding MinDisplay}"/>
                                        <DataGridTextColumn Header="Max"   Width="65"  Binding="{Binding MaxDisplay}"/>
                                        <DataGridTextColumn Header="P95"   Width="65"  Binding="{Binding P95Display}"/>
                                        <DataGridTextColumn Header="P99"   Width="65"  Binding="{Binding P99Display}"/>
                                        <DataGridTextColumn Header="req/s" Width="65"  Binding="{Binding RpsDisplay}"/>
                                        <DataGridTemplateColumn Header="Err" Width="45">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding FailDisplay}"
                                                               Foreground="{Binding PassRateColor}"
                                                               VerticalAlignment="Center"/>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Grid>

                            <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch"
                                          Background="{DynamicResource CardBorder}" Cursor="SizeWE"/>

                            <!-- Live request log -->
                            <Grid Grid.Column="2">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <Border Padding="12,8,12,4">
                                    <Grid>
                                        <TextBlock Text="Live Log" FontSize="12" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource PrimaryText}"/>
                                        <Button HorizontalAlignment="Right" Content="Clear" FontSize="11"
                                                Height="22" Padding="8,0"
                                                Click="PerfClearLog_Click"
                                                Background="{DynamicResource CardBg}"
                                                Foreground="{DynamicResource SubText}"
                                                BorderBrush="{DynamicResource CardBorder}" BorderThickness="1">
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <Border Background="{TemplateBinding Background}" CornerRadius="6"
                                                            Padding="{TemplateBinding Padding}"
                                                            BorderBrush="{TemplateBinding BorderBrush}"
                                                            BorderThickness="{TemplateBinding BorderThickness}">
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                </ControlTemplate>
                                            </Button.Template>
                                        </Button>
                                    </Grid>
                                </Border>
                                <DataGrid x:Name="PerfLogGrid" Grid.Row="1"
                                          AutoGenerateColumns="False"
                                          IsReadOnly="True"
                                          CanUserAddRows="False"
                                          HeadersVisibility="Column"
                                          BorderThickness="0"
                                          Background="{DynamicResource InputBg}"
                                          RowBackground="{DynamicResource InputBg}"
                                          AlternatingRowBackground="{DynamicResource CardBg}"
                                          GridLinesVisibility="None"
                                          FontSize="11.5"
                                          FontFamily="Cascadia Code, Consolas, Courier New">
                                    <DataGrid.Columns>
                                        <DataGridTemplateColumn Header="#" Width="32">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding Iteration}"
                                                               Foreground="{DynamicResource SubText}"
                                                               VerticalAlignment="Center"/>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                        <DataGridTemplateColumn Header="Status" Width="50">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding StatusDisplay}"
                                                               Foreground="{Binding StatusColor}"
                                                               FontWeight="SemiBold" VerticalAlignment="Center"/>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                        <DataGridTextColumn Header="Total"    Width="58"  Binding="{Binding ElapsedDisplay}"/>
                                        <DataGridTextColumn Header="TTFB"     Width="58"  Binding="{Binding TtfbDisplay}"/>
                                        <DataGridTextColumn Header="Down"     Width="58"  Binding="{Binding DownloadDisplay}"/>
                                        <DataGridTextColumn Header="Size"     Width="58"  Binding="{Binding SizeDisplay}"/>
                                        <DataGridTextColumn Header="↪"        Width="28"  Binding="{Binding RedirectDisplay}"/>
                                        <DataGridTextColumn Header="Env"      Width="75"  Binding="{Binding Environment}"/>
                                        <DataGridTextColumn Header="Request"  Width="*"   Binding="{Binding RequestName}"/>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Grid>
                        </Grid>

                    </Grid>
                </TabItem>

                <!-- Tab 17: Subscriptions (was 17, now push CoreDB to 18) -->
                <TabItem x:Name="TabItem17" Header="📦  Subscriptions"   Visibility="Collapsed">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="20,16,20,20">
                        <StackPanel MaxWidth="960">

                            <!-- Header -->
                            <StackPanel Margin="0,0,0,20">
                                <TextBlock Text="📦  Subscriptions" FontSize="20" FontWeight="Bold"
                                           Foreground="{DynamicResource PrimaryText}"/>
                                <TextBlock Text="View and manage BQE Core company subscriptions. Requires BQE Core sign-in (Settings tab)."
                                           FontSize="12" Foreground="{DynamicResource SubText}" Margin="0,4,0,0"/>
                            </StackPanel>

                            <!-- Search / Resolve Company card -->
                            <Border Background="{DynamicResource CardBg}" BorderBrush="{DynamicResource CardBorder}"
                                    BorderThickness="1" CornerRadius="10" Padding="20,16" Margin="0,0,0,14">
                                <StackPanel>

                                    <!-- Title -->
                                    <TextBlock Text="Search / Resolve Company" FontSize="14" FontWeight="Bold"
                                               Foreground="{DynamicResource PrimaryText}" Margin="0,0,0,2"/>
                                    <TextBlock Text="Find existing company or add a new one"
                                               FontSize="11.5" Foreground="{DynamicResource SubText}" Margin="0,0,0,14"/>

                                    <!-- ── Email row ── -->
                                    <TextBlock Text="Email" FontSize="12" FontWeight="SemiBold"
                                               Foreground="{DynamicResource LabelFg}" Margin="0,0,0,5"/>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                        <TextBox x:Name="SubEmailBox"
                                                 Width="280" Height="36" Padding="10,0" FontSize="13"
                                                 VerticalContentAlignment="Center"
                                                 BorderBrush="{DynamicResource InputBorder}" BorderThickness="1"
                                                 ToolTip="Enter user email to find all companies linked to it"
                                                 KeyDown="SubEmailBox_KeyDown"/>

                                        <!-- Email from Host DB — outlined blue -->
                                        <Button Height="36" Padding="14,0" Margin="8,0,0,0"
                                                FontSize="12" FontWeight="SemiBold" Cursor="Hand"
                                                BorderThickness="1" BorderBrush="#BBF7D0"
                                                Background="Transparent" Foreground="#7C3AED"
                                                Click="SubFetchEmailFromHostBtn_Click"
                                                ToolTip="Fetch Account.Email from BQECoreHost using the AccountID in Entity Custom field">
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <Border Background="{TemplateBinding Background}"
                                                            BorderBrush="{TemplateBinding BorderBrush}"
                                                            BorderThickness="{TemplateBinding BorderThickness}"
                                                            CornerRadius="7" Padding="{TemplateBinding Padding}">
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="Background" Value="#F0FDF4"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Button.Template>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="✉" FontSize="13" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                                <TextBlock Text="Email from Host DB" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Button>

                                        <!-- Fetch by Email — outlined purple -->
                                        <Button Height="36" Padding="14,0" Margin="6,0,0,0"
                                                FontSize="12" FontWeight="SemiBold" Cursor="Hand"
                                                BorderThickness="1" BorderBrush="#DDD6FE"
                                                Background="Transparent" Foreground="#7C3AED"
                                                Click="SubFetchByEmailBtn_Click"
                                                ToolTip="Fetch all companies linked to this email from Host DB">
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <Border Background="{TemplateBinding Background}"
                                                            BorderBrush="{TemplateBinding BorderBrush}"
                                                            BorderThickness="{TemplateBinding BorderThickness}"
                                                            CornerRadius="7" Padding="{TemplateBinding Padding}">
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="Background" Value="#F5F3FF"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Button.Template>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="🔍" FontSize="12" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                                <TextBlock Text="Fetch by Email" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Button>
                                    </StackPanel>

                                    <!-- ── Company ID row ── -->
                                    <TextBlock Text="Company ID" FontSize="12" FontWeight="SemiBold"
                                               Foreground="{DynamicResource LabelFg}" Margin="0,0,0,5"/>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                        <ComboBox x:Name="SubCompanyIdBox"
                                                  IsEditable="True" Width="280" Height="36" Padding="8,0"
                                                  FontFamily="Consolas" FontSize="11"
                                                  VerticalContentAlignment="Center"
                                                  BorderBrush="{DynamicResource InputBorder}" BorderThickness="1"
                                                  SelectionChanged="SubCompanyIdBox_SelectionChanged"
                                                  ToolTip="BQE Core Company GUID. Use Auto-fill to populate from Entity Custom / Host DB."/>

                                        <!-- Auto-fill — outlined gray -->
                                        <Button Height="36" Padding="12,0" Margin="8,0,0,0"
                                                FontSize="12" Cursor="Hand"
                                                BorderThickness="1" BorderBrush="{DynamicResource InputBorder}"
                                                Background="Transparent" Foreground="{DynamicResource PrimaryText}"
                                                Click="SubAutoFillCompanyBtn_Click"
                                                ToolTip="Fill Company ID from Entity Custom field, Host DB result, or selected transaction">
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <Border Background="{TemplateBinding Background}"
                                                            BorderBrush="{TemplateBinding BorderBrush}"
                                                            BorderThickness="{TemplateBinding BorderThickness}"
                                                            CornerRadius="7" Padding="{TemplateBinding Padding}">
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="Background" Value="{DynamicResource DarkBtnBg}"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Button.Template>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="↺" FontSize="14" Margin="0,0,5,0" VerticalAlignment="Center"/>
                                                <TextBlock Text="Auto-fill" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Button>

                                        <!-- Fetch from DB — outlined green -->
                                        <Button x:Name="SubFetchDbBtn" Height="36" Padding="12,0" Margin="6,0,0,0"
                                                FontSize="12" FontWeight="SemiBold" Cursor="Hand"
                                                BorderThickness="1" BorderBrush="#A7F3D0"
                                                Background="Transparent" Foreground="#059669"
                                                Click="SubFetchDbBtn_Click"
                                                ToolTip="Query CompanySubscription directly from Host DB (no API required)">
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <Border Background="{TemplateBinding Background}"
                                                            BorderBrush="{TemplateBinding BorderBrush}"
                                                            BorderThickness="{TemplateBinding BorderThickness}"
                                                            CornerRadius="7" Padding="{TemplateBinding Padding}">
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="Background" Value="#F0FDF4"/>
                                                        </Trigger>
                                                        <Trigger Property="IsEnabled" Value="False">
                                                            <Setter Property="Opacity" Value="0.5"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Button.Template>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="🗄" FontSize="12" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                                <TextBlock Text="Fetch from DB" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Button>

                                        <!-- Fetch via API — outlined blue -->
                                        <Button x:Name="SubFetchBtn" Height="36" Padding="12,0" Margin="6,0,0,0"
                                                FontSize="12" FontWeight="SemiBold" Cursor="Hand"
                                                BorderThickness="1" BorderBrush="#BBF7D0"
                                                Background="Transparent" Foreground="#7C3AED"
                                                Click="SubFetchBtn_Click"
                                                ToolTip="Fetch subscriptions via BQE Core API">
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <Border Background="{TemplateBinding Background}"
                                                            BorderBrush="{TemplateBinding BorderBrush}"
                                                            BorderThickness="{TemplateBinding BorderThickness}"
                                                            CornerRadius="7" Padding="{TemplateBinding Padding}">
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="Background" Value="#F0FDF4"/>
                                                        </Trigger>
                                                        <Trigger Property="IsEnabled" Value="False">
                                                            <Setter Property="Opacity" Value="0.5"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Button.Template>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="🌐" FontSize="12" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                                <TextBlock Text="Fetch via API" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Button>

                                        <!-- Include inactive + toggle -->
                                        <CheckBox x:Name="SubShowInactiveChk" Margin="14,0,0,0"
                                                  Content="Include inactive" FontSize="12"
                                                  VerticalAlignment="Center"
                                                  Foreground="{DynamicResource SubLabelFg}"/>

                                        <TextBlock x:Name="SubStatusText" Margin="12,0,0,0"
                                                   FontSize="12" VerticalAlignment="Center"
                                                   Foreground="{DynamicResource SubText}"
                                                   TextWrapping="NoWrap" TextTrimming="CharacterEllipsis"
                                                   ToolTip="{Binding Text, RelativeSource={RelativeSource Self}}"/>
                                    </StackPanel>

                                    <!-- ── Resolved row ── -->
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="✅" FontSize="13" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="Resolved from: " FontSize="12"
                                                   Foreground="{DynamicResource HintFg}" VerticalAlignment="Center"/>
                                        <TextBlock x:Name="SubResolvedSourceText" FontSize="12" FontWeight="SemiBold"
                                                   Foreground="#7C3AED" VerticalAlignment="Center"/>
                                    </StackPanel>

                                </StackPanel>
                            </Border>

                            <!-- Subscriptions DataGrid -->
                            <Border Background="{DynamicResource CardBg}" BorderBrush="{DynamicResource CardBorder}"
                                    BorderThickness="1" CornerRadius="8" ClipToBounds="True">
                                <StackPanel>
                                    <!-- Grid header bar -->
                                    <Border Background="{DynamicResource CardBg}"
                                            BorderBrush="{DynamicResource CardBorder}" BorderThickness="0,0,0,1"
                                            Padding="14,10">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="6"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="6"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="6"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="6"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <!-- Icon + count -->
                                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                <Border Width="34" Height="34" CornerRadius="8"
                                                        Background="{DynamicResource GreenIconBadgeBg}" Margin="0,0,10,0">
                                                    <TextBlock Text="📋" FontSize="16"
                                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <TextBlock x:Name="SubCountText"
                                                           Text="No subscriptions loaded"
                                                           FontSize="15" FontWeight="Bold"
                                                           Foreground="{DynamicResource PrimaryText}"
                                                           VerticalAlignment="Center"/>
                                            </StackPanel>

                                            <!-- Add Subscription — outlined blue -->
                                            <Button x:Name="SubAddBtn" Grid.Column="1" Height="32" Padding="14,0"
                                                    FontSize="12" FontWeight="SemiBold" Cursor="Hand"
                                                    BorderThickness="1" BorderBrush="#7C3AED"
                                                    Background="Transparent" Foreground="#7C3AED"
                                                    Click="SubAddBtn_Click"
                                                    ToolTip="Add a new subscription package to this company">
                                                <Button.Template>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border Background="{TemplateBinding Background}"
                                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter Property="Background" Value="#F0FDF4"/>
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Button.Template>
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="+" FontSize="15" FontWeight="Bold" Margin="0,0,5,0" VerticalAlignment="Center"/>
                                                    <TextBlock Text="Add Subscription" VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </Button>

                                            <!-- Change Expiry — outlined orange -->
                                            <Button x:Name="SubChangeExpiryBtn" Grid.Column="3" Height="32" Padding="12,0"
                                                    FontSize="12" FontWeight="SemiBold" Cursor="Hand"
                                                    BorderThickness="1" BorderBrush="#F59E0B"
                                                    Background="Transparent" Foreground="#D97706"
                                                    IsEnabled="False"
                                                    Click="SubChangeExpiryBtn_Click"
                                                    ToolTip="Change expiry date of selected subscription">
                                                <Button.Template>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border Background="{TemplateBinding Background}"
                                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter Property="Background" Value="#FFF7ED"/>
                                                            </Trigger>
                                                            <Trigger Property="IsEnabled" Value="False">
                                                                <Setter Property="Opacity" Value="0.45"/>
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Button.Template>
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="📅" Margin="0,0,5,0" VerticalAlignment="Center"/>
                                                    <TextBlock Text="Change Expiry" VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </Button>

                                            <!-- Refresh — outlined gray -->
                                            <Button x:Name="SubRefreshBtn" Grid.Column="5" Height="32" Padding="12,0"
                                                    FontSize="12" Cursor="Hand"
                                                    BorderThickness="1" BorderBrush="{DynamicResource InputBorder}"
                                                    Background="Transparent" Foreground="{DynamicResource PrimaryText}"
                                                    Click="SubFetchBtn_Click">
                                                <Button.Template>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border Background="{TemplateBinding Background}"
                                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter Property="Background" Value="{DynamicResource DarkBtnBg}"/>
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Button.Template>
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="↻" FontSize="13" Margin="0,0,5,0" VerticalAlignment="Center"/>
                                                    <TextBlock Text="Refresh" VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </Button>

                                            <!-- Assign Users — outlined purple -->
                                            <Button x:Name="SubAssignBtn" Grid.Column="7" Height="32" Padding="12,0"
                                                    FontSize="12" FontWeight="SemiBold" Cursor="Hand"
                                                    BorderThickness="1" BorderBrush="#7C3AED"
                                                    Background="Transparent" Foreground="#7C3AED"
                                                    IsEnabled="False"
                                                    Click="SubAssignBtn_Click"
                                                    ToolTip="Assign or unassign users (AccountCompany) to the selected subscription">
                                                <Button.Template>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border Background="{TemplateBinding Background}"
                                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter Property="Background" Value="#F5F3FF"/>
                                                            </Trigger>
                                                            <Trigger Property="IsEnabled" Value="False">
                                                                <Setter Property="Opacity" Value="0.45"/>
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Button.Template>
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="👥" Margin="0,0,5,0" VerticalAlignment="Center"/>
                                                    <TextBlock Text="Assign Users" VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </Button>

                                            <!-- Delete — outlined red -->
                                            <Button x:Name="SubDeleteBtn" Grid.Column="9" Height="32" Padding="12,0"
                                                    FontSize="12" FontWeight="SemiBold" Cursor="Hand"
                                                    BorderThickness="1" BorderBrush="#DC2626"
                                                    Background="Transparent" Foreground="#DC2626"
                                                    IsEnabled="False"
                                                    Click="SubDeleteBtn_Click"
                                                    ToolTip="Delete selected subscription from Host DB">
                                                <Button.Template>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border Background="{TemplateBinding Background}"
                                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter Property="Background" Value="#FEF2F2"/>
                                                            </Trigger>
                                                            <Trigger Property="IsEnabled" Value="False">
                                                                <Setter Property="Opacity" Value="0.45"/>
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Button.Template>
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="🗑" Margin="0,0,5,0" VerticalAlignment="Center"/>
                                                    <TextBlock Text="Delete" VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </Button>
                                        </Grid>
                                    </Border>

                                    <!-- DataGrid -->
                                    <DataGrid x:Name="SubscriptionsGrid"
                                              AutoGenerateColumns="False" IsReadOnly="True"
                                              CanUserResizeColumns="True"
                                              GridLinesVisibility="Horizontal"
                                              HeadersVisibility="Column"
                                              BorderThickness="0"
                                              RowHeight="52"
                                              SelectionUnit="FullRow" SelectionMode="Single"
                                              HorizontalScrollBarVisibility="Auto"
                                              VerticalScrollBarVisibility="Auto"
                                              MaxHeight="520" FontSize="12.5"
                                              SelectionChanged="SubscriptionsGrid_SelectionChanged">
                                        <DataGrid.Columns>
                                            <!-- Package: coloured initial icon + name -->
                                            <DataGridTemplateColumn Header="Package" Width="210" SortMemberPath="PackageName">
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <StackPanel Orientation="Horizontal" Margin="4,4,4,4" VerticalAlignment="Center">
                                                            <Border Width="30" Height="30" CornerRadius="6" Margin="0,0,8,0"
                                                                    VerticalAlignment="Center">
                                                                <Border.Background>
                                                                    <Binding Path="PackageIconBg" Converter="{StaticResource StringToBrushConverter}"/>
                                                                </Border.Background>
                                                                <TextBlock Text="{Binding PackageInitials}"
                                                                           FontSize="13" FontWeight="Bold"
                                                                           HorizontalAlignment="Center" VerticalAlignment="Center">
                                                                    <TextBlock.Foreground>
                                                                        <Binding Path="PackageIconFg" Converter="{StaticResource StringToBrushConverter}"/>
                                                                    </TextBlock.Foreground>
                                                                </TextBlock>
                                                            </Border>
                                                            <TextBlock Text="{Binding PackageName}"
                                                                       FontSize="12.5" VerticalAlignment="Center"
                                                                       Foreground="{DynamicResource PrimaryText}"
                                                                       TextTrimming="CharacterEllipsis"/>
                                                        </StackPanel>
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                            </DataGridTemplateColumn>

                                            <DataGridTextColumn Header="Plan"      Binding="{Binding PlanName}"        Width="110"/>
                                            <DataGridTextColumn Header="Licenses"  Binding="{Binding NumberOfLicense}" Width="75"/>
                                            <DataGridTextColumn Header="Used"      Binding="{Binding LicenseUsed}"     Width="60"/>
                                            <DataGridTextColumn Header="Remaining" Binding="{Binding LicenseRemaining}" Width="85"/>

                                            <!-- Auto Renew: green tick or dash -->
                                            <DataGridTemplateColumn Header="Auto Renew" Width="85">
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <TextBlock Text="{Binding AutoRenewLabel}"
                                                                   FontWeight="Bold" FontSize="14"
                                                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                                                   Foreground="#7C3AED"/>
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                            </DataGridTemplateColumn>

                                            <DataGridTextColumn Header="Starts"  Binding="{Binding StartFormatted}"  Width="105"/>
                                            <DataGridTextColumn Header="Expires" Binding="{Binding ExpiryFormatted}" Width="105"/>

                                            <!-- Status: light background + coloured text -->
                                            <DataGridTemplateColumn Header="Status" Width="95">
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <Border CornerRadius="12" Padding="10,4"
                                                                HorizontalAlignment="Left" Margin="2,3"
                                                                VerticalAlignment="Center">
                                                            <Border.Background>
                                                                <Binding Path="StatusBgColor" Converter="{StaticResource StringToBrushConverter}"/>
                                                            </Border.Background>
                                                            <TextBlock Text="{Binding StatusLabel}"
                                                                       FontWeight="SemiBold" FontSize="11">
                                                                <TextBlock.Foreground>
                                                                    <Binding Path="StatusColor" Converter="{StaticResource StringToBrushConverter}"/>
                                                                </TextBlock.Foreground>
                                                            </TextBlock>
                                                        </Border>
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                            </DataGridTemplateColumn>

                                            <!-- ID: short (first 4 chars), full in tooltip -->
                                            <DataGridTemplateColumn Header="ID" Width="60">
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <TextBlock Text="{Binding IdShort}"
                                                                   FontFamily="Consolas" FontSize="12"
                                                                   VerticalAlignment="Center"
                                                                   Foreground="{DynamicResource HintFg}"
                                                                   ToolTip="{Binding Id}"/>
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                            </DataGridTemplateColumn>
                                        </DataGrid.Columns>
                                    </DataGrid>

                                    <!-- Pagination footer -->
                                    <Border BorderBrush="{DynamicResource CardBorder}" BorderThickness="0,1,0,0"
                                            Padding="14,8" Background="{DynamicResource CardBg}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="8"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="6"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="6"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <!-- Show N rows -->
                                            <TextBlock Grid.Column="0" Text="Show" FontSize="12"
                                                       Foreground="{DynamicResource HintFg}"
                                                       VerticalAlignment="Center"/>
                                            <ComboBox x:Name="SubPageSizeBox" Grid.Column="2"
                                                      Height="28" Width="60" FontSize="12"
                                                      SelectedIndex="0"
                                                      SelectionChanged="SubPageSizeBox_SelectionChanged"
                                                      BorderBrush="{DynamicResource InputBorder}">
                                                <ComboBoxItem Content="25"/>
                                                <ComboBoxItem Content="50"/>
                                                <ComboBoxItem Content="100"/>
                                            </ComboBox>

                                            <!-- Showing X to Y of Z -->
                                            <TextBlock x:Name="SubPagingText" Grid.Column="3"
                                                       Text="Showing 0 entries" FontSize="12"
                                                       Foreground="{DynamicResource HintFg}"
                                                       VerticalAlignment="Center" Margin="12,0"/>

                                            <!-- Prev button -->
                                            <Button x:Name="SubPrevPageBtn" Grid.Column="4"
                                                    Content="‹" Width="30" Height="30"
                                                    FontSize="14" Cursor="Hand"
                                                    BorderThickness="1" BorderBrush="{DynamicResource InputBorder}"
                                                    Background="Transparent" Foreground="{DynamicResource PrimaryText}"
                                                    Click="SubPrevPageBtn_Click">
                                                <Button.Template>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border Background="{TemplateBinding Background}"
                                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                                CornerRadius="6">
                                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter Property="Background" Value="{DynamicResource DarkBtnBg}"/>
                                                            </Trigger>
                                                            <Trigger Property="IsEnabled" Value="False">
                                                                <Setter Property="Opacity" Value="0.4"/>
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Button.Template>
                                            </Button>

                                            <!-- Current page badge -->
                                            <Border Grid.Column="6" Width="30" Height="30" CornerRadius="6"
                                                    Background="#7C3AED">
                                                <TextBlock x:Name="SubPageNumText" Text="1"
                                                           FontSize="12" FontWeight="Bold" Foreground="White"
                                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>

                                            <!-- Next button -->
                                            <Button x:Name="SubNextPageBtn" Grid.Column="8"
                                                    Content="›" Width="30" Height="30"
                                                    FontSize="14" Cursor="Hand"
                                                    BorderThickness="1" BorderBrush="{DynamicResource InputBorder}"
                                                    Background="Transparent" Foreground="{DynamicResource PrimaryText}"
                                                    Click="SubNextPageBtn_Click">
                                                <Button.Template>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border Background="{TemplateBinding Background}"
                                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                                CornerRadius="6">
                                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter Property="Background" Value="{DynamicResource DarkBtnBg}"/>
                                                            </Trigger>
                                                            <Trigger Property="IsEnabled" Value="False">
                                                                <Setter Property="Opacity" Value="0.4"/>
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Button.Template>
                                            </Button>
                                        </Grid>
                                    </Border>
                                </StackPanel>
                            </Border>

                            <!-- Raw debug log (shown after fetch) -->
                            <Border x:Name="SubRawLogCard"
                                    Visibility="Collapsed" Margin="0,10,0,0"
                                    Background="{DynamicResource CodeBg}" CornerRadius="4">
                                <TextBox x:Name="SubRawLogBox"
                                         IsReadOnly="True" TextWrapping="Wrap"
                                         FontFamily="Consolas" FontSize="10"
                                         Background="Transparent"
                                         Foreground="{DynamicResource CodeFg}"
                                         BorderThickness="0" Padding="10,8"
                                         MaxHeight="200" VerticalScrollBarVisibility="Auto">
                                    <TextBox.Template>
                                        <ControlTemplate TargetType="TextBox">
                                            <ScrollViewer x:Name="PART_ContentHost" Background="Transparent"
                                                          Padding="{TemplateBinding Padding}"
                                                          VerticalScrollBarVisibility="{TemplateBinding VerticalScrollBarVisibility}"/>
                                        </ControlTemplate>
                                    </TextBox.Template>
                                </TextBox>
                            </Border>

                            <!-- ── Add Subscription card ─────────────────────────────── -->
                            <Border x:Name="SubAddCard"
                                    Visibility="Collapsed" Margin="0,14,0,0"
                                    Background="{DynamicResource CardBg}"
                                    BorderBrush="{DynamicResource CardBorder}"
                                    BorderThickness="1" CornerRadius="8" Padding="20,16">
                                <StackPanel>
                                    <!-- Header row -->
                                    <Grid Margin="0,0,0,16">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="➕  Add Subscription" FontSize="15" FontWeight="Bold"
                                                   Foreground="{DynamicResource PrimaryText}"/>
                                        <Button Grid.Column="1" Content="✕" Height="28" Width="28"
                                                Cursor="Hand" FontSize="13" BorderThickness="0"
                                                Background="Transparent" Foreground="{DynamicResource HintFg}"
                                                Click="SubAddCancelBtn_Click"/>
                                    </Grid>

                                    <!-- Package + Plan rows (built in code-behind) -->
                                    <Border Margin="0,0,0,12" BorderThickness="1"
                                            BorderBrush="{DynamicResource InputBorder}"
                                            Background="{DynamicResource InputBg}" CornerRadius="4">
                                        <ScrollViewer MaxHeight="200" VerticalScrollBarVisibility="Auto"
                                                      HorizontalScrollBarVisibility="Disabled">
                                            <StackPanel x:Name="SubPackagePlanPanel" Margin="8,6"/>
                                        </ScrollViewer>
                                    </Border>

                                    <!-- Licenses + Start date + Auto-renew -->
                                    <Grid Margin="0,0,0,16">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="120"/>
                                            <ColumnDefinition Width="80"/>
                                            <ColumnDefinition Width="30"/>
                                            <ColumnDefinition Width="120"/>
                                            <ColumnDefinition Width="160"/>
                                            <ColumnDefinition Width="30"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Licenses:" FontSize="13" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource LabelFg}" VerticalAlignment="Center"/>
                                        <TextBox x:Name="SubAddLicensesBox" Grid.Column="1"
                                                 Height="34" Padding="8,0" FontSize="13" Text="1"
                                                 VerticalContentAlignment="Center"
                                                 BorderBrush="{DynamicResource InputBorder}" BorderThickness="1"/>
                                        <TextBlock Grid.Column="2"/>
                                        <TextBlock Grid.Column="3" Text="Starts On:" FontSize="13" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource LabelFg}" VerticalAlignment="Center"/>
                                        <DatePicker x:Name="SubAddStartDatePicker" Grid.Column="4"
                                                    Height="34" FontSize="13"
                                                    BorderBrush="{DynamicResource InputBorder}" BorderThickness="1"/>
                                        <TextBlock Grid.Column="5"/>
                                        <TextBlock Grid.Column="6" Text="Auto-Renew:" FontSize="13" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource LabelFg}" VerticalAlignment="Center"
                                                   Margin="0,0,8,0"/>
                                        <CheckBox x:Name="SubAddAutoRenewChk" Grid.Column="7"
                                                  VerticalAlignment="Center" IsChecked="True"/>
                                    </Grid>

                                    <!-- Place Order button + status -->
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="12"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Button x:Name="SubPlaceOrderBtn" Grid.Column="0"
                                                Content="✓  Place Order" Height="36" Padding="20,0"
                                                FontSize="13" FontWeight="SemiBold" Cursor="Hand" BorderThickness="0"
                                                Background="#17A34A" Foreground="White"
                                                Click="SubPlaceOrderBtn_Click">
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <Border Background="{TemplateBinding Background}" CornerRadius="4"
                                                            Padding="{TemplateBinding Padding}">
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="Background" Value="#6D28D9"/>
                                                        </Trigger>
                                                        <Trigger Property="IsEnabled" Value="False">
                                                            <Setter Property="Background" Value="#86EFAC"/>
                                                            <Setter Property="Foreground" Value="#4C1D95"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Button.Template>
                                        </Button>
                                        <TextBlock x:Name="SubAddStatus" Grid.Column="2"
                                                   FontSize="12" VerticalAlignment="Center"
                                                   Foreground="{DynamicResource SubText}" TextWrapping="Wrap"/>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <!-- Change Expiry form (shown when row selected) -->
                            <Border x:Name="SubChangeExpiryCard"
                                    Visibility="Collapsed" Margin="0,14,0,0"
                                    Background="{DynamicResource CardBg}"
                                    BorderBrush="{DynamicResource InfoBannerBorder}"
                                    BorderThickness="1" CornerRadius="8" Padding="18,14">
                                <StackPanel>
                                    <TextBlock Text="Change Expiry Date" FontSize="14" FontWeight="SemiBold"
                                               Foreground="{DynamicResource PrimaryText}" Margin="0,0,0,12"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="10"/>
                                            <ColumnDefinition Width="160"/>
                                            <ColumnDefinition Width="16"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="10"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="16"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="New Expiry:" FontSize="13" FontWeight="SemiBold"
                                                   VerticalAlignment="Center" Foreground="{DynamicResource LabelFg}"/>
                                        <DatePicker x:Name="SubNewExpiryPicker" Grid.Column="2"
                                                    Height="34" FontSize="13"
                                                    BorderBrush="{DynamicResource InputBorder}" BorderThickness="1"/>
                                        <TextBlock Grid.Column="4" Text="Auto Renew:" FontSize="13" FontWeight="SemiBold"
                                                   VerticalAlignment="Center" Foreground="{DynamicResource LabelFg}"/>
                                        <CheckBox x:Name="SubAutoRenewChk" Grid.Column="6"
                                                  VerticalAlignment="Center"
                                                  Foreground="{DynamicResource LabelFg}"/>
                                        <Button x:Name="SubSaveExpiryBtn" Grid.Column="8"
                                                Content="✓  Save" Height="34" Padding="16,0"
                                                FontSize="13" FontWeight="SemiBold" Cursor="Hand"
                                                BorderThickness="0" Background="#17A34A" Foreground="White"
                                                Click="SubSaveExpiryBtn_Click">
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <Border Background="{TemplateBinding Background}" CornerRadius="4"
                                                            Padding="{TemplateBinding Padding}">
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="Background" Value="#6D28D9"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Button.Template>
                                        </Button>
                                    </Grid>
                                    <TextBlock x:Name="SubChangeExpiryStatus"
                                               FontSize="12" Foreground="{DynamicResource SubText}"
                                               Margin="0,10,0,0" TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>

                            <!-- ── Assign Users card ─────────────────────────────────── -->
                            <Border x:Name="SubAssignCard"
                                    Visibility="Collapsed" Margin="0,14,0,0"
                                    Background="{DynamicResource CardBg}"
                                    BorderBrush="{DynamicResource CardBorder}"
                                    BorderThickness="1" CornerRadius="8" Padding="18,14">
                                <StackPanel>
                                    <!-- Header -->
                                    <Grid Margin="0,0,0,12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="8"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock x:Name="SubAssignTitle"
                                                   Text="👤  Assign Users"
                                                   FontSize="14" FontWeight="Bold"
                                                   Foreground="{DynamicResource PrimaryText}"
                                                   VerticalAlignment="Center"/>
                                        <TextBlock x:Name="SubAssignCountText"
                                                   Grid.Column="1"
                                                   FontSize="12" VerticalAlignment="Center"
                                                   Foreground="{DynamicResource HintFg}"/>
                                        <Button Grid.Column="3" Content="✕" Height="26" Width="26"
                                                Cursor="Hand" FontSize="13" BorderThickness="0"
                                                Background="Transparent" Foreground="{DynamicResource HintFg}"
                                                Click="SubAssignCancelBtn_Click"/>
                                    </Grid>

                                    <!-- Users list with checkboxes -->
                                    <Border BorderBrush="{DynamicResource InputBorder}" BorderThickness="1"
                                            CornerRadius="4" Margin="0,0,0,12"
                                            Background="{DynamicResource CardBg}">
                                        <ScrollViewer VerticalScrollBarVisibility="Auto"
                                                      MaxHeight="300" Padding="0">
                                            <ItemsControl x:Name="SubAssignUsersList"
                                                          Background="Transparent">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border Padding="10,6"
                                                                BorderBrush="{DynamicResource SeparatorFg}" BorderThickness="0,0,0,1">
                                                            <CheckBox IsChecked="{Binding IsAssigned, Mode=TwoWay}"
                                                                      Content="{Binding DisplayName}"
                                                                      FontSize="12.5"
                                                                      Foreground="{DynamicResource PrimaryText}"
                                                                      VerticalContentAlignment="Center"/>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </ScrollViewer>
                                    </Border>

                                    <!-- Footer: Save + status -->
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="12"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Button x:Name="SubSaveAssignBtn"
                                                Content="✓  Save Assignments" Height="34" Padding="18,0"
                                                FontSize="13" FontWeight="SemiBold" Cursor="Hand"
                                                BorderThickness="0" Background="#7C3AED" Foreground="White"
                                                Click="SubSaveAssignBtn_Click">
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <Border Background="{TemplateBinding Background}" CornerRadius="4"
                                                            Padding="{TemplateBinding Padding}">
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="Background" Value="#6D28D9"/>
                                                        </Trigger>
                                                        <Trigger Property="IsEnabled" Value="False">
                                                            <Setter Property="Background" Value="#DDD6FE"/>
                                                            <Setter Property="Foreground" Value="#4C1D95"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Button.Template>
                                        </Button>
                                        <TextBlock x:Name="SubAssignStatus" Grid.Column="2"
                                                   FontSize="12" VerticalAlignment="Center"
                                                   Foreground="{DynamicResource SubText}" TextWrapping="Wrap"/>
                                    </Grid>
                                </StackPanel>
                            </Border>

                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <!-- Tab 18: Fiddler / Traffic Inspector -->
                <TabItem x:Name="TabItem18" Header="🔎  Fiddler"         Visibility="Collapsed">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>  <!-- Proxy card -->
                            <RowDefinition Height="Auto"/>  <!-- Toolbar -->
                            <RowDefinition Height="*"/>     <!-- Sessions + Detail split -->
                        </Grid.RowDefinitions>

                        <!-- ── Proxy / Fiddler setup card ── -->
                        <Border Grid.Row="0"
                                Background="{DynamicResource InfoBannerBg}"
                                BorderBrush="{DynamicResource InfoBannerBorder}"
                                BorderThickness="0,0,0,1" Padding="16,10">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="16"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <!-- Setup hint -->
                                    <TextBlock FontSize="11" FontWeight="SemiBold"
                                               Foreground="{DynamicResource InfoBannerTitleFg}"
                                               Margin="0,0,0,3">
                                        Fiddler Classic setup (one-time):
                                    </TextBlock>
                                    <TextBlock FontSize="11" Foreground="{DynamicResource InfoBannerTextFg}"
                                               TextWrapping="Wrap" Margin="0,0,0,8">
                                        1. Open Fiddler → Tools → Options → HTTPS tab&#x0a;2. Check ✅ "Decrypt HTTPS traffic" → trust the certificate&#x0a;3. Start Fiddler, enable proxy below, then make any API call
                                    </TextBlock>

                                    <!-- Enable checkbox -->
                                    <CheckBox x:Name="FiddlerTabProxyEnabledChk"
                                              Content="Enable proxy / Fiddler capture"
                                              FontSize="12" FontWeight="SemiBold"
                                              Foreground="{DynamicResource PrimaryText}"
                                              Margin="0,0,0,8"
                                              Checked="FiddlerTabProxy_Changed"
                                              Unchecked="FiddlerTabProxy_Changed"/>

                                    <!-- Proxy URL row -->
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="Proxy URL:" FontSize="12" FontWeight="SemiBold"
                                                   VerticalAlignment="Center" Foreground="{DynamicResource LabelFg}"
                                                   Margin="0,0,10,0"/>
                                        <TextBox x:Name="FiddlerTabProxyUrlBox"
                                                 Width="260" Height="30" Padding="8,0" FontFamily="Consolas"
                                                 FontSize="12" VerticalContentAlignment="Center"
                                                 Text="http://localhost:8888"
                                                 BorderBrush="{DynamicResource InputBorder}" BorderThickness="1"
                                                 LostFocus="FiddlerTabProxy_Changed"/>
                                        <Button Content="Fiddler" Height="30" Padding="12,0" FontSize="12"
                                                Cursor="Hand" Margin="6,0,0,0"
                                                BorderBrush="{DynamicResource InputBorder}" BorderThickness="1"
                                                Background="{DynamicResource DarkBtnBg}"
                                                Foreground="{DynamicResource PrimaryText}"
                                                Click="FiddlerTabPreset_Click"
                                                ToolTip="Set to Fiddler default: http://localhost:8888"/>
                                    </StackPanel>

                                    <!-- Bypass local -->
                                    <CheckBox x:Name="FiddlerTabBypassLocalChk"
                                              Content="Bypass proxy for local addresses (localhost, 127.*)"
                                              FontSize="11" Foreground="{DynamicResource SubLabelFg}"
                                              Margin="0,6,0,0"
                                              Checked="FiddlerTabProxy_Changed"
                                              Unchecked="FiddlerTabProxy_Changed"/>
                                </StackPanel>

                                <!-- Status badge -->
                                <Border Grid.Column="2" CornerRadius="6" Padding="14,10" MinWidth="280"
                                        Background="{DynamicResource CardBg}"
                                        BorderBrush="{DynamicResource CardBorder}" BorderThickness="1"
                                        VerticalAlignment="Center">
                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                            <TextBlock x:Name="FiddlerTabStatusDot" Text="⬤ " FontSize="13"
                                                       Foreground="#64748B" VerticalAlignment="Center"/>
                                            <TextBlock x:Name="FiddlerTabStatusText"
                                                       Text="Proxy disabled"
                                                       FontSize="12" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource PrimaryText}"
                                                       VerticalAlignment="Center"/>
                                        </StackPanel>
                                        <TextBlock x:Name="FiddlerTabStatusDetail"
                                                   Text="Traffic goes directly to APIs"
                                                   FontSize="11" Foreground="{DynamicResource SubText}"
                                                   TextWrapping="Wrap"/>
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </Border>

                        <!-- ── Toolbar ── -->
                        <Border Grid.Row="1" Background="{DynamicResource KpiHeaderBg}"
                                BorderBrush="{DynamicResource CardBorder}" BorderThickness="0,0,0,1"
                                Padding="10,6">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="6"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="6"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="6"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="16"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="6"/>
                                    <ColumnDefinition Width="160"/>
                                    <ColumnDefinition Width="6"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <!-- Clear -->
                                <Button Grid.Column="0" x:Name="FiddlerClearBtn"
                                        Content="🗑  Clear" Height="28" Padding="12,0" FontSize="11"
                                        Cursor="Hand" Click="FiddlerClearBtn_Click"
                                        ToolTip="Clear all captured sessions (Ctrl+X)"/>

                                <!-- Pause/Resume -->
                                <Button Grid.Column="2" x:Name="FiddlerPauseBtn"
                                        Content="⏸  Pause" Height="28" Padding="12,0" FontSize="11"
                                        Cursor="Hand" Click="FiddlerPauseBtn_Click"
                                        ToolTip="Pause / resume traffic capture"/>

                                <!-- Save -->
                                <Button Grid.Column="4" x:Name="FiddlerSaveBtn"
                                        Content="💾  Save" Height="28" Padding="12,0" FontSize="11"
                                        Cursor="Hand" Click="FiddlerSaveBtn_Click"
                                        ToolTip="Export all sessions to a .txt file"/>

                                <!-- Statistics -->
                                <TextBlock Grid.Column="6" x:Name="FiddlerStatsText"
                                           FontSize="11" Foreground="{DynamicResource SubLabelFg}"
                                           VerticalAlignment="Center"/>

                                <!-- Separator -->
                                <Border Grid.Column="7" Width="1" Background="{DynamicResource SeparatorFg}"
                                        Margin="4,4"/>

                                <!-- Filter label -->
                                <TextBlock Grid.Column="8" Text="Filter:" FontSize="11"
                                           Foreground="{DynamicResource LabelFg}" VerticalAlignment="Center"/>

                                <!-- Filter box -->
                                <TextBox x:Name="FiddlerFilterBox" Grid.Column="10"
                                         Height="26" Padding="6,0" FontSize="11"
                                         VerticalContentAlignment="Center"
                                         BorderBrush="{DynamicResource InputBorder}" BorderThickness="1"
                                         ToolTip="Filter by host, URL, method, status or source — e.g. 'payrix' or '200'"
                                         TextChanged="FiddlerFilterBox_TextChanged"/>

                                <!-- Clear filter -->
                                <Button Grid.Column="12" Content="✕" Height="26" Width="26"
                                        FontSize="11" Cursor="Hand" Padding="0"
                                        Click="FiddlerClearFilter_Click"
                                        ToolTip="Clear filter"/>

                                <!-- Session count -->
                                <TextBlock Grid.Column="14" x:Name="FiddlerSessionCountText"
                                           FontSize="11" Foreground="{DynamicResource HintFg}"
                                           VerticalAlignment="Center" HorizontalAlignment="Right"/>
                            </Grid>
                        </Border>

                        <!-- ── Sessions + Detail ── -->
                        <Grid Grid.Row="2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="420" MinWidth="200"/>
                                <ColumnDefinition Width="4"/>
                                <ColumnDefinition Width="*" MinWidth="300"/>
                            </Grid.ColumnDefinitions>

                            <!-- ── Session list (left) ── -->
                            <DataGrid x:Name="FiddlerSessionGrid" Grid.Column="0"
                                      AutoGenerateColumns="False" IsReadOnly="True"
                                      CanUserResizeColumns="True"
                                      GridLinesVisibility="Horizontal"
                                      HeadersVisibility="Column"
                                      BorderThickness="0"
                                      SelectionUnit="FullRow" SelectionMode="Single"
                                      HorizontalScrollBarVisibility="Auto"
                                      VerticalScrollBarVisibility="Auto"
                                      FontSize="11.5"
                                      SelectionChanged="FiddlerSessionGrid_SelectionChanged">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="#"       Binding="{Binding SessionId}" Width="36"  CanUserSort="True"/>
                                    <DataGridTemplateColumn Header="Res" Width="42" CanUserSort="True" SortMemberPath="Result">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding ResultLabel}" FontWeight="Bold" Padding="4,0"
                                                           Foreground="{Binding ResultColor,
                                                               Converter={StaticResource StringToBrushConverter}}"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTextColumn Header="Method"  Binding="{Binding Method}"  Width="54"/>
                                    <DataGridTextColumn Header="Host"    Binding="{Binding Host}"    Width="130"/>
                                    <DataGridTextColumn Header="URL"     Binding="{Binding Url}"     Width="200"/>
                                    <DataGridTextColumn Header="Body"    Binding="{Binding BodySizeLabel}" Width="60"/>
                                    <DataGridTextColumn Header="ms"      Binding="{Binding DurationLabel}" Width="65"/>
                                    <DataGridTextColumn Header="Source"  Binding="{Binding Source}"  Width="120"/>
                                </DataGrid.Columns>
                            </DataGrid>

                            <!-- Splitter -->
                            <GridSplitter Grid.Column="1" Width="4"
                                          HorizontalAlignment="Stretch"
                                          Background="{DynamicResource SeparatorFg}"/>

                            <!-- ── Detail panes (right) ── -->
                            <Grid Grid.Column="2">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*" MinHeight="120"/>
                                    <RowDefinition Height="4"/>
                                    <RowDefinition Height="*" MinHeight="120"/>
                                </Grid.RowDefinitions>

                                <!-- REQUEST detail -->
                                <Border Grid.Row="0" BorderBrush="{DynamicResource CardBorder}"
                                        BorderThickness="1,0,0,0">
                                    <TabControl BorderThickness="0" Background="Transparent">
                                        <TabItem>
                                            <TabItem.Header>
                                                <TextBlock Text="▲ Headers" FontWeight="SemiBold" FontSize="11"
                                                           Foreground="{DynamicResource TabSelectedFg}"/>
                                            </TabItem.Header>
                                            <Border Background="{DynamicResource CodeBg}">
                                                <TextBox x:Name="FiddlerReqHeadersBox"
                                                         IsReadOnly="True" TextWrapping="NoWrap"
                                                         FontFamily="Consolas" FontSize="11"
                                                         Background="Transparent"
                                                         Foreground="{DynamicResource CodeFg}"
                                                         BorderThickness="0" Padding="8,6"
                                                         VerticalScrollBarVisibility="Auto"
                                                         HorizontalScrollBarVisibility="Auto">
                                                    <TextBox.Template>
                                                        <ControlTemplate TargetType="TextBox">
                                                            <ScrollViewer x:Name="PART_ContentHost" Background="Transparent"
                                                                          Padding="{TemplateBinding Padding}"
                                                                          VerticalScrollBarVisibility="{TemplateBinding VerticalScrollBarVisibility}"
                                                                          HorizontalScrollBarVisibility="{TemplateBinding HorizontalScrollBarVisibility}"/>
                                                        </ControlTemplate>
                                                    </TextBox.Template>
                                                </TextBox>
                                            </Border>
                                        </TabItem>
                                        <TabItem Header="Raw">
                                            <Border Background="{DynamicResource CodeBg}">
                                                <TextBox x:Name="FiddlerReqRawBox"
                                                         IsReadOnly="True" TextWrapping="NoWrap"
                                                         FontFamily="Consolas" FontSize="11"
                                                         Background="Transparent"
                                                         Foreground="{DynamicResource CodeFg}"
                                                         BorderThickness="0" Padding="8,6"
                                                         VerticalScrollBarVisibility="Auto"
                                                         HorizontalScrollBarVisibility="Auto">
                                                    <TextBox.Template>
                                                        <ControlTemplate TargetType="TextBox">
                                                            <ScrollViewer x:Name="PART_ContentHost" Background="Transparent"
                                                                          Padding="{TemplateBinding Padding}"
                                                                          VerticalScrollBarVisibility="{TemplateBinding VerticalScrollBarVisibility}"
                                                                          HorizontalScrollBarVisibility="{TemplateBinding HorizontalScrollBarVisibility}"/>
                                                        </ControlTemplate>
                                                    </TextBox.Template>
                                                </TextBox>
                                            </Border>
                                        </TabItem>
                                        <TabItem Header="JSON">
                                            <Border Background="{DynamicResource CodeBg}">
                                                <TextBox x:Name="FiddlerReqJsonBox"
                                                         IsReadOnly="True" TextWrapping="NoWrap"
                                                         FontFamily="Consolas" FontSize="11"
                                                         Background="Transparent"
                                                         Foreground="{DynamicResource CodeFg}"
                                                         BorderThickness="0" Padding="8,6"
                                                         VerticalScrollBarVisibility="Auto"
                                                         HorizontalScrollBarVisibility="Auto">
                                                    <TextBox.Template>
                                                        <ControlTemplate TargetType="TextBox">
                                                            <ScrollViewer x:Name="PART_ContentHost" Background="Transparent"
                                                                          Padding="{TemplateBinding Padding}"
                                                                          VerticalScrollBarVisibility="{TemplateBinding VerticalScrollBarVisibility}"
                                                                          HorizontalScrollBarVisibility="{TemplateBinding HorizontalScrollBarVisibility}"/>
                                                        </ControlTemplate>
                                                    </TextBox.Template>
                                                </TextBox>
                                            </Border>
                                        </TabItem>
                                    </TabControl>
                                </Border>

                                <!-- Splitter -->
                                <GridSplitter Grid.Row="1" Height="4" HorizontalAlignment="Stretch"
                                              Background="{DynamicResource SeparatorFg}"/>

                                <!-- RESPONSE detail -->
                                <Border Grid.Row="2" BorderBrush="{DynamicResource CardBorder}"
                                        BorderThickness="1,0,0,0">
                                    <TabControl BorderThickness="0" Background="Transparent">
                                        <TabItem>
                                            <TabItem.Header>
                                                <TextBlock Text="▼ Headers" FontWeight="SemiBold" FontSize="11"
                                                           Foreground="{DynamicResource TabSelectedFg}"/>
                                            </TabItem.Header>
                                            <Border Background="{DynamicResource CodeBg}">
                                                <TextBox x:Name="FiddlerRespHeadersBox"
                                                         IsReadOnly="True" TextWrapping="NoWrap"
                                                         FontFamily="Consolas" FontSize="11"
                                                         Background="Transparent"
                                                         Foreground="{DynamicResource CodeFg}"
                                                         BorderThickness="0" Padding="8,6"
                                                         VerticalScrollBarVisibility="Auto"
                                                         HorizontalScrollBarVisibility="Auto">
                                                    <TextBox.Template>
                                                        <ControlTemplate TargetType="TextBox">
                                                            <ScrollViewer x:Name="PART_ContentHost" Background="Transparent"
                                                                          Padding="{TemplateBinding Padding}"
                                                                          VerticalScrollBarVisibility="{TemplateBinding VerticalScrollBarVisibility}"
                                                                          HorizontalScrollBarVisibility="{TemplateBinding HorizontalScrollBarVisibility}"/>
                                                        </ControlTemplate>
                                                    </TextBox.Template>
                                                </TextBox>
                                            </Border>
                                        </TabItem>
                                        <TabItem Header="Raw">
                                            <Border Background="{DynamicResource CodeBg}">
                                                <TextBox x:Name="FiddlerRespRawBox"
                                                         IsReadOnly="True" TextWrapping="NoWrap"
                                                         FontFamily="Consolas" FontSize="11"
                                                         Background="Transparent"
                                                         Foreground="{DynamicResource CodeFg}"
                                                         BorderThickness="0" Padding="8,6"
                                                         VerticalScrollBarVisibility="Auto"
                                                         HorizontalScrollBarVisibility="Auto">
                                                    <TextBox.Template>
                                                        <ControlTemplate TargetType="TextBox">
                                                            <ScrollViewer x:Name="PART_ContentHost" Background="Transparent"
                                                                          Padding="{TemplateBinding Padding}"
                                                                          VerticalScrollBarVisibility="{TemplateBinding VerticalScrollBarVisibility}"
                                                                          HorizontalScrollBarVisibility="{TemplateBinding HorizontalScrollBarVisibility}"/>
                                                        </ControlTemplate>
                                                    </TextBox.Template>
                                                </TextBox>
                                            </Border>
                                        </TabItem>
                                        <TabItem Header="JSON / XML">
                                            <Border Background="{DynamicResource CodeBg}">
                                                <TextBox x:Name="FiddlerRespJsonBox"
                                                         IsReadOnly="True" TextWrapping="NoWrap"
                                                         FontFamily="Consolas" FontSize="11"
                                                         Background="Transparent"
                                                         Foreground="{DynamicResource CodeFg}"
                                                         BorderThickness="0" Padding="8,6"
                                                         VerticalScrollBarVisibility="Auto"
                                                         HorizontalScrollBarVisibility="Auto">
                                                    <TextBox.Template>
                                                        <ControlTemplate TargetType="TextBox">
                                                            <ScrollViewer x:Name="PART_ContentHost" Background="Transparent"
                                                                          Padding="{TemplateBinding Padding}"
                                                                          VerticalScrollBarVisibility="{TemplateBinding VerticalScrollBarVisibility}"
                                                                          HorizontalScrollBarVisibility="{TemplateBinding HorizontalScrollBarVisibility}"/>
                                                        </ControlTemplate>
                                                    </TextBox.Template>
                                                </TextBox>
                                            </Border>
                                        </TabItem>
                                        <TabItem Header="Cookies">
                                            <Border Background="{DynamicResource CodeBg}">
                                                <TextBox x:Name="FiddlerRespCookiesBox"
                                                         IsReadOnly="True" TextWrapping="Wrap"
                                                         FontFamily="Consolas" FontSize="11"
                                                         Background="Transparent"
                                                         Foreground="{DynamicResource CodeFg}"
                                                         BorderThickness="0" Padding="8,6"
                                                         VerticalScrollBarVisibility="Auto">
                                                    <TextBox.Template>
                                                        <ControlTemplate TargetType="TextBox">
                                                            <ScrollViewer x:Name="PART_ContentHost" Background="Transparent"
                                                                          Padding="{TemplateBinding Padding}"
                                                                          VerticalScrollBarVisibility="{TemplateBinding VerticalScrollBarVisibility}"/>
                                                        </ControlTemplate>
                                                    </TextBox.Template>
                                                </TextBox>
                                            </Border>
                                        </TabItem>
                                        <TabItem Header="Auth">
                                            <Border Background="{DynamicResource CodeBg}">
                                                <TextBox x:Name="FiddlerRespAuthBox"
                                                         IsReadOnly="True" TextWrapping="Wrap"
                                                         FontFamily="Consolas" FontSize="11"
                                                         Background="Transparent"
                                                         Foreground="{DynamicResource CodeFg}"
                                                         BorderThickness="0" Padding="8,6"
                                                         VerticalScrollBarVisibility="Auto">
                                                    <TextBox.Template>
                                                        <ControlTemplate TargetType="TextBox">
                                                            <ScrollViewer x:Name="PART_ContentHost" Background="Transparent"
                                                                          Padding="{TemplateBinding Padding}"
                                                                          VerticalScrollBarVisibility="{TemplateBinding VerticalScrollBarVisibility}"/>
                                                        </ControlTemplate>
                                                    </TextBox.Template>
                                                </TextBox>
                                            </Border>
                                        </TabItem>
                                        <TabItem Header="Timeline">
                                            <Border Background="{DynamicResource CardBg}" Padding="12">
                                                <StackPanel>
                                                    <TextBlock x:Name="FiddlerTimelineBox"
                                                               FontFamily="Consolas" FontSize="11"
                                                               Foreground="{DynamicResource CodeFg}"
                                                               TextWrapping="Wrap"/>
                                                </StackPanel>
                                            </Border>
                                        </TabItem>
                                    </TabControl>
                                </Border>
                            </Grid>
                        </Grid>
                    </Grid>
                </TabItem>

                <!-- Tab 19: Core DB Utility -->
                <TabItem x:Name="TabItem19" Header="🗄  Core DB"         Visibility="Collapsed">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- ── Toolbar ── -->
                        <Border Grid.Row="0" Padding="20,12"
                                BorderBrush="{DynamicResource CardBorder}" BorderThickness="0,0,0,1"
                                Background="{DynamicResource CardBg}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="Core DB Utility" FontSize="18" FontWeight="Bold"
                                               Foreground="{DynamicResource PrimaryText}"/>
                                    <TextBlock Text="Connect, restore, and manage BQE CORE databases"
                                               FontSize="11.5" Foreground="{DynamicResource SubText}"/>
                                </StackPanel>
                                <TextBlock Grid.Column="1" x:Name="CoreDbStatusText"
                                           FontSize="11.5" Foreground="{DynamicResource SubText}"
                                           VerticalAlignment="Center"/>
                            </Grid>
                        </Border>

                        <!-- ── Body ── -->
                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled">
                            <StackPanel Margin="24,20">

                                <!-- ══ Two-column card row ══ -->
                                <Grid Margin="0,0,0,16">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="16"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- ── Left card: Core Host Database ── -->
                                    <Border Grid.Column="0"
                                            Background="{DynamicResource CardBg}" CornerRadius="12"
                                            BorderBrush="{DynamicResource CardBorder}" BorderThickness="1"
                                            Padding="20,18"
                                            ToolTip="BQECoreHost SQL Server — the master registry that stores all company database mappings">
                                        <StackPanel>

                                            <!-- Header -->
                                            <Grid Margin="0,0,0,16">
                                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                    <TextBlock Text="🗄" FontSize="16" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                                    <TextBlock Text="CORE HOST DATABASE" FontSize="11" FontWeight="Bold"
                                                               Foreground="{DynamicResource SubText}" VerticalAlignment="Center"
                                                               />
                                                </StackPanel>
                                                <Button Content="↺  Reset" HorizontalAlignment="Right" VerticalAlignment="Center"
                                                        Height="26" Padding="10,0" FontSize="11"
                                                        Style="{StaticResource SecondaryButton}"
                                                        ToolTip="Clear all Host DB fields and disconnect"
                                                        Click="ResetHostDb_Click"/>
                                            </Grid>

                                            <!-- Server -->
                                            <Grid Margin="0,0,0,10">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="80"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="36"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="Server" FontSize="12.5" VerticalAlignment="Center"
                                                           Foreground="{DynamicResource SubText}"/>
                                                <ComboBox x:Name="HostServerBox" Grid.Column="1" Height="36"
                                                          IsEditable="True" FontSize="12.5"
                                                          Text="KFWSHAVAK\SQL2022"
                                                          BorderBrush="{DynamicResource InputBorder}"
                                                          SelectionChanged="HostServerBox_SelectionChanged"
                                                          LostFocus="HostServerBox_LostFocus"/>
                                                <Button Grid.Column="2" Content="⟳" Width="30" Height="36" Margin="6,0,0,0"
                                                        FontSize="14" ToolTip="Scan for local SQL Server instances"
                                                        Click="RefreshHostServers_Click"/>
                                            </Grid>

                                            <!-- User ID -->
                                            <Grid Margin="0,0,0,10">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="80"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="User ID" FontSize="12.5" VerticalAlignment="Center"
                                                           Foreground="{DynamicResource SubText}"/>
                                                <TextBox x:Name="HostUserBox" Grid.Column="1" Height="36"
                                                         Padding="10,0" VerticalContentAlignment="Center"
                                                         FontSize="12.5" Text="sa"
                                                         BorderBrush="{DynamicResource InputBorder}" BorderThickness="1"/>
                                            </Grid>

                                            <!-- Password with eye toggle -->
                                            <Grid Margin="0,0,0,10">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="80"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="Password" FontSize="12.5" VerticalAlignment="Center"
                                                           Foreground="{DynamicResource SubText}"/>
                                                <Grid Grid.Column="1">
                                                    <PasswordBox x:Name="HostPasswordBox" Height="36"
                                                                 Padding="10,0,36,0" VerticalContentAlignment="Center"
                                                                 FontSize="12.5"
                                                                 BorderBrush="{DynamicResource InputBorder}" BorderThickness="1"
                                                                 KeyDown="HostPasswordBox_KeyDown"/>
                                                    <TextBox x:Name="HostPasswordVisible" Height="36"
                                                             Padding="10,0,36,0" VerticalContentAlignment="Center"
                                                             FontSize="12.5" Visibility="Collapsed"
                                                             BorderBrush="{DynamicResource InputBorder}" BorderThickness="1"/>
                                                    <Button x:Name="HostPasswordEyeBtn"
                                                            Content="👁" Width="30" Height="30"
                                                            HorizontalAlignment="Right" VerticalAlignment="Center"
                                                            Margin="0,0,3,0" FontSize="13"
                                                            Background="Transparent" BorderThickness="0" Cursor="Hand"
                                                            Click="HostPasswordEye_Click"/>
                                                </Grid>
                                            </Grid>

                                            <!-- Database -->
                                            <Grid Margin="0,0,0,16">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="80"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="36"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="Database" FontSize="12.5" VerticalAlignment="Center"
                                                           Foreground="{DynamicResource SubText}"/>
                                                <ComboBox x:Name="HostDatabaseBox" Grid.Column="1" Height="36"
                                                          IsEditable="True" FontSize="12.5"
                                                          Text="BQECoreHost"
                                                          BorderBrush="{DynamicResource InputBorder}"/>
                                                <Button Grid.Column="2" Content="⟳" Width="30" Height="36" Margin="6,0,0,0"
                                                        FontSize="14" ToolTip="Load available databases from this server"
                                                        Click="LoadHostDatabases_Click"/>
                                            </Grid>

                                            <!-- CONNECT button -->
                                            <Button x:Name="ConnectHostBtn" Height="44" FontSize="13" FontWeight="Bold"
                                                    Background="#7C3AED" Foreground="White" BorderThickness="0"
                                                    Cursor="Hand"
                                                    ToolTip="Open a connection to the Host DB"
                                                    Click="ConnectHostDb_Click">
                                                <Button.Template>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border Background="{TemplateBinding Background}" CornerRadius="8"
                                                                Padding="{TemplateBinding Padding}">
                                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter Property="Background" Value="#6D28D9"/>
                                                            </Trigger>
                                                            <Trigger Property="IsEnabled" Value="False">
                                                                <Setter Property="Background" Value="#86EFAC"/>
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Button.Template>
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="🔌" FontSize="14" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                                    <TextBlock Text="CONNECT" FontSize="13" FontWeight="Bold" VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </Button>

                                            <!-- Status badge -->
                                            <Border x:Name="HostStatusBadge" Visibility="Collapsed"
                                                    CornerRadius="6" Padding="10,5" Margin="0,10,0,0"
                                                    HorizontalAlignment="Left">
                                                <TextBlock x:Name="HostStatusText" FontSize="12" FontWeight="SemiBold"/>
                                            </Border>

                                            <!-- Info message -->
                                            <Border Background="{DynamicResource EmailSectionBg}" BorderBrush="{DynamicResource EmailSectionBorder}" BorderThickness="1"
                                                    CornerRadius="8" Padding="12,10" Margin="0,12,0,0">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="ℹ" FontSize="14" Foreground="{DynamicResource EmailSectionFg}"
                                                               Margin="0,0,8,0" VerticalAlignment="Center"/>
                                                    <TextBlock Text="This is the main Core Host database."
                                                               FontSize="12" Foreground="{DynamicResource EmailSectionFg}"
                                                               VerticalAlignment="Center" TextWrapping="Wrap"/>
                                                </StackPanel>
                                            </Border>

                                            <!-- Host DB Stats (visible once connected) -->
                                            <Border x:Name="HostStatsPanel" Visibility="Collapsed" Margin="0,12,0,0">
                                                <UniformGrid Columns="4">
                                                    <Border Background="{DynamicResource SidebarBg}" CornerRadius="8"
                                                            Padding="12,10" Margin="0,0,6,0">
                                                        <StackPanel>
                                                            <TextBlock x:Name="HostStatTotal" Text="—"
                                                                       FontSize="22" FontWeight="Bold" Foreground="#7C3AED"/>
                                                            <TextBlock Text="Total DBs" FontSize="10"
                                                                       Foreground="{DynamicResource SubText}" Margin="0,2,0,0"/>
                                                        </StackPanel>
                                                    </Border>
                                                    <Border Background="{DynamicResource SidebarBg}" CornerRadius="8"
                                                            Padding="12,10" Margin="3,0,3,0">
                                                        <StackPanel>
                                                            <TextBlock x:Name="HostStatActive" Text="—"
                                                                       FontSize="22" FontWeight="Bold" Foreground="#A78BFA"/>
                                                            <TextBlock Text="Active" FontSize="10"
                                                                       Foreground="{DynamicResource SubText}" Margin="0,2,0,0"/>
                                                        </StackPanel>
                                                    </Border>
                                                    <Border Background="{DynamicResource SidebarBg}" CornerRadius="8"
                                                            Padding="12,10" Margin="3,0,3,0">
                                                        <StackPanel>
                                                            <TextBlock x:Name="HostStatTrial" Text="—"
                                                                       FontSize="22" FontWeight="Bold" Foreground="#FCD34D"/>
                                                            <TextBlock Text="Trial" FontSize="10"
                                                                       Foreground="{DynamicResource SubText}" Margin="0,2,0,0"/>
                                                        </StackPanel>
                                                    </Border>
                                                    <Border Background="{DynamicResource SidebarBg}" CornerRadius="8"
                                                            Padding="12,10" Margin="6,0,0,0">
                                                        <StackPanel>
                                                            <TextBlock x:Name="HostStatExpired" Text="—"
                                                                       FontSize="22" FontWeight="Bold" Foreground="#EF4444"/>
                                                            <TextBlock Text="Expired" FontSize="10"
                                                                       Foreground="{DynamicResource SubText}" Margin="0,2,0,0"/>
                                                        </StackPanel>
                                                    </Border>
                                                </UniformGrid>
                                            </Border>
                                        </StackPanel>
                                    </Border>

                                    <!-- ── Right card: Core Database ── -->
                                    <Border Grid.Column="2"
                                            Background="{DynamicResource CardBg}" CornerRadius="12"
                                            BorderBrush="{DynamicResource CardBorder}" BorderThickness="1"
                                            Padding="20,18"
                                            ToolTip="The individual company Core database you want to restore, link, or work with">
                                        <StackPanel>

                                            <!-- Header -->
                                            <Grid Margin="0,0,0,4">
                                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                    <TextBlock Text="🗄" FontSize="16" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                                    <TextBlock Text="CORE DATABASE" FontSize="11" FontWeight="Bold"
                                                               Foreground="{DynamicResource SubText}" VerticalAlignment="Center"
                                                               />
                                                </StackPanel>
                                                <Button Grid.Column="1" Content="↺  Reset" HorizontalAlignment="Right" VerticalAlignment="Center"
                                                        Height="26" Padding="10,0" FontSize="11"
                                                        Style="{StaticResource SecondaryButton}"
                                                        ToolTip="Clear all Core DB fields and disconnect"
                                                        Click="ResetCoreDb_Click"/>
                                            </Grid>
                                            <TextBlock Text="The database you want to attach with the Core Host above"
                                                       FontSize="11.5" Foreground="{DynamicResource SubText}"
                                                       Margin="0,0,0,14"/>

                                            <!-- Server -->
                                            <Grid Margin="0,0,0,10">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="80"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="36"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="Server" FontSize="12.5" VerticalAlignment="Center"
                                                           Foreground="{DynamicResource SubText}"/>
                                                <ComboBox x:Name="CoreServerBox" Grid.Column="1" Height="36"
                                                          IsEditable="True" FontSize="12.5"
                                                          Text="KFWSHAVAK\SQL2022"
                                                          BorderBrush="{DynamicResource InputBorder}"/>
                                                <Button Grid.Column="2" Content="⟳" Width="30" Height="36" Margin="6,0,0,0"
                                                        FontSize="14" ToolTip="Scan for local SQL Server instances"
                                                        Click="RefreshCoreServers_Click"/>
                                            </Grid>

                                            <!-- User ID -->
                                            <Grid Margin="0,0,0,10">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="80"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="User ID" FontSize="12.5" VerticalAlignment="Center"
                                                           Foreground="{DynamicResource SubText}"/>
                                                <TextBox x:Name="CoreUserBox" Grid.Column="1" Height="36"
                                                         Padding="10,0" VerticalContentAlignment="Center"
                                                         FontSize="12.5" Text="sa"
                                                         BorderBrush="{DynamicResource InputBorder}" BorderThickness="1"/>
                                            </Grid>

                                            <!-- Password with eye toggle -->
                                            <Grid Margin="0,0,0,10">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="80"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="Password" FontSize="12.5" VerticalAlignment="Center"
                                                           Foreground="{DynamicResource SubText}"/>
                                                <Grid Grid.Column="1">
                                                    <PasswordBox x:Name="CorePasswordBox" Height="36"
                                                                 Padding="10,0,36,0" VerticalContentAlignment="Center"
                                                                 FontSize="12.5"
                                                                 BorderBrush="{DynamicResource InputBorder}" BorderThickness="1"/>
                                                    <TextBox x:Name="CorePasswordVisible" Height="36"
                                                             Padding="10,0,36,0" VerticalContentAlignment="Center"
                                                             FontSize="12.5" Visibility="Collapsed"
                                                             BorderBrush="{DynamicResource InputBorder}" BorderThickness="1"/>
                                                    <Button x:Name="CorePasswordEyeBtn"
                                                            Content="👁" Width="30" Height="30"
                                                            HorizontalAlignment="Right" VerticalAlignment="Center"
                                                            Margin="0,0,3,0" FontSize="13"
                                                            Background="Transparent" BorderThickness="0" Cursor="Hand"
                                                            Click="CorePasswordEye_Click"/>
                                                </Grid>
                                            </Grid>

                                            <!-- Database -->
                                            <Grid Margin="0,0,0,16">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="80"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="36"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="Database" FontSize="12.5" VerticalAlignment="Center"
                                                           Foreground="{DynamicResource SubText}"/>
                                                <ComboBox x:Name="CoreDatabaseBox" Grid.Column="1" Height="36"
                                                          IsEditable="True" FontSize="12.5"
                                                          BorderBrush="{DynamicResource InputBorder}"
                                                          SelectionChanged="CoreDatabaseBox_SelectionChanged"/>
                                                <Button Grid.Column="2" Content="⟳" Width="30" Height="36" Margin="6,0,0,0"
                                                        FontSize="14" ToolTip="Load available databases (excludes system databases)"
                                                        Click="LoadCoreDatabases_Click"/>
                                            </Grid>

                                            <!-- CONNECT button -->
                                            <Button x:Name="ConnectCoreBtn" Height="44" FontSize="13" FontWeight="Bold"
                                                    Background="#7C3AED" Foreground="White" BorderThickness="0"
                                                    Cursor="Hand"
                                                    ToolTip="Connect to the Core database. Unlocks the Actions section."
                                                    Click="ConnectCoreDb_Click">
                                                <Button.Template>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border Background="{TemplateBinding Background}" CornerRadius="8"
                                                                Padding="{TemplateBinding Padding}">
                                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter Property="Background" Value="#6D28D9"/>
                                                            </Trigger>
                                                            <Trigger Property="IsEnabled" Value="False">
                                                                <Setter Property="Background" Value="#86EFAC"/>
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Button.Template>
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="🔌" FontSize="14" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                                    <TextBlock Text="CONNECT" FontSize="13" FontWeight="Bold" VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </Button>

                                            <!-- Status badge -->
                                            <Border x:Name="CoreStatusBadge" Visibility="Collapsed"
                                                    CornerRadius="6" Padding="10,5" Margin="0,10,0,0"
                                                    HorizontalAlignment="Left">
                                                <TextBlock x:Name="CoreStatusText" FontSize="12" FontWeight="SemiBold"/>
                                            </Border>

                                            <!-- Info message -->
                                            <Border Background="{DynamicResource EmailSectionBg}" BorderBrush="{DynamicResource EmailSectionBorder}" BorderThickness="1"
                                                    CornerRadius="8" Padding="12,10" Margin="0,12,0,0">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="ℹ" FontSize="14" Foreground="{DynamicResource EmailSectionFg}"
                                                               Margin="0,0,8,0" VerticalAlignment="Center"/>
                                                    <TextBlock Text="Select or enter the Core database to attach."
                                                               FontSize="12" Foreground="{DynamicResource EmailSectionFg}"
                                                               VerticalAlignment="Center" TextWrapping="Wrap"/>
                                                </StackPanel>
                                            </Border>
                                        </StackPanel>
                                    </Border>
                                </Grid>

                                <!-- ══ Section 3: Actions ══ -->
                                <Border x:Name="CoreActionsCard"
                                        Background="{DynamicResource CardBg}" CornerRadius="12"
                                        BorderBrush="{DynamicResource CardBorder}" BorderThickness="1"
                                        Padding="20,16" Margin="0,0,0,16" IsEnabled="False" Opacity="0.5"
                                        ToolTip="Unlocked after connecting to the Core database in Section 2">
                                    <StackPanel>
                                        <Grid Margin="0,0,0,14">
                                            <TextBlock Text="ACTIONS" FontSize="10.5" FontWeight="Bold"
                                                       Foreground="{DynamicResource SubText}" VerticalAlignment="Center"/>
                                            <Button Content="↺  Reset" HorizontalAlignment="Right"
                                                    Height="24" Padding="8,0" FontSize="11"
                                                    Style="{StaticResource SecondaryButton}"
                                                    ToolTip="Clear the Actions result badge"
                                                    Click="ResetActions_Click"/>
                                        </Grid>

                                        <!-- Restore As New Company -->
                                        <Grid Margin="0,0,0,10">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="220"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="Restore As New Company (Host DB):"
                                                       FontSize="12" VerticalAlignment="Center"
                                                       Foreground="{DynamicResource SubText}" TextWrapping="Wrap"
                                                       ToolTip="Company name to register in the Host DB. Auto-filled from the Core database's CompanyInfo table (format: [DB_ID] CompanyName)."/>
                                            <TextBox x:Name="NewCompanyBox" Grid.Column="1" Height="34"
                                                     Padding="10,0" VerticalContentAlignment="Center" FontSize="12.5"
                                                     ToolTip="Auto-filled with [DB_ID] CompanyName. Edit if you want a different display name in the Host registry."/>
                                        </Grid>

                                        <!-- Account ID / Email -->
                                        <Grid Margin="0,0,0,10">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="220"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="Restore with Account ID (Email ID):"
                                                       FontSize="12" VerticalAlignment="Center"
                                                       Foreground="{DynamicResource SubText}" TextWrapping="Wrap"
                                                       ToolTip="BQE account owner email. Auto-filled from the Host DB. Used to reset admin access on the restored database."/>
                                            <ComboBox x:Name="RestoreEmailBox" Grid.Column="1" Height="34"
                                                      IsEditable="True" IsTextSearchEnabled="False" StaysOpenOnEdit="True"
                                                      FontSize="12.5"
                                                      ToolTip="Auto-filled with eligible Core DB users (Host Account + Security Profile required). Type to search by name, email, or profile."
                                                      DropDownClosed="RestoreEmailBox_DropDownClosed"
                                                      KeyUp="RestoreEmailBox_KeyUp"/>
                                        </Grid>

                                        <!-- CORE Users -->
                                        <Grid Margin="0,0,0,10">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="220"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="CORE Users (make it a Core user):"
                                                       FontSize="12" VerticalAlignment="Center"
                                                       Foreground="{DynamicResource SubText}" TextWrapping="Wrap"
                                                       ToolTip="Comma-separated emails to grant Core user access. Auto-filled with full-access users found in the selected Core database."/>
                                            <ComboBox x:Name="CoreUsersBox" Grid.Column="1" Height="34"
                                                      IsEditable="True" IsTextSearchEnabled="False" StaysOpenOnEdit="True"
                                                      FontSize="12.5"
                                                      ToolTip="Only users with a Host Account ID and Security Profile are listed. Type to search by name, email, or profile."
                                                      DropDownClosed="CoreUsersBox_DropDownClosed"
                                                      KeyUp="CoreUsersBox_KeyUp"/>
                                        </Grid>

                                        <!-- Account Users -->
                                        <Grid Margin="0,0,0,18">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="220"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="Account Users if already attached:"
                                                       FontSize="12" VerticalAlignment="Center"
                                                       Foreground="{DynamicResource SubText}" TextWrapping="Wrap"
                                                       ToolTip="Comma-separated emails of existing users that are already attached to this account. Their IsActive flag will be set to 1."/>
                                            <ComboBox x:Name="AccountUsersBox" Grid.Column="1" Height="34"
                                                      IsEditable="True" IsTextSearchEnabled="False" StaysOpenOnEdit="True"
                                                      FontSize="12.5"
                                                      ToolTip="Only users with a Host Account ID and Security Profile are listed. Type to search by name, email, or profile."
                                                      DropDownClosed="AccountUsersBox_DropDownClosed"
                                                      KeyUp="AccountUsersBox_KeyUp"/>
                                        </Grid>

                                        <!-- Bottom action row -->
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <!-- Left: Extend Expiry + Sanitize DB -->
                                            <StackPanel Grid.Column="0" Orientation="Horizontal">
                                                <Button x:Name="ExtendExpiryBtn" Content="Extend Expiry"
                                                        Height="34" Padding="14,0" FontSize="12.5"
                                                        Background="{DynamicResource DarkBtnBg}"
                                                        Foreground="{DynamicResource PrimaryText}"
                                                        BorderBrush="{DynamicResource CardBorder}" BorderThickness="1"
                                                        ToolTip="Extend ExpiryDate and TrialEndDate in CompanyInfo and LicenseInfo by 90 days"
                                                        Click="ExtendExpiry_Click"/>
                                                <Button x:Name="SanitizeDbBtn" Content="Sanitize DB" Margin="6,0,0,0"
                                                        Height="34" Padding="14,0" FontSize="12.5"
                                                        Background="{DynamicResource DarkBtnBg}"
                                                        Foreground="{DynamicResource PrimaryText}"
                                                        BorderBrush="{DynamicResource CardBorder}" BorderThickness="1"
                                                        ToolTip="Sanitize the already-linked Core DB: clear tokens, mask emails, clear card data — same as the sanitize step in Link Database"
                                                        Click="SanitizeDb_Click"/>
                                            </StackPanel>

                                            <!-- Middle: checkboxes -->
                                            <StackPanel Grid.Column="1" Orientation="Horizontal"
                                                        HorizontalAlignment="Center" VerticalAlignment="Center">
                                                <CheckBox x:Name="SanitizeChk" Content="Sanitize database"
                                                          FontSize="12" Margin="0,0,16,0" IsChecked="True"
                                                          Foreground="{DynamicResource PrimaryText}"
                                                          ToolTip="During Link Database: delete all auth tokens, session data, API keys, email queues; mask email addresses with @test.bqe.com placeholders; clear payment card data and password hashes"/>
                                                <CheckBox x:Name="OwnerChk" Content="Owner"
                                                          FontSize="12" Margin="0,0,10,0"
                                                          Foreground="{DynamicResource PrimaryText}"
                                                          ToolTip="When checked, Make Owner uses sp_changedbowner instead of ALTER AUTHORIZATION"/>
                                                <Button x:Name="MakeOwnerBtn" Content="Make Owner" Height="30" Padding="10,0"
                                                        FontSize="12" Background="{DynamicResource DarkBtnBg}"
                                                        Foreground="{DynamicResource PrimaryText}"
                                                        BorderBrush="{DynamicResource CardBorder}" BorderThickness="1"
                                                        ToolTip="Makes the above user (Account Users dropdown) the owner of the already attached company — sets SQL DB owner and marks them as SysAdmin"
                                                        Click="MakeOwner_Click"/>
                                            </StackPanel>

                                            <!-- Right: Link Database -->
                                            <Button x:Name="LinkDatabaseBtn" Grid.Column="2" Content="Link Database"
                                                    Height="36" Padding="18,0" FontSize="13" FontWeight="SemiBold"
                                                    Style="{StaticResource PrimaryButton}"
                                                    ToolTip="Register this Core DB in the Host registry, set account email, add Core Users, activate Account Users, optionally sanitize — all in one click"
                                                    Click="LinkDatabase_Click"/>
                                        </Grid>

                                        <!-- Set as Default Company -->
                                        <Grid Margin="0,12,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <CheckBox x:Name="SetDefaultChk" Content="Set it as Default Company"
                                                      FontSize="12" VerticalAlignment="Center"
                                                      Foreground="{DynamicResource PrimaryText}" Margin="0,0,0,0"
                                                      ToolTip="Sets IsDefault = 1 for this database in the Host DB's DatabaseInfo table, clearing the flag from all others"/>
                                        </Grid>

                                        <!-- Actions result -->
                                        <Border x:Name="ActionResultBadge" Visibility="Collapsed"
                                                CornerRadius="6" Padding="10,5" Margin="0,12,0,0">
                                            <TextBlock x:Name="ActionResultText" FontSize="12"
                                                       FontWeight="SemiBold" TextWrapping="Wrap"/>
                                        </Border>
                                    </StackPanel>
                                </Border>
                                <!-- ══ Section 5: Unlink Database ══ -->
                                <Border Background="{DynamicResource CardBg}" CornerRadius="12"
                                        BorderBrush="#F59E0B" BorderThickness="1"
                                        Padding="20,16" Margin="0,0,0,16"
                                        ToolTip="Remove all Host DB links (Company, AccountCompany, subscriptions) without dropping the SQL database itself">
                                    <StackPanel>

                                        <!-- Header -->
                                        <Grid Margin="0,0,0,14">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                                <TextBlock Text="🔗" FontSize="14" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                                <StackPanel>
                                                    <TextBlock Text="UNLINK DATABASE" FontSize="10.5" FontWeight="Bold"
                                                               Foreground="#FCD34D"/>
                                                    <TextBlock Text="Removes Company + all linked Host records — SQL database is kept intact"
                                                               FontSize="11" Foreground="{DynamicResource SubText}" Margin="0,2,0,0"/>
                                                </StackPanel>
                                            </StackPanel>
                                            <Button Grid.Column="1" Content="↺  Reset" VerticalAlignment="Center"
                                                    Height="24" Padding="8,0" FontSize="11"
                                                    Style="{StaticResource SecondaryButton}"
                                                    ToolTip="Clear selection and result badge"
                                                    Click="ResetUnlinkDb_Click"/>
                                        </Grid>

                                        <!-- Database selector -->
                                        <Grid Margin="0,0,0,14">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="160"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="Database:" FontSize="13" VerticalAlignment="Center"
                                                       Foreground="{DynamicResource SubText}"
                                                       ToolTip="The Core company database to unlink from Host"/>
                                            <ComboBox x:Name="UnlinkDatabaseBox" Grid.Column="1" Height="34"
                                                      IsEditable="True" FontSize="12.5"
                                                      SelectionChanged="UnlinkDatabaseBox_SelectionChanged"
                                                      ToolTip="Select the database whose Host links will be removed. The SQL database itself is not touched."/>
                                        </Grid>

                                        <!-- Host Company selector — shown only when multiple Host companies share this DB -->
                                        <Grid x:Name="UnlinkHostCompanyRow" Margin="0,-6,0,14" Visibility="Collapsed">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="160"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                                <TextBlock Text="⚠" FontSize="11" Foreground="#FCD34D" Margin="0,0,4,0" VerticalAlignment="Center"/>
                                                <TextBlock Text="Host Company:" FontSize="13" FontWeight="SemiBold"
                                                           Foreground="#FCD34D" VerticalAlignment="Center"
                                                           ToolTip="Multiple Host DB companies share this database — select which one to unlink"/>
                                            </StackPanel>
                                            <ComboBox x:Name="UnlinkHostCompanyBox" Grid.Column="1" Height="34"
                                                      FontSize="12"
                                                      ToolTip="Select the specific Host Company record to unlink"/>
                                        </Grid>

                                        <!-- Unlink button -->
                                        <Button Content="UNLINK DATABASE"
                                                Height="36" FontSize="13" FontWeight="SemiBold"
                                                Background="#D97706" Foreground="White"
                                                BorderThickness="0" Cursor="Hand"
                                                ToolTip="Removes all Host DB links (AccountCompanySubscription → SubscriptionDetail → CompanySubscription → AccountCompany → Company). A confirmation dialog is shown first."
                                                Click="UnlinkDatabase_Click"/>

                                        <!-- Result badge -->
                                        <Border x:Name="UnlinkResultBadge" Visibility="Collapsed"
                                                CornerRadius="6" Padding="10,5" Margin="0,12,0,0" BorderThickness="1">
                                            <TextBlock x:Name="UnlinkResultText" FontSize="12"
                                                       FontWeight="SemiBold" TextWrapping="Wrap"/>
                                        </Border>
                                    </StackPanel>
                                </Border>

                                <!-- ══ Section 6: Delete Database ══ -->
                                <Border Background="{DynamicResource CardBg}" CornerRadius="12"
                                        BorderBrush="#FF453A" BorderThickness="1"
                                        Padding="20,16" Margin="0,0,0,16"
                                        ToolTip="Permanently remove a database from the Host registry and/or drop it from SQL Server. A confirmation dialog is always shown first.">
                                    <StackPanel>

                                        <!-- Header -->
                                        <Grid Margin="0,0,0,14">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                                <TextBlock Text="⚠" FontSize="14" Foreground="#FF453A"
                                                           VerticalAlignment="Center" Margin="0,0,8,0"/>
                                                <StackPanel>
                                                    <TextBlock Text="DELETE DATABASE" FontSize="10.5" FontWeight="Bold"
                                                               Foreground="#FF453A"/>
                                                    <TextBlock Text="Removes the database and all linked records from every Host table"
                                                               FontSize="11" Foreground="{DynamicResource SubText}" Margin="0,2,0,0"/>
                                                </StackPanel>
                                            </StackPanel>
                                            <Button Grid.Column="1" Content="↺  Reset" VerticalAlignment="Center"
                                                    Height="24" Padding="8,0" FontSize="11"
                                                    Style="{StaticResource SecondaryButton}"
                                                    ToolTip="Clear selection and result badge"
                                                    Click="ResetDeleteDb_Click"/>
                                        </Grid>

                                        <!-- Database to delete -->
                                        <Grid Margin="0,0,0,10">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="160"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="Database:" FontSize="13" VerticalAlignment="Center"
                                                       Foreground="{DynamicResource SubText}"
                                                       ToolTip="The Core company database to delete"/>
                                            <ComboBox x:Name="DelDatabaseBox" Grid.Column="1" Height="34"
                                                      IsEditable="True" FontSize="12.5"
                                                      SelectionChanged="DelDatabaseBox_SelectionChanged"
                                                      ToolTip="Select the database to remove. Populated automatically when you connect."/>
                                        </Grid>

                                        <!-- Host Company selector — shown only when multiple Host companies share this DB -->
                                        <Grid x:Name="DelHostCompanyRow" Margin="0,-2,0,10" Visibility="Collapsed">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="160"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                                <TextBlock Text="⚠" FontSize="11" Foreground="#FF453A" Margin="0,0,4,0" VerticalAlignment="Center"/>
                                                <TextBlock Text="Host Company:" FontSize="13" FontWeight="SemiBold"
                                                           Foreground="#FF453A" VerticalAlignment="Center"
                                                           ToolTip="Multiple Host DB companies share this database — select which one to delete"/>
                                            </StackPanel>
                                            <ComboBox x:Name="DelHostCompanyBox" Grid.Column="1" Height="34"
                                                      FontSize="12"
                                                      ToolTip="Select the specific Host Company record to delete"/>
                                        </Grid>

                                        <!-- Options -->
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                                            <CheckBox x:Name="DelHostRegistryChk"
                                                      Content="Remove from Host DB registry"
                                                      IsChecked="True" FontSize="12"
                                                      Foreground="{DynamicResource PrimaryText}"
                                                      Margin="0,0,20,0"
                                                      ToolTip="Discovers every table in the Host DB with a DatabaseName column and deletes matching rows — fully dynamic, no hard-coded table list"/>
                                            <CheckBox x:Name="DelDropDbChk"
                                                      Content="DROP the SQL database"
                                                      IsChecked="False" FontSize="12"
                                                      Foreground="#FF453A"
                                                      ToolTip="⚠ IRREVERSIBLE — kills all active connections and issues DROP DATABASE. Only check this if you want the SQL database permanently deleted."/>
                                        </StackPanel>

                                        <!-- Delete button -->
                                        <Button Content="DELETE DATABASE"
                                                Height="36" FontSize="13" FontWeight="SemiBold"
                                                Background="#FF453A" Foreground="White"
                                                BorderThickness="0" Cursor="Hand"
                                                ToolTip="Shows a confirmation dialog, then deletes linked Host records and/or drops the SQL database based on the options above"
                                                Click="DeleteDatabase_Click"/>

                                        <!-- Result badge -->
                                        <Border x:Name="DelResultBadge" Visibility="Collapsed"
                                                CornerRadius="6" Padding="10,5" Margin="0,12,0,0" BorderThickness="1">
                                            <TextBlock x:Name="DelResultText" FontSize="12"
                                                       FontWeight="SemiBold" TextWrapping="Wrap"/>
                                        </Border>
                                    </StackPanel>
                                </Border>


                                <!-- ══ Section 6: DB Maintenance ══ -->
                                <Border Background="{DynamicResource CardBg}" CornerRadius="12"
                                        BorderBrush="{DynamicResource CardBorder}" BorderThickness="1"
                                        Padding="20,16" Margin="0,0,0,16"
                                        ToolTip="Backup, restore, and execute stored procedures on the selected Core database.">
                                    <StackPanel>

                                        <!-- Header -->
                                        <Grid Margin="0,0,0,14">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                                <TextBlock Text="🛠" FontSize="14" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                                <StackPanel>
                                                    <TextBlock Text="DB MAINTENANCE" FontSize="10.5" FontWeight="Bold"
                                                               Foreground="{DynamicResource AccentBlue}"/>
                                                    <TextBlock Text="Execute procedures · Backup · Restore"
                                                               FontSize="11" Foreground="{DynamicResource SubText}" Margin="0,2,0,0"/>
                                                </StackPanel>
                                            </StackPanel>
                                            <Button Grid.Column="1" Content="↺  Reset" VerticalAlignment="Center"
                                                    Height="24" Padding="8,0" FontSize="11"
                                                    Style="{StaticResource SecondaryButton}"
                                                    ToolTip="Clear all Maintenance inputs and result badges"
                                                    Click="ResetMaintenance_Click"/>
                                        </Grid>

                                        <!-- ── Sub-card: Execute Procedure ── -->
                                        <Border Background="{DynamicResource InputBg}" CornerRadius="8"
                                                BorderBrush="{DynamicResource CardBorder}" BorderThickness="1"
                                                Padding="14,12" Margin="0,0,0,12">
                                            <StackPanel>
                                                <TextBlock Text="EXECUTE PROCEDURE / SCRIPT" FontSize="10"
                                                           FontWeight="Bold" Foreground="{DynamicResource SubText}"
                                                           Margin="0,0,0,10"/>

                                                <!-- ── Connection row ── -->
                                                <Border Background="{DynamicResource CardBg}" CornerRadius="6"
                                                        BorderBrush="{DynamicResource CardBorder}" BorderThickness="1"
                                                        Padding="10,10" Margin="0,0,0,10">
                                                    <StackPanel>
                                                        <TextBlock Text="CONNECTION" FontSize="9.5" FontWeight="Bold"
                                                                   Foreground="{DynamicResource SubText}" Margin="0,0,0,8"/>

                                                        <!-- Server -->
                                                        <Grid Margin="0,0,0,6">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="110"/>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                            </Grid.ColumnDefinitions>
                                                            <TextBlock Text="Server:" FontSize="12.5"
                                                                       VerticalAlignment="Center"
                                                                       Foreground="{DynamicResource SubText}"
                                                                       ToolTip="SQL Server instance for script execution"/>
                                                            <ComboBox x:Name="ExecServerBox" Grid.Column="1" Height="32"
                                                                      IsEditable="True" FontSize="12"
                                                                      ToolTip="SQL Server instance. Populated from registry — type manually if not listed."
                                                                      Margin="0,0,6,0"
                                                                      SelectionChanged="ExecServerBox_SelectionChanged"
                                                                      LostFocus="ExecServerBox_LostFocus"/>
                                                            <Button Content="⟳" Grid.Column="2" Width="32" Height="32"
                                                                    FontSize="14" Background="Transparent"
                                                                    BorderBrush="{DynamicResource CardBorder}" BorderThickness="1"
                                                                    Cursor="Hand" ToolTip="Re-scan registry for SQL Server instances"
                                                                    Click="RefreshExecServers_Click"/>
                                                        </Grid>

                                                        <!-- User / Password -->
                                                        <Grid Margin="0,0,0,6">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="110"/>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="20"/>
                                                                <ColumnDefinition Width="*"/>
                                                            </Grid.ColumnDefinitions>
                                                            <TextBlock Text="User / Pass:" FontSize="12.5"
                                                                       VerticalAlignment="Center"
                                                                       Foreground="{DynamicResource SubText}"/>
                                                            <TextBox x:Name="ExecUserBox" Grid.Column="1" Height="32"
                                                                     Text="sa" FontSize="12" Padding="8,0"
                                                                     VerticalContentAlignment="Center"
                                                                     Background="{DynamicResource InputBg}"
                                                                     Foreground="{DynamicResource PrimaryText}"
                                                                     BorderBrush="{DynamicResource CardBorder}" BorderThickness="1"
                                                                     ToolTip="SQL login username"/>
                                                            <TextBlock Grid.Column="2"/>
                                                            <PasswordBox x:Name="ExecPasswordBox" Grid.Column="3" Height="32"
                                                                         FontSize="12" Padding="8,0"
                                                                         VerticalContentAlignment="Center"
                                                                         Background="{DynamicResource InputBg}"
                                                                         Foreground="{DynamicResource PrimaryText}"
                                                                         BorderBrush="{DynamicResource CardBorder}" BorderThickness="1"
                                                                         ToolTip="SQL login password"/>
                                                        </Grid>

                                                        <!-- Database + Connect -->
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="110"/>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                            </Grid.ColumnDefinitions>
                                                            <TextBlock Text="Database:" FontSize="12.5"
                                                                       VerticalAlignment="Center"
                                                                       Foreground="{DynamicResource SubText}"
                                                                       ToolTip="Target database for script execution"/>
                                                            <ComboBox x:Name="ExecDatabaseBox" Grid.Column="1" Height="32"
                                                                      IsEditable="True" FontSize="12"
                                                                      ToolTip="Database to run scripts against"
                                                                      Margin="0,0,6,0"
                                                                      SelectionChanged="ExecDatabaseBox_SelectionChanged"/>
                                                            <Button Content="⟳" Grid.Column="2" Width="32" Height="32"
                                                                    FontSize="14" Background="Transparent"
                                                                    BorderBrush="{DynamicResource CardBorder}" BorderThickness="1"
                                                                    Cursor="Hand" ToolTip="Reload database list"
                                                                    Margin="0,0,6,0"
                                                                    Click="LoadExecDatabases_Click"/>
                                                            <Button Content="Connect" Grid.Column="3" Height="32"
                                                                    Padding="12,0" FontSize="12" FontWeight="SemiBold"
                                                                    Background="{DynamicResource AccentBlue}" Foreground="White"
                                                                    BorderThickness="0" Cursor="Hand"
                                                                    ToolTip="Connect to the selected database"
                                                                    Click="ConnectExecDb_Click"/>
                                                            <!-- Status badge inline -->
                                                            <Border x:Name="ExecConnBadge" Grid.Column="4"
                                                                    Visibility="Collapsed"
                                                                    CornerRadius="6" Padding="8,4" Margin="6,0,0,0"
                                                                    BorderThickness="1">
                                                                <TextBlock x:Name="ExecConnText" FontSize="11.5"
                                                                           FontWeight="SemiBold"/>
                                                            </Border>
                                                        </Grid>
                                                    </StackPanel>
                                                </Border>

                                                <!-- Preset procedures dropdown -->
                                                <Grid Margin="0,0,0,8">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="160"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Text="Quick Presets:" FontSize="13"
                                                               VerticalAlignment="Center"
                                                               Foreground="{DynamicResource SubText}"
                                                               ToolTip="Common stored procedures for BQE Core databases"/>
                                                    <ComboBox x:Name="ProcPresetBox" Grid.Column="1" Height="34" FontSize="12.5"
                                                              SelectionChanged="ProcPresetBox_SelectionChanged"
                                                              ToolTip="Select a preset to load it into the script editor below">
                                                        <ComboBoxItem Content="-- Select a preset --" IsSelected="True"/>
                                                        <ComboBoxItem Content="Rebuild all indexes"/>
                                                        <ComboBoxItem Content="Update statistics"/>
                                                        <ComboBoxItem Content="Shrink database"/>
                                                        <ComboBoxItem Content="Check DB integrity (DBCC CHECKDB)"/>
                                                        <ComboBoxItem Content="List all stored procedures"/>
                                                        <ComboBoxItem Content="List tables and row counts"/>
                                                        <ComboBoxItem Content="Kill all connections"/>
                                                        <ComboBoxItem Content="Clear query plan cache"/>
                                                    </ComboBox>
                                                </Grid>

                                                <!-- Script editor -->
                                                <TextBox x:Name="ProcScriptBox"
                                                         Height="110" AcceptsReturn="True" AcceptsTab="True"
                                                         VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                                                         FontFamily="Cascadia Code, Consolas, Courier New"
                                                         FontSize="12" TextWrapping="NoWrap"
                                                         Padding="10,8" Margin="0,0,0,8"
                                                         Background="{DynamicResource InputBg}"
                                                         Foreground="{DynamicResource PrimaryText}"
                                                         BorderBrush="{DynamicResource CardBorder}" BorderThickness="1"
                                                         ToolTip="SQL script to execute. Runs against the connected Core database. Supports GO batch separator."
                                                         xml:space="preserve"/>

                                                <!-- Timeout + Execute row -->
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="160"/>
                                                        <ColumnDefinition Width="100"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Text="Timeout (seconds):" FontSize="13"
                                                               VerticalAlignment="Center"
                                                               Foreground="{DynamicResource SubText}"
                                                               ToolTip="Command timeout in seconds. Use 0 for no timeout (long-running procedures)."/>
                                                    <TextBox x:Name="ProcTimeoutBox" Grid.Column="1" Height="34"
                                                             Text="300" FontSize="12.5" Padding="8,0"
                                                             VerticalContentAlignment="Center"
                                                             Background="{DynamicResource InputBg}"
                                                             Foreground="{DynamicResource PrimaryText}"
                                                             BorderBrush="{DynamicResource CardBorder}" BorderThickness="1"
                                                             ToolTip="0 = no timeout. Increase for long maintenance jobs."/>
                                                    <StackPanel Grid.Column="2"/>
                                                    <Button Content="▶  Execute" Grid.Column="3"
                                                            Height="34" Padding="16,0" FontSize="12.5" FontWeight="SemiBold"
                                                            Background="{DynamicResource AccentBlue}" Foreground="White"
                                                            BorderThickness="0" Cursor="Hand"
                                                            ToolTip="Execute the script against the connected Core database"
                                                            Click="ExecuteProc_Click"/>
                                                </Grid>

                                                <!-- Output -->
                                                <Border x:Name="ProcResultBadge" Visibility="Collapsed"
                                                        CornerRadius="6" Padding="10,5" Margin="0,10,0,0" BorderThickness="1">
                                                    <TextBlock x:Name="ProcResultText" FontSize="12"
                                                               FontWeight="SemiBold" TextWrapping="Wrap"/>
                                                </Border>
                                                <TextBox x:Name="ProcOutputBox" Visibility="Collapsed"
                                                         MinHeight="120" MaxHeight="480" IsReadOnly="True" AcceptsReturn="True"
                                                         VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                                                         FontFamily="Cascadia Code, Consolas, Courier New"
                                                         FontSize="11.5" Padding="10,8" Margin="0,6,0,0"
                                                         Background="{DynamicResource InputBg}"
                                                         Foreground="{DynamicResource PrimaryText}"
                                                         BorderBrush="{DynamicResource CardBorder}" BorderThickness="1"
                                                         ToolTip="Script execution output — messages, row counts, result sets, and errors"/>
                                            </StackPanel>
                                        </Border>

                                        <!-- ── Sub-card: SQL Connection (Backup + Restore) ── -->
                                        <Border Background="{DynamicResource InputBg}" CornerRadius="8"
                                                BorderBrush="{DynamicResource CardBorder}" BorderThickness="1"
                                                Padding="14,12" Margin="0,0,0,12">
                                            <StackPanel>
                                                <TextBlock Text="SQL CONNECTION  (for Backup &amp; Restore)"
                                                           FontSize="10" FontWeight="Bold"
                                                           Foreground="{DynamicResource SubText}" Margin="0,0,0,10"
                                                           ToolTip="Dedicated SQL Server connection used for Backup and Restore. Leave blank to fall back to the Core DB connection from Section 2."/>

                                                <!-- Row: Server / User / Password / Test -->
                                                <Grid Margin="0,0,0,8">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="60"/>
                                                        <ColumnDefinition Width="*" MinWidth="100"/>
                                                        <ColumnDefinition Width="12"/>
                                                        <ColumnDefinition Width="50"/>
                                                        <ColumnDefinition Width="110"/>
                                                        <ColumnDefinition Width="12"/>
                                                        <ColumnDefinition Width="64"/>
                                                        <ColumnDefinition Width="*" MinWidth="100"/>
                                                        <ColumnDefinition Width="12"/>
                                                        <ColumnDefinition Width="Auto"/>  <!-- 9: Fetch button -->
                                                        <ColumnDefinition Width="8"/>
                                                        <ColumnDefinition Width="Auto"/>  <!-- 11: Test button -->
                                                    </Grid.ColumnDefinitions>

                                                    <TextBlock Text="Server:" Grid.Column="0"
                                                               FontSize="12.5" VerticalAlignment="Center"
                                                               Foreground="{DynamicResource SubText}"/>
                                                    <TextBox x:Name="MaintServerBox" Grid.Column="1"
                                                             Height="32" Padding="8,0" FontSize="12.5"
                                                             VerticalContentAlignment="Center"
                                                             Background="{DynamicResource InputBg}"
                                                             Foreground="{DynamicResource PrimaryText}"
                                                             BorderBrush="{DynamicResource CardBorder}" BorderThickness="1"
                                                             ToolTip="SQL Server instance for backup/restore (e.g. localhost or 192.168.1.10\SQLEXPRESS)"/>

                                                    <TextBlock Text="User:" Grid.Column="3"
                                                               FontSize="12.5" VerticalAlignment="Center"
                                                               Foreground="{DynamicResource SubText}" Margin="0,0,6,0"/>
                                                    <TextBox x:Name="MaintUserBox" Grid.Column="4"
                                                             Height="32" Padding="8,0" FontSize="12.5"
                                                             VerticalContentAlignment="Center"
                                                             Background="{DynamicResource InputBg}"
                                                             Foreground="{DynamicResource PrimaryText}"
                                                             BorderBrush="{DynamicResource CardBorder}" BorderThickness="1"
                                                             ToolTip="SQL login username (leave blank for Windows auth)"/>

                                                    <TextBlock Text="Password:" Grid.Column="6"
                                                               FontSize="12.5" VerticalAlignment="Center"
                                                               Foreground="{DynamicResource SubText}" Margin="0,0,6,0"/>
                                                    <PasswordBox x:Name="MaintPasswordBox" Grid.Column="7"
                                                                 Height="32" Padding="8,0" FontSize="12.5"
                                                                 VerticalContentAlignment="Center"
                                                                 Background="{DynamicResource InputBg}"
                                                                 Foreground="{DynamicResource PrimaryText}"
                                                                 BorderBrush="{DynamicResource CardBorder}" BorderThickness="1"
                                                                 ToolTip="SQL login password"/>

                                                    <Button Grid.Column="9"
                                                            Content="↙ Fetch from Host DB" Height="32" Padding="10,0"
                                                            FontSize="11" FontWeight="SemiBold"
                                                            Background="#7C3AED" Foreground="White"
                                                            BorderThickness="0" Cursor="Hand"
                                                            ToolTip="Auto-fill Server/User/Password from the Main Host DB (BQECoreHost) connection string"
                                                            Click="FetchSqlConnFromHostDb_Click">
                                                        <Button.Template>
                                                            <ControlTemplate TargetType="Button">
                                                                <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                </Border>
                                                                <ControlTemplate.Triggers>
                                                                    <Trigger Property="IsMouseOver" Value="True"><Setter Property="Background" Value="#6D28D9"/></Trigger>
                                                                </ControlTemplate.Triggers>
                                                            </ControlTemplate>
                                                        </Button.Template>
                                                    </Button>
                                                    <Button x:Name="TestMaintConnBtn" Grid.Column="11"
                                                            Content="✔  Test" Height="32" Padding="12,0"
                                                            FontSize="12" FontWeight="SemiBold"
                                                            Background="{DynamicResource AccentBlue}" Foreground="White"
                                                            BorderThickness="0" Cursor="Hand"
                                                            ToolTip="Test the connection to this SQL Server"
                                                            Click="TestMaintConn_Click"/>
                                                </Grid>

                                                <Border x:Name="MaintConnBadge" Visibility="Collapsed"
                                                        CornerRadius="6" Padding="8,4" Margin="0,2,0,0" BorderThickness="1">
                                                    <TextBlock x:Name="MaintConnText" FontSize="12"
                                                               FontWeight="SemiBold" TextWrapping="Wrap"/>
                                                </Border>
                                            </StackPanel>
                                        </Border>

                                        <!-- ── Sub-card: Backup ── -->
                                        <Border Background="{DynamicResource InputBg}" CornerRadius="8"
                                                BorderBrush="{DynamicResource CardBorder}" BorderThickness="1"
                                                Padding="14,12" Margin="0,0,0,12">
                                            <StackPanel>
                                                <TextBlock Text="BACKUP DATABASE" FontSize="10"
                                                           FontWeight="Bold" Foreground="{DynamicResource SubText}"
                                                           Margin="0,0,0,8"/>

                                                <Grid Margin="0,0,0,8">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="160"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Text="Backup path (.bak):" FontSize="13"
                                                               VerticalAlignment="Center"
                                                               Foreground="{DynamicResource SubText}"
                                                               ToolTip="Full UNC or local path on the SQL Server machine where the .bak file will be written"/>
                                                    <TextBox x:Name="BackupPathBox" Grid.Column="1" Height="34"
                                                             FontSize="12.5" Padding="8,0" VerticalContentAlignment="Center"
                                                             Background="{DynamicResource InputBg}"
                                                             Foreground="{DynamicResource PrimaryText}"
                                                             BorderBrush="{DynamicResource CardBorder}" BorderThickness="1"
                                                             ToolTip="Example: C:\Backups\MyCompany_20260101.bak — path must be accessible to the SQL Server service account"
                                                             Margin="0,0,8,0"/>
                                                    <Button Content="📂" Grid.Column="2" Height="34" Width="36"
                                                            FontSize="14" Background="Transparent"
                                                            BorderBrush="{DynamicResource CardBorder}" BorderThickness="1"
                                                            Cursor="Hand"
                                                            ToolTip="Browse for a backup file location"
                                                            Click="BrowseBackupPath_Click"/>
                                                </Grid>

                                                <!-- Options row -->
                                                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                                    <CheckBox x:Name="BackupCompressChk"
                                                              Content="Compress backup" IsChecked="True"
                                                              FontSize="12" Foreground="{DynamicResource PrimaryText}"
                                                              Margin="0,0,20,0"
                                                              ToolTip="WITH COMPRESSION — reduces .bak file size, requires SQL Server Standard/Enterprise"/>
                                                    <CheckBox x:Name="BackupCopyOnlyChk"
                                                              Content="Copy-only (no log truncation)" IsChecked="False"
                                                              FontSize="12" Foreground="{DynamicResource PrimaryText}"
                                                              ToolTip="COPY_ONLY — takes a standalone backup without affecting the regular backup chain"/>
                                                </StackPanel>

                                                <Button Content="💾  Backup Now"
                                                        Height="34" Padding="16,0" FontSize="12.5" FontWeight="SemiBold"
                                                        Background="{DynamicResource AccentBlue}" Foreground="White"
                                                        BorderThickness="0" Cursor="Hand" HorizontalAlignment="Left"
                                                        ToolTip="Run BACKUP DATABASE … TO DISK against the connected Core database"
                                                        Click="BackupDatabase_Click"/>

                                                <Border x:Name="BackupResultBadge" Visibility="Collapsed"
                                                        CornerRadius="6" Padding="10,5" Margin="0,10,0,0" BorderThickness="1">
                                                    <TextBlock x:Name="BackupResultText" FontSize="12"
                                                               FontWeight="SemiBold" TextWrapping="Wrap"/>
                                                </Border>
                                            </StackPanel>
                                        </Border>

                                        <!-- ── Sub-card: Restore ── -->
                                        <Border Background="{DynamicResource InputBg}" CornerRadius="8"
                                                BorderBrush="{DynamicResource CardBorder}" BorderThickness="1"
                                                Padding="14,12">
                                            <StackPanel>
                                                <TextBlock Text="RESTORE BACKUP" FontSize="10"
                                                           FontWeight="Bold" Foreground="{DynamicResource SubText}"
                                                           Margin="0,0,0,8"/>

                                                <!-- .bak file -->
                                                <Grid Margin="0,0,0,8">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="160"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Text="Backup file (.bak):" FontSize="13"
                                                               VerticalAlignment="Center"
                                                               Foreground="{DynamicResource SubText}"
                                                               ToolTip="Full path to the .bak file on the SQL Server machine"/>
                                                    <TextBox x:Name="RestoreFileBox" Grid.Column="1" Height="34"
                                                             FontSize="12.5" Padding="8,0" VerticalContentAlignment="Center"
                                                             Background="{DynamicResource InputBg}"
                                                             Foreground="{DynamicResource PrimaryText}"
                                                             BorderBrush="{DynamicResource CardBorder}" BorderThickness="1"
                                                             ToolTip="Path to the .bak file. Must be accessible by the SQL Server service account."
                                                             Margin="0,0,8,0"/>
                                                    <Button Content="📂" Grid.Column="2" Height="34" Width="36"
                                                            FontSize="14" Background="Transparent"
                                                            BorderBrush="{DynamicResource CardBorder}" BorderThickness="1"
                                                            Cursor="Hand"
                                                            ToolTip="Browse for a .bak file"
                                                            Click="BrowseRestoreFile_Click"/>
                                                </Grid>

                                                <!-- Restore as -->
                                                <Grid Margin="0,0,0,8">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="160"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Text="Restore as DB name:" FontSize="13"
                                                               VerticalAlignment="Center"
                                                               Foreground="{DynamicResource SubText}"
                                                               ToolTip="The name the restored database will have in SQL Server. Leave blank to overwrite the original."/>
                                                    <TextBox x:Name="RestoreAsBox" Grid.Column="1" Height="34"
                                                             FontSize="12.5" Padding="8,0" VerticalContentAlignment="Center"
                                                             Background="{DynamicResource InputBg}"
                                                             Foreground="{DynamicResource PrimaryText}"
                                                             BorderBrush="{DynamicResource CardBorder}" BorderThickness="1"
                                                             ToolTip="Leave empty to restore over the existing database, or enter a new name to create a separate copy"/>
                                                </Grid>

                                                <!-- Options -->
                                                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                                    <CheckBox x:Name="RestoreWithReplaceChk"
                                                              Content="WITH REPLACE" IsChecked="True"
                                                              FontSize="12" Foreground="{DynamicResource PrimaryText}"
                                                              Margin="0,0,20,0"
                                                              ToolTip="Overwrites existing DB if the restore target already exists"/>
                                                    <CheckBox x:Name="RestoreKillConnChk"
                                                              Content="Kill connections first" IsChecked="True"
                                                              FontSize="12" Foreground="{DynamicResource PrimaryText}"
                                                              ToolTip="Sets the database to SINGLE_USER to kick everyone out before restoring"/>
                                                </StackPanel>

                                                <!-- Auto-detect logical names note -->
                                                <TextBlock Text="ℹ  Logical file names are detected automatically from the .bak header."
                                                           FontSize="11" Foreground="{DynamicResource SubText}"
                                                           Margin="0,0,0,10" TextWrapping="Wrap"/>

                                                <Button Content="♻  Restore Now"
                                                        Height="34" Padding="16,0" FontSize="12.5" FontWeight="SemiBold"
                                                        Background="{DynamicResource AccentBlue}" Foreground="White"
                                                        BorderThickness="0" Cursor="Hand" HorizontalAlignment="Left"
                                                        ToolTip="Restore the .bak file to the specified database name against the connected SQL Server"
                                                        Click="RestoreDatabase_Click"/>

                                                <Border x:Name="RestoreResultBadge" Visibility="Collapsed"
                                                        CornerRadius="6" Padding="10,5" Margin="0,10,0,0" BorderThickness="1">
                                                    <TextBlock x:Name="RestoreResultText" FontSize="12"
                                                               FontWeight="SemiBold" TextWrapping="Wrap"/>
                                                </Border>
                                            </StackPanel>
                                        </Border>

                                    </StackPanel>
                                </Border>

                            </StackPanel>
                        </ScrollViewer>
                    </Grid>
                </TabItem>

                <!-- ═══════════════════════════════════════════════════════
                     TAB 20 — VERIFY & REPAIR MERCHANT
                     ═══════════════════════════════════════════════════════ -->
                <TabItem x:Name="TabItem20" Header="🔧 Merchant Verify">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Topbar -->
                        <Border Grid.Row="0" Padding="14,9" Background="{DynamicResource CardBg}"
                                BorderBrush="{DynamicResource CardBorder}" BorderThickness="0,0,0,1">
                            <Grid>
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <Border Width="28" Height="28" CornerRadius="7"
                                            Background="#D9770620" BorderBrush="#D9770640" BorderThickness="1"
                                            Margin="0,0,10,0">
                                        <TextBlock Text="🔧" FontSize="12" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <StackPanel>
                                        <TextBlock Text="Verify &amp; Repair Merchant" FontSize="14" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource PrimaryText}"/>
                                        <TextBlock Text="DB + Payrix health check" FontSize="11"
                                                   Foreground="{DynamicResource SubText}"/>
                                    </StackPanel>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- Scrollable content -->
                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled" Padding="16,14">
                            <StackPanel>
                                <Border Background="{DynamicResource CardBg}" CornerRadius="8"
                                        BorderBrush="{DynamicResource CardBorder}" BorderThickness="1"
                                        Padding="16,14">
                                    <StackPanel>
                                        <TextBlock Text="Enter a BQE Core Company ID to check whether the Payrix merchant stored in the payment-service DB actually exists in Payrix."
                                                   FontSize="12" Foreground="{DynamicResource SubText}"
                                                   TextWrapping="Wrap" Margin="0,0,0,12"/>

                                        <!-- Email + find companies row -->
                                        <Grid Margin="0,0,0,10">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="Email:" FontWeight="SemiBold" FontSize="12"
                                                       Foreground="{DynamicResource SubLabelFg}"
                                                       VerticalAlignment="Center" Margin="0,0,10,0"/>
                                            <Border Grid.Column="1" CornerRadius="6" Height="34"
                                                    Background="{DynamicResource InputBg}"
                                                    BorderBrush="{DynamicResource CardBorder}" BorderThickness="1"
                                                    Padding="10,0" Margin="0,0,8,0">
                                                <TextBox x:Name="VmEmailBox"
                                                         Background="Transparent" BorderThickness="0"
                                                         VerticalAlignment="Center" FontSize="12"
                                                         Foreground="{DynamicResource PrimaryText}"
                                                         ToolTip="BQE Core user email to look up companies"/>
                                            </Border>
                                            <Button x:Name="VmFindCompaniesBtn" Grid.Column="2"
                                                    Content="Find Companies"
                                                    Height="34" Padding="12,0" FontSize="12"
                                                    Style="{StaticResource PrimaryButton}"
                                                    Click="VmFindCompaniesBtn_Click"/>
                                        </Grid>

                                        <!-- Company ID + environment + verify button -->
                                        <Grid Margin="0,0,0,10">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="Company ID:" FontWeight="SemiBold" FontSize="12"
                                                       Foreground="{DynamicResource SubLabelFg}"
                                                       VerticalAlignment="Center" Margin="0,0,10,0"/>
                                            <Border Grid.Column="1" CornerRadius="6" Height="34"
                                                    Background="{DynamicResource InputBg}"
                                                    BorderBrush="{DynamicResource CardBorder}" BorderThickness="1"
                                                    Padding="10,0" Margin="0,0,8,0">
                                                <TextBox x:Name="VerifyMerchantCompanyBox"
                                                         Background="Transparent" BorderThickness="0"
                                                         VerticalAlignment="Center" FontSize="12"
                                                         Foreground="{DynamicResource PrimaryText}"
                                                         FontFamily="Consolas"
                                                         ToolTip="BQE Core Company GUID"/>
                                            </Border>
                                            <ComboBox x:Name="VerifyMerchantEnvBox" Grid.Column="2"
                                                      Height="34" Width="120" FontSize="12"
                                                      Margin="0,0,8,0"
                                                      Background="{DynamicResource InputBg}"
                                                      Foreground="{DynamicResource PrimaryText}"
                                                      BorderBrush="{DynamicResource CardBorder}">
                                                <ComboBoxItem Content="Local"    IsSelected="True"/>
                                                <ComboBoxItem Content="Staging"/>
                                                <ComboBoxItem Content="Sprint"/>
                                                <ComboBoxItem Content="Production"/>
                                            </ComboBox>
                                            <Button x:Name="VerifyMerchantBtn" Grid.Column="3"
                                                    Content="🔎  Verify Merchant"
                                                    Height="34" Padding="14,0" FontSize="12.5"
                                                    Style="{StaticResource PrimaryButton}"
                                                    Background="#0EA5E9"
                                                    Click="VerifyMerchantBtn_Click"/>
                                        </Grid>

                                        <!-- Company selector (shown after email lookup) -->
                                        <Grid x:Name="VmCompanySelectorRow" Visibility="Collapsed" Margin="0,0,0,10">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock x:Name="VmCompanySelectorLabel" Grid.Column="0"
                                                       Text="Select Company:" FontSize="12" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource SubLabelFg}"
                                                       VerticalAlignment="Center" Margin="0,0,10,0"/>
                                            <ComboBox x:Name="VmCompanyCombo" Grid.Column="1" Height="34" FontSize="12"
                                                      Background="{DynamicResource InputBg}"
                                                      SelectionChanged="VmCompanyCombo_SelectionChanged"/>
                                        </Grid>

                                        <!-- Fix / Re-create panel -->
                                        <Border x:Name="VmFixPanel" Margin="0,0,0,10"
                                                CornerRadius="8" Padding="14,12"
                                                Background="#FFF7ED"
                                                BorderBrush="#F59E0B" BorderThickness="1">
                                            <StackPanel>
                                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                                    <TextBlock Text="🔧" FontSize="14" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                                    <TextBlock Text="Re-create Merchant in Payrix" FontSize="13" FontWeight="SemiBold"
                                                               Foreground="#92400E" VerticalAlignment="Center"/>
                                                </StackPanel>
                                                <TextBlock FontSize="11.5" Foreground="#78350F" TextWrapping="Wrap" Margin="0,0,0,10"
                                                           Text="Uses the company selected in the Entity Custom dropdown above. Creates a new Payrix login + entity, boards the merchant (status=2), and writes the correct merchant ID back to the DB."/>
                                                <StackPanel Orientation="Horizontal">
                                                    <Button x:Name="VmFixBtn"
                                                            Content="🔧  Re-create Merchant"
                                                            Height="34" Padding="16,0" FontSize="12.5"
                                                            Click="VmFixBtn_Click">
                                                        <Button.Style>
                                                            <Style TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
                                                                <Setter Property="Background" Value="#D97706"/>
                                                                <Style.Triggers>
                                                                    <Trigger Property="IsMouseOver" Value="True">
                                                                        <Setter Property="Background" Value="#B45309"/>
                                                                    </Trigger>
                                                                    <Trigger Property="IsEnabled" Value="False">
                                                                        <Setter Property="Background" Value="#FDE68A"/>
                                                                        <Setter Property="Foreground" Value="#92400E"/>
                                                                    </Trigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Button.Style>
                                                    </Button>
                                                </StackPanel>
                                                <Border x:Name="VmFixLogPanel" Visibility="Collapsed"
                                                        Margin="0,10,0,0" CornerRadius="6"
                                                        Background="{DynamicResource SearchCardBg}"
                                                        BorderBrush="{DynamicResource CardBorder}" BorderThickness="1">
                                                    <StackPanel>
                                                        <Grid Margin="10,7">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                                <ColumnDefinition Width="6"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                            </Grid.ColumnDefinitions>
                                                            <TextBlock x:Name="VmFixLogTitle" Text="Fix Log"
                                                                       FontSize="11.5" FontWeight="SemiBold"
                                                                       Foreground="{DynamicResource SubLabelFg}" VerticalAlignment="Center"/>
                                                            <Button x:Name="VmFixExportBtn" Grid.Column="1"
                                                                    Content="📥  Export Log" Height="28" Padding="10,0" FontSize="11"
                                                                    Click="VmFixExportBtn_Click" Style="{StaticResource SecondaryButton}"/>
                                                            <Button x:Name="VmFixCloseLogBtn" Grid.Column="3"
                                                                    Content="✕  Close" Height="28" Padding="10,0" FontSize="11"
                                                                    Click="VmFixCloseLogBtn_Click" Style="{StaticResource SecondaryButton}"/>
                                                        </Grid>
                                                        <Border BorderBrush="{DynamicResource CardBorder}" BorderThickness="0,1,0,0">
                                                            <ScrollViewer MaxHeight="260" VerticalScrollBarVisibility="Auto"
                                                                          HorizontalScrollBarVisibility="Auto" Padding="10,8">
                                                                <TextBlock x:Name="VmFixResult" FontSize="11" FontFamily="Consolas"
                                                                           TextWrapping="NoWrap" Foreground="{DynamicResource PrimaryText}" LineHeight="17"/>
                                                            </ScrollViewer>
                                                        </Border>
                                                    </StackPanel>
                                                </Border>
                                            </StackPanel>
                                        </Border>

                                        <!-- Verify result card -->
                                        <Border x:Name="VerifyMerchantResultCard" Visibility="Collapsed"
                                                CornerRadius="8" Padding="14,12" Margin="0,4,0,0"
                                                Background="{DynamicResource DbConfigBg}"
                                                BorderBrush="{DynamicResource DbConfigBorder}" BorderThickness="1">
                                            <StackPanel>
                                                <Border x:Name="VerifyMerchantStatusBanner" CornerRadius="6" Padding="12,8" Margin="0,0,0,10"
                                                        Background="#0EA5E920" BorderBrush="#0EA5E9" BorderThickness="1">
                                                    <TextBlock x:Name="VerifyMerchantStatusText" FontSize="13" FontWeight="SemiBold"
                                                               Foreground="#0EA5E9" TextWrapping="Wrap"/>
                                                </Border>
                                                <Grid x:Name="VerifyMerchantDetailGrid" Visibility="Collapsed">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="150"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                    </Grid.RowDefinitions>
                                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Merchant ID:" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource SubLabelFg}" Margin="0,0,0,6"/>
                                                    <TextBlock x:Name="VmMerchantId" Grid.Row="0" Grid.Column="1" FontSize="12" FontFamily="Consolas" Foreground="{DynamicResource PrimaryText}" TextWrapping="Wrap" Margin="0,0,0,6"/>
                                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Merchant Name:" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource SubLabelFg}" Margin="0,0,0,6"/>
                                                    <TextBlock x:Name="VmMerchantName" Grid.Row="1" Grid.Column="1" FontSize="12" Foreground="{DynamicResource PrimaryText}" TextWrapping="Wrap" Margin="0,0,0,6"/>
                                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Status:" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource SubLabelFg}" Margin="0,0,0,6"/>
                                                    <TextBlock x:Name="VmMerchantStatus" Grid.Row="2" Grid.Column="1" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                                    <TextBlock Grid.Row="3" Grid.Column="0" Text="Entity ID:" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource SubLabelFg}" Margin="0,0,0,6"/>
                                                    <TextBlock x:Name="VmEntityId" Grid.Row="3" Grid.Column="1" FontSize="12" FontFamily="Consolas" Foreground="{DynamicResource PrimaryText}" TextWrapping="Wrap" Margin="0,0,0,6"/>
                                                    <TextBlock Grid.Row="4" Grid.Column="0" Text="Environment:" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource SubLabelFg}" Margin="0,0,0,6"/>
                                                    <TextBlock x:Name="VmEnvironment" Grid.Row="4" Grid.Column="1" FontSize="12" Foreground="{DynamicResource PrimaryText}" Margin="0,0,0,6"/>
                                                    <TextBlock Grid.Row="5" Grid.Column="0" Text="API Key (stored):" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource SubLabelFg}" Margin="0,0,0,6"/>
                                                    <TextBlock x:Name="VmApiKey" Grid.Row="5" Grid.Column="1" FontSize="12" FontFamily="Consolas" Foreground="{DynamicResource PrimaryText}" TextWrapping="Wrap" Margin="0,0,0,6"/>
                                                    <TextBlock Grid.Row="6" Grid.Column="0" Text="Diagnosis:" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource SubLabelFg}" Margin="0,0,0,0"/>
                                                    <TextBlock x:Name="VmDiagnosis" Grid.Row="6" Grid.Column="1" FontSize="12" Foreground="{DynamicResource SubText}" TextWrapping="Wrap"/>
                                                </Grid>
                                            </StackPanel>
                                        </Border>

                                        <!-- Health Check -->
                                        <Border Margin="0,10,0,0" CornerRadius="8" Padding="14,12"
                                                Background="{DynamicResource DbConfigBg}"
                                                BorderBrush="{DynamicResource DbConfigBorder}" BorderThickness="1">
                                            <StackPanel>
                                                <Grid Margin="0,0,0,4">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel>
                                                        <TextBlock Text="🩺  Full Health Check" FontSize="13" FontWeight="SemiBold"
                                                                   Foreground="{DynamicResource PrimaryText}"/>
                                                        <TextBlock Text="Checks Host DB, ThirdPartySetting, BQSTable, payment methods, Payrix entity/merchant/members, and token test."
                                                                   FontSize="11" Foreground="{DynamicResource SubText}" TextWrapping="Wrap" Margin="0,3,0,0"/>
                                                    </StackPanel>
                                                    <Button x:Name="VmHealthCheckBtn" Grid.Column="1"
                                                            Content="🩺  Run Health Check"
                                                            Height="34" Padding="14,0" FontSize="12"
                                                            VerticalAlignment="Top"
                                                            Click="VmHealthCheckBtn_Click"
                                                            Style="{StaticResource PrimaryButton}"
                                                            Background="#0EA5E9"/>
                                                </Grid>
                                                <ScrollViewer Margin="0,8,0,0" MaxHeight="300"
                                                              VerticalScrollBarVisibility="Auto"
                                                              HorizontalScrollBarVisibility="Disabled">
                                                    <ItemsControl x:Name="VmHealthRows">
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate>
                                                                <Border CornerRadius="5" Padding="10,6" Margin="0,2,0,0"
                                                                        Background="{DynamicResource SearchCardBg}"
                                                                        BorderBrush="{DynamicResource CardBorder}" BorderThickness="1">
                                                                    <Grid>
                                                                        <Grid.ColumnDefinitions>
                                                                            <ColumnDefinition Width="22"/>
                                                                            <ColumnDefinition Width="200"/>
                                                                            <ColumnDefinition Width="*"/>
                                                                        </Grid.ColumnDefinitions>
                                                                        <TextBlock Grid.Column="0" Text="{Binding Icon}" FontSize="13" VerticalAlignment="Center"/>
                                                                        <TextBlock Grid.Column="1" Text="{Binding Label}" FontSize="12" FontWeight="SemiBold"
                                                                                   Foreground="{DynamicResource SubLabelFg}" VerticalAlignment="Center"/>
                                                                        <TextBlock Grid.Column="2" Text="{Binding Detail}" FontSize="12"
                                                                                   Foreground="{Binding DetailColor}" TextWrapping="Wrap" VerticalAlignment="Center"/>
                                                                    </Grid>
                                                                </Border>
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                                </ScrollViewer>
                                                <Border x:Name="VmHealthSummary" Visibility="Collapsed"
                                                        CornerRadius="6" Padding="10,7" Margin="0,8,0,0"
                                                        Background="#16A34A20" BorderBrush="#16A34A" BorderThickness="1">
                                                    <TextBlock x:Name="VmHealthSummaryText" FontSize="12.5" FontWeight="SemiBold"
                                                               Foreground="#166534" TextWrapping="Wrap"/>
                                                </Border>
                                            </StackPanel>
                                        </Border>

                                        <!-- Payrix Details Panel -->
                                        <Border x:Name="VmDetailsPanel" Visibility="Collapsed" Margin="0,10,0,0"
                                                CornerRadius="8" Padding="14,12"
                                                Background="{DynamicResource DbConfigBg}"
                                                BorderBrush="{DynamicResource DbConfigBorder}" BorderThickness="1">
                                            <StackPanel>
                                                <TextBlock Text="📋  Payrix Details" FontSize="13" FontWeight="SemiBold"
                                                           Foreground="{DynamicResource PrimaryText}" Margin="0,0,0,10"/>
                                                <TextBlock Text="Entity" FontSize="11.5" FontWeight="Bold"
                                                           Foreground="{DynamicResource SubLabelFg}" Margin="0,0,0,6"/>
                                                <Border CornerRadius="6" Padding="10,8" Margin="0,0,0,10"
                                                        Background="{DynamicResource SearchCardBg}"
                                                        BorderBrush="{DynamicResource CardBorder}" BorderThickness="1">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="130"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="130"/>
                                                            <ColumnDefinition Width="*"/>
                                                        </Grid.ColumnDefinitions>
                                                        <Grid.RowDefinitions>
                                                            <RowDefinition Height="Auto"/>
                                                            <RowDefinition Height="Auto"/>
                                                        </Grid.RowDefinitions>
                                                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Entity ID:" FontSize="11.5" FontWeight="SemiBold" Foreground="{DynamicResource SubLabelFg}" Margin="0,0,0,5"/>
                                                        <TextBlock x:Name="VdEntityId" Grid.Row="0" Grid.Column="1" FontSize="11.5" FontFamily="Consolas" Foreground="{DynamicResource PrimaryText}" TextWrapping="Wrap" Margin="0,0,0,5"/>
                                                        <TextBlock Grid.Row="0" Grid.Column="2" Text="Status:" FontSize="11.5" FontWeight="SemiBold" Foreground="{DynamicResource SubLabelFg}" Margin="8,0,0,5"/>
                                                        <TextBlock x:Name="VdEntityStatus" Grid.Row="0" Grid.Column="3" FontSize="11.5" FontWeight="SemiBold" Margin="0,0,0,5"/>
                                                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Name:" FontSize="11.5" FontWeight="SemiBold" Foreground="{DynamicResource SubLabelFg}" Margin="0,0,0,0"/>
                                                        <TextBlock x:Name="VdEntityName" Grid.Row="1" Grid.Column="1" FontSize="11.5" Foreground="{DynamicResource PrimaryText}"/>
                                                        <TextBlock Grid.Row="1" Grid.Column="2" Text="Custom:" FontSize="11.5" FontWeight="SemiBold" Foreground="{DynamicResource SubLabelFg}" Margin="8,0,0,0"/>
                                                        <TextBlock x:Name="VdEntityCustom" Grid.Row="1" Grid.Column="3" FontSize="11.5" FontFamily="Consolas" Foreground="{DynamicResource PrimaryText}" TextWrapping="Wrap"/>
                                                    </Grid>
                                                </Border>
                                                <TextBlock Text="Merchant" FontSize="11.5" FontWeight="Bold"
                                                           Foreground="{DynamicResource SubLabelFg}" Margin="0,0,0,6"/>
                                                <Border CornerRadius="6" Padding="10,8" Margin="0,0,0,10"
                                                        Background="{DynamicResource SearchCardBg}"
                                                        BorderBrush="{DynamicResource CardBorder}" BorderThickness="1">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="130"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="130"/>
                                                            <ColumnDefinition Width="*"/>
                                                        </Grid.ColumnDefinitions>
                                                        <Grid.RowDefinitions>
                                                            <RowDefinition Height="Auto"/>
                                                            <RowDefinition Height="Auto"/>
                                                            <RowDefinition Height="Auto"/>
                                                        </Grid.RowDefinitions>
                                                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Merchant ID:" FontSize="11.5" FontWeight="SemiBold" Foreground="{DynamicResource SubLabelFg}" Margin="0,0,0,5"/>
                                                        <TextBlock x:Name="VdMerchantId" Grid.Row="0" Grid.Column="1" FontSize="11.5" FontFamily="Consolas" Foreground="{DynamicResource PrimaryText}" TextWrapping="Wrap" Margin="0,0,0,5"/>
                                                        <TextBlock Grid.Row="0" Grid.Column="2" Text="Status:" FontSize="11.5" FontWeight="SemiBold" Foreground="{DynamicResource SubLabelFg}" Margin="8,0,0,5"/>
                                                        <StackPanel Grid.Row="0" Grid.Column="3" Orientation="Horizontal" Margin="0,0,0,5">
                                                            <TextBlock x:Name="VdMerchantStatus" FontSize="11.5" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                                            <Button x:Name="VdActivateMerchantBtn" Content="Activate" Visibility="Collapsed"
                                                                    Height="22" Padding="8,0" FontSize="11" Margin="8,0,0,0"
                                                                    Style="{StaticResource PrimaryButton}"
                                                                    Click="VdActivateMerchant_Click"/>
                                                        </StackPanel>
                                                        <TextBlock Grid.Row="1" Grid.Column="0" Text="DBA:" FontSize="11.5" FontWeight="SemiBold" Foreground="{DynamicResource SubLabelFg}" Margin="0,0,0,5"/>
                                                        <TextBlock x:Name="VdMerchantDba" Grid.Row="1" Grid.Column="1" FontSize="11.5" Foreground="{DynamicResource PrimaryText}" Margin="0,0,0,5"/>
                                                        <TextBlock Grid.Row="1" Grid.Column="2" Text="MCC:" FontSize="11.5" FontWeight="SemiBold" Foreground="{DynamicResource SubLabelFg}" Margin="8,0,0,5"/>
                                                        <TextBlock x:Name="VdMerchantMcc" Grid.Row="1" Grid.Column="3" FontSize="11.5" Foreground="{DynamicResource PrimaryText}" Margin="0,0,0,5"/>
                                                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Email:" FontSize="11.5" FontWeight="SemiBold" Foreground="{DynamicResource SubLabelFg}" Margin="0,0,0,0"/>
