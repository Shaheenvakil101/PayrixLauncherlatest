                                        <Grid.ColumnDefinitions><ColumnDefinition Width="160"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                        <TextBlock Text="Batch operations" FontWeight="SemiBold" Foreground="#FCD34D" FontSize="12" VerticalAlignment="Top"/>
                                        <TextBlock Grid.Column="1" FontSize="12" Foreground="{DynamicResource SubText}" TextWrapping="Wrap">PUT .../BatchUpdateEntries — body: { entryIds: [&quot;id1&quot;,...], status: 1, billStatus: 1 }. Processes multiple records in one call.</TextBlock>
                                    </Grid>
                                </StackPanel>
                            </Border>

