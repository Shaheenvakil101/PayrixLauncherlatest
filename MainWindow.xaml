                                                   Foreground="{DynamicResource InfoStripGreenFg}" VerticalAlignment="Center"
                                                   Text="—"
                                                   ToolTip="CompanyID from Payrix entity custom field"/>
                                    </Border>
                                    <Button Content="⧉" Height="22" Width="22" Padding="0"
                                            FontSize="11" Cursor="Hand" Margin="4,0,0,0"
                                            BorderThickness="1" BorderBrush="{DynamicResource InfoStripGreenBorder}"
                                            Background="{DynamicResource InfoStripGreenBtnBg}" Foreground="{DynamicResource InfoStripGreenFg}"
                                            Click="CopyEntityCompanyIdBtn_Click"
                                            ToolTip="Copy Company ID">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}"
                                                        BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True"><Setter Property="Background" Value="{DynamicResource InfoStripGreenBtnHover}"/></Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                    <TextBlock x:Name="EntityIdText"
                                               FontSize="11" Foreground="{DynamicResource SubLabelFg}"
                                               VerticalAlignment="Center" Margin="12,0,0,0"
                                               Text=""/>
                                    <Button Content="📋 Copy Both" Height="24" Padding="8,0"
                                            FontSize="11" Cursor="Hand" Margin="10,0,0,0"
                                            BorderThickness="1" BorderBrush="{DynamicResource InfoStripGreenBorder}"
                                            Background="{DynamicResource InfoStripGreenBtnBg}" Foreground="{DynamicResource InfoStripGreenFg}"
                                            Click="CopyEntityIdsBtn_Click"
                                            ToolTip="Copy AccountID and CompanyID to clipboard">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}"
                                                        BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True"><Setter Property="Background" Value="{DynamicResource InfoStripGreenBtnHover}"/></Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                </StackPanel>

                                <!-- ── Host DB result strip (Row 4) ── -->
                                <StackPanel Grid.Row="4" Orientation="Horizontal"
                                            Margin="0,4,0,0" Visibility="Collapsed"
                                            x:Name="HostDbInfoPanel">
                                    <Border Background="{DynamicResource InfoStripBlueBtnBg}" BorderBrush="{DynamicResource InfoStripBlueBorder}"
                                            BorderThickness="1" CornerRadius="4" Padding="6,2" Margin="0,0,8,0">
                                        <TextBlock Text="CORE DB" FontSize="10" FontWeight="Bold"
                                                   Foreground="{DynamicResource InfoStripBlueFg}" VerticalAlignment="Center"/>
                                    </Border>
                                    <TextBlock Text="Account ID:" FontSize="12" FontWeight="SemiBold"
                                               Foreground="{DynamicResource LabelFg}" VerticalAlignment="Center"
                                               Margin="0,0,6,0"/>
                                    <Border Background="{DynamicResource InfoBoxBg}" BorderBrush="{DynamicResource InfoStripBlueBorder}"
                                            BorderThickness="1" CornerRadius="4" Padding="8,3">
                                        <TextBlock x:Name="HostDbAccountIdText"
                                                   FontFamily="Consolas" FontSize="12"
                                                   Foreground="{DynamicResource InfoStripBlueFg}" VerticalAlignment="Center"
                                                   Text="—"
                                                   ToolTip="AccountID from BQECoreHost DB"/>
                                    </Border>
                                    <Button Content="⧉" Height="22" Width="22" Padding="0"
                                            FontSize="11" Cursor="Hand" Margin="4,0,0,0"
                                            BorderThickness="1" BorderBrush="{DynamicResource InfoStripBlueBorder}"
                                            Background="{DynamicResource InfoStripBlueBtnBg}" Foreground="{DynamicResource InfoStripBlueFg}"
                                            Click="CopyHostDbAccountIdBtn_Click"
                                            ToolTip="Copy Account ID">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}"
                                                        BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True"><Setter Property="Background" Value="{DynamicResource InfoStripBlueBtnHover}"/></Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                    <TextBlock Text="Company ID:" FontSize="12" FontWeight="SemiBold"
                                               Foreground="{DynamicResource LabelFg}" VerticalAlignment="Center"
                                               Margin="14,0,6,0"/>
                                    <Border Background="{DynamicResource InfoBoxBg}" BorderBrush="{DynamicResource InfoStripBlueBorder}"
                                            BorderThickness="1" CornerRadius="4" Padding="8,3">
                                        <TextBlock x:Name="HostDbCompanyIdText"
                                                   FontFamily="Consolas" FontSize="12"
                                                   Foreground="{DynamicResource InfoStripBlueFg}" VerticalAlignment="Center"
                                                   Text="—"
                                                   ToolTip="CoreCompany_ID from BQECoreHost DB"/>
                                    </Border>
                                    <Button Content="⧉" Height="22" Width="22" Padding="0"
                                            FontSize="11" Cursor="Hand" Margin="4,0,0,0"
                                            BorderThickness="1" BorderBrush="{DynamicResource InfoStripBlueBorder}"
                                            Background="{DynamicResource InfoStripBlueBtnBg}" Foreground="{DynamicResource InfoStripBlueFg}"
                                            Click="CopyHostDbCompanyIdBtn_Click"
                                            ToolTip="Copy Company ID">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}"
                                                        BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True"><Setter Property="Background" Value="{DynamicResource InfoStripBlueBtnHover}"/></Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                    <TextBlock x:Name="HostDbSourceText"
                                               FontSize="11" Foreground="{DynamicResource SubLabelFg}"
                                               VerticalAlignment="Center" Margin="12,0,0,0"
                                               Text=""/>
                                    <Button Content="📋 Copy Both" Height="24" Padding="8,0"
                                            FontSize="11" Cursor="Hand" Margin="10,0,0,0"
                                            BorderThickness="1" BorderBrush="{DynamicResource InfoStripBlueBorder}"
                                            Background="{DynamicResource InfoStripBlueBtnBg}" Foreground="{DynamicResource InfoStripBlueFg}"
                                            Click="CopyHostDbIdsBtn_Click"
                                            ToolTip="Copy AccountID and CompanyID to clipboard">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}"
                                                        BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True"><Setter Property="Background" Value="{DynamicResource InfoStripBlueBtnHover}"/></Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                </StackPanel>

                            </Grid>
                        </Border>
                        </ScrollViewer>

                        <!-- ── Configuration header (Row 1) — outside ScrollViewer so star-sizing works ── -->
                        <Border Grid.Row="1" Margin="0,0,0,4"
                                Background="{DynamicResource WebhookConfigBg}" BorderBrush="{DynamicResource WebhookConfigBorder}"
                                BorderThickness="1" CornerRadius="6" Padding="10,6">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="10"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="6"/>
                                    <ColumnDefinition Width="140"/>
                                    <ColumnDefinition Width="10"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="6"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="10"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="⚙ Configuration"
                                           FontSize="11" FontWeight="SemiBold"
                                           Foreground="{DynamicResource WebhookConfigFg}" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="2" Text="Endpoint:" FontSize="11"
                                           Foreground="{DynamicResource SubLabelFg}" VerticalAlignment="Center"/>
                                <ComboBox x:Name="WebhookEnvBox" Grid.Column="4" Height="26"
                                          VerticalContentAlignment="Center" FontSize="12"
                                          SelectionChanged="WebhookEnvBox_SelectionChanged" SelectedIndex="0">
                                    <ComboBoxItem Content="Local"/>
                                    <ComboBoxItem Content="Staging"/>
                                    <ComboBoxItem Content="Sprint"/>
                                    <ComboBoxItem Content="Production"/>
                                    <ComboBoxItem Content="Custom"/>
                                </ComboBox>
                                <TextBlock Grid.Column="6" Text="URL:" FontSize="11"
                                           Foreground="{DynamicResource SubLabelFg}" VerticalAlignment="Center"/>
                                <TextBox x:Name="WebhookUrlBox" Grid.Column="8" Height="26" Padding="7,0"
                                         VerticalContentAlignment="Center" FontSize="11" FontFamily="Consolas"
                                         BorderBrush="{DynamicResource InputBorder}" BorderThickness="1"/>
                                <Border x:Name="WebhookConfigToggleBorder2" Grid.Column="10"
                                        Cursor="Hand" CornerRadius="4" Padding="8,3"
                                        Background="Transparent"
                                        BorderBrush="{DynamicResource WebhookConfigBorder}" BorderThickness="1"
                                        MouseLeftButtonUp="WebhookConfigToggle_Click"
                                        ToolTip="Show / hide date filter, entity custom field and DB connection strings">
                                    <TextBlock x:Name="WebhookConfigToggleText2"
                                               Text="Config ▼" FontSize="10" FontWeight="SemiBold"
                                               Foreground="{DynamicResource WebhookConfigFg}"/>
                                </Border>
                            </Grid>
                        </Border>

                        <!-- ── Transaction Detail Card (compact single row) ──── -->
                        <Border x:Name="TxnDetailCard" Grid.Row="2"
                                Visibility="Collapsed"
                                Background="{DynamicResource CardBg}" BorderBrush="{DynamicResource CardBorder}"
                                BorderThickness="1" CornerRadius="8" Margin="0,0,0,8" Padding="0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/><!-- Left badge panel -->
                                    <ColumnDefinition Width="*"/> <!-- 5 tiles -->
                                </Grid.ColumnDefinitions>

                                <!-- Left colored badge — horizontal compact -->
                                <Border x:Name="TxnCardLeftPanel" Grid.Column="0"
                                        Background="#7C3AED" CornerRadius="8,0,0,8" Padding="14,10">
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <TextBlock x:Name="TxnCardIcon" Text="🏦"
                                                   FontSize="20" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock x:Name="TxnCardTypeLabel" Text="ACH RETURN"
                                                       FontSize="12" FontWeight="Bold" Foreground="White"/>
                                            <StackPanel Orientation="Horizontal" Margin="0,3,0,0">
                                                <Border x:Name="TxnCardStatusBadge"
                                                        Background="#7C3AED" CornerRadius="8" Padding="6,2"
                                                        Margin="0,0,6,0">
                                                    <TextBlock x:Name="TxnCardStatusBadgeText" Text="Processed"
                                                               FontSize="9" FontWeight="Bold" Foreground="White"/>
                                                </Border>
                                                <TextBlock x:Name="TxnCardStatusText" Text="✓ Settled"
                                                           FontSize="9" Foreground="#86EFAC" FontWeight="SemiBold"
                                                           VerticalAlignment="Center"/>
                                            </StackPanel>
                                            <TextBlock x:Name="TxnCardSubType" Text="Type: ACH Return"
                                                       FontSize="9" Foreground="#C4B5FD" Margin="0,2,0,0"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>

                                <!-- Right: 5 tiles in a single row -->
                                <Grid Grid.Column="1" Margin="10,8,10,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="2*"/><!-- TxnID wider -->
                                        <ColumnDefinition Width="6"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="6"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="6"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="6"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Tile: Transaction ID -->
                                    <Border Grid.Column="0"
                                            Background="{DynamicResource TileCardBg}" BorderBrush="{DynamicResource CardBorder}"
                                            BorderThickness="1" CornerRadius="5" Padding="8,6">
                                        <StackPanel>
                                            <TextBlock Text="TRANSACTION ID" FontSize="8" FontWeight="Bold"
                                                       Foreground="{DynamicResource SubText}" Margin="0,0,0,3"/>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock x:Name="TxnCardId" Text="—"
                                                           FontFamily="Consolas" FontSize="10"
                                                           Foreground="{DynamicResource PrimaryText}"
                                                           TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/>
                                                <Button Grid.Column="1" x:Name="CopyTxnCardIdBtn"
                                                        Content="⧉" Width="18" Height="18" Padding="0"
                                                        FontSize="10" Cursor="Hand" Margin="3,0,0,0"
                                                        BorderThickness="1" BorderBrush="{DynamicResource CopyBtnBorder}"
                                                        Background="{DynamicResource CopyBtnBg}" Foreground="{DynamicResource SubText}"
                                                        ToolTip="Copy Transaction ID"
                                                        Click="CopyTxnCardIdBtn_Click">
                                                    <Button.Template>
                                                        <ControlTemplate TargetType="Button">
                                                            <Border Background="{TemplateBinding Background}"
                                                                    BorderBrush="{TemplateBinding BorderBrush}"
                                                                    BorderThickness="{TemplateBinding BorderThickness}"
                                                                    CornerRadius="3">
                                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                            </Border>
                                                        </ControlTemplate>
                                                    </Button.Template>
                                                </Button>
                                            </Grid>
                                        </StackPanel>
                                    </Border>

                                    <!-- Tile: Amount -->
                                    <Border Grid.Column="2"
                                            Background="{DynamicResource TileCardBg}" BorderBrush="{DynamicResource CardBorder}"
                                            BorderThickness="1" CornerRadius="5" Padding="8,6">
                                        <StackPanel>
                                            <TextBlock Text="AMOUNT" FontSize="8" FontWeight="Bold"
                                                       Foreground="{DynamicResource SubText}" Margin="0,0,0,3"/>
                                            <TextBlock x:Name="TxnCardAmount" Text="—"
                                                       FontFamily="Consolas" FontSize="12" FontWeight="Bold"
                                                       Foreground="#7C3AED"/>
                                        </StackPanel>
                                    </Border>

                                    <!-- Tile: Timestamp -->
                                    <Border Grid.Column="4"
                                            Background="{DynamicResource TileCardBg}" BorderBrush="{DynamicResource CardBorder}"
                                            BorderThickness="1" CornerRadius="5" Padding="8,6">
                                        <StackPanel>
                                            <TextBlock Text="TIMESTAMP" FontSize="8" FontWeight="Bold"
                                                       Foreground="{DynamicResource SubText}" Margin="0,0,0,3"/>
                                            <TextBlock x:Name="TxnCardTimestamp" Text="—"
                                                       FontSize="10" Foreground="{DynamicResource PrimaryText}"
                                                       TextTrimming="CharacterEllipsis"/>
                                        </StackPanel>
                                    </Border>

                                    <!-- Tile: Descriptor -->
                                    <Border Grid.Column="6"
                                            Background="{DynamicResource TileCardBg}" BorderBrush="{DynamicResource CardBorder}"
                                            BorderThickness="1" CornerRadius="5" Padding="8,6">
                                        <StackPanel>
                                            <TextBlock Text="DESCRIPTOR" FontSize="8" FontWeight="Bold"
                                                       Foreground="{DynamicResource SubText}" Margin="0,0,0,3"/>
                                            <TextBlock x:Name="TxnCardDescriptor" Text="—"
                                                       FontSize="10" Foreground="{DynamicResource PrimaryText}"
                                                       TextTrimming="CharacterEllipsis"/>
                                        </StackPanel>
                                    </Border>

                                    <!-- Tile: Payment Type -->
                                    <Border Grid.Column="8"
                                            Background="{DynamicResource TileCardBg}" BorderBrush="{DynamicResource CardBorder}"
                                            BorderThickness="1" CornerRadius="5" Padding="8,6">
                                        <StackPanel>
                                            <TextBlock Text="PAYMENT TYPE" FontSize="8" FontWeight="Bold"
                                                       Foreground="{DynamicResource SubText}" Margin="0,0,0,3"/>
                                            <TextBlock x:Name="TxnCardPaymentType" Text="—"
                                                       FontSize="10" Foreground="{DynamicResource PrimaryText}"/>
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </Grid>
                        </Border>

                        <!-- Controls row -->
                        <Grid Grid.Row="3" Margin="0,4,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <Button x:Name="RunAllTestsBtn" Grid.Column="1"
                                    Content="▶  Run All Tests"
                                    Height="30" Padding="14,0" FontSize="12" FontWeight="SemiBold"
                                    Cursor="Hand" BorderThickness="0"
                                    Background="#7C3AED" Foreground="White"
                                    Click="RunAllTestsBtn_Click"
                                    ToolTip="Run all webhook test cases against the selected endpoint">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}"
                                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#6D28D9"/>
                                            </Trigger>
                                            <Trigger Property="IsEnabled" Value="False">
                                                <Setter Property="Background" Value="#86EFAC"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                            <Button x:Name="ResetTestsBtn" Grid.Column="3"
                                    Content="↺  Reset"
                                    Click="ResetTestsBtn_Click"
                                    ToolTip="Reset all test results to their initial state">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="Foreground" Value="{DynamicResource LabelFg}"/>
                                        <Setter Property="BorderBrush" Value="{DynamicResource CardBorder}"/>
                                        <Setter Property="BorderThickness" Value="1"/>
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="{DynamicResource DarkBtnBgHover}"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                        </Grid>

                        <!-- ── Results + Summary + Payload wrapper ── -->
                        <Grid Grid.Row="4">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>   <!-- Row 0: Test Cases header -->
                                <RowDefinition x:Name="TestListRow" Height="160" MinHeight="0"/><!-- Row 1: test list (fixed default, collapsible) -->
                                <RowDefinition Height="Auto"/>   <!-- Row 2: summary bar -->
                                <RowDefinition Height="5"/>      <!-- Row 3: drag splitter -->
                                <RowDefinition Height="*" MinHeight="120"/><!-- Row 4: JSON payload (fills rest) -->
                            </Grid.RowDefinitions>

                        <!-- Test Cases header -->
                        <Grid Grid.Row="0" Margin="0,0,0,5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="6"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="Test Cases" FontSize="13" FontWeight="SemiBold"
                                           Foreground="{DynamicResource LabelFg}" VerticalAlignment="Center"/>
                                <Border Background="{DynamicResource SummaryBarBg}" BorderBrush="{DynamicResource CardBorder}"
                                        BorderThickness="1" CornerRadius="10" Padding="7,1" Margin="8,0,0,0">
                                    <TextBlock x:Name="TestCaseCountText" FontSize="11"
                                               Foreground="{DynamicResource SubLabelFg}" VerticalAlignment="Center"
                                               Text="0 tests"/>
                                </Border>
                            </StackPanel>
                            <Button Grid.Column="2" x:Name="ExportWebhookJsonBtn"
                                    Content="⬇ Export JSON" Height="26" Padding="10,0" FontSize="11"
                                    Cursor="Hand" BorderThickness="1" BorderBrush="{DynamicResource CardBorder}"
                                    Background="Transparent" Foreground="{DynamicResource LabelFg}"
                                    Click="ExportWebhookJsonBtn_Click"
                                    ToolTip="Export test results as JSON">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="5" Padding="{TemplateBinding Padding}">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True"><Setter Property="Background" Value="{DynamicResource DarkBtnBgHover}"/></Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                            <Button Grid.Column="4" x:Name="ExportWebhookCsvBtn"
                                    Content="⬇ Export CSV" Height="26" Padding="10,0" FontSize="11"
                                    Cursor="Hand" BorderThickness="1" BorderBrush="{DynamicResource CardBorder}"
                                    Background="Transparent" Foreground="{DynamicResource LabelFg}"
                                    Click="ExportWebhookCsvBtn_Click"
                                    ToolTip="Export test results as CSV">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="5" Padding="{TemplateBinding Padding}">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True"><Setter Property="Background" Value="{DynamicResource DarkBtnBgHover}"/></Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </Grid>

                        <!-- Results grid -->
                        <DataGrid x:Name="TestResultsGrid" Grid.Row="1"
                                  AutoGenerateColumns="False" IsReadOnly="True"
                                  CanUserResizeColumns="True" GridLinesVisibility="Horizontal"
                                  AlternatingRowBackground="{DynamicResource GridAltRowBg}" RowBackground="{DynamicResource GridRowBg}"
                                  HeadersVisibility="Column" BorderThickness="1" BorderBrush="{DynamicResource CardBorder2}"
                                  SelectionUnit="FullRow" SelectionMode="Single"
                                  HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto"
                                  FontSize="12" SelectionChanged="TestResultsGrid_SelectionChanged">
                            <DataGrid.ColumnHeaderStyle>
                                <Style TargetType="DataGridColumnHeader">
                                    <Setter Property="Background" Value="{DynamicResource GridHeaderBg}"/>
                                    <Setter Property="Foreground" Value="{DynamicResource GridHeaderFg}"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                    <Setter Property="Padding" Value="10,8"/>
                                    <Setter Property="BorderBrush" Value="{DynamicResource GridBorder}"/>
                                    <Setter Property="BorderThickness" Value="0,0,1,1"/>
                                </Style>
                            </DataGrid.ColumnHeaderStyle>
                            <DataGrid.RowStyle>
                                <Style TargetType="DataGridRow">
                                    <Setter Property="Background" Value="{DynamicResource GridRowBg}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Status}" Value="{x:Static local:TestStatus.Pass}">
                                            <Setter Property="Background" Value="{DynamicResource TestRowPassBg}"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Status}" Value="{x:Static local:TestStatus.Fail}">
                                            <Setter Property="Background" Value="{DynamicResource TestRowFailBg}"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Status}" Value="{x:Static local:TestStatus.Running}">
                                            <Setter Property="Background" Value="{DynamicResource TestRowRunningBg}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGrid.RowStyle>
                            <DataGrid.Columns>
                                <DataGridTemplateColumn Header="Status" Width="80">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Border CornerRadius="4" Padding="6,2" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="#F1F5F9"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Status}" Value="{x:Static local:TestStatus.Pass}">
                                                                <Setter Property="Background" Value="#DCFCE7"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Status}" Value="{x:Static local:TestStatus.Fail}">
                                                                <Setter Property="Background" Value="#FEE2E2"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Status}" Value="{x:Static local:TestStatus.Running}">
                                                                <Setter Property="Background" Value="#FEF3C7"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <TextBlock Text="{Binding StatusLabel}" FontWeight="Bold" FontSize="11">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Foreground" Value="#6B7280"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Status}" Value="{x:Static local:TestStatus.Pass}">
                                                                    <Setter Property="Foreground" Value="#4C1D95"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Status}" Value="{x:Static local:TestStatus.Fail}">
                                                                    <Setter Property="Foreground" Value="#991B1B"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Status}" Value="{x:Static local:TestStatus.Running}">
                                                                    <Setter Property="Foreground" Value="#92400E"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </Border>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTextColumn Header="Test Name"   Binding="{Binding Name}"       Width="*"/>
                                <DataGridTextColumn Header="Entity ID"   Binding="{Binding EntityId}"   Width="200"/>
                                <DataGridTextColumn Header="Entity Name" Binding="{Binding EntityName}" Width="160"/>
                                <DataGridTextColumn Header="Webhook Created"
                                                    Binding="{Binding PayrixCreatedDisplay}"
                                                    Width="140"/>
                                <DataGridTextColumn Header="Webhook Processed"
                                                    Binding="{Binding PayrixSentDisplay}"
                                                    Width="140"/>
                                <DataGridTemplateColumn Header="Tag" Width="84">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Border CornerRadius="10" Padding="8,2"
                                                    Background="{Binding TagBg}"
                                                    HorizontalAlignment="Left" VerticalAlignment="Center" Margin="4,2">
                                                <TextBlock Text="{Binding Tag}" FontSize="11" FontWeight="SemiBold"
                                                           Foreground="{Binding TagFg}"/>
                                            </Border>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTextColumn Header="Description" Binding="{Binding Description}" Width="260"/>
                                <DataGridTextColumn Header="HTTP"        Binding="{Binding HttpCode}"    Width="55"/>
                                <DataGridTextColumn Header="ms"          Binding="{Binding DurationMs}"  Width="55"/>
                                <DataGridTemplateColumn Header="Detail" Width="220">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0"
                                                           Text="{Binding Detail}"
                                                           FontSize="11"
                                                           TextTrimming="CharacterEllipsis"
                                                           VerticalAlignment="Center"
                                                           ToolTip="{Binding Detail}"
                                                           Margin="4,0,2,0"/>
                                                <Button Grid.Column="1"
                                                        x:Name="DismissErrorBtn"
                                                        Content="✕"
                                                        Tag="{Binding}"
                                                        Click="DismissTestError_Click"
                                                        Height="20" Width="20"
                                                        FontSize="10" FontWeight="Bold"
                                                        Cursor="Hand" BorderThickness="0"
                                                        Background="#EF4444" Foreground="White"
                                                        Margin="2,2"
                                                        ToolTip="Dismiss error and reset test">
                                                    <Button.Style>
                                                        <Style TargetType="Button">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsFailed}" Value="True">
                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Button.Style>
                                                    <Button.Template>
                                                        <ControlTemplate TargetType="Button">
                                                            <Border Background="{TemplateBinding Background}"
                                                                    CornerRadius="4" Padding="{TemplateBinding Padding}">
                                                                <ContentPresenter HorizontalAlignment="Center"
                                                                                  VerticalAlignment="Center"/>
                                                            </Border>
                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter Property="Background" Value="#DC2626"/>
                                                                </Trigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Button.Template>
                                                </Button>
                                            </Grid>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTemplateColumn Header="Run" Width="70">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Button Content="▶ Run"
                                                    Tag="{Binding}"
                                                    Click="RunSingleTestBtn_Click"
                                                    Height="26" Padding="8,0"
                                                    FontSize="11" FontWeight="SemiBold"
                                                    Cursor="Hand" BorderThickness="0"
                                                    Background="#7C3AED" Foreground="White"
                                                    Margin="4,2">
                                                <Button.Template>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border Background="{TemplateBinding Background}"
                                                                CornerRadius="4" Padding="{TemplateBinding Padding}">
                                                            <ContentPresenter HorizontalAlignment="Center"
                                                                              VerticalAlignment="Center"/>
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter Property="Background" Value="#6D28D9"/>
                                                            </Trigger>
                                                            <Trigger Property="IsEnabled" Value="False">
                                                                <Setter Property="Background" Value="#A5B4FC"/>
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Button.Template>
                                            </Button>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>

                        <!-- Summary bar + collapse/expand toggle -->
                        <Border Grid.Row="2" Background="{DynamicResource SummaryBarBg}" BorderBrush="{DynamicResource SummaryBarBorder}"
                                BorderThickness="1" CornerRadius="6" Padding="8,4" Margin="0,5,0,0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <!-- Minimize/Expand toggle -->
                                <Button x:Name="TestListCollapseBtn" Grid.Column="0"
                                        Content="▲" Width="24" Height="22" Padding="0"
                                        FontSize="10" FontWeight="Bold" Cursor="Hand"
                                        Background="Transparent" BorderThickness="0"
                                        Foreground="{DynamicResource SubText}"
                                        Click="TestListCollapseBtn_Click"
                                        ToolTip="Minimize test list to see full JSON payload">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}" CornerRadius="4"
                                                    Padding="{TemplateBinding Padding}" BorderThickness="1"
                                                    BorderBrush="{DynamicResource CardBorder}">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="{DynamicResource DarkBtnBgHover}"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                                <TextBlock x:Name="WebhookTestSummary" Grid.Column="1"
                                           Text="Select an environment and click Run All Tests"
                                           FontSize="12" Foreground="{DynamicResource SubLabelFg}"
                                           VerticalAlignment="Center" Margin="8,0,0,0"/>
                                <TextBlock x:Name="WebhookTestProgress" Grid.Column="2"
                                           FontSize="11" Foreground="{DynamicResource SubText}"
                                           VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <Button x:Name="ClearWebhookErrorBtn" Grid.Column="3"
                                        Content="✕" Width="22" Height="22" Padding="0"
                                        FontSize="10" FontWeight="Bold" Cursor="Hand"
                                        Background="#EF4444" Foreground="White" BorderThickness="0"
                                        ToolTip="Clear error / dismiss"
                                        Visibility="Collapsed"
                                        Click="ClearWebhookError_Click">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}" CornerRadius="4"
                                                    Padding="{TemplateBinding Padding}">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="#DC2626"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                            </Grid>
                        </Border>

                        <!-- Drag handle between test list and JSON editor -->
                        <GridSplitter Grid.Row="3" Height="5" HorizontalAlignment="Stretch"
                                      Background="{DynamicResource CardBorder2}" Cursor="SizeNS"
                                      ResizeDirection="Rows" ResizeBehavior="PreviousAndNext"
                                      ToolTip="Drag to resize test list / JSON editor"/>

                        <!-- Payload panel (editable + toolbar) -->
                        <Border Grid.Row="4" BorderBrush="{DynamicResource CardBorder2}" BorderThickness="1" CornerRadius="6" Margin="0,2,0,0">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>  <!-- Row 0: toolbar -->
                                    <RowDefinition Height="Auto"/>  <!-- Row 1: signup guide (collapsible) -->
                                    <RowDefinition Height="*" MinHeight="100"/><!-- Row 2: JSON editor (always visible) -->
                                </Grid.RowDefinitions>

                                <!-- Toolbar -->
                                <Border Grid.Row="0" Background="#1E293B" CornerRadius="6,6,0,0" Padding="8,5">
                                    <StackPanel>
                                        <!-- Title row + action buttons -->
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="JSON Payload  (editable)"
                                                       FontSize="11" FontWeight="SemiBold"
                                                       Foreground="#94A3B8" VerticalAlignment="Center"/>
                                            <Border x:Name="ReplaceToggleBorder"
                                                    Cursor="Hand" CornerRadius="3" Padding="6,2" Margin="10,0,0,0"
                                                    Background="#334155" BorderBrush="#475569" BorderThickness="1"
                                                    MouseLeftButtonUp="ReplaceRowToggle_Click"
                                                    ToolTip="Show / hide the field-replace bar">
                                                <TextBlock x:Name="ReplaceToggleText" Text="🔄 Replace ▼"
                                                           FontSize="10" Foreground="#94A3B8"/>
                                            </Border>
                                        </StackPanel>
                                            <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="0,0,2,0">
                                            <Button Content="📋 Copy All"
                                                    Click="WebhookPayloadCopyAll_Click"
                                                    Height="24" Padding="8,0" Margin="0,0,4,0"
                                                    FontSize="11" Cursor="Hand" BorderThickness="0"
                                                    Background="#334155" Foreground="#E2E8F0">
                                                <Button.Template>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter Property="Background" Value="#475569"/>
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Button.Template>
                                            </Button>
                                            <Button Content="📌 Paste (Replace All)"
                                                    Click="WebhookPayloadPaste_Click"
                                                    Height="24" Padding="8,0" Margin="0,0,4,0"
                                                    FontSize="11" Cursor="Hand" BorderThickness="0"
                                                    Background="#334155" Foreground="#E2E8F0">
                                                <Button.Template>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter Property="Background" Value="#475569"/>
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Button.Template>
                                            </Button>
                                            <Button Content="🗑 Clear"
                                                    Click="WebhookPayloadClear_Click"
                                                    Height="24" Padding="8,0" Margin="0,0,4,0"
                                                    FontSize="11" Cursor="Hand" BorderThickness="0"
                                                    Background="#334155" Foreground="#E2E8F0">
                                                <Button.Template>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter Property="Background" Value="#475569"/>
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Button.Template>
                                            </Button>
                                            <Button Content="⎌ Undo"
                                                    Click="PayloadUndoBtn_Click"
                                                    Height="24" Padding="8,0"
                                                    FontSize="11" Cursor="Hand" BorderThickness="0"
                                                    Background="#334155" Foreground="#E2E8F0"
                                                    ToolTip="Undo last programmatic change to payload">
                                                <Button.Template>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter Property="Background" Value="#475569"/>
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Button.Template>
                                            </Button>
                                        </StackPanel>
                                        </Grid>

                                        <!-- Replace field row (hidden by default) -->
                                        <StackPanel x:Name="ReplaceFieldPanel"
                                                    Orientation="Horizontal" Margin="0,5,0,0"
                                                    Visibility="Collapsed">
                                            <TextBlock Text="Replace field:" FontSize="11" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource SubText}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                            <TextBox x:Name="ReplaceFieldNameBox"
                                                     Width="120" Height="24" Padding="6,0"
                                                     FontFamily="Consolas" FontSize="11"
                                                     Background="#334155" Foreground="#E2E8F0"
                                                     CaretBrush="White" BorderBrush="#475569" BorderThickness="1"
                                                     VerticalContentAlignment="Center"
                                                     ToolTip="JSON field name to replace (e.g.  custom  or  email)"/>
                                            <TextBlock Text="→" FontSize="13" Foreground="#64748B"
                                                       VerticalAlignment="Center" Margin="6,0"/>
                                            <TextBox x:Name="ReplaceFieldValueBox"
                                                     Width="280" Height="24" Padding="6,0"
                                                     FontFamily="Consolas" FontSize="11"
                                                     Background="#334155" Foreground="#E2E8F0"
                                                     CaretBrush="White" BorderBrush="#475569" BorderThickness="1"
                                                     VerticalContentAlignment="Center"
                                                     ToolTip="New value to set (string, number or null — quotes added automatically for strings)"/>
                                            <Button Content="✔ Apply"
                                                    Click="ReplaceFieldBtn_Click"
                                                    Height="24" Padding="10,0" Margin="6,0,0,0"
                                                    FontSize="11" FontWeight="SemiBold" Cursor="Hand"
                                                    BorderThickness="0" Background="#7C3AED" Foreground="White">
                                                <Button.Template>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True"><Setter Property="Background" Value="#6D28D9"/></Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Button.Template>
                                            </Button>
                                            <!-- Quick-fill chips -->
                                            <TextBlock Text="Quick:" FontSize="10" Foreground="#64748B"
                                                       VerticalAlignment="Center" Margin="12,0,4,0"/>
                                            <Button Content="custom"   Tag="custom"   Click="QuickFieldChip_Click" Height="22" Padding="7,0" Margin="0,0,3,0" FontSize="10" Cursor="Hand" BorderThickness="1" BorderBrush="#475569" Background="#1E293B" Foreground="{DynamicResource SubText}"><Button.Template><ControlTemplate TargetType="Button"><Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="3" Padding="{TemplateBinding Padding}"><ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/></Border><ControlTemplate.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter Property="Background" Value="#334155"/></Trigger></ControlTemplate.Triggers></ControlTemplate></Button.Template></Button>
                                            <Button Content="email"    Tag="email"    Click="QuickFieldChip_Click" Height="22" Padding="7,0" Margin="0,0,3,0" FontSize="10" Cursor="Hand" BorderThickness="1" BorderBrush="#475569" Background="#1E293B" Foreground="{DynamicResource SubText}"><Button.Template><ControlTemplate TargetType="Button"><Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="3" Padding="{TemplateBinding Padding}"><ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/></Border><ControlTemplate.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter Property="Background" Value="#334155"/></Trigger></ControlTemplate.Triggers></ControlTemplate></Button.Template></Button>
                                            <Button Content="name"     Tag="name"     Click="QuickFieldChip_Click" Height="22" Padding="7,0" Margin="0,0,3,0" FontSize="10" Cursor="Hand" BorderThickness="1" BorderBrush="#475569" Background="#1E293B" Foreground="{DynamicResource SubText}"><Button.Template><ControlTemplate TargetType="Button"><Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="3" Padding="{TemplateBinding Padding}"><ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/></Border><ControlTemplate.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter Property="Background" Value="#334155"/></Trigger></ControlTemplate.Triggers></ControlTemplate></Button.Template></Button>
                                            <Button Content="id"       Tag="id"       Click="QuickFieldChip_Click" Height="22" Padding="7,0" Margin="0,0,3,0" FontSize="10" Cursor="Hand" BorderThickness="1" BorderBrush="#475569" Background="#1E293B" Foreground="{DynamicResource SubText}"><Button.Template><ControlTemplate TargetType="Button"><Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="3" Padding="{TemplateBinding Padding}"><ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/></Border><ControlTemplate.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter Property="Background" Value="#334155"/></Trigger></ControlTemplate.Triggers></ControlTemplate></Button.Template></Button>
                                            <Button Content="txnId"    Tag="txnId"    Click="QuickFieldChip_Click" Height="22" Padding="7,0" Margin="0,0,0,0" FontSize="10" Cursor="Hand" BorderThickness="1" BorderBrush="#475569" Background="#1E293B" Foreground="{DynamicResource SubText}"><Button.Template><ControlTemplate TargetType="Button"><Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="3" Padding="{TemplateBinding Padding}"><ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/></Border><ControlTemplate.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter Property="Background" Value="#334155"/></Trigger></ControlTemplate.Triggers></ControlTemplate></Button.Template></Button>
                                            <TextBlock x:Name="ReplaceFieldStatus" FontSize="11" Foreground="#4ADE80"
                                                       VerticalAlignment="Center" Margin="10,0,0,0" Text=""/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>

                                <!-- ── Merchant Signup Flow Guide (shown only for types 8 & 9) ── -->
                                <Border x:Name="MerchantSignupGuide"
                                        Grid.Row="1" Margin="0,0,0,0"
                                        Background="#0F172A" BorderBrush="#334155" BorderThickness="1"
                                        CornerRadius="6" Padding="12,8"
                                        Visibility="Collapsed">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- Step 1 -->
                                        <Border Grid.Column="0" CornerRadius="5" Padding="10,6"
                                                Background="#1E293B" BorderThickness="1"
                                                BorderBrush="{Binding Tag, ElementName=SignupStep1Badge}">
                                            <StackPanel>
                                                <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                                    <Border x:Name="SignupStep1Badge"
                                                            CornerRadius="10" Padding="7,2" Margin="0,0,6,0"
                                                            Background="#7C3AED" Tag="#7C3AED">
                                                        <TextBlock Text="Step 1" FontSize="10" FontWeight="Bold" Foreground="White"/>
                                                    </Border>
                                                    <TextBlock Text="Entities Created" FontSize="12" FontWeight="SemiBold"
                                                               Foreground="#C7D2FE" VerticalAlignment="Center"/>
                                                    <TextBlock x:Name="SignupStep1Done" Text=" ✓" FontSize="12"
                                                               Foreground="#4ADE80" VerticalAlignment="Center"
                                                               Visibility="Collapsed"/>
                                                </StackPanel>
                                                <TextBlock FontSize="11" Foreground="#94A3B8" TextWrapping="Wrap">
                                                    Select type <Run FontWeight="Bold" Foreground="#C7D2FE">Entities Created</Run>, click
                                                    <Run FontWeight="Bold" Foreground="#C7D2FE">Fetch</Run> then
                                                    <Run FontWeight="Bold" Foreground="#C7D2FE">Send POST</Run>.
                                                    Stores the entity in BQE Core's signup queue.
                                                </TextBlock>
                                            </StackPanel>
                                        </Border>

                                        <!-- Arrow -->
                                        <TextBlock Grid.Column="1" Text="→" FontSize="20" Foreground="#475569"
                                                   VerticalAlignment="Center" HorizontalAlignment="Center"
                                                   Margin="10,0"/>

                                        <!-- Step 2 -->
                                        <Border Grid.Column="2" CornerRadius="5" Padding="10,6"
                                                Background="#1E293B" BorderThickness="1"
                                                BorderBrush="{Binding Tag, ElementName=SignupStep2Badge}">
                                            <StackPanel>
                                                <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                                    <Border x:Name="SignupStep2Badge"
                                                            CornerRadius="10" Padding="7,2" Margin="0,0,6,0"
                                                            Background="#7C3AED" Tag="#7C3AED">
                                                        <TextBlock Text="Step 2" FontSize="10" FontWeight="Bold" Foreground="White"/>
                                                    </Border>
                                                    <TextBlock Text="Merchant Boarded" FontSize="12" FontWeight="SemiBold"
                                                               Foreground="#DDD6FE" VerticalAlignment="Center"/>
                                                    <TextBlock x:Name="SignupStep2Done" Text=" ✓" FontSize="12"
                                                               Foreground="#4ADE80" VerticalAlignment="Center"
                                                               Visibility="Collapsed"/>
                                                </StackPanel>
                                                <TextBlock FontSize="11" Foreground="#94A3B8" TextWrapping="Wrap">
                                                    Select type <Run FontWeight="Bold" Foreground="#DDD6FE">Merchant Boarded</Run>, click
                                                    <Run FontWeight="Bold" Foreground="#DDD6FE">Fetch</Run> then
                                                    <Run FontWeight="Bold" Foreground="#DDD6FE">Send POST</Run>.
                                                    Completes ePayments signup in BQE Core.
                                                </TextBlock>
                                            </StackPanel>
                                        </Border>

                                        <!-- Bottom row: diagnostics -->
                                        <StackPanel Grid.Row="1" Grid.ColumnSpan="3"
                                                    Orientation="Horizontal" Margin="0,8,0,0">
                                            <Button x:Name="CheckSignupStateBtn"
                                                    Content="🔎 Check DB State"
                                                    Click="CheckSignupStateBtn_Click"
                                                    Height="26" Padding="10,0"
                                                    FontSize="11" FontWeight="SemiBold" Cursor="Hand"
                                                    BorderThickness="0" Background="#0F172A"
                                                    Foreground="#94A3B8">
                                                <Button.Template>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border Background="{TemplateBinding Background}" CornerRadius="4"
                                                                BorderBrush="#334155" BorderThickness="1"
                                                                Padding="{TemplateBinding Padding}">
                                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter Property="Background" Value="#1E293B"/>
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Button.Template>
                                            </Button>
                                            <TextBlock x:Name="SignupStateResult"
                                                       FontSize="11" Foreground="#94A3B8"
                                                       VerticalAlignment="Center" Margin="10,0,0,0"
                                                       TextWrapping="Wrap" Text=""
                                                       ToolTip="{Binding Text, RelativeSource={RelativeSource Self}}"/>
                                        </StackPanel>

                                    </Grid>
                                </Border>

                                <!-- Draggable splitter between guide and payload -->
                                <GridSplitter Grid.Row="2" Height="4" HorizontalAlignment="Stretch"
                                              Background="#334155" Cursor="SizeNS"
                                              ResizeDirection="Rows" ResizeBehavior="PreviousAndNext"
                                              Visibility="{Binding Visibility, ElementName=MerchantSignupGuide}"/>

                                <!-- Editable JSON box -->
                                <TextBox x:Name="WebhookPayloadBox" Grid.Row="2"
                                         IsReadOnly="False"
                                         FontFamily="Consolas" FontSize="11"
                                         Background="{DynamicResource CodeBg}" Foreground="{DynamicResource CodeFg}"
                                         CaretBrush="White" SelectionBrush="#7C3AED"
                                         BorderThickness="0"
                                         Padding="10" TextWrapping="NoWrap"
                                         VerticalScrollBarVisibility="Auto"
                                         HorizontalScrollBarVisibility="Auto"
                                         AcceptsReturn="True" AcceptsTab="True"
                                         SpellCheck.IsEnabled="False"
                                         Tag="Select a webhook type and click Fetch to load payload — or paste / type JSON directly here"/>
                            </Grid>
                        </Border>
                        </Grid><!-- end Results+Summary+Payload wrapper -->
                    </Grid><!-- end Webhook Tests Grid -->
                
            </Grid>
        </Grid>
        </Grid><!-- inner layout grid (sidebar + content) -->

        <!-- ══ Celebration canvas — balloons + confetti ══ -->
        <Canvas x:Name="CelebrationCanvas"
                Grid.RowSpan="2"
                Panel.ZIndex="9998"
                IsHitTestVisible="False"
                ClipToBounds="True"/>

        <!-- ══ Success toast — slides up from bottom, auto-dismisses ══ -->
        <Border x:Name="ToastBorder"
                Grid.RowSpan="2"
                HorizontalAlignment="Center" VerticalAlignment="Bottom"
                Margin="0,0,0,32"
                Panel.ZIndex="10000"
                Visibility="Collapsed" Opacity="0"
                IsHitTestVisible="False"
                Background="#7C3AED" CornerRadius="12"
                Padding="20,14,20,14"
                MinWidth="260">
            <Border.Effect>
                <DropShadowEffect BlurRadius="20" ShadowDepth="4" Color="#000000" Opacity="0.20"/>
            </Border.Effect>
            <Border.RenderTransform>
                <TranslateTransform x:Name="ToastSlide" Y="40"/>
            </Border.RenderTransform>
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="✅  " FontSize="16" VerticalAlignment="Center"/>
                <TextBlock x:Name="ToastText"
                           Text="All transactions fetched — enjoy!"
                           FontSize="14" FontWeight="SemiBold"
                           Foreground="White" VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

    </Grid><!-- outer grid (content + global progress bar row) -->
</Window>












