<Window x:Class="PayrixLauncher.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:PayrixLauncher.Models"
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        mc:Ignorable="d"
        Title="PayrixViewer — ePayment Tools" Height="960" Width="1250"
        MinWidth="800" MinHeight="600"
        WindowState="Maximized"
        WindowStartupLocation="CenterScreen"
        Icon="pack://application:,,,/app.ico"
        FontFamily="Segoe UI"
        TextOptions.TextFormattingMode="Display"
        Background="{DynamicResource WindowBg}">

    <Window.Resources>

        <!-- Converts a hex colour string (e.g. "#17A34A") to a SolidColorBrush.
             Used by the Status badge column to drive background from StatusColor property. -->
        <local:StringToBrushConverter x:Key="StringToBrushConverter"/>
        <local:PctToWidthConverter    x:Key="PctToWidthConverter"/>

        <!-- Implicit TextBlock — QB Inter/Segoe UI, theme-aware foreground -->
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource PrimaryText}"/>
            <Setter Property="FontFamily" Value="Segoe UI Variable Display, Segoe UI Variable Text, Inter, Segoe UI"/>
        </Style>

        <!-- Shared right-click context menu for DataGrids -->
        <ContextMenu x:Key="GridContextMenu">
            <MenuItem Header="📋  Copy Cell Value"  Click="CtxCopyCell_Click"  InputGestureText="Ctrl+C"/>
            <MenuItem Header="📄  Copy Row"         Click="CtxCopyRow_Click"/>
            <Separator/>
            <MenuItem Header="⎘   Copy All Rows"    Click="CtxCopyAll_Click"/>
            <Separator/>
            <MenuItem Header="🔍  Search This Value" Click="CtxSearchValue_Click"/>
        </ContextMenu>

        <!-- Shared right-click context menu for TextBoxes -->
        <ContextMenu x:Key="TextBoxContextMenu">
            <MenuItem Header="📋  Copy"        Command="ApplicationCommands.Copy"/>
            <MenuItem Header="✂️  Cut"         Command="ApplicationCommands.Cut"/>
            <MenuItem Header="📌  Paste"       Command="ApplicationCommands.Paste"/>
            <Separator/>
            <MenuItem Header="☰   Select All"  Command="ApplicationCommands.SelectAll"/>
            <Separator/>
            <MenuItem Header="🗑️  Clear"       Click="CtxClearTextBox_Click"/>
        </ContextMenu>

        <!-- Implicit TextBox — Apple-style, DynamicResource colors, 10px radius -->
        <Style TargetType="TextBox">
            <Setter Property="Background"      Value="{DynamicResource InputBg}"/>
            <Setter Property="Foreground"      Value="{DynamicResource InputFg}"/>
            <Setter Property="BorderBrush"     Value="{DynamicResource InputBorder}"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="CaretBrush"      Value="{DynamicResource InputFg}"/>
            <Setter Property="SelectionBrush"  Value="{DynamicResource TabSelectedBorder}"/>
            <Setter Property="ContextMenu"     Value="{StaticResource TextBoxContextMenu}"/>
            <Setter Property="FontFamily"      Value="Segoe UI Variable Text, Segoe UI, Inter"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Padding="{TemplateBinding Padding}"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                          Focusable="False"
                                          CanContentScroll="True"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource TabSelectedBorder}"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource SubText}"/>
                            </Trigger>
                            <Trigger Property="IsReadOnly" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource SearchCardBg}"/>
                                <Setter Property="Foreground" Value="{DynamicResource SubText}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Implicit Button — QB style, 8px radius, slate bg -->
        <Style TargetType="Button">
            <Setter Property="Background"      Value="{DynamicResource DarkBtnBg}"/>
            <Setter Property="Foreground"      Value="{DynamicResource DarkText}"/>
            <Setter Property="BorderBrush"     Value="{DynamicResource DarkBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="FontFamily"      Value="Segoe UI Variable Display, Segoe UI Variable Text, Inter, Segoe UI"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{DynamicResource DarkBtnBgHover}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- PrimaryButton — accent purple default; subclasses pass their own Background.
             Hover/press use an overlay Border so the TemplateBinding Background is
             never overwritten — custom colors (red delete, amber deactivate, etc.) are
             preserved on all interaction states. -->
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background"      Value="#7C3AED"/>
            <Setter Property="Foreground"      Value="White"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="FontFamily"      Value="Segoe UI Variable Text, Segoe UI, Inter"/>
            <Setter Property="Padding"         Value="18,8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Height"          Value="36"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="12" ShadowDepth="0" Opacity="0.20" Color="#7C3AED"/>
                            </Border.Effect>
                            <!-- dark translucent overlay on hover/press; keeps base color intact -->
                            <Grid>
                                <Border x:Name="HoverOverlay" CornerRadius="8" Background="Black" Opacity="0" IsHitTestVisible="False"/>
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="HoverOverlay" Property="Opacity" Value="0.15"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="HoverOverlay" Property="Opacity" Value="0.30"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- SortHeaderButton — flat table-header sort button -->
        <Style x:Key="SortHeaderButton" TargetType="Button">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="Foreground"      Value="{DynamicResource SubText}"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="FontSize"        Value="10"/>
            <Setter Property="FontFamily"      Value="Segoe UI Variable Text, Segoe UI"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding"         Value="12,10"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource TabHoverBg}"/>
                                <Setter Property="Foreground" Value="{DynamicResource PrimaryText}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- SecondaryButton — outlined green, theme-aware -->
        <Style x:Key="SecondaryButton" TargetType="Button">
            <Setter Property="Background"      Value="{DynamicResource SecondaryBtnBg}"/>
            <Setter Property="Foreground"      Value="{DynamicResource SecondaryBtnFg}"/>
            <Setter Property="BorderBrush"     Value="{DynamicResource SecondaryBtnBorder}"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="FontFamily"      Value="Segoe UI Variable Text, Segoe UI, Inter"/>
            <Setter Property="Padding"         Value="18,8"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Height"          Value="36"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                              TextBlock.Foreground="{TemplateBinding Foreground}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource SecondaryBtnHoverBg}"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource SecondaryBtnHoverBorder}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- DangerButton — Red; inherits PrimaryButton's overlay-hover template -->
        <Style x:Key="DangerButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
            <Setter Property="Background" Value="#EF4444"/>
        </Style>

        <!-- Card — QB style, 12px radius, subtle shadow -->
        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background"      Value="{DynamicResource CardBg}"/>
            <Setter Property="CornerRadius"    Value="12"/>
            <Setter Property="Padding"         Value="20"/>
            <Setter Property="BorderBrush"     Value="{DynamicResource CardBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="16" ShadowDepth="1" Opacity="0.06"
                                      Color="{DynamicResource CardShadowColor}"/>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- NavBtn — dark sidebar, muted foreground, subtle green hover -->
        <Style x:Key="NavBtn" TargetType="Button">
            <Setter Property="Background"                 Value="Transparent"/>
            <Setter Property="Foreground"                 Value="{DynamicResource SidebarNavFg}"/>
            <Setter Property="BorderThickness"            Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Padding"                    Value="14,9"/>
            <Setter Property="Margin"                     Value="0,1"/>
            <Setter Property="Cursor"                     Value="Hand"/>
            <Setter Property="FocusVisualStyle"           Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Stretch" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#FFFFFF0D"/>
                                <Setter Property="Foreground" Value="#C9D1D9"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#7C3AED1A"/>
                                <Setter Property="Foreground" Value="#A78BFA"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- NavBtnActive — green left-bar indicator, matching webapp active link -->
        <Style x:Key="NavBtnActive" TargetType="Button" BasedOn="{StaticResource NavBtn}">
            <Setter Property="Foreground" Value="#A78BFA"/>
            <Setter Property="Background" Value="#7C3AED1A"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                    CornerRadius="6" Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Stretch" VerticalAlignment="Center"/>
                            </Border>
                            <!-- Active indicator bar on left edge -->
                            <Border Width="3" HorizontalAlignment="Left" CornerRadius="0,2,2,0"
                                    Background="#A78BFA" VerticalAlignment="Stretch" Margin="-10,3,0,3"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#7C3AED2A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Mail Tab Styles ─────────────────────────────────────────────── -->
        <Style x:Key="MailToolbarBtn" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="{DynamicResource PrimaryText}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{DynamicResource DarkBtnBg}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{DynamicResource DarkBtnBgHover}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="MailIconBtn" TargetType="Button" BasedOn="{StaticResource MailToolbarBtn}">
            <Setter Property="Width" Value="30"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="Padding" Value="0"/>
        </Style>

        <Style x:Key="MailActionBtn" TargetType="Button" BasedOn="{StaticResource MailToolbarBtn}">
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Margin" Value="2,0"/>
            <Setter Property="Foreground" Value="#7C3AED"/>
        </Style>

        <Style x:Key="MailSummarizeBtn" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource SecondaryBtnBg}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="10,4"/>
            <Setter Property="FontSize" Value="11.5"/>
            <Setter Property="Foreground" Value="#7C3AED"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                CornerRadius="12" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#DCFCE7"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="MailJunkBtn" TargetType="Button">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="{DynamicResource CardBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,4"/>
            <Setter Property="FontSize" Value="11.5"/>
            <Setter Property="Foreground" Value="{DynamicResource PrimaryText}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{DynamicResource DarkBtnBg}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Mail folder TreeViewItem style — compact Outlook-like rows -->
        <Style x:Key="MailFolderItem" TargetType="TreeViewItem">
            <Setter Property="IsExpanded"              Value="{Binding IsExpanded, Mode=TwoWay}"/>
            <Setter Property="Padding"                 Value="6,3"/>
            <Setter Property="Margin"                  Value="0,1"/>
            <Setter Property="Background"              Value="Transparent"/>
            <Setter Property="BorderThickness"         Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Foreground"              Value="{DynamicResource PrimaryText}"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#7C3AED"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
                <MultiTrigger>
                    <MultiTrigger.Conditions>
                        <Condition Property="IsSelected"  Value="False"/>
                        <Condition Property="IsMouseOver" Value="True"/>
                    </MultiTrigger.Conditions>
                    <Setter Property="Background" Value="#E0E0E0"/>
                </MultiTrigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <!-- Root Grid — Sidebar + Main content -->
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ══ Processing overlay (spans both rows, sits above all content) ══ -->
        <Grid x:Name="GlobalProgressBar" Grid.RowSpan="2"
              Visibility="Collapsed" Panel.ZIndex="9999"
              IsHitTestVisible="False"
              RenderTransformOrigin="0.5,0.5">
            <Grid.RenderTransform>
                <ScaleTransform x:Name="GlassScaleTransform"/>
            </Grid.RenderTransform>

            <!-- Backdrop -->
            <Rectangle Fill="#99000000"/>

            <!-- Centered card -->
            <Border x:Name="OverlayCard"
                    Background="{DynamicResource CardBg}" CornerRadius="10"
                    Width="560"
                    VerticalAlignment="Center" HorizontalAlignment="Center"
                    Padding="0">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="48" ShadowDepth="0"
                                      Color="#000000" Opacity="0.32"/>
                </Border.Effect>
                <StackPanel>

                    <!-- Header bar -->
                    <Border Background="#7C3AED" CornerRadius="10,10,0,0" Padding="28,20">
                        <StackPanel Orientation="Horizontal">
                            <!-- Spinner in header -->
                            <Canvas Width="20" Height="20" VerticalAlignment="Center" Margin="0,0,14,0"
                                    RenderTransformOrigin="0.5,0.5">
                                <Canvas.RenderTransform>
                                    <RotateTransform x:Name="SpinnerRotate" Angle="0" CenterX="10" CenterY="10"/>
                                </Canvas.RenderTransform>
                                <Ellipse Canvas.Left="8.5"  Canvas.Top="0"   Width="3" Height="3" Fill="#FFFFFF" Opacity="1.0"/>
                                <Ellipse Canvas.Left="13.5" Canvas.Top="1.5" Width="3" Height="3" Fill="#FFFFFF" Opacity="0.8"/>
                                <Ellipse Canvas.Left="17"   Canvas.Top="6"   Width="3" Height="3" Fill="#FFFFFF" Opacity="0.6"/>
                                <Ellipse Canvas.Left="15.5" Canvas.Top="12"  Width="3" Height="3" Fill="#FFFFFF" Opacity="0.45"/>
                                <Ellipse Canvas.Left="10"   Canvas.Top="15"  Width="3" Height="3" Fill="#FFFFFF" Opacity="0.3"/>
                                <Ellipse Canvas.Left="3.5"  Canvas.Top="13"  Width="3" Height="3" Fill="#FFFFFF" Opacity="0.2"/>
                                <Ellipse Canvas.Left="1"    Canvas.Top="7"   Width="3" Height="3" Fill="#FFFFFF" Opacity="0.12"/>
                                <Ellipse Canvas.Left="3.5"  Canvas.Top="1.5" Width="3" Height="3" Fill="#FFFFFF" Opacity="0.06"/>
                            </Canvas>
                            <TextBlock x:Name="OverlayTitle" Text="Processing…"
                                       FontSize="16" FontWeight="SemiBold" Foreground="White"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <!-- Body -->
                    <StackPanel Margin="28,24,28,24">

                        <!-- Step track -->
                        <Grid Margin="0,0,0,24">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- Connecting lines (sit at vertical centre of the bubbles, 14px from top) -->
                            <Rectangle x:Name="StepLine12" Grid.Column="0" Grid.ColumnSpan="2"
                                       Height="1" VerticalAlignment="Top" Margin="42,13,42,0"/>
                            <Rectangle x:Name="StepLine23" Grid.Column="1" Grid.ColumnSpan="2"
                                       Height="1" VerticalAlignment="Top" Margin="42,13,42,0"/>
                            <Rectangle x:Name="StepLine34" Grid.Column="2" Grid.ColumnSpan="2"
                                       Height="1" VerticalAlignment="Top" Margin="42,13,42,0"/>

                            <!-- Step 1 -->
                            <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                                <Border x:Name="StepBubble1" Width="28" Height="28" CornerRadius="14"
                                        BorderThickness="1.5" HorizontalAlignment="Center">
                                    <TextBlock x:Name="StepNum1" Text="✓" FontSize="12" FontWeight="Bold"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock x:Name="StepLbl1" Text="Starting" FontSize="11"
                                           HorizontalAlignment="Center" Margin="0,5,0,0"/>
                            </StackPanel>

                            <!-- Step 2 -->
                            <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                                <Border x:Name="StepBubble2" Width="28" Height="28" CornerRadius="14"
                                        BorderThickness="1.5" HorizontalAlignment="Center">
                                    <TextBlock x:Name="StepNum2" Text="2" FontSize="11" FontWeight="SemiBold"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock x:Name="StepLbl2" Text="Processing" FontSize="11"
                                           HorizontalAlignment="Center" Margin="0,5,0,0"/>
                            </StackPanel>

                            <!-- Step 3 -->
                            <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                                <Border x:Name="StepBubble3" Width="28" Height="28" CornerRadius="14"
                                        BorderThickness="1.5" HorizontalAlignment="Center">
                                    <TextBlock x:Name="StepNum3" Text="3" FontSize="11" FontWeight="SemiBold"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock x:Name="StepLbl3" Text="Finalizing" FontSize="11"
                                           HorizontalAlignment="Center" Margin="0,5,0,0"/>
                            </StackPanel>

                            <!-- Step 4 -->
                            <StackPanel Grid.Column="3" HorizontalAlignment="Center">
                                <Border x:Name="StepBubble4" Width="28" Height="28" CornerRadius="14"
                                        BorderThickness="1.5" HorizontalAlignment="Center">
                                    <TextBlock x:Name="StepNum4" Text="4" FontSize="11" FontWeight="SemiBold"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock x:Name="StepLbl4" Text="Completed" FontSize="11"
                                           HorizontalAlignment="Center" Margin="0,5,0,0"/>
                            </StackPanel>
                        </Grid>

                        <!-- Divider -->
                        <Border Background="{DynamicResource CardBorder}" Height="1" Margin="0,0,0,20"/>

                        <!-- Status line -->
                        <TextBlock x:Name="OverlaySubTitle"
                                   Text="Processing your request…"
                                   FontSize="13" Foreground="{DynamicResource PrimaryText}"
                                   Margin="0,0,0,12"/>

                        <!-- Progress bar — thin, refined -->
                        <Grid Margin="0,0,0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="40"/>
                            </Grid.ColumnDefinitions>
                            <Grid x:Name="ProgBarTrack" Grid.Column="0" VerticalAlignment="Center">
                                <Border Background="{DynamicResource ProgBarTrackBg}" CornerRadius="3" Height="6"/>
                                <Border x:Name="ProgFill" Background="#7C3AED"
                                        CornerRadius="3" HorizontalAlignment="Left"
                                        Height="6" Width="0"/>
                            </Grid>
                            <TextBlock x:Name="ProgPct" Grid.Column="1"
                                       Text="0%" FontSize="12" FontWeight="SemiBold"
                                       Foreground="{DynamicResource PrimaryText}"
                                       HorizontalAlignment="Right" VerticalAlignment="Center"/>
                        </Grid>

                        <!-- Counter badge -->
                        <Border x:Name="OverlayCountBadge"
                                Background="{DynamicResource OverlayCountBg}" CornerRadius="4" Padding="10,4"
                                Margin="0,10,0,0" HorizontalAlignment="Left"
                                Visibility="Collapsed">
                            <TextBlock x:Name="OverlayCountText" Text="" FontSize="12" FontWeight="SemiBold"
                                       Foreground="{DynamicResource OverlayCountFg}"/>
                        </Border>

                        <!-- Estimated time -->
                        <TextBlock x:Name="EstTimeText" FontSize="11"
                                   Foreground="{DynamicResource SubText}"
                                   Margin="0,10,0,0" Text="Estimating time remaining…"/>
                    </StackPanel>

                    <!-- Footer -->
                    <Border Background="{DynamicResource OverlayInfoBg}" CornerRadius="0,0,10,10"
                            Padding="28,12">
                        <TextBlock Text="Do not close this window while the operation is running."
                                   FontSize="11" Foreground="{DynamicResource OverlayInfoFg}"/>
                    </Border>

                </StackPanel>
            </Border>
        </Grid>

        <Grid Grid.Row="0">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="210"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ══════════════════════════════════════════════════════════
             SIDEBAR
             ══════════════════════════════════════════════════════════ -->
        <Border Grid.Column="0"
                Background="{DynamicResource SidebarBg}"
                BorderBrush="{DynamicResource SidebarBorder}"
                BorderThickness="0,0,1,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>   <!-- Logo -->
                    <RowDefinition Height="*"/>      <!-- Nav items -->
                    <RowDefinition Height="Auto"/>   <!-- User profile -->
                    <RowDefinition Height="Auto"/>   <!-- BQE Core account badge -->
                </Grid.RowDefinitions>

                <!-- Logo area -->
                <Border Grid.Row="0" Padding="16,20,16,16"
                        BorderBrush="#FFFFFF14" BorderThickness="0,0,0,1">
                    <StackPanel Orientation="Horizontal">
                        <Border Width="32" Height="32" CornerRadius="8"
                                Margin="0,0,10,0">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#6D28D9" Offset="0"/>
                                    <GradientStop Color="#7C3AED" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <TextBlock Text="⚡" FontSize="15"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center" Foreground="White"/>
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="PayrixViewer" FontSize="13" FontWeight="SemiBold" Foreground="White"/>
                            <TextBlock Text="ePayment Tools" FontSize="10" Foreground="#6E7681" Margin="0,1,0,0"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Nav items -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              Padding="10,14,10,0">
                    <ScrollViewer.Resources>
                        <!-- Always-dark thumb — overrides whatever theme is active -->
                        <Style x:Key="SidebarThumb" TargetType="Thumb">
                            <Setter Property="OverridesDefaultStyle" Value="True"/>
                            <Setter Property="IsTabStop"             Value="False"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Thumb">
                                        <Border x:Name="Bd" Background="#AEAEB2" CornerRadius="3"/>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Bd" Property="Background" Value="#6E6E73"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                        <Style x:Key="SidebarPageBtn" TargetType="RepeatButton">
                            <Setter Property="OverridesDefaultStyle" Value="True"/>
                            <Setter Property="IsTabStop"             Value="False"/>
                            <Setter Property="Focusable"             Value="False"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="RepeatButton">
                                        <Border Background="Transparent"/>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                        <Style TargetType="ScrollBar">
                            <Setter Property="OverridesDefaultStyle"  Value="True"/>
                            <Setter Property="Stylus.IsFlicksEnabled" Value="False"/>
                            <Style.Triggers>
                                <Trigger Property="Orientation" Value="Vertical">
                                    <Setter Property="Width"    Value="4"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ScrollBar">
                                                <Border Background="Transparent" Width="4" Padding="1,4">
                                                    <Track x:Name="PART_Track" IsDirectionReversed="True">
                                                        <Track.DecreaseRepeatButton>
                                                            <RepeatButton Style="{StaticResource SidebarPageBtn}" Command="ScrollBar.PageUpCommand"/>
                                                        </Track.DecreaseRepeatButton>
                                                        <Track.Thumb>
                                                            <Thumb Style="{StaticResource SidebarThumb}"/>
                                                        </Track.Thumb>
                                                        <Track.IncreaseRepeatButton>
                                                            <RepeatButton Style="{StaticResource SidebarPageBtn}" Command="ScrollBar.PageDownCommand"/>
                                                        </Track.IncreaseRepeatButton>
                                                    </Track>
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </ScrollViewer.Resources>
                    <StackPanel>

                        <!-- ── Overview ───────────────────────────────── -->
                        <Button x:Name="NavTxnViewer" Tag="0"
                                Style="{StaticResource NavBtnActive}"
                                Click="SidebarNav_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="▦" FontSize="13" VerticalAlignment="Center" Margin="0,0,10,0"
                                           Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                                <TextBlock Text="Overview" FontSize="12.5" FontWeight="Medium" VerticalAlignment="Center"
                                           Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                            </StackPanel>
                        </Button>

                        <!-- ── Section: Payments ───────────────────────── -->
                        <TextBlock Text="MONITOR" FontSize="10" FontWeight="SemiBold"
                                   Foreground="#4D5562"
                                   Margin="14,14,0,4" Opacity="0.7"/>

                        <Button x:Name="NavTxn" Tag="1"
                                Style="{StaticResource NavBtn}"
                                Click="SidebarNav_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="↔" FontSize="14" VerticalAlignment="Center" Margin="0,0,10,0"
                                           Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                                <TextBlock Text="Transactions" FontSize="12.5" VerticalAlignment="Center"
                                           Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                            </StackPanel>
                        </Button>

                        <Button x:Name="NavDisbursements" Tag="11"
                                Style="{StaticResource NavBtn}"
                                Click="SidebarNav_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="⇢" FontSize="14" VerticalAlignment="Center" Margin="0,0,10,0"
                                           Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                                <TextBlock Text="Disbursements" FontSize="12.5" VerticalAlignment="Center"
                                           Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                            </StackPanel>
                        </Button>

                        <Button x:Name="NavLineItems" Tag="2"
                                Style="{StaticResource NavBtn}"
                                Click="SidebarNav_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="≡" FontSize="14" VerticalAlignment="Center" Margin="0,0,10,0"
                                           Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                                <TextBlock Text="Line Items" FontSize="12.5" VerticalAlignment="Center"
                                           Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                            </StackPanel>
                        </Button>

                        <Button x:Name="NavSubscriptions" Tag="17"
                                Style="{StaticResource NavBtn}"
                                Click="SidebarNav_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="◌" FontSize="14" VerticalAlignment="Center" Margin="0,0,10,0"
                                           Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                                <TextBlock Text="Subscriptions" FontSize="12.5" VerticalAlignment="Center"
                                           Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                            </StackPanel>
                        </Button>

                        <!-- ── Section: Entities ───────────────────────── -->
                        <TextBlock Text="MANAGE" FontSize="10" FontWeight="SemiBold"
                                   Foreground="#4D5562"
                                   Margin="14,14,0,4" Opacity="0.7"/>

                        <Button x:Name="NavMerchants" Tag="13"
                                Style="{StaticResource NavBtn}"
                                Click="SidebarNav_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="◈" FontSize="13" VerticalAlignment="Center" Margin="0,0,10,0"
                                           Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                                <TextBlock Text="Merchants" FontSize="12.5" VerticalAlignment="Center"
                                           Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                            </StackPanel>
                        </Button>

                        <Button x:Name="NavAccounts" Tag="12"
                                Style="{StaticResource NavBtn}"
                                Click="SidebarNav_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="◻" FontSize="13" VerticalAlignment="Center" Margin="0,0,10,0"
                                           Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                                <TextBlock Text="Accounts" FontSize="12.5" VerticalAlignment="Center"
                                           Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                            </StackPanel>
                        </Button>

                        <Button x:Name="NavDashboard" Tag="10"
                                Style="{StaticResource NavBtn}"
                                Click="SidebarNav_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="◎" FontSize="13" VerticalAlignment="Center" Margin="0,0,10,0"
                                           Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                                <TextBlock Text="Dashboard" FontSize="12.5" VerticalAlignment="Center"
                                           Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                            </StackPanel>
                        </Button>

                        <Button x:Name="NavReports" Tag="14"
                                Style="{StaticResource NavBtn}"
                                Click="SidebarNav_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="↗" FontSize="14" VerticalAlignment="Center" Margin="0,0,10,0"
                                           Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                                <TextBlock Text="Reports" FontSize="12.5" VerticalAlignment="Center"
                                           Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                            </StackPanel>
                        </Button>

                        <!-- ── Section: Dev ────────────────────────────── -->
                        <TextBlock Text="SYSTEM" FontSize="10" FontWeight="SemiBold"
                                   Foreground="#4D5562"
                                   Margin="14,14,0,4" Opacity="0.7"/>

                        <Button x:Name="NavMerchantVerify" Tag="20"
                                Style="{StaticResource NavBtn}"
                                Click="SidebarNav_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="🔧" FontSize="13" VerticalAlignment="Center" Margin="0,0,10,0"
                                           Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                                <TextBlock Text="Merchant Verify" FontSize="12.5" VerticalAlignment="Center"
                                           Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                            </StackPanel>
                        </Button>

                        <Button x:Name="NavWebhooks" Tag="3"
                                Style="{StaticResource NavBtn}"
                                Click="SidebarNav_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="⚡" FontSize="13" VerticalAlignment="Center" Margin="0,0,10,0"
                                           Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                                <TextBlock Text="Webhook Tests" FontSize="12.5" VerticalAlignment="Center"
                                           Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                            </StackPanel>
                        </Button>

                        <Button x:Name="NavCoreDb" Tag="19"
                                Style="{StaticResource NavBtn}"
                                Click="SidebarNav_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="⊞" FontSize="13" VerticalAlignment="Center" Margin="0,0,10,0"
                                           Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                                <TextBlock Text="Core DB" FontSize="12.5" VerticalAlignment="Center"
                                           Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                            </StackPanel>
                        </Button>

                        <Button x:Name="NavRawJson" Tag="4"
                                Style="{StaticResource NavBtn}"
                                Click="SidebarNav_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{}{}" FontSize="12" FontFamily="Consolas" VerticalAlignment="Center" Margin="0,0,10,0"
                                           Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                                <TextBlock Text="Raw JSON" FontSize="12.5" VerticalAlignment="Center"
                                           Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                            </StackPanel>
                        </Button>

                        <Button x:Name="NavJsonTools" Tag="5"
                                Style="{StaticResource NavBtn}"
                                Click="SidebarNav_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="⌥" FontSize="13" VerticalAlignment="Center" Margin="0,0,10,0"
                                           Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                                <TextBlock Text="JSON Tools" FontSize="12.5" VerticalAlignment="Center"
                                           Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                            </StackPanel>
                        </Button>

                        <Button x:Name="NavHttpClient" Tag="15"
                                Style="{StaticResource NavBtn}"
                                Click="SidebarNav_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="⇄" FontSize="14" VerticalAlignment="Center" Margin="0,0,10,0"
                                           Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                                <TextBlock Text="HTTP Client" FontSize="12.5" VerticalAlignment="Center"
                                           Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                            </StackPanel>
                        </Button>

                        <Button x:Name="NavPerf" Tag="16"
                                Style="{StaticResource NavBtn}"
                                Click="SidebarNav_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="◈" FontSize="13" VerticalAlignment="Center" Margin="0,0,10,0"
                                           Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                                <TextBlock Text="Performance" FontSize="12.5" VerticalAlignment="Center"
                                           Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                            </StackPanel>
                        </Button>

                        <Button x:Name="NavCrypto" Tag="6"
                                Style="{StaticResource NavBtn}"
                                Click="SidebarNav_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="◉" FontSize="13" VerticalAlignment="Center" Margin="0,0,10,0"
                                           Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                                <TextBlock Text="Crypto" FontSize="12.5" VerticalAlignment="Center"
                                           Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                            </StackPanel>
                        </Button>

                        <Button x:Name="NavPortal" Tag="7"
                                Style="{StaticResource NavBtn}"
                                Click="SidebarNav_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="⬡" FontSize="13" VerticalAlignment="Center" Margin="0,0,10,0"
                                           Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                                <TextBlock Text="Payrix Portal" FontSize="12.5" VerticalAlignment="Center"
                                           Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                            </StackPanel>
                        </Button>

                        <Button x:Name="NavFiddler" Tag="18"
                                Style="{StaticResource NavBtn}"
                                Click="SidebarNav_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="🔎" FontSize="13" VerticalAlignment="Center" Margin="0,0,10,0"
                                           Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                                <TextBlock Text="Fiddler" FontSize="12.5" VerticalAlignment="Center"
                                           Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                            </StackPanel>
                        </Button>

                        <!-- ── Divider + Settings ──────────────────────── -->
                        <Border Height="1" Background="#FFFFFF12" Margin="4,10"/>

                        <Button x:Name="NavSettings" Tag="8"
                                Style="{StaticResource NavBtn}"
                                Click="SidebarNav_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="⚙" FontSize="14" VerticalAlignment="Center" Margin="0,0,10,0"
                                           Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                                <TextBlock Text="Settings" FontSize="12.5" VerticalAlignment="Center"
                                           Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                            </StackPanel>
                        </Button>

                        <Button x:Name="NavHelp" Tag="9"
                                Style="{StaticResource NavBtn}"
                                Click="SidebarNav_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="?" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,10,0"
                                           Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                                <TextBlock Text="Help &amp; Docs" FontSize="12.5" VerticalAlignment="Center"
                                           Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                            </StackPanel>
                        </Button>

                    </StackPanel>
                </ScrollViewer>

                <!-- User profile + Logout -->
                <Border Grid.Row="2" Padding="12,12"
                        BorderBrush="#FFFFFF18" BorderThickness="0,1,0,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- Avatar + name -->
                        <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                            <Border Width="34" Height="34" CornerRadius="17" Margin="0,0,10,0">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#6D28D9" Offset="0"/>
                                        <GradientStop Color="#7C3AED" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <TextBlock x:Name="SidebarAvatarText" Text="S" FontSize="14" FontWeight="Bold"
                                           Foreground="White" HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock x:Name="SidebarUserName" Text="Shaheen" FontSize="12.5" FontWeight="SemiBold"
                                           Foreground="#E6EDF3"/>
                                <TextBlock x:Name="SidebarUserRole" Text="QA Lead" FontSize="10.5"
                                           Foreground="{DynamicResource MutedText}"/>
                            </StackPanel>
                        </StackPanel>

                        <!-- Sign Out button -->
                        <Border Grid.Column="1" Width="30" Height="30" CornerRadius="8"
                                Background="Transparent" Cursor="Hand"
                                ToolTip="Sign out — returns to login screen"
                                MouseLeftButtonDown="LogoutBtn_Click"
                                VerticalAlignment="Center" Margin="6,0,0,0">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#FFFFFF18"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <TextBlock Text="⏻" FontSize="14" Foreground="{DynamicResource MutedText}"
                                       HorizontalAlignment="Center" VerticalAlignment="Center">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Foreground" Value="#F87171"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Border>

                    </Grid>
                </Border>

                <!-- BQE Core account badge (shown after sign-in) -->
                <Border x:Name="SidebarBqeBadge" Grid.Row="3"
                        Padding="12,8" Margin="0,0,0,0"
                        Visibility="Collapsed"
                        Background="#7C3AED14"
                        BorderBrush="#7C3AED30" BorderThickness="0,1,0,0">
                    <StackPanel Orientation="Horizontal">
                        <Border Width="8" Height="8" CornerRadius="4"
                                Background="#A78BFA" Margin="0,0,8,0"
                                VerticalAlignment="Center"/>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="BQE Core" FontSize="9" FontWeight="SemiBold"
                                       Foreground="{DynamicResource MutedText}" Margin="0,0,0,1"/>
                            <TextBlock x:Name="SidebarBqeUserText"
                                       FontSize="10.5" FontWeight="SemiBold"
                                       Foreground="{DynamicResource SubText}"
                                       TextTrimming="CharacterEllipsis" MaxWidth="130"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

            </Grid>
        </Border>

        <!-- ══════════════════════════════════════════════════════════
             MAIN CONTENT
             ══════════════════════════════════════════════════════════ -->
        <!-- DockPanel root — upper content stacks at top, footer pins at bottom,
             tabs card fills all remaining space so the DataGrid scrolls within
             its own space (no double scrollbar). -->
        <DockPanel Grid.Column="1" x:Name="RootScroll" Margin="10" LastChildFill="True">

        <!-- ── Topbar (webapp-style) ─────────────────────────────────────────── -->
        <Border DockPanel.Dock="Top" Background="{DynamicResource CardBg}" CornerRadius="8"
                BorderBrush="{DynamicResource CardBorder}" BorderThickness="1" Margin="0,0,0,8" Padding="18,14,18,14">
            <Border.Effect>
                <DropShadowEffect BlurRadius="8" ShadowDepth="0" Opacity="0.06"
                                  Color="{DynamicResource CardShadowColor}"/>
            </Border.Effect>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Left: icon badge + title + subtitle -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Border x:Name="PageIconBadge" Width="34" Height="34" CornerRadius="8"
                            Background="#7C3AED1A" BorderBrush="#7C3AED40" BorderThickness="1"
                            Margin="0,0,12,0" VerticalAlignment="Center">
                        <TextBlock x:Name="PageIconText" Text="↔" FontSize="16"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                   Foreground="#A78BFA"/>
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock x:Name="PageTitle" Text="Transactions"
                                   FontSize="16" FontWeight="SemiBold"
                                   Foreground="{DynamicResource PrimaryText}"/>
                        <TextBlock x:Name="PageSubtitle" Text="Search, inspect, and export payment transactions"
                                   FontSize="11.5" Foreground="{DynamicResource SubText}" Margin="0,2,0,0"/>
                    </StackPanel>
                </StackPanel>

                <!-- Right: owner + env toggle + URL + connection pill + theme + KPI -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">

                    <!-- Env toggle group (pill) -->
                    <Border CornerRadius="7" Margin="0,0,8,0"
                            Background="{DynamicResource DarkBtnBg}"
                            BorderBrush="{DynamicResource DarkBorder}" BorderThickness="1" Padding="2">
                        <StackPanel Orientation="Horizontal">
                            <!-- Sandbox button -->
                            <Border x:Name="SandboxBorder" CornerRadius="5" Cursor="Hand"
                                    Padding="10,5" MouseLeftButtonUp="SandboxBorder_Click"
                                    ToolTip="Switch to Sandbox environment">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsSandbox, RelativeSource={RelativeSource AncestorType=Window}}" Value="True">
                                                <Setter Property="Background" Value="#F59E0B22"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <StackPanel Orientation="Horizontal">
                                    <Ellipse Width="6" Height="6" Margin="0,0,5,0" VerticalAlignment="Center">
                                        <Ellipse.Style>
                                            <Style TargetType="Ellipse">
                                                <Setter Property="Fill" Value="{DynamicResource SubText}"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsSandbox, RelativeSource={RelativeSource AncestorType=Window}}" Value="True">
                                                        <Setter Property="Fill" Value="#F59E0B"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Ellipse.Style>
                                    </Ellipse>
                                    <TextBlock Text="Sandbox" FontSize="11.5" FontWeight="Medium">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="{DynamicResource SubText}"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsSandbox, RelativeSource={RelativeSource AncestorType=Window}}" Value="True">
                                                        <Setter Property="Foreground" Value="#F59E0B"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </StackPanel>
                            </Border>
                            <!-- Production button -->
                            <Border x:Name="ProductionBorder" CornerRadius="5" Cursor="Hand"
                                    Padding="10,5" MouseLeftButtonUp="ProductionBorder_Click"
                                    ToolTip="Switch to Production environment">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsSandbox, RelativeSource={RelativeSource AncestorType=Window}}" Value="False">
                                                <Setter Property="Background" Value="#05966922"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <StackPanel Orientation="Horizontal">
                                    <Ellipse Width="6" Height="6" Margin="0,0,5,0" VerticalAlignment="Center">
                                        <Ellipse.Style>
                                            <Style TargetType="Ellipse">
                                                <Setter Property="Fill" Value="{DynamicResource SubText}"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsSandbox, RelativeSource={RelativeSource AncestorType=Window}}" Value="False">
                                                        <Setter Property="Fill" Value="#10B981"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Ellipse.Style>
                                    </Ellipse>
                                    <TextBlock Text="Production" FontSize="11.5" FontWeight="Medium">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="{DynamicResource SubText}"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsSandbox, RelativeSource={RelativeSource AncestorType=Window}}" Value="False">
                                                        <Setter Property="Foreground" Value="#10B981"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- Active API URL chip -->
                    <Border CornerRadius="6" Padding="10,5" Margin="0,0,8,0"
                            Background="{DynamicResource DarkBtnBg}"
                            BorderBrush="{DynamicResource DarkBorder}" BorderThickness="1"
                            MaxWidth="150">
                        <TextBlock x:Name="ActiveUrlText" FontSize="10.5"
                                   FontFamily="Consolas, Courier New"
                                   Foreground="{DynamicResource SubText}"
                                   TextTrimming="CharacterEllipsis"
                                   VerticalAlignment="Center"/>
                    </Border>

                    <!-- Connection status pill -->
                    <Border x:Name="ConnectionPill" CornerRadius="6" Padding="10,5" Margin="0,0,8,0"
                            BorderThickness="1" BorderBrush="{DynamicResource DarkBorder}"
                            Background="{DynamicResource DarkBtnBg}"
                            ToolTip="Purple = API connected  |  Red = not connected or error">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Ellipse x:Name="StatusDot" Width="6" Height="6" Fill="#F87171"
                                     VerticalAlignment="Center" Margin="0,0,5,0"/>
                            <TextBlock x:Name="StatusText" Text="Not connected"
                                       Foreground="{DynamicResource SubText}" FontSize="11.5"
                                       FontWeight="Medium" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <!-- Theme toggle pill -->
                    <Border x:Name="ThemeToggleBorder" CornerRadius="14" Width="46" Height="26"
                            Margin="0,0,8,0" Cursor="Hand" MouseLeftButtonUp="ThemeToggle_Click"
                            ToolTip="Toggle Dark / Light mode"
                            Background="{DynamicResource DarkBtnBg}" BorderBrush="{DynamicResource DarkBorder}" BorderThickness="1">
                        <Grid>
                            <TextBlock x:Name="ThemeToggleIcon" Text="☀️" FontSize="10"
                                       HorizontalAlignment="Left" VerticalAlignment="Center"
                                       Foreground="#FCD34D" Margin="5,0,0,0"/>
                            <TextBlock Text="🌙" FontSize="9"
                                       HorizontalAlignment="Right" VerticalAlignment="Center"
                                       Margin="0,0,4,0" Opacity="0.45"/>
                            <Ellipse x:Name="ThemeToggleThumb" Width="18" Height="18"
                                     Fill="#7C3AED" HorizontalAlignment="Left"
                                     VerticalAlignment="Center" Margin="3,0,0,0"/>
                        </Grid>
                    </Border>

                    <!-- KPI toggle -->
                    <Border x:Name="KpiToggleBorder" CornerRadius="6" Cursor="Hand"
                            Padding="9,5"
                            Background="{DynamicResource DarkBtnBg}"
                            BorderBrush="{DynamicResource DarkBorder}" BorderThickness="1"
                            MouseLeftButtonUp="KpiToggle_Click"
                            ToolTip="Show / hide KPI summary cards">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="{DynamicResource DarkBtnBgHover}"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="⊟" FontSize="12" Margin="0,0,4,0"
                                       Foreground="{DynamicResource SubText}"/>
                            <TextBlock x:Name="KpiToggleText" Text="KPIs"
                                       FontSize="11.5" FontWeight="Medium"
                                       Foreground="{DynamicResource SubText}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                </StackPanel>
            </Grid>
        </Border>


        <!-- Hidden API key inputs (referenced by code-behind) -->
        <Grid DockPanel.Dock="Top" Visibility="Collapsed">
            <PasswordBox x:Name="SandboxApiKeyBox"/>
            <PasswordBox x:Name="ProductionApiKeyBox"/>
        </Grid>

        <!-- KPI bar (compact single row) -->
        <Border x:Name="KpiGrid" DockPanel.Dock="Top" Margin="0,0,0,8"
                Background="{DynamicResource CardBg}" BorderBrush="{DynamicResource CardBorder}"
                BorderThickness="1" CornerRadius="8" Padding="14,9">
            <UniformGrid Rows="1">

                <!-- TXN count -->
                <StackPanel Orientation="Vertical" VerticalAlignment="Center" HorizontalAlignment="Center"
                            ToolTip="Total number of transactions loaded in the current result set">
                    <TextBlock Text="TXN" FontSize="8" FontWeight="Bold" Foreground="{DynamicResource SubText}" Margin="0,0,0,2"/>
                    <TextBlock x:Name="SummaryCount" Text="0" FontSize="14" FontWeight="Bold"
                               Foreground="{DynamicResource StatCountFg}"/>
                </StackPanel>

                <!-- TOTAL $ -->
                <StackPanel Orientation="Vertical" VerticalAlignment="Center" HorizontalAlignment="Center"
                            ToolTip="Total charged amount across all transactions in this result set">
                    <TextBlock Text="TOTAL" FontSize="8" FontWeight="Bold" Foreground="{DynamicResource SubText}" Margin="0,0,0,2"/>
                    <TextBlock x:Name="SummaryTotal" Text="$0.00" FontSize="14" FontWeight="Bold"
                               Foreground="{DynamicResource StatCountFg}"/>
                </StackPanel>

                <!-- APPROVED $ -->
                <StackPanel Orientation="Vertical" VerticalAlignment="Center" HorizontalAlignment="Center"
                            ToolTip="Total amount authorised by the card network or ACH processor">
                    <TextBlock Text="APPROVED" FontSize="8" FontWeight="Bold" Foreground="{DynamicResource SubText}" Margin="0,0,0,2"/>
                    <TextBlock x:Name="SummaryApproved" Text="$0.00" FontSize="14" FontWeight="Bold"
                               Foreground="#059669"/>
                </StackPanel>

                <!-- TAX $ -->
                <StackPanel Orientation="Vertical" VerticalAlignment="Center" HorizontalAlignment="Center"
                            ToolTip="Total tax collected across all transactions in this result set">
                    <TextBlock Text="TAX" FontSize="8" FontWeight="Bold" Foreground="{DynamicResource SubText}" Margin="0,0,0,2"/>
                    <TextBlock x:Name="SummaryTax" Text="$0.00" FontSize="14" FontWeight="Bold"
                               Foreground="#D97706"/>
                </StackPanel>

                <!-- SETTLED count -->
                <StackPanel Orientation="Vertical" VerticalAlignment="Center" HorizontalAlignment="Center"
                            ToolTip="Number of transactions that have been settled and funded to the merchant">
                    <TextBlock Text="SETTLED" FontSize="8" FontWeight="Bold" Foreground="{DynamicResource SubText}" Margin="0,0,0,2"/>
                    <TextBlock x:Name="SummarySettled" Text="0" FontSize="14" FontWeight="Bold"
                               Foreground="#7C3AED"/>
                </StackPanel>

                <!-- DECLINED count -->
                <StackPanel Orientation="Vertical" VerticalAlignment="Center" HorizontalAlignment="Center"
                            ToolTip="Number of transactions declined by the card network or payment processor">
                    <TextBlock Text="DECLINED" FontSize="8" FontWeight="Bold" Foreground="{DynamicResource SubText}" Margin="0,0,0,2"/>
                    <TextBlock x:Name="SummaryDeclined" Text="0" FontSize="14" FontWeight="Bold"
                               Foreground="#EF4444"/>
                </StackPanel>

                <!-- LINE ITEMS count -->
                <StackPanel Orientation="Vertical" VerticalAlignment="Center" HorizontalAlignment="Center"
                            ToolTip="Total number of line items across all transactions (loaded separately via Line Items)">
                    <TextBlock Text="LINE ITEMS" FontSize="8" FontWeight="Bold" Foreground="{DynamicResource SubText}" Margin="0,0,0,2"/>
                    <TextBlock x:Name="SummaryItems" Text="0" FontSize="14" FontWeight="Bold"
                               Foreground="{DynamicResource DarkAccent}"/>
                </StackPanel>

                <!-- FEES $ -->
                <StackPanel Orientation="Vertical" VerticalAlignment="Center" HorizontalAlignment="Center"
                            ToolTip="Total Payrix processing fees charged across all transactions">
                    <TextBlock Text="FEES" FontSize="8" FontWeight="Bold" Foreground="{DynamicResource SubText}" Margin="0,0,0,2"/>
                    <TextBlock x:Name="SummaryFees" Text="$0.00" FontSize="14" FontWeight="Bold"
                               Foreground="#B45309"/>
                </StackPanel>

                <!-- PENDING count -->
                <StackPanel Orientation="Vertical" VerticalAlignment="Center" HorizontalAlignment="Center"
                            ToolTip="Number of transactions approved but not yet captured or settled">
                    <TextBlock Text="PENDING" FontSize="8" FontWeight="Bold" Foreground="{DynamicResource SubText}" Margin="0,0,0,2"/>
                    <TextBlock x:Name="SummaryPending" Text="0" FontSize="14" FontWeight="Bold"
                               Foreground="#0891B2"/>
                </StackPanel>

                <!-- REFUNDED count -->
                <StackPanel Orientation="Vertical" VerticalAlignment="Center" HorizontalAlignment="Center"
                            ToolTip="Number of transactions where a partial or full refund has been issued">
                    <TextBlock Text="REFUNDED" FontSize="8" FontWeight="Bold" Foreground="{DynamicResource SubText}" Margin="0,0,0,2"/>
                    <TextBlock x:Name="SummaryRefunded" Text="0" FontSize="14" FontWeight="Bold"
                               Foreground="#DB2777"/>
                </StackPanel>

                <!-- AVG $ per transaction -->
                <StackPanel Orientation="Vertical" VerticalAlignment="Center" HorizontalAlignment="Center"
                            ToolTip="Average approved amount per transaction (total approved ÷ transaction count)">
                    <TextBlock Text="AVG TXN" FontSize="8" FontWeight="Bold" Foreground="{DynamicResource SubText}" Margin="0,0,0,2"/>
                    <TextBlock x:Name="SummaryAvg" Text="$0.00" FontSize="14" FontWeight="Bold"
                               Foreground="{DynamicResource StatCountFg}"/>
                </StackPanel>

                <!-- DISCOUNT $ -->
                <StackPanel Orientation="Vertical" VerticalAlignment="Center" HorizontalAlignment="Center"
                            ToolTip="Total discounts applied across all transactions">
                    <TextBlock Text="DISCOUNT" FontSize="8" FontWeight="Bold" Foreground="{DynamicResource SubText}" Margin="0,0,0,2"/>
                    <TextBlock x:Name="SummaryDiscount" Text="$0.00" FontSize="14" FontWeight="Bold"
                               Foreground="#65A30D"/>
                </StackPanel>

                <!-- SETTLED $ -->
                <StackPanel Orientation="Vertical" VerticalAlignment="Center" HorizontalAlignment="Center"
                            ToolTip="Total amount actually settled and funded to the merchant account">
                    <TextBlock Text="SETTLED $" FontSize="9" FontWeight="Bold" Foreground="{DynamicResource SubText}" Margin="0,0,0,2"/>
                    <TextBlock x:Name="SummarySettledAmt" Text="$0.00" FontSize="14" FontWeight="Bold"
                               Foreground="#7C3AED"/>
                </StackPanel>

                <!-- CARD count -->
                <StackPanel Orientation="Vertical" VerticalAlignment="Center" HorizontalAlignment="Center"
                            ToolTip="Number of credit/debit card transactions (Sales, Authorisations, Captures, Refunds, Voids)">
                    <TextBlock Text="CARD" FontSize="8" FontWeight="Bold" Foreground="{DynamicResource SubText}" Margin="0,0,0,2"/>
                    <TextBlock x:Name="SummaryCard" Text="0" FontSize="14" FontWeight="Bold"
                               Foreground="#7C3AED"/>
                </StackPanel>

                <!-- ACH count -->
                <StackPanel Orientation="Vertical" VerticalAlignment="Center" HorizontalAlignment="Center"
                            ToolTip="Number of ACH / eCheck transactions (Sales and Returns)">
                    <TextBlock Text="ACH" FontSize="8" FontWeight="Bold" Foreground="{DynamicResource SubText}" Margin="0,0,0,2"/>
                    <TextBlock x:Name="SummaryAch" Text="0" FontSize="14" FontWeight="Bold"
                               Foreground="#0891B2"/>
                </StackPanel>

                <!-- CAPTURED count -->
                <StackPanel Orientation="Vertical" VerticalAlignment="Center" HorizontalAlignment="Center"
                            ToolTip="Number of transactions where the authorisation has been captured and is pending settlement">
                    <TextBlock Text="CAPTURED" FontSize="8" FontWeight="Bold" Foreground="{DynamicResource SubText}" Margin="0,0,0,2"/>
                    <TextBlock x:Name="SummaryCaptured" Text="0" FontSize="14" FontWeight="Bold"
                               Foreground="#059669"/>
                </StackPanel>

                <!-- DISBURSED count -->
                <StackPanel Orientation="Vertical" VerticalAlignment="Center" HorizontalAlignment="Center"
                            ToolTip="Number of credit or disbursement transactions (funds sent out to the merchant)">
                    <TextBlock Text="DISBURSED" FontSize="8" FontWeight="Bold" Foreground="{DynamicResource SubText}" Margin="0,0,0,2"/>
                    <TextBlock x:Name="SummaryDisbursed" Text="0" FontSize="14" FontWeight="Bold"
                               Foreground="#FCD34D"/>
                </StackPanel>

                <!-- COMPANY -->
                <StackPanel Orientation="Vertical" VerticalAlignment="Center" HorizontalAlignment="Center"
                            ToolTip="BQE Core company name matched to the transactions in this result">
                    <TextBlock Text="COMPANY" FontSize="8" FontWeight="Bold" Foreground="{DynamicResource SubText}" Margin="0,0,0,2"/>
                    <TextBlock x:Name="SummaryCompany" Text="—" FontSize="14" FontWeight="Bold"
                               Foreground="{DynamicResource StatCountFg}"
                               TextTrimming="CharacterEllipsis" MaxWidth="200"
                               ToolTip="{Binding Text, RelativeSource={RelativeSource Self}}"/>
                </StackPanel>

            </UniformGrid>
        </Border>

        <!-- Footer — DockPanel.Dock="Bottom" must appear BEFORE the fill child -->
        <Grid DockPanel.Dock="Bottom" Margin="0,8,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Button Grid.Column="0" Content="📤  Export JSON" Style="{StaticResource SecondaryButton}"
                    Click="ExportJsonBtn_Click" x:Name="ExportJsonBtn" IsEnabled="False"/>
            <Button Grid.Column="2" Content="📊  Export CSV" Style="{StaticResource SecondaryButton}"
                    Click="ExportCsvBtn_Click" x:Name="ExportCsvBtn" IsEnabled="False"/>
            <TextBlock Grid.Column="3" x:Name="FooterStatus" Text="Ready"
                       Foreground="{DynamicResource SubLabelFg}"
                       FontSize="12" VerticalAlignment="Center" Margin="12,0,0,0"
                       TextTrimming="CharacterEllipsis"/>
        </Grid>

        <!-- Tabs: fills all remaining vertical space — DataGrid scrolls within its own space -->
        <!-- Padding="0,0,16,0": right pad keeps content clear of the 14px rounded corner clipping zone -->
        <Border Style="{StaticResource Card}" Padding="0,0,16,0">
            <TabControl x:Name="MainTabControl" BorderThickness="0" Background="Transparent">
                <TabControl.Resources>
                    <!-- Tab headers hidden — navigation is sidebar-only; each tab is an independent screen -->
                    <Style TargetType="TabItem">
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="TabItem">
                                    <Border Height="0" Width="0" Visibility="Collapsed"/>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </TabControl.Resources>

                <!-- Transactions Tab -->
                <!-- ═══════════════════════════════════════════════════════
                     TAB 0 — OVERVIEW DASHBOARD
                     ═══════════════════════════════════════════════════════ -->
                <TabItem x:Name="TabItem0" Header="Overview">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- ── Header bar ── -->
                        <Border Grid.Row="0" Padding="20,14" Background="{DynamicResource CardBg}"
                                BorderBrush="{DynamicResource CardBorder}" BorderThickness="0,0,0,1">
                            <Grid DataContext="{Binding RelativeSource={RelativeSource AncestorType=Window}}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="Overview" FontSize="18" FontWeight="Bold"
                                               Foreground="{DynamicResource PrimaryText}"/>
                                    <TextBlock Text="High-level summary of the currently loaded transactions."
                                               FontSize="12" Foreground="{DynamicResource SubText}" Margin="0,2,0,0"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,0,0">
                                    <!-- Period picker -->
                                    <Border CornerRadius="6" BorderThickness="1" BorderBrush="{DynamicResource CardBorder}"
                                            Padding="6,3" Margin="0,0,10,0">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="📅" FontSize="12" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                            <ComboBox x:Name="DashPeriodCombo"
                                                      BorderThickness="0" Background="Transparent"
                                                      FontSize="12" Height="24" MinWidth="100"
                                                      Foreground="{DynamicResource SubText}"
                                                      SelectionChanged="DashPeriodCombo_SelectionChanged">
                                                <ComboBoxItem Content="Last 7 days"/>
                                                <ComboBoxItem Content="Last 30 days" IsSelected="True"/>
                                                <ComboBoxItem Content="Last 90 days"/>
                                                <ComboBoxItem Content="All time"/>
                                            </ComboBox>
                                        </StackPanel>
                                    </Border>
                                    <!-- Export Report button -->
                                    <Button Content="⬇ Export Report" FontSize="12" Padding="12,6"
                                            BorderThickness="1" BorderBrush="{DynamicResource CardBorder}"
                                            Background="Transparent" Foreground="{DynamicResource PrimaryText}"
                                            Cursor="Hand" Click="ExportJsonBtn_Click">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}"
                                                        BorderBrush="{TemplateBinding BorderBrush}"
                                                        BorderThickness="{TemplateBinding BorderThickness}"
                                                        CornerRadius="6" Padding="{TemplateBinding Padding}">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="{DynamicResource TabHoverBg}"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- ── Scrollable body ── -->
                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="20,18,20,20">
                            <StackPanel DataContext="{Binding RelativeSource={RelativeSource AncestorType=Window}}">

                                <!-- Row 1: 4 KPI mega-cards -->
                                <UniformGrid Columns="4" Margin="0,0,0,14">

                                    <!-- Card 1: Total Transactions -->
                                    <Border Margin="0,0,7,0" Background="{DynamicResource CardBg}"
                                            CornerRadius="12" Padding="20,18"
                                            BorderBrush="{DynamicResource CardBorder}" BorderThickness="1">
                                        <StackPanel>
                                            <Border Width="38" Height="38" CornerRadius="8" Background="{DynamicResource GreenIconBadgeBg}"
                                                    HorizontalAlignment="Left" Margin="0,0,0,10">
                                                <TextBlock Text="⊞" FontSize="17" HorizontalAlignment="Center"
                                                           VerticalAlignment="Center" Foreground="#7C3AED"/>
                                            </Border>
                                            <TextBlock Text="Total Transactions" FontSize="11"
                                                       Foreground="{DynamicResource SubText}" Margin="0,0,0,4"/>
                                            <TextBlock Text="{Binding OverviewTxnCount}" FontSize="32"
                                                       FontWeight="Bold" Foreground="#7C3AED"/>
                                            <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                                <TextBlock FontSize="12" Foreground="{DynamicResource SubText}">
                                                    <Run Text="{Binding OverviewAchCount, Mode=OneWay}"/>
                                                    <Run Text=" ACH · "/>
                                                    <Run Text="{Binding OverviewCardCount, Mode=OneWay}"/>
                                                    <Run Text=" Card"/>
                                                </TextBlock>
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>

                                    <!-- Card 2: Total Approved Volume -->
                                    <Border Margin="7,0" Background="{DynamicResource CardBg}"
                                            CornerRadius="12" Padding="20,18"
                                            BorderBrush="{DynamicResource CardBorder}" BorderThickness="1">
                                        <StackPanel>
                                            <Border Width="38" Height="38" CornerRadius="8" Background="{DynamicResource GreenIconBadgeBg}"
                                                    HorizontalAlignment="Left" Margin="0,0,0,10">
                                                <TextBlock Text="$" FontSize="18" FontWeight="Bold"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center" Foreground="#A78BFA"/>
                                            </Border>
                                            <TextBlock Text="Total Approved Volume" FontSize="11"
                                                       Foreground="{DynamicResource SubText}" Margin="0,0,0,4"/>
                                            <TextBlock Text="{Binding OverviewApproved}" FontSize="28"
                                                       FontWeight="Bold" Foreground="#A78BFA"
                                                       TextTrimming="CharacterEllipsis"/>
                                            <TextBlock Text="vs Apr 11 – May 10  ↗ —" FontSize="12"
                                                       Foreground="{DynamicResource SubText}" Margin="0,6,0,0"/>
                                        </StackPanel>
                                    </Border>

                                    <!-- Card 3: Payment Split -->
                                    <Border Margin="7,0" Background="{DynamicResource CardBg}"
                                            CornerRadius="12" Padding="20,18"
                                            BorderBrush="{DynamicResource CardBorder}" BorderThickness="1">
                                        <StackPanel>
                                            <Border Width="38" Height="38" CornerRadius="8" Background="#F5F3FF"
                                                    HorizontalAlignment="Left" Margin="0,0,0,10">
                                                <TextBlock Text="⇄" FontSize="16" HorizontalAlignment="Center"
                                                           VerticalAlignment="Center" Foreground="#8B5CF6"/>
                                            </Border>
                                            <TextBlock Text="Payment Split" FontSize="11"
                                                       Foreground="{DynamicResource SubText}" Margin="0,0,0,8"/>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition/>
                                                    <ColumnDefinition/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel>
                                                    <TextBlock Text="{Binding OverviewAchCount}" FontSize="26"
                                                               FontWeight="Bold" Foreground="#8B5CF6"/>
                                                    <TextBlock FontSize="11" Foreground="{DynamicResource SubText}" Margin="0,2,0,0">
                                                        <Run Text="ACH ("/>
                                                        <Run Text="{Binding OverviewAchPct, Mode=OneWay}"/>
                                                        <Run Text="%)"/>
                                                    </TextBlock>
                                                </StackPanel>
                                                <StackPanel Grid.Column="1">
                                                    <TextBlock Text="{Binding OverviewCardCount}" FontSize="26"
                                                               FontWeight="Bold" Foreground="#7C3AED"/>
                                                    <TextBlock FontSize="11" Foreground="{DynamicResource SubText}" Margin="0,2,0,0">
                                                        <Run Text="Card ("/>
                                                        <Run Text="{Binding OverviewCardPct, Mode=OneWay}"/>
                                                        <Run Text="%)"/>
                                                    </TextBlock>
                                                </StackPanel>
                                            </Grid>
                                        </StackPanel>
                                    </Border>

                                    <!-- Card 4: Issues -->
                                    <Border Margin="7,0,0,0" Background="{DynamicResource CardBg}"
                                            CornerRadius="12" Padding="20,18"
                                            BorderBrush="{DynamicResource CardBorder}" BorderThickness="1">
                                        <StackPanel>
                                            <Border Width="38" Height="38" CornerRadius="8" Background="#FEF2F2"
                                                    HorizontalAlignment="Left" Margin="0,0,0,10">
                                                <TextBlock Text="⚠" FontSize="16" HorizontalAlignment="Center"
                                                           VerticalAlignment="Center" Foreground="#EF4444"/>
                                            </Border>
                                            <TextBlock Text="Issues" FontSize="11"
                                                       Foreground="{DynamicResource SubText}" Margin="0,0,0,8"/>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition/>
                                                    <ColumnDefinition/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel>
                                                    <TextBlock Text="{Binding OverviewFailedCount}" FontSize="26"
                                                               FontWeight="Bold" Foreground="#EF4444"/>
                                                    <TextBlock Text="Failed" FontSize="11"
                                                               Foreground="{DynamicResource SubText}" Margin="0,2,0,0"/>
                                                </StackPanel>
                                                <StackPanel Grid.Column="1">
                                                    <TextBlock Text="{Binding OverviewReturnedCount}" FontSize="26"
                                                               FontWeight="Bold" Foreground="#FCD34D"/>
                                                    <TextBlock Text="Returned" FontSize="11"
                                                               Foreground="{DynamicResource SubText}" Margin="0,2,0,0"/>
                                                </StackPanel>
                                            </Grid>
                                        </StackPanel>
                                    </Border>

                                </UniformGrid>

                                <!-- Row 2: 6 stat cards (2 rows × 3) -->
                                <UniformGrid Columns="3" Margin="0,0,0,20">

                                    <!-- 1: Settled Count -->
                                    <Border Margin="0,0,6,6" Background="{DynamicResource CardBg}"
                                            CornerRadius="10" Padding="14,14"
                                            BorderBrush="{DynamicResource CardBorder}" BorderThickness="1">
                                        <StackPanel>
                                            <Border Width="30" Height="30" CornerRadius="6" Background="{DynamicResource GreenIconBadgeBg}"
                                                    HorizontalAlignment="Left" Margin="0,0,0,8">
                                                <TextBlock Text="✓" FontSize="14" HorizontalAlignment="Center"
                                                           VerticalAlignment="Center" Foreground="#7C3AED"/>
                                            </Border>
                                            <TextBlock Text="Settled" FontSize="10" Foreground="{DynamicResource SubText}" Margin="0,0,0,3"/>
                                            <TextBlock Text="{Binding OverviewSettledCount}" FontSize="22"
                                                       FontWeight="Bold" Foreground="#7C3AED"/>
                                            <TextBlock Text="{Binding OverviewSettledPctLabel}" FontSize="10" Foreground="{DynamicResource SubText}" Margin="0,2,0,6"/>
                                            <Grid x:Name="SettledBarGrid" Height="4">
                                                <Border CornerRadius="2" Background="#E2E8F0" HorizontalAlignment="Stretch"/>
                                                <Border CornerRadius="2" Background="#A78BFA" HorizontalAlignment="Left">
                                                    <Border.Width>
                                                        <MultiBinding Converter="{StaticResource PctToWidthConverter}">
                                                            <Binding Path="OverviewSettledPctDouble"/>
                                                            <Binding RelativeSource="{RelativeSource AncestorType=Grid}" Path="ActualWidth"/>
                                                        </MultiBinding>
                                                    </Border.Width>
                                                </Border>
                                            </Grid>
                                        </StackPanel>
                                    </Border>

                                    <!-- 2: Settled Amount -->
                                    <Border Margin="0,0,6,6" Background="{DynamicResource CardBg}"
                                            CornerRadius="10" Padding="14,14"
                                            BorderBrush="{DynamicResource CardBorder}" BorderThickness="1">
                                        <StackPanel>
                                            <Border Width="30" Height="30" CornerRadius="6" Background="{DynamicResource GreenIconBadgeBg}"
                                                    HorizontalAlignment="Left" Margin="0,0,0,8">
                                                <TextBlock Text="$" FontSize="14" FontWeight="Bold" HorizontalAlignment="Center"
                                                           VerticalAlignment="Center" Foreground="#7C3AED"/>
                                            </Border>
                                            <TextBlock Text="Settled Amt" FontSize="10" Foreground="{DynamicResource SubText}" Margin="0,0,0,3"/>
                                            <TextBlock Text="{Binding OverviewSettledAmount}" FontSize="16"
                                                       FontWeight="Bold" Foreground="#7C3AED" TextTrimming="CharacterEllipsis"/>
                                            <TextBlock Text="of total volume" FontSize="10" Foreground="{DynamicResource SubText}" Margin="0,2,0,6"/>
                                            <Border Height="4" CornerRadius="2" Background="#A78BFA" HorizontalAlignment="Stretch" Opacity="0.4"/>
                                        </StackPanel>
                                    </Border>

                                    <!-- 3: Pending -->
                                    <Border Margin="0,0,0,6" Background="{DynamicResource CardBg}"
                                            CornerRadius="10" Padding="14,14"
                                            BorderBrush="{DynamicResource CardBorder}" BorderThickness="1">
                                        <StackPanel>
                                            <Border Width="30" Height="30" CornerRadius="6" Background="#FFFBEB"
                                                    HorizontalAlignment="Left" Margin="0,0,0,8">
                                                <TextBlock Text="⏳" FontSize="13" HorizontalAlignment="Center"
                                                           VerticalAlignment="Center" Foreground="#D97706"/>
                                            </Border>
                                            <TextBlock Text="Pending" FontSize="10" Foreground="{DynamicResource SubText}" Margin="0,0,0,3"/>
                                            <TextBlock Text="{Binding OverviewPendingCount}" FontSize="22"
                                                       FontWeight="Bold" Foreground="#D97706"/>
                                            <TextBlock Text="{Binding OverviewPendingPctLabel}" FontSize="10" Foreground="{DynamicResource SubText}" Margin="0,2,0,6"/>
                                            <Grid Height="4">
                                                <Border CornerRadius="2" Background="#E2E8F0" HorizontalAlignment="Stretch"/>
                                                <Border CornerRadius="2" Background="#D97706" HorizontalAlignment="Left">
                                                    <Border.Width>
                                                        <MultiBinding Converter="{StaticResource PctToWidthConverter}">
                                                            <Binding Path="OverviewPendingPctDouble"/>
                                                            <Binding RelativeSource="{RelativeSource AncestorType=Grid}" Path="ActualWidth"/>
                                                        </MultiBinding>
                                                    </Border.Width>
                                                </Border>
                                            </Grid>
                                        </StackPanel>
                                    </Border>

                                    <!-- 4: Captured -->
                                    <Border Margin="0,0,6,0" Background="{DynamicResource CardBg}"
                                            CornerRadius="10" Padding="14,14"
                                            BorderBrush="{DynamicResource CardBorder}" BorderThickness="1">
                                        <StackPanel>
                                            <Border Width="30" Height="30" CornerRadius="6" Background="{DynamicResource GreenIconBadgeBg}"
                                                    HorizontalAlignment="Left" Margin="0,0,0,8">
                                                <TextBlock Text="🔒" FontSize="13" HorizontalAlignment="Center"
                                                           VerticalAlignment="Center" Foreground="#7C3AED"/>
                                            </Border>
                                            <TextBlock Text="Captured" FontSize="10" Foreground="{DynamicResource SubText}" Margin="0,0,0,3"/>
                                            <TextBlock Text="{Binding OverviewCapturedCount}" FontSize="22"
                                                       FontWeight="Bold" Foreground="#7C3AED"/>
                                            <TextBlock Text="{Binding OverviewCapturedPctLabel}" FontSize="10" Foreground="{DynamicResource SubText}" Margin="0,2,0,6"/>
                                            <Grid Height="4">
                                                <Border CornerRadius="2" Background="#E2E8F0" HorizontalAlignment="Stretch"/>
                                                <Border CornerRadius="2" Background="#7C3AED" HorizontalAlignment="Left">
                                                    <Border.Width>
                                                        <MultiBinding Converter="{StaticResource PctToWidthConverter}">
                                                            <Binding Path="OverviewCapturedPctDouble"/>
                                                            <Binding RelativeSource="{RelativeSource AncestorType=Grid}" Path="ActualWidth"/>
                                                        </MultiBinding>
                                                    </Border.Width>
                                                </Border>
                                            </Grid>
                                        </StackPanel>
                                    </Border>

                                    <!-- 5: Avg Amount -->
                                    <Border Margin="0,0,6,0" Background="{DynamicResource CardBg}"
                                            CornerRadius="10" Padding="14,14"
                                            BorderBrush="{DynamicResource CardBorder}" BorderThickness="1">
                                        <StackPanel>
                                            <Border Width="30" Height="30" CornerRadius="6" Background="#F5F3FF"
                                                    HorizontalAlignment="Left" Margin="0,0,0,8">
                                                <TextBlock Text="$" FontSize="14" FontWeight="Bold" HorizontalAlignment="Center"
                                                           VerticalAlignment="Center" Foreground="#7C3AED"/>
                                            </Border>
                                            <TextBlock Text="Avg Amount" FontSize="10" Foreground="{DynamicResource SubText}" Margin="0,0,0,3"/>
                                            <TextBlock Text="{Binding OverviewAvgAmount}" FontSize="16"
                                                       FontWeight="Bold" Foreground="{DynamicResource PrimaryText}"
                                                       TextTrimming="CharacterEllipsis"/>
                                            <TextBlock Text="Per transaction" FontSize="10" Foreground="{DynamicResource SubText}" Margin="0,2,0,6"/>
                                            <Border Height="4" CornerRadius="2" Background="#8B5CF6" HorizontalAlignment="Stretch" Opacity="0.4"/>
                                        </StackPanel>
                                    </Border>

                                    <!-- 6: Disbursed -->
                                    <Border Margin="0" Background="{DynamicResource CardBg}"
                                            CornerRadius="10" Padding="14,14"
                                            BorderBrush="{DynamicResource CardBorder}" BorderThickness="1">
                                        <StackPanel>
                                            <Border Width="30" Height="30" CornerRadius="6" Background="#F8FAFC"
                                                    HorizontalAlignment="Left" Margin="0,0,0,8">
                                                <TextBlock Text="🏛" FontSize="13" HorizontalAlignment="Center"
                                                           VerticalAlignment="Center" Foreground="#64748B"/>
                                            </Border>
                                            <TextBlock Text="Disbursed" FontSize="10" Foreground="{DynamicResource SubText}" Margin="0,0,0,3"/>
                                            <TextBlock Text="{Binding OverviewDisbursedCount}" FontSize="22"
                                                       FontWeight="Bold" Foreground="#64748B"/>
                                            <TextBlock Text="0% of captured" FontSize="10" Foreground="{DynamicResource SubText}" Margin="0,2,0,6"/>
                                            <Border Height="4" CornerRadius="2" Background="#94A3B8" HorizontalAlignment="Stretch" Opacity="0.4"/>
                                        </StackPanel>
                                    </Border>

                                </UniformGrid>

                                <!-- ── API Tools section ── -->
                                <TextBlock Text="🔌  API Tools" FontSize="13" FontWeight="SemiBold"
                                           Foreground="{DynamicResource PrimaryText}" Margin="0,0,0,10"/>
                                <UniformGrid Columns="3" Margin="0,0,0,20">

                                    <!-- Total Endpoints — horizontal layout -->
                                    <Border Margin="0,0,7,0" Background="{DynamicResource CardBg}"
                                            CornerRadius="12" Padding="16,16"
                                            BorderBrush="{DynamicResource CardBorder}" BorderThickness="1">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="90"/>
                                            </Grid.ColumnDefinitions>
                                            <!-- Icon -->
                                            <Border Width="40" Height="40" CornerRadius="8" Background="#F5F3FF"
                                                    VerticalAlignment="Center" Margin="0,0,12,0">
                                                <TextBlock Text="⚡" FontSize="18" HorizontalAlignment="Center"
                                                           VerticalAlignment="Center" Foreground="#7C3AED"/>
                                            </Border>
                                            <!-- Label + number -->
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                <TextBlock Text="Total API Endpoints" FontSize="11"
                                                           Foreground="{DynamicResource SubText}" Margin="0,0,0,4"/>
                                                <TextBlock Text="{Binding OverviewApiCountFmt}" FontSize="28"
                                                           FontWeight="Bold" Foreground="#7C3AED"/>
                                            </StackPanel>
                                            <!-- Sparkline -->
                                            <Border Grid.Column="2" Height="46" CornerRadius="6" Background="#F5F3FF" VerticalAlignment="Center">
                                                <Canvas Width="80" Height="36" Margin="5,5">
                                                    <Polyline Points="0,28 13,22 26,18 39,20 52,12 65,8 78,14"
                                                              Stroke="#8B5CF6" StrokeThickness="2" StrokeLineJoin="Round"/>
                                                    <Polyline Points="0,36 13,34 26,32 39,33 52,29 65,26 78,30"
                                                              Stroke="#C4B5FD" StrokeThickness="1.5" StrokeLineJoin="Round" Opacity="0.6"/>
                                                </Canvas>
                                            </Border>
                                        </Grid>
                                    </Border>

                                    <!-- Collections — horizontal layout -->
                                    <Border Margin="7,0" Background="{DynamicResource CardBg}"
                                            CornerRadius="12" Padding="16,16"
                                            BorderBrush="{DynamicResource CardBorder}" BorderThickness="1">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="90"/>
                                            </Grid.ColumnDefinitions>
                                            <!-- Icon -->
                                            <Border Width="40" Height="40" CornerRadius="8" Background="{DynamicResource GreenIconBadgeBg}"
                                                    VerticalAlignment="Center" Margin="0,0,12,0">
                                                <TextBlock Text="📁" FontSize="17" HorizontalAlignment="Center"
                                                           VerticalAlignment="Center" Foreground="#7C3AED"/>
                                            </Border>
                                            <!-- Label + number -->
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                <TextBlock Text="Collections" FontSize="11"
                                                           Foreground="{DynamicResource SubText}" Margin="0,0,0,4"/>
                                                <TextBlock Text="{Binding OverviewCollectionCount}" FontSize="28"
                                                           FontWeight="Bold" Foreground="#7C3AED"/>
                                            </StackPanel>
                                            <!-- Sparkline -->
                                            <Border Grid.Column="2" Height="46" CornerRadius="6" Background="{DynamicResource GreenIconBadgeBg}" VerticalAlignment="Center">
                                                <Canvas Width="80" Height="36" Margin="5,5">
                                                    <Polyline Points="0,30 13,26 26,20 39,22 52,16 65,18 78,10"
                                                              Stroke="#7C3AED" StrokeThickness="2" StrokeLineJoin="Round"/>
                                                    <Polyline Points="0,36 13,34 26,32 39,33 52,30 65,31 78,28"
                                                              Stroke="#93C5FD" StrokeThickness="1.5" StrokeLineJoin="Round" Opacity="0.6"/>
                                                </Canvas>
                                            </Border>
                                        </Grid>
                                    </Border>

                                    <!-- Recent Requests — horizontal layout -->
                                    <Border Margin="7,0,0,0" Background="{DynamicResource CardBg}"
                                            CornerRadius="12" Padding="16,16"
                                            BorderBrush="{DynamicResource CardBorder}" BorderThickness="1">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="90"/>
                                            </Grid.ColumnDefinitions>
                                            <!-- Icon -->
                                            <Border Width="40" Height="40" CornerRadius="8" Background="#FFFBEB"
                                                    VerticalAlignment="Center" Margin="0,0,12,0">
                                                <TextBlock Text="🕐" FontSize="16" HorizontalAlignment="Center"
                                                           VerticalAlignment="Center" Foreground="#D97706"/>
                                            </Border>
                                            <!-- Label + number -->
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                <TextBlock Text="Recent Requests (24h)" FontSize="11"
                                                           Foreground="{DynamicResource SubText}" Margin="0,0,0,4"/>
                                                <TextBlock Text="{Binding OverviewRecentCount}" FontSize="28"
                                                           FontWeight="Bold" Foreground="#D97706"/>
                                            </StackPanel>
                                            <!-- Sparkline -->
                                            <Border Grid.Column="2" Height="46" CornerRadius="6" Background="#FFFBEB" VerticalAlignment="Center">
                                                <Canvas Width="80" Height="36" Margin="5,5">
                                                    <Polyline Points="0,32 13,20 26,24 39,10 52,18 65,14 78,6"
                                                              Stroke="#F59E0B" StrokeThickness="2" StrokeLineJoin="Round"/>
                                                    <Polyline Points="0,36 13,32 26,34 39,28 52,30 65,28 78,24"
                                                              Stroke="#FDE68A" StrokeThickness="1.5" StrokeLineJoin="Round" Opacity="0.6"/>
                                                </Canvas>
                                            </Border>
                                        </Grid>
                                    </Border>

                                </UniformGrid>

                                <!-- ── Bottom 3-column section ── -->
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="14"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="14"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Left: Transactions Over Time -->
                                    <Border Grid.Column="0" Background="{DynamicResource CardBg}"
                                            CornerRadius="12" Padding="16,14"
                                            BorderBrush="{DynamicResource CardBorder}" BorderThickness="1">
                                        <StackPanel>
                                            <Grid Margin="0,0,0,12">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="Transactions Over Time" FontSize="13" FontWeight="SemiBold"
                                                           Foreground="{DynamicResource PrimaryText}" VerticalAlignment="Center"/>
                                                <ComboBox Grid.Column="1" Width="70" Height="26" FontSize="11" SelectedIndex="0">
                                                    <ComboBoxItem Content="Daily"/>
                                                    <ComboBoxItem Content="Weekly"/>
                                                    <ComboBoxItem Content="Monthly"/>
                                                </ComboBox>
                                            </Grid>
                                            <!-- Line chart using Canvas -->
                                            <Border CornerRadius="8" Background="#F8FAFC"
                                                    BorderBrush="#CBD5E1" BorderThickness="1" Padding="10,10,10,6">
                                                <StackPanel>
                                                    <!-- Y-axis labels + chart area -->
                                                    <Grid Height="160">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="28"/>
                                                            <ColumnDefinition Width="*"/>
                                                        </Grid.ColumnDefinitions>
                                                        <!-- Y labels -->
                                                        <StackPanel Grid.Column="0" VerticalAlignment="Stretch">
                                                            <TextBlock Text="100" FontSize="9" Foreground="#94A3B8" VerticalAlignment="Top"/>
                                                            <TextBlock Text="75"  FontSize="9" Foreground="#94A3B8" VerticalAlignment="Center" Margin="0,22,0,0"/>
                                                            <TextBlock Text="50"  FontSize="9" Foreground="#94A3B8" VerticalAlignment="Center" Margin="0,22,0,0"/>
                                                            <TextBlock Text="25"  FontSize="9" Foreground="#94A3B8" VerticalAlignment="Center" Margin="0,22,0,0"/>
                                                            <TextBlock Text="0"   FontSize="9" Foreground="#94A3B8" VerticalAlignment="Bottom"/>
                                                        </StackPanel>
                                                        <!-- Chart canvas -->
                                                        <Canvas Grid.Column="1" ClipToBounds="True">
                                                            <!-- Grid lines -->
                                                            <Line X1="0" Y1="0"   X2="500" Y2="0"   Stroke="#E2E8F0" StrokeThickness="1"/>
                                                            <Line X1="0" Y1="40"  X2="500" Y2="40"  Stroke="#E2E8F0" StrokeThickness="1"/>
                                                            <Line X1="0" Y1="80"  X2="500" Y2="80"  Stroke="#E2E8F0" StrokeThickness="1"/>
                                                            <Line X1="0" Y1="120" X2="500" Y2="120" Stroke="#E2E8F0" StrokeThickness="1"/>
                                                            <Line X1="0" Y1="160" X2="500" Y2="160" Stroke="#E2E8F0" StrokeThickness="1"/>
                                                            <!-- Count line (blue) -->
                                                            <Polyline Points="0,130 50,110 100,90 150,100 200,60 250,45 300,70 350,40 400,55 450,30 500,45"
                                                                      Stroke="#7C3AED" StrokeThickness="2.5" StrokeLineJoin="Round"
                                                                      Fill="Transparent"/>
                                                            <!-- Volume line (green) -->
                                                            <Polyline Points="0,150 50,135 100,120 150,125 200,100 250,85 300,105 350,80 400,95 450,65 500,80"
                                                                      Stroke="#A78BFA" StrokeThickness="2.5" StrokeLineJoin="Round"
                                                                      Fill="Transparent"/>
                                                        </Canvas>
                                                    </Grid>
                                                    <!-- X-axis date labels -->
                                                    <Grid Margin="28,4,0,0">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="*"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Grid.Column="0" Text="May 11" FontSize="9" Foreground="#94A3B8" HorizontalAlignment="Center"/>
                                                        <TextBlock Grid.Column="1" Text="May 16" FontSize="9" Foreground="#94A3B8" HorizontalAlignment="Center"/>
                                                        <TextBlock Grid.Column="2" Text="May 21" FontSize="9" Foreground="#94A3B8" HorizontalAlignment="Center"/>
                                                        <TextBlock Grid.Column="3" Text="May 26" FontSize="9" Foreground="#94A3B8" HorizontalAlignment="Center"/>
                                                        <TextBlock Grid.Column="4" Text="May 31" FontSize="9" Foreground="#94A3B8" HorizontalAlignment="Center"/>
                                                        <TextBlock Grid.Column="5" Text="Jun 5"  FontSize="9" Foreground="#94A3B8" HorizontalAlignment="Center"/>
                                                    </Grid>
                                                </StackPanel>
                                            </Border>
                                            <!-- Legend -->
                                            <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                                                <Ellipse Width="8" Height="8" Fill="#7C3AED" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                                <TextBlock Text="Count" FontSize="11" Foreground="{DynamicResource SubText}" Margin="0,0,16,0"/>
                                                <Ellipse Width="8" Height="8" Fill="#A78BFA" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                                <TextBlock Text="Volume (USD)" FontSize="11" Foreground="{DynamicResource SubText}"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>

                                    <!-- Middle: Top Merchants by Volume -->
                                    <Border Grid.Column="2" Background="{DynamicResource CardBg}"
                                            CornerRadius="12" Padding="16,14"
                                            BorderBrush="{DynamicResource CardBorder}" BorderThickness="1">
                                        <StackPanel>
                                            <Grid Margin="0,0,0,12">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="Top Merchants by Volume" FontSize="13" FontWeight="SemiBold"
                                                           Foreground="{DynamicResource PrimaryText}" VerticalAlignment="Center"/>
                                                <Border Grid.Column="1" CornerRadius="5" Padding="4,2"
                                                        BorderBrush="{DynamicResource CardBorder}" BorderThickness="1">
                                                    <ComboBox x:Name="DashTopNCombo"
                                                              BorderThickness="0" Background="Transparent"
                                                              FontSize="11" Height="22" MinWidth="60"
                                                              Foreground="{DynamicResource SubText}"
                                                              SelectionChanged="DashTopNCombo_SelectionChanged">
                                                        <ComboBoxItem Content="Top 3"/>
                                                        <ComboBoxItem Content="Top 5" IsSelected="True"/>
                                                        <ComboBoxItem Content="Top 10"/>
                                                        <ComboBoxItem Content="Top 20"/>
                                                    </ComboBox>
                                                </Border>
                                            </Grid>
                                            <DataGrid ItemsSource="{Binding DashTopMerchants}"
                                                      AutoGenerateColumns="False" IsReadOnly="True"
                                                      HeadersVisibility="Column" GridLinesVisibility="None"
                                                      BorderThickness="0" RowHeight="44" FontSize="12"
                                                      Background="Transparent"
                                                      RowBackground="Transparent"
                                                      AlternatingRowBackground="Transparent"
                                                      HorizontalScrollBarVisibility="Disabled"
                                                      VerticalScrollBarVisibility="Disabled">
                                                <DataGrid.ColumnHeaderStyle>
                                                    <Style TargetType="DataGridColumnHeader">
                                                        <Setter Property="Background" Value="Transparent"/>
                                                        <Setter Property="Foreground" Value="{DynamicResource SubText}"/>
                                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                                        <Setter Property="FontSize" Value="10"/>
                                                        <Setter Property="Padding" Value="4,4"/>
                                                        <Setter Property="BorderThickness" Value="0"/>
                                                    </Style>
                                                </DataGrid.ColumnHeaderStyle>
                                                <DataGrid.Columns>
                                                    <DataGridTemplateColumn Header="Merchant" Width="*">
                                                        <DataGridTemplateColumn.CellTemplate>
                                                            <DataTemplate>
                                                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="4,0">
                                                                    <Border Width="28" Height="28" CornerRadius="14" Background="{DynamicResource GreenIconBadgeBg}" Margin="0,0,8,0">
                                                                        <TextBlock Text="M" FontSize="11" FontWeight="Bold" Foreground="#7C3AED"
                                                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                    </Border>
                                                                    <TextBlock Text="{Binding Name}" FontSize="12"
                                                                               Foreground="{DynamicResource PrimaryText}"
                                                                               VerticalAlignment="Center"
                                                                               TextTrimming="CharacterEllipsis"/>
                                                                </StackPanel>
                                                            </DataTemplate>
                                                        </DataGridTemplateColumn.CellTemplate>
                                                    </DataGridTemplateColumn>
                                                    <DataGridTextColumn Header="Volume (USD)" Binding="{Binding Volume}" Width="Auto"/>
                                                    <DataGridTextColumn Header="Txns" Binding="{Binding Count}" Width="50"/>
                                                </DataGrid.Columns>
                                            </DataGrid>
                                        </StackPanel>
                                    </Border>

                                    <!-- Right: Transaction Status Distribution -->
                                    <Border Grid.Column="4" Background="{DynamicResource CardBg}"
                                            CornerRadius="12" Padding="16,14"
                                            BorderBrush="{DynamicResource CardBorder}" BorderThickness="1">
                                        <StackPanel>
                                            <TextBlock Text="Transaction Status Distribution" FontSize="13" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource PrimaryText}" Margin="0,0,0,12"/>

                                            <!-- Donut chart -->
                                            <Grid HorizontalAlignment="Center" Margin="0,0,0,16" Width="130" Height="130"
                                                  Loaded="DonutChart_Loaded">
                                                <!-- Track ring -->
                                                <Ellipse Width="130" Height="130"
                                                         Stroke="#E2E8F0" StrokeThickness="22" Fill="Transparent"/>
                                                <!-- Arc segments — geometry set in UpdateDonutChart() -->
                                                <Path x:Name="DonutGreenArc" Stroke="#A78BFA" StrokeThickness="22"
                                                      Fill="Transparent" StrokeStartLineCap="Flat" StrokeEndLineCap="Flat"/>
                                                <Path x:Name="DonutBlueArc"  Stroke="#7C3AED" StrokeThickness="22"
                                                      Fill="Transparent" StrokeStartLineCap="Flat" StrokeEndLineCap="Flat"/>
                                                <Path x:Name="DonutAmberArc" Stroke="#F59E0B" StrokeThickness="22"
                                                      Fill="Transparent" StrokeStartLineCap="Flat" StrokeEndLineCap="Flat"/>
                                                <Path x:Name="DonutRedArc"   Stroke="#EF4444" StrokeThickness="22"
                                                      Fill="Transparent" StrokeStartLineCap="Flat" StrokeEndLineCap="Flat"/>
                                                <!-- Centre label -->
                                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding OverviewTxnCount}" FontSize="22"
                                                               FontWeight="Bold" Foreground="{DynamicResource PrimaryText}"
                                                               HorizontalAlignment="Center"/>
                                                    <TextBlock Text="total" FontSize="10"
                                                               Foreground="{DynamicResource SubText}"
                                                               HorizontalAlignment="Center"/>
                                                </StackPanel>
                                            </Grid>

                                            <!-- Legend rows -->
                                            <!-- Approved -->
                                            <Grid Margin="0,0,0,7">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="52"/>
                                                </Grid.ColumnDefinitions>
                                                <Border Width="10" Height="10" CornerRadius="5" Background="#A78BFA" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                                <TextBlock Grid.Column="1" Text="Approved" FontSize="12" Foreground="{DynamicResource PrimaryText}" VerticalAlignment="Center"/>
                                                <TextBlock Grid.Column="2" Text="{Binding DashApprovedCount}" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryText}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                                <TextBlock Grid.Column="3" Text="{Binding DashApprovedPct}" FontSize="11" Foreground="{DynamicResource SubText}" VerticalAlignment="Center"/>
                                            </Grid>
                                            <!-- Captured -->
                                            <Grid Margin="0,0,0,7">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="52"/>
                                                </Grid.ColumnDefinitions>
                                                <Border Width="10" Height="10" CornerRadius="5" Background="#7C3AED" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                                <TextBlock Grid.Column="1" Text="Captured / Settled" FontSize="12" Foreground="{DynamicResource PrimaryText}" VerticalAlignment="Center"/>
                                                <TextBlock Grid.Column="2" Text="{Binding OverviewSettledCount}" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryText}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                                <TextBlock Grid.Column="3" Text="{Binding DashSettledPct}" FontSize="11" Foreground="{DynamicResource SubText}" VerticalAlignment="Center"/>
                                            </Grid>
                                            <!-- Pending -->
                                            <Grid Margin="0,0,0,7">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="52"/>
                                                </Grid.ColumnDefinitions>
                                                <Border Width="10" Height="10" CornerRadius="5" Background="#F59E0B" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                                <TextBlock Grid.Column="1" Text="Pending" FontSize="12" Foreground="{DynamicResource PrimaryText}" VerticalAlignment="Center"/>
                                                <TextBlock Grid.Column="2" Text="{Binding OverviewPendingCount}" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryText}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                                <TextBlock Grid.Column="3" Text="{Binding DashPendingPct}" FontSize="11" Foreground="{DynamicResource SubText}" VerticalAlignment="Center"/>
                                            </Grid>
                                            <!-- Declined -->
                                            <Grid Margin="0,0,0,7">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="52"/>
                                                </Grid.ColumnDefinitions>
                                                <Border Width="10" Height="10" CornerRadius="5" Background="#F59E0B" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                                <TextBlock Grid.Column="1" Text="Declined" FontSize="12" Foreground="{DynamicResource PrimaryText}" VerticalAlignment="Center"/>
                                                <TextBlock Grid.Column="2" Text="{Binding DashDeclinedCount}" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryText}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                                <TextBlock Grid.Column="3" Text="{Binding DashDeclinedPct}" FontSize="11" Foreground="{DynamicResource SubText}" VerticalAlignment="Center"/>
                                            </Grid>
                                            <!-- Error/Failed -->
                                            <Grid Margin="0,0,0,7">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="52"/>
                                                </Grid.ColumnDefinitions>
                                                <Border Width="10" Height="10" CornerRadius="5" Background="#F97316" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                                <TextBlock Grid.Column="1" Text="Error/Failed" FontSize="12" Foreground="{DynamicResource PrimaryText}" VerticalAlignment="Center"/>
                                                <TextBlock Grid.Column="2" Text="{Binding DashErrorCount}" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryText}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                                <TextBlock Grid.Column="3" Text="{Binding DashErrorPct}" FontSize="11" Foreground="{DynamicResource SubText}" VerticalAlignment="Center"/>
                                            </Grid>
                                            <!-- ACH -->
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="52"/>
                                                </Grid.ColumnDefinitions>
                                                <Border Width="10" Height="10" CornerRadius="5" Background="#8B5CF6" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                                <TextBlock Grid.Column="1" FontSize="12" Foreground="{DynamicResource PrimaryText}" VerticalAlignment="Center">
                                                    <Run Text="ACH "/>
                                                    <Run Text="{Binding DashSettledAchCount, Mode=OneWay}"/>
                                                    <Run Text="/"/>
                                                    <Run Text="{Binding DashReturnedCount, Mode=OneWay}"/>
                                                </TextBlock>
                                                <TextBlock Grid.Column="2" Text="" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryText}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                                <TextBlock Grid.Column="3" Text="{Binding DashAchPct}" FontSize="11" Foreground="{DynamicResource SubText}" VerticalAlignment="Center"/>
                                            </Grid>
                                        </StackPanel>
                                    </Border>

                                </Grid>

                            </StackPanel>
                        </ScrollViewer>
                    </Grid>
                </TabItem>

                <!-- ═══════════════════════════════════════════════════════
                     TAB 1 — TRANSACTIONS (original tab 0)
                     ═══════════════════════════════════════════════════════ -->
                <TabItem x:Name="TabItem1" Header="Transactions">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/><!-- search sections -->
                            <RowDefinition Height="Auto"/><!-- toolbar -->
                            <RowDefinition Height="*"/>  <!-- DataGrid -->
                            <RowDefinition Height="Auto"/><!-- footer -->
                        </Grid.RowDefinitions>
                                                <!-- ── Search accordion sections (Row 0) ─────────────────────── -->
                        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled" MaxHeight="680">
                <StackPanel x:Name="SearchSectionsPanel">

                <!-- ── 3-card horizontal search grid (matching webapp layout) ─── -->
                <!-- Order: Col 0=By Transaction ID, Col 1=By Disbursement ID, Col 2=Verify & Repair Merchant -->
                <Grid Margin="0,6,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                <!-- ── Card 3: Verify & Repair Merchant (Col 2) ───────────────────── -->
                <Border Grid.Column="4" Margin="0" CornerRadius="8"
                        BorderBrush="{DynamicResource CardBorder}" BorderThickness="1"
                        Background="{DynamicResource CardBg}">
                    <StackPanel>
                                <Border x:Name="EmailSectionHeader" Cursor="Hand" MouseLeftButtonUp="EmailSectionHeader_Click"
                        Padding="16,0" MinHeight="48" Background="Transparent">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="{DynamicResource HoverBg}"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <Grid VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Border Width="28" Height="28" CornerRadius="7"
                                    Background="#7C3AED20" BorderBrush="#7C3AED40" BorderThickness="1"
                                    Margin="0,0,12,0">
                                <TextBlock Text="✦" FontSize="12" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#7C3AED"/>
                            </Border>
                            <TextBlock Text="Search by Email / Category" FontWeight="SemiBold" FontSize="13"
                                       Foreground="{DynamicResource PrimaryText}" VerticalAlignment="Center"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                            <TextBlock x:Name="EmailPinBtn" Text="📍" FontSize="11" Cursor="Hand"
                                       Foreground="{DynamicResource SubText}" Visibility="Collapsed"
                                       Margin="0,0,8,0" VerticalAlignment="Center"
                                       MouseLeftButtonDown="EmailPinBtn_Click"/>
                            <TextBlock x:Name="EmailSectionArrow" Text="›" FontSize="22" FontWeight="Light"
                                       Foreground="{DynamicResource SubText}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Grid>
                </Border>
                <Border BorderBrush="{DynamicResource CardBorder}" BorderThickness="0,1,0,0">
                <StackPanel x:Name="EmailSectionContent" Visibility="Visible">
                <!-- Row 3: Single email field with Search + Fetch Latest buttons (2-row layout) -->
                <Border Background="{DynamicResource SearchCardBg}" CornerRadius="6" Padding="12,10" Margin="0,0,0,10"
                        BorderBrush="{DynamicResource SearchCardBorder}" BorderThickness="1">
                    <StackPanel>
                        <!-- Row A: label + email box -->
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,8,0">
                                <TextBlock Text="📧 " FontSize="13"/>
                                <TextBlock Text="User Email:" FontWeight="SemiBold" FontSize="13"/>
                            </StackPanel>
                            <TextBox x:Name="UserEmailBox" Grid.Column="1" Height="34" Padding="10,0"
                                     VerticalContentAlignment="Center" FontSize="12" BorderBrush="{DynamicResource InputBorder}"
                                     BorderThickness="1"
                                     ToolTip="Email address used for searching transactions and fetching the latest transaction IDs"
                                     Text="Shaheen.Vakil@bqe.com"/>
                        </Grid>
                        <!-- Row B: Limit + Search & Load + Latest count (right-aligned) -->
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <TextBlock Text="Limit:" FontSize="11" Foreground="{DynamicResource SubLabelFg}" VerticalAlignment="Center" Margin="0,0,4,0"/>
                            <TextBox x:Name="SearchLimitBox" Width="55" Height="32" Padding="8,0"
                                     VerticalContentAlignment="Center" FontSize="12" BorderBrush="{DynamicResource InputBorder}"
                                     BorderThickness="1" Text="20" ToolTip="Enter max number of transactions to fetch"
                                     Margin="0,0,8,0"/>
                            <Button x:Name="SearchEmailBtn" Content="🔍 Search &amp; Load" Height="32" Padding="12,0"
                                    Margin="0,0,6,0" Click="SearchEmailBtn_Click">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
                                        <Setter Property="Background" Value="#2563EB"/>
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#1D4ED8"/>
                                            </Trigger>
                                            <Trigger Property="IsEnabled" Value="False">
                                                <Setter Property="Background" Value="#BFDBFE"/>
                                                <Setter Property="Foreground" Value="#2563EB"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                            <ComboBox x:Name="LatestCountBox" Width="55" Height="32"
                                      VerticalContentAlignment="Center" FontSize="12" SelectedIndex="0">
                                <ComboBoxItem Content="1"/>
                                <ComboBoxItem Content="5"/>
                                <ComboBoxItem Content="10"/>
                                <ComboBoxItem Content="20"/>
                            </ComboBox>
                        </StackPanel>
                    </StackPanel>
                </Border>
                <!-- Search mode row -->
                <Border Background="{DynamicResource SearchCardBg}" CornerRadius="6" Padding="12,8" Margin="0,4,0,0"
                        BorderBrush="{DynamicResource SearchCardBorder}" BorderThickness="1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="170"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Search mode:" FontWeight="SemiBold" FontSize="12"
                                   Foreground="{DynamicResource SubLabelFg}" VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <ComboBox x:Name="SearchModeBox" Grid.Column="1" Height="32" FontSize="12"
                                  VerticalContentAlignment="Center"
                                  Background="{DynamicResource InputBg}"
                                  Foreground="{DynamicResource PrimaryText}"
                                  BorderBrush="{DynamicResource InputBorder}"
                                  SelectionChanged="SearchModeBox_Changed"
                                  SelectedIndex="0"
                                  ToolTip="Select how to search for transactions">
                            <ComboBoxItem Content="By Email"            Tag="email"/>
                            <ComboBoxItem Content="Latest N"            Tag="latest"/>
                            <ComboBoxItem Content="ACH / eCheck (all)"  Tag="ach"/>
                            <ComboBoxItem Content="ACH Return"          Tag="achreturn"/>
                            <ComboBoxItem Content="ACH Refund"          Tag="achrefund"/>
                            <ComboBoxItem Content="Credit Card (all)"   Tag="card"/>
                            <ComboBoxItem Content="CC Refund"           Tag="ccrefund"/>
                            <ComboBoxItem Content="CC Return"           Tag="ccreturn"/>
                        </ComboBox>
                        <TextBlock x:Name="SearchModeHint" Grid.Column="2"
                                   FontSize="11" Foreground="{DynamicResource SubText}"
                                   VerticalAlignment="Center" Margin="12,0,0,0"
                                   Text="Searches transactions for the email above"/>
                    </Grid>
                </Border>

                <!-- Merchant / Entity search row -->
                <Border Background="{DynamicResource SearchCardBg}" CornerRadius="6" Padding="12,8" Margin="0,-6,0,10"
                        BorderBrush="{DynamicResource SearchCardBorder}" BorderThickness="1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,10,0">
                            <TextBlock Text="🏢 " FontSize="13"/>
                            <TextBlock Text="Merchant:" FontWeight="SemiBold" FontSize="13"/>
                        </StackPanel>
                        <TextBox x:Name="TxnMerchantFilterBox" Grid.Column="1" Height="30" Padding="10,0"
                                 VerticalContentAlignment="Center" FontSize="12" BorderBrush="{DynamicResource InputBorder}"
                                 BorderThickness="1"
                                 ToolTip="Search by merchant name, DBA, email, account email, or ID (t1_mer_… / p1_mer_…). Leave blank to ignore."/>
                        <TextBlock Grid.Column="3" Text="Resolved:" FontSize="11"
                                   Foreground="{DynamicResource SubText}" VerticalAlignment="Center"/>
                        <TextBlock x:Name="MerchantResolvedLabel" Grid.Column="5" FontSize="11"
                                   Foreground="{DynamicResource SubText}" VerticalAlignment="Center"
                                   MaxWidth="280" TextTrimming="CharacterEllipsis"
                                   Text="—" ToolTip="{Binding Text, RelativeSource={RelativeSource Self}}"/>
                    </Grid>
                </Border>

                <Border Background="{DynamicResource QuickFetchAchBg}" CornerRadius="6" Padding="12,8" Margin="0,-6,0,10"
                        BorderBrush="{DynamicResource QuickFetchAchBorder}" BorderThickness="1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="↑ Select count → fetches latest IDs (filtered by email if provided above) → pastes into Transaction IDs"
                                   FontSize="11" Foreground="{DynamicResource QuickFetchAchFg}" VerticalAlignment="Center"/>
                        <Button x:Name="FetchLatestBtn" Grid.Column="1" Content="⚡ Fetch Latest IDs"
                                Click="FetchLatestBtn_Click">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
                                    <Setter Property="Background" Value="#8B5CF6"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#7C3AED"/>
                                        </Trigger>
                                        <Trigger Property="IsEnabled" Value="False">
                                            <Setter Property="Background" Value="#DDD6FE"/>
                                            <Setter Property="Foreground" Value="#7C3AED"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </Grid>
                </Border>

                <!-- Row 3b: Quick-filter fetch buttons -->
                <Border Background="{DynamicResource QuickFetchCcBg}" CornerRadius="6" Padding="12,8" Margin="0,-6,0,10"
                        BorderBrush="{DynamicResource QuickFetchCcBorder}" BorderThickness="1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Quick-fetch by payment type (email filter applied if provided above, count dropdown applies):"
                                   FontSize="11" Foreground="{DynamicResource QuickFetchCcFg}" VerticalAlignment="Center"/>
                        <Button x:Name="FetchAchBtn" Grid.Column="1"
                                Content="🏦  Fetch ACH Payments"
                                Height="32" Padding="14,0" FontWeight="SemiBold" FontSize="12"
                                Cursor="Hand" BorderThickness="0"
                                Click="FetchAchBtn_Click"
                                ToolTip="Fetch all eCheck/ACH transactions (type 7 &amp; 8) for the email above">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Background" Value="#059669"/>
                                    <Setter Property="Foreground" Value="White"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}" CornerRadius="6"
                                                        Padding="{TemplateBinding Padding}">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#047857"/>
                                        </Trigger>
                                        <Trigger Property="IsEnabled" Value="False">
                                            <Setter Property="Background" Value="#A7F3D0"/>
                                            <Setter Property="Foreground" Value="#059669"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                        <Button x:Name="FetchCardBtn" Grid.Column="3"
                                Content="💳  Fetch Credit Card"
                                Height="32" Padding="14,0" FontWeight="SemiBold" FontSize="12"
                                Cursor="Hand" BorderThickness="0"
                                Click="FetchCardBtn_Click"
                                ToolTip="Fetch all credit/debit card transactions (type 1–6) for the email above">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Background" Value="#DB2777"/>
                                    <Setter Property="Foreground" Value="White"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}" CornerRadius="6"
                                                        Padding="{TemplateBinding Padding}">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#BE185D"/>
                                        </Trigger>
                                        <Trigger Property="IsEnabled" Value="False">
                                            <Setter Property="Background" Value="#FBCFE8"/>
                                            <Setter Property="Foreground" Value="#DB2777"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </Grid>
                </Border>

                </StackPanel>
                </Border><!-- EmailSectionContent border -->
                    </StackPanel>
                </Border><!-- Email accordion card -->

                <!-- ── Card 1: By Transaction ID (Col 0) ──────────────────────────── -->
                <Border Grid.Column="0" Margin="0" CornerRadius="8"
                        BorderBrush="{DynamicResource CardBorder}" BorderThickness="1"
                        Background="{DynamicResource CardBg}">
                    <StackPanel>
                                <Border x:Name="TxnSectionHeader" Cursor="Hand" MouseLeftButtonUp="TxnSectionHeader_Click"
                        Padding="16,0" MinHeight="48" Background="Transparent">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="{DynamicResource HoverBg}"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <Grid VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Border Width="28" Height="28" CornerRadius="7"
                                    Background="#7C3AED20" BorderBrush="#7C3AED40" BorderThickness="1"
                                    Margin="0,0,12,0">
                                <TextBlock Text="#" FontSize="14" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#7C3AED"/>
                            </Border>
                            <TextBlock Text="By Transaction ID" FontWeight="SemiBold" FontSize="13"
                                       Foreground="{DynamicResource PrimaryText}" VerticalAlignment="Center"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                            <TextBlock x:Name="TxnPinBtn" Text="📍" FontSize="11" Cursor="Hand"
                                       Foreground="{DynamicResource SubText}" Visibility="Collapsed"
                                       Margin="0,0,8,0" VerticalAlignment="Center"
                                       MouseLeftButtonDown="TxnPinBtn_Click"/>
                            <TextBlock x:Name="TxnSectionArrow" Text="›" FontSize="22" FontWeight="Light"
                                       Foreground="{DynamicResource SubText}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Grid>
                </Border>
                <Border BorderBrush="{DynamicResource CardBorder}" BorderThickness="0,1,0,0"
                        Padding="12,10,12,12">
                <!-- Row 4: Transaction IDs + buttons -->
                <Grid x:Name="TxnSectionContent">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Transaction IDs:" FontWeight="SemiBold"
                               VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <TextBox x:Name="TxnIdsBox" Grid.Column="1" Height="36" Padding="10,0"
                             VerticalContentAlignment="Center" FontSize="12" BorderBrush="{DynamicResource InputBorder}"
                             BorderThickness="1" ToolTip="Enter one or more transaction IDs separated by commas"
                             Text="t1_txn_6a10176e8d7bf4048722919"/>
                    <Button x:Name="FetchBtn" Grid.Column="3" Content="🔍  Fetch Transactions"
                            Click="FetchBtn_Click">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
                                <Setter Property="Background" Value="#4F46E5"/>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#4338CA"/>
                                    </Trigger>
                                    <Trigger Property="IsEnabled" Value="False">
                                        <Setter Property="Background" Value="#C7D2FE"/>
                                        <Setter Property="Foreground" Value="#6366F1"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                    <Button x:Name="ClearBtn" Grid.Column="5" Content="🗑  Clear"
                            Click="ClearBtn_Click">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="Foreground" Value="{DynamicResource LabelFg}"/>
                                <Setter Property="BorderBrush" Value="{DynamicResource CardBorder}"/>
                                <Setter Property="BorderThickness" Value="1"/>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="{DynamicResource DarkBtnBgHover}"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                    <Button Grid.Column="7" Content="🔗" Width="36" Height="36"
                            Click="ShareTxnIdBtn_Click" Cursor="Hand"
                            ToolTip="Share transaction ID(s)"
                            Background="#F5F5F7" Foreground="#007AFF" BorderBrush="#E5E5EA" BorderThickness="1">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}"
                                        BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="6">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#E5E5EA"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>
                </Border><!-- TxnSectionContent border -->
                    </StackPanel>
                </Border><!-- Txn accordion card -->

                <!-- ── Card 2: By Disbursement ID (Col 2) ─────────────────────────── -->
                <Border Grid.Column="2" Margin="0" CornerRadius="8"
                        BorderBrush="{DynamicResource CardBorder}" BorderThickness="1"
                        Background="{DynamicResource CardBg}">
                    <StackPanel>
                                <Border x:Name="DisbSectionHeader" Cursor="Hand" MouseLeftButtonUp="DisbSectionHeader_Click"
                        Padding="16,0" MinHeight="48" Background="Transparent">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="{DynamicResource HoverBg}"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <Grid VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Border Width="28" Height="28" CornerRadius="7"
                                    Background="#0891B220" BorderBrush="#0891B240" BorderThickness="1"
                                    Margin="0,0,12,0">
                                <TextBlock Text="⊞" FontSize="13" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#0891B2"/>
                            </Border>
                            <TextBlock Text="By Disbursement ID" FontWeight="SemiBold" FontSize="13"
                                       Foreground="{DynamicResource PrimaryText}" VerticalAlignment="Center"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                            <TextBlock x:Name="DisbPinBtn" Text="📍" FontSize="11" Cursor="Hand"
                                       Foreground="{DynamicResource SubText}" Visibility="Collapsed"
                                       Margin="0,0,8,0" VerticalAlignment="Center"
                                       MouseLeftButtonDown="DisbPinBtn_Click"/>
                            <TextBlock x:Name="DisbSectionArrow" Text="›" FontSize="22" FontWeight="Light"
                                       Foreground="{DynamicResource SubText}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Grid>
                </Border>
                <Border BorderBrush="{DynamicResource CardBorder}" BorderThickness="0,1,0,0"
                        Padding="12,10,12,12">
                <!-- Row 5: Disbursement ID search -->
                <Grid x:Name="DisbSectionContent" Visibility="Visible">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="4"/>
                        <ColumnDefinition Width="60"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Disbursement ID:" FontWeight="SemiBold"
                               VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <TextBox x:Name="DisbursementIdBox" Grid.Column="1" Height="36" Padding="10,0"
                             VerticalContentAlignment="Center" FontSize="12" FontFamily="Consolas"
                             BorderBrush="{DynamicResource InputBorder}" BorderThickness="1"
                             ToolTip="Enter a disbursement ID to fetch that specific disbursement, or leave blank to fetch the latest"/>
                    <TextBlock Grid.Column="3" Text="Limit:" FontWeight="SemiBold"
                               VerticalAlignment="Center" Margin="0,0,4,0"/>
                    <TextBox x:Name="DisbLimitBox" Grid.Column="5" Height="36" Padding="8,0"
                             VerticalContentAlignment="Center" FontSize="12" Text="20"
                             BorderBrush="{DynamicResource InputBorder}" BorderThickness="1"
                             ToolTip="Number of disbursements to fetch when no ID is specified"/>
                    <Button x:Name="FetchDisbursementBtn" Grid.Column="7"
                            Content="💸  Fetch Disbursement"
                            Height="36" Padding="14,0" FontWeight="SemiBold" FontSize="12"
                            Cursor="Hand" BorderThickness="0"
                            Click="FetchDisbursementBtn_Click"
                            ToolTip="Fetch all transactions belonging to this disbursement ID">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="#0F766E"/>
                                <Setter Property="Foreground" Value="White"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}" CornerRadius="6"
                                                    Padding="{TemplateBinding Padding}">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="#0D9488"/>
                                                </Trigger>
                                                <Trigger Property="IsEnabled" Value="False">
                                                    <Setter Property="Background" Value="#99F6E4"/>
                                                    <Setter Property="Foreground" Value="#0F766E"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                    </Button>
                    <Button Grid.Column="9" Content="Clear"
                            Height="36" Padding="14,0" FontSize="12"
                            Cursor="Hand" BorderThickness="0"
                            Background="#EF4444" Foreground="White"
                            Click="ClearDisbursementBtn_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" CornerRadius="6"
                                        Padding="{TemplateBinding Padding}">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#DC2626"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    <Button Grid.Column="11" Content="🔗" Width="36" Height="36"
                            Click="ShareDisbIdBtn_Click" Cursor="Hand"
                            ToolTip="Share disbursement ID"
                            Background="#F5F5F7" Foreground="#007AFF" BorderBrush="#E5E5EA" BorderThickness="1">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}"
                                        BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="6">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#E5E5EA"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>
                </Border><!-- DisbSectionContent border -->
                    </StackPanel>
                </Border><!-- Disb accordion card -->
                </Grid><!-- end 3-card horizontal grid -->

                <!-- ── Link: Verify & Repair Merchant — opens its own screen ────── -->
                <Border Margin="0,6,0,0" CornerRadius="8"
                        BorderBrush="#0EA5E940" BorderThickness="1"
                        Background="{DynamicResource CardBg}" Cursor="Hand"
                        MouseLeftButtonUp="NavMerchantVerifyBtn_Click">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="{DynamicResource HoverBg}"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <Grid Margin="16,12" VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Border Width="28" Height="28" CornerRadius="7"
                                    Background="#D9770620" BorderBrush="#D9770640" BorderThickness="1"
                                    Margin="0,0,12,0">
                                <TextBlock Text="🔧" FontSize="12" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel>
                                <TextBlock Text="Verify &amp; Repair Merchant" FontWeight="SemiBold" FontSize="13"
                                           Foreground="{DynamicResource PrimaryText}"/>
                                <TextBlock Text="DB + Payrix health check — click to open" FontSize="11"
                                           Foreground="{DynamicResource SubText}"/>
                            </StackPanel>
                        </StackPanel>
                        <TextBlock Text="›" FontSize="22" FontWeight="Light"
                                   Foreground="{DynamicResource SubText}" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                    </Grid>
                </Border><!-- Verify Merchant link card -->

                <!-- ═══════════════════════════════════════════════════════════
                     REMOVED: Verify Merchant accordion body (now TabItem20)
                     ═══════════════════════════════════════════════════════════
                     The following block was moved to TabItem20 (Verify Merchant screen).
                     x:Name references preserved: VerifyMerchantSectionHeader (stub below) -->
                <Border x:Name="VerifyMerchantSectionHeader" Visibility="Collapsed"/>
                <!-- Collapsed stubs to satisfy any x:Name lookups in code-behind -->
                <StackPanel Visibility="Collapsed">
                    <TextBlock x:Name="VerifyMerchantArrow"/>
                    <StackPanel x:Name="VerifyMerchantContent"/>
                </StackPanel>

                </StackPanel><!-- end SearchSectionsPanel -->

                        </ScrollViewer>

<!-- Header / toolbar -->
                        <Border Grid.Row="1" Padding="14,9" Background="{DynamicResource CardBg}"
                                BorderBrush="{DynamicResource CardBorder}" BorderThickness="0,0,0,1">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/><!-- search box -->
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="Auto"/><!-- status filter -->
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/><!-- right controls -->
                                </Grid.ColumnDefinitions>

                                <!-- Search input -->
                                <Border Grid.Column="0" CornerRadius="6" BorderBrush="{DynamicResource DarkBorder}"
                                        BorderThickness="1" Background="{DynamicResource InputBg}" Width="220" Height="32">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="🔍" FontSize="11" Foreground="{DynamicResource SubText}"
                                                   VerticalAlignment="Center" Margin="8,0,4,0"/>
                                        <TextBox x:Name="TxnSearchBox" Grid.Column="1" BorderThickness="0"
                                                 Background="Transparent" FontSize="11.5"
                                                 VerticalContentAlignment="Center" Padding="0,0,8,0"
                                                 ToolTip="Search txnId, merchant, email…"
                                                 TextChanged="TxnSearchBox_TextChanged">
                                            <TextBox.Style>
                                                <Style TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
                                                    <Style.Resources>
                                                        <VisualBrush x:Key="PlaceholderBrush" TileMode="None" Stretch="None" AlignmentX="Left" AlignmentY="Center">
                                                            <VisualBrush.Visual>
                                                                <TextBlock Text="Search txnId or merchant…" Foreground="{DynamicResource MutedText}" FontSize="11"/>
                                                            </VisualBrush.Visual>
                                                        </VisualBrush>
                                                    </Style.Resources>
                                                    <Style.Triggers>
                                                        <Trigger Property="Text" Value="">
                                                            <Setter Property="Background" Value="{StaticResource PlaceholderBrush}"/>
                                                        </Trigger>
                                                        <Trigger Property="IsFocused" Value="True">
                                                            <Setter Property="Background" Value="Transparent"/>
                                                        </Trigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBox.Style>
                                        </TextBox>
                                    </Grid>
                                </Border>

                                <!-- Status filter -->
                                <ComboBox x:Name="TxnStatusFilter" Grid.Column="2" Height="32" Width="130"
                                          FontSize="11.5" VerticalContentAlignment="Center"
                                          SelectionChanged="TxnStatusFilter_Changed"
                                          ToolTip="Filter by transaction status">
                                    <ComboBoxItem Content="All statuses" IsSelected="True" Tag=""/>
                                    <ComboBoxItem Content="Approved"   Tag="approved"/>
                                    <ComboBoxItem Content="Settled"    Tag="settled"/>
                                    <ComboBoxItem Content="Pending"    Tag="pending"/>
                                    <ComboBoxItem Content="Processing" Tag="processing"/>
                                    <ComboBoxItem Content="Declined"   Tag="declined"/>
                                    <ComboBoxItem Content="Failed"     Tag="failed"/>
                                    <ComboBoxItem Content="Refunded"   Tag="refunded"/>
                                    <ComboBoxItem Content="Voided"     Tag="voided"/>
                                </ComboBox>

                                <!-- Count label (center-left) -->
                                <TextBlock x:Name="TxnCountLabel" Grid.Column="3" FontSize="11.5"
                                           Foreground="{DynamicResource SubText}" VerticalAlignment="Center"
                                           Margin="12,0,0,0"/>

                                <!-- Right: sort + date + columns + export -->
                                <StackPanel Grid.Column="4" Orientation="Horizontal" VerticalAlignment="Center">
                                    <!-- Column chooser -->
                                    <ToggleButton x:Name="TxnColChooserBtn" Content="⊞ Columns"
                                                  Height="30" Padding="8,0" FontSize="11" Margin="0,0,10,0"
                                                  Cursor="Hand" ToolTip="Show / hide columns"
                                                  Checked="TxnColChooserBtn_Toggled"
                                                  Unchecked="TxnColChooserBtn_Toggled">
                                        <ToggleButton.Style>
                                            <Style TargetType="ToggleButton">
                                                <Setter Property="Background" Value="{DynamicResource CardBg}"/>
                                                <Setter Property="Foreground" Value="{DynamicResource PrimaryText}"/>
                                                <Setter Property="BorderBrush" Value="{DynamicResource CardBorder}"/>
                                                <Setter Property="BorderThickness" Value="1"/>
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="ToggleButton">
                                                            <Border Background="{TemplateBinding Background}"
                                                                    BorderBrush="{TemplateBinding BorderBrush}"
                                                                    BorderThickness="{TemplateBinding BorderThickness}"
                                                                    CornerRadius="4" Padding="{TemplateBinding Padding}">
                                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                            </Border>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                                <Style.Triggers>
                                                    <Trigger Property="IsChecked" Value="True">
                                                        <Setter Property="Background" Value="#7C3AED"/>
                                                        <Setter Property="Foreground" Value="White"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </ToggleButton.Style>
                                    </ToggleButton>
                                    <Popup x:Name="TxnColChooserPopup"
                                           PlacementTarget="{Binding ElementName=TxnColChooserBtn}"
                                           Placement="Bottom" StaysOpen="False"
                                           Closed="TxnColChooserPopup_Closed">
                                        <Border Background="{DynamicResource CardBg}"
                                                BorderBrush="{DynamicResource CardBorder}"
                                                BorderThickness="1" CornerRadius="6"
                                                Padding="6" MinWidth="160">
                                            <StackPanel>
                                                <TextBlock Text="Show / Hide Columns" FontSize="11" FontWeight="SemiBold"
                                                           Foreground="{DynamicResource SubText}" Margin="4,2,4,6"/>
                                                <ScrollViewer MaxHeight="340" VerticalScrollBarVisibility="Auto">
                                                    <StackPanel x:Name="TxnColChooserPanel"/>
                                                </ScrollViewer>
                                            </StackPanel>
                                        </Border>
                                    </Popup>
                                    <TextBlock Text="Sort by:" FontSize="11" Foreground="{DynamicResource SubText}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                    <ComboBox x:Name="TxnSortCombo" Width="110" Height="30" FontSize="11"
                                              VerticalContentAlignment="Center"
                                              SelectionChanged="TxnSortCombo_Changed">
                                        <ComboBoxItem Content="Created" Tag="Created" IsSelected="True"/>
                                        <ComboBoxItem Content="Total"   Tag="Total"/>
                                        <ComboBoxItem Content="Customer" Tag="CustomerName"/>
                                        <ComboBoxItem Content="Merchant" Tag="Merchant"/>
                                        <ComboBoxItem Content="Status"  Tag="StatusLabel"/>
                                        <ComboBoxItem Content="Email"   Tag="Email"/>
                                    </ComboBox>
                                    <ToggleButton x:Name="TxnSortDirBtn" Width="30" Height="30" Margin="4,0,12,0"
                                                  Content="↓" FontSize="13" Cursor="Hand"
                                                  ToolTip="Toggle sort direction"
                                                  Checked="TxnSortCombo_Changed"
                                                  Unchecked="TxnSortCombo_Changed">
                                        <ToggleButton.Style>
                                            <Style TargetType="ToggleButton">
                                                <Setter Property="Background" Value="Transparent"/>
                                                <Setter Property="BorderThickness" Value="0"/>
                                                <Setter Property="Foreground" Value="{DynamicResource SubText}"/>
                                                <Style.Triggers>
                                                    <Trigger Property="IsChecked" Value="True">
                                                        <Setter Property="Content" Value="↑"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </ToggleButton.Style>
                                    </ToggleButton>
                                    <TextBlock Text="From:" FontSize="11" Foreground="{DynamicResource SubText}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                    <DatePicker x:Name="TxnFromDatePicker" Width="120" Height="30" FontSize="11"
                                                SelectedDateFormat="Short" VerticalContentAlignment="Center"
                                                SelectedDateChanged="TxnDatePicker_SelectedDateChanged"
                                                ToolTip="Filter transactions created on or after this date"/>
                                    <TextBlock Text="To:" FontSize="11" Foreground="{DynamicResource SubText}" VerticalAlignment="Center" Margin="10,0,6,0"/>
                                    <DatePicker x:Name="TxnToDatePicker" Width="120" Height="30" FontSize="11"
                                                SelectedDateFormat="Short" VerticalContentAlignment="Center"
                                                SelectedDateChanged="TxnDatePicker_SelectedDateChanged"
                                                ToolTip="Filter transactions created on or before this date"/>
                                    <Button x:Name="TxnClearDateBtn" Content="✕" Width="26" Height="26"
                                            Margin="6,0,12,0" FontSize="11" Cursor="Hand"
                                            ToolTip="Clear date filter"
                                            Click="TxnClearDateBtn_Click">
                                        <Button.Style>
                                            <Style TargetType="Button">
                                                <Setter Property="Background" Value="Transparent"/>
                                                <Setter Property="BorderThickness" Value="0"/>
                                                <Setter Property="Foreground" Value="{DynamicResource SubText}"/>
                                            </Style>
                                        </Button.Style>
                                    </Button>

                                    <!-- Export CSV -->
                                    <Button x:Name="TxnExportCsvBtn" Height="32" Padding="10,0"
                                            FontSize="11.5" Margin="0,0,6,0" Cursor="Hand"
                                            ToolTip="Export visible rows to CSV"
                                            Click="ExportCsvBtn_Click">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="⬇ " FontSize="11"/>
                                            <TextBlock Text="Export CSV"/>
                                        </StackPanel>
                                    </Button>

                                    <!-- Export JSON -->
                                    <Button x:Name="TxnExportJsonBtn" Height="32" Padding="10,0"
                                            FontSize="11.5" Cursor="Hand"
                                            ToolTip="Export visible rows to JSON"
                                            Click="ExportJsonBtn_Click">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="⬇ " FontSize="11"/>
                                            <TextBlock Text="Export JSON"/>
                                        </StackPanel>
                                    </Button>
                                </StackPanel>
                            </Grid>
                        </Border>
                        <!-- DataGrid -->
                        <DataGrid Grid.Row="2" x:Name="TxnGrid" AutoGenerateColumns="False" IsReadOnly="True"
                              CanUserResizeColumns="True" GridLinesVisibility="Horizontal"
                              AlternatingRowBackground="{DynamicResource GridAltRowBg}"
                              RowBackground="{DynamicResource GridRowBg}"
                              Foreground="{DynamicResource GridFg}"
                              HeadersVisibility="Column" BorderThickness="0"
                              SelectionUnit="Cell" SelectionMode="Single"
                              HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto"
                              FontSize="12" RowHeight="NaN"
                              SelectionChanged="TxnGrid_SelectionChanged"
                              MouseDoubleClick="TxnGrid_MouseDoubleClick"
                              ContextMenu="{StaticResource GridContextMenu}"
                              ContextMenuOpening="Grid_ContextMenuOpening">
                        <DataGrid.ColumnHeaderStyle>
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="Background" Value="{DynamicResource GridHeaderBg}"/>
                                <Setter Property="Foreground" Value="{DynamicResource GridHeaderFg}"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                                <Setter Property="Padding" Value="10,8"/>
                                <Setter Property="BorderBrush" Value="{DynamicResource GridBorder}"/>
                                <Setter Property="BorderThickness" Value="0,0,1,1"/>
                            </Style>
                        </DataGrid.ColumnHeaderStyle>
                        <!-- Row style: hand cursor + tooltip -->
                        <DataGrid.RowStyle>
                            <Style TargetType="DataGridRow">
                                <Setter Property="Cursor" Value="Hand"/>
                                <Setter Property="ToolTip" Value="Double-click to open in ePayments portal"/>
                                <Setter Property="Background" Value="{DynamicResource GridRowBg}"/>
                            </Style>
                        </DataGrid.RowStyle>

                        <DataGrid.Columns>
                            <!-- ══ Primary columns (webapp order) ══ -->

                            <!-- TRANSACTION ID — blue link -->
                            <DataGridTemplateColumn Header="TRANSACTION ID" Width="220" SortMemberPath="Id">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Padding="2,0" Cursor="Hand"
                                                HorizontalAlignment="Left"
                                                Background="Transparent" BorderThickness="0"
                                                ToolTip="Click to view line items • Double-click to open in portal"
                                                Click="TxnIdBtn_Click"
                                                Tag="{Binding}">
                                            <TextBlock Text="{Binding Id}" Foreground="#7C3AED"
                                                       FontSize="12" TextDecorations="Underline"
                                                       TextTrimming="CharacterEllipsis"/>
                                        </Button>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <!-- AMOUNT -->
                            <DataGridTextColumn Header="AMOUNT" Binding="{Binding TotalFormatted}" Width="90" SortMemberPath="Total"/>

                            <!-- STATUS badge -->
                            <DataGridTemplateColumn Header="STATUS" Width="130" SortMemberPath="StatusLabel">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border CornerRadius="4" Padding="8,3" HorizontalAlignment="Left" Margin="4,2">
                                            <Border.Background>
                                                <Binding Path="StatusColor" Converter="{StaticResource StringToBrushConverter}"/>
                                            </Border.Background>
                                            <TextBlock Text="{Binding StatusLabel}"
                                                       FontWeight="Bold" FontSize="10.5"
                                                       Foreground="White" TextOptions.TextFormattingMode="Display"/>
                                        </Border>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <!-- MERCHANT -->
                            <DataGridTextColumn Header="MERCHANT" Binding="{Binding MerchantDisplayName}" Width="170"/>

                            <!-- TYPE chip: ACH = blue, Card = purple -->
                            <DataGridTemplateColumn Header="TYPE" Width="70" SortMemberPath="TypeChipLabel">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border CornerRadius="4" Padding="7,3" HorizontalAlignment="Left" Margin="4,2">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="#374151"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding TypeChipLabel}" Value="ACH">
                                                            <Setter Property="Background" Value="#1D4ED8"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding TypeChipLabel}" Value="Card">
                                                            <Setter Property="Background" Value="#7C3AED"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <TextBlock Text="{Binding TypeChipLabel}"
                                                       FontWeight="Bold" FontSize="10.5"
                                                       Foreground="White"/>
                                        </Border>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <!-- METHOD -->
                            <DataGridTextColumn Header="METHOD" Binding="{Binding PaymentMethodDisplay}" Width="110"/>

                            <!-- CREATED -->
                            <DataGridTextColumn Header="CREATED" Binding="{Binding Created}" Width="160"/>

                            <!-- SETTLED -->
                            <DataGridTextColumn Header="SETTLED" Binding="{Binding Settled}" Width="160"/>

                            <!-- BATCH ID -->
                            <DataGridTextColumn Header="BATCH ID" Binding="{Binding Batch}" Width="200"/>

                            <!-- ACTIONS -->
                            <DataGridTemplateColumn Header="ACTIONS" Width="90" CanUserSort="False">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                            <Button Content="⧉" FontSize="14" Cursor="Hand"
                                                    Background="Transparent" BorderThickness="0"
                                                    Padding="4,2" ToolTip="Copy transaction ID"
                                                    Tag="{Binding Id}" Click="CopyTxnIdBtn_Click"/>
                                            <Button Content="↗" FontSize="14" Cursor="Hand"
                                                    Background="Transparent" BorderThickness="0"
                                                    Padding="4,2" ToolTip="Open in portal"
                                                    Tag="{Binding Id}" Click="PortalLinkBtn_Click"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <!-- ══ Secondary / extended columns ══ -->
                            <DataGridTextColumn Header="Customer"       Binding="{Binding CustomerName}"      Width="150" Visibility="Collapsed"/>
                            <DataGridTextColumn Header="Merchant Name"  Binding="{Binding MerchantName}"      Width="160" Visibility="Collapsed"/>
                            <DataGridTextColumn Header="Entity ID"      Binding="{Binding EntityId}"          Width="200" Visibility="Collapsed"/>
                            <DataGridTextColumn Header="Entity Name"    Binding="{Binding EntityName}"        Width="160" Visibility="Collapsed"/>
                            <DataGridTextColumn Header="Disbursement ID" Binding="{Binding DisbursementId}"   Width="220" Visibility="Collapsed"/>
                            <DataGridTextColumn Header="Email"          Binding="{Binding Email}"             Width="200" Visibility="Collapsed"/>
                            <DataGridTextColumn Header="Order"          Binding="{Binding Order}"             Width="160" Visibility="Collapsed"/>
                            <DataGridTextColumn Header="Currency"       Binding="{Binding Currency}"          Width="80"  Visibility="Collapsed"/>
                            <DataGridTextColumn Header="Approved"       Binding="{Binding ApprovedFormatted}" Width="100" Visibility="Collapsed" SortMemberPath="Approved"/>
                            <DataGridTextColumn Header="Tax"            Binding="{Binding TaxFormatted}"      Width="80"  Visibility="Collapsed" SortMemberPath="Tax"/>
                            <DataGridTextColumn Header="Authorization"  Binding="{Binding Authorization}"     Width="110" Visibility="Collapsed"/>
                            <DataGridTextColumn Header="Platform"       Binding="{Binding Platform}"          Width="90"  Visibility="Collapsed"/>
                            <DataGridTextColumn Header="Merchant ID"    Binding="{Binding Merchant}"          Width="220" Visibility="Collapsed"/>
                            <DataGridTextColumn Header="City"           Binding="{Binding City}"              Width="120" Visibility="Collapsed"/>
                            <DataGridTextColumn Header="State"          Binding="{Binding State}"             Width="140" Visibility="Collapsed"/>
                            <DataGridTextColumn Header="Country"        Binding="{Binding Country}"           Width="80"  Visibility="Collapsed"/>
                            <DataGridTextColumn Header="Gateway"        Binding="{Binding GatewayDisplay}"    Width="110" Visibility="Collapsed"/>
                            <DataGridTextColumn Header="Payment Type"   Binding="{Binding PaymentTypeLabel}"  Width="110" Visibility="Collapsed"/>
                            <DataGridTemplateColumn Header="Discrepancy" Width="280" SortMemberPath="HasDiscrepancy" Visibility="Collapsed">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border CornerRadius="4" Padding="6,4" Margin="2"
                                                HorizontalAlignment="Stretch">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="#DCFCE7"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding HasDiscrepancy}" Value="True">
                                                            <Setter Property="Background" Value="#FEE2E2"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <StackPanel>
                                                <TextBlock Text="{Binding DiscrepancyLabel}"
                                                           FontWeight="Bold" FontSize="11" Margin="0,0,0,2">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Foreground" Value="#4C1D95"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding HasDiscrepancy}" Value="True">
                                                                    <Setter Property="Foreground" Value="#991B1B"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                                <TextBlock FontSize="10" Foreground="#7F1D1D" FontStyle="Italic"
                                                           Margin="0,0,0,2" TextWrapping="Wrap" MaxWidth="260">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding HasDiscrepancy}" Value="True">
                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                    <Run Text="Txn: "/><Run Text="{Binding Id}" FontWeight="SemiBold"/>
                                                </TextBlock>
                                                <TextBlock Text="{Binding DiscrepancySummary}"
                                                           FontSize="10.5" TextWrapping="Wrap"
                                                           Foreground="#7F1D1D" MaxWidth="260"
                                                           Margin="0,0,0,4">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding HasDiscrepancy}" Value="True">
                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                                <Button Content="🔧 Fix Discrepancy"
                                                        Height="24" Padding="8,0" FontSize="11"
                                                        FontWeight="SemiBold" Cursor="Hand"
                                                        BorderThickness="1" BorderBrush="#DC2626"
                                                        Background="#FFF1F2" Foreground="#991B1B"
                                                        Tag="{Binding}"
                                                        Click="TxnGridFixDiscrepancyBtn_Click">
                                                    <Button.Style>
                                                        <Style TargetType="Button">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                            <Setter Property="Template">
                                                                <Setter.Value>
                                                                    <ControlTemplate TargetType="Button">
                                                                        <Border x:Name="Bd"
                                                                                Background="{TemplateBinding Background}"
                                                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                                                CornerRadius="4"
                                                                                Padding="{TemplateBinding Padding}">
                                                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                        </Border>
                                                                        <ControlTemplate.Triggers>
                                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                                <Setter TargetName="Bd" Property="Background" Value="#FEE2E2"/>
                                                                            </Trigger>
                                                                        </ControlTemplate.Triggers>
                                                                    </ControlTemplate>
                                                                </Setter.Value>
                                                            </Setter>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding HasDiscrepancy}" Value="True">
                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Button.Style>
                                                </Button>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <!-- Webhook button -->
                            <DataGridTemplateColumn Header="Webhook" Width="110" CanUserSort="False" Visibility="Collapsed">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Content="⚡ Webhook"
                                                Tag="{Binding}"
                                                Click="BuildAchWebhookBtn_Click"
                                                Padding="6,3" FontSize="11" FontWeight="SemiBold"
                                                Cursor="Hand">
                                            <Button.Style>
                                                <Style TargetType="Button">
                                                    <Setter Property="Background" Value="#7C3AED"/>
                                                    <Setter Property="Foreground" Value="White"/>
                                                    <Setter Property="BorderThickness" Value="0"/>
                                                    <Setter Property="Template">
                                                        <Setter.Value>
                                                            <ControlTemplate TargetType="Button">
                                                                <Border Background="{TemplateBinding Background}"
                                                                        CornerRadius="5"
                                                                        Padding="{TemplateBinding Padding}">
                                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                </Border>
                                                            </ControlTemplate>
                                                        </Setter.Value>
                                                    </Setter>
                                                    <Style.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="Background" Value="#6D28D9"/>
                                                        </Trigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                        </Button>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <!-- Delete button -->
                            <DataGridTemplateColumn Header="Delete" Width="80" CanUserSort="False" Visibility="Collapsed">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Content="🗑"
                                                Tag="{Binding Id}"
                                                Click="DeleteTransaction_Click"
                                                Padding="6,3" FontSize="13" FontWeight="SemiBold"
                                                Cursor="Hand" ToolTip="Delete this transaction">
                                            <Button.Style>
                                                <Style TargetType="Button">
                                                    <Setter Property="Background" Value="#DC2626"/>
                                                    <Setter Property="Foreground" Value="White"/>
                                                    <Setter Property="BorderThickness" Value="0"/>
                                                    <Setter Property="Template">
                                                        <Setter.Value>
                                                            <ControlTemplate TargetType="Button">
                                                                <Border Background="{TemplateBinding Background}"
                                                                        CornerRadius="5"
                                                                        Padding="{TemplateBinding Padding}">
                                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                </Border>
                                                            </ControlTemplate>
                                                        </Setter.Value>
                                                    </Setter>
                                                    <Style.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="Background" Value="#B91C1C"/>
                                                        </Trigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                        </Button>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                        </DataGrid>
                        <!-- Footer -->
                        <Border Grid.Row="3" Padding="16,8" Background="{DynamicResource CardBg}"
                                BorderBrush="{DynamicResource CardBorder}" BorderThickness="0,1,0,0">
                            <TextBlock Text="All dates and times are in UTC" FontSize="11" Foreground="{DynamicResource SubText}"/>
                        </Border>
                    </Grid>
                </TabItem>

                <!-- Line Items Tab -->
                <TabItem x:Name="TabItem2" Header="Line Items">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                    <!-- Toolbar -->
                    <Border Grid.Row="0" Background="{DynamicResource CardBg}"
                            BorderBrush="{DynamicResource CardBorder}" BorderThickness="0,0,0,1"
                            Padding="12,8">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Orientation="Horizontal">
                                <Button x:Name="LineItemsBackBtn"
                                        Content="← Back to Transactions"
                                        Height="28" Padding="10,0" FontSize="11" FontWeight="SemiBold"
                                        Cursor="Hand" Visibility="Collapsed"
                                        Style="{StaticResource SecondaryButton}"
                                        Click="LineItemsBackBtn_Click"
                                        Margin="0,0,12,0"/>
                                <TextBlock x:Name="LineItemsContextLabel"
                                           Text="Select a transaction to view its line items"
                                           FontSize="12" Foreground="{DynamicResource SubText}"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                <TextBlock x:Name="LineItemsCountBadge"
                                           Visibility="Collapsed"
                                           FontSize="11" Foreground="{DynamicResource HintFg}"
                                           VerticalAlignment="Center" Margin="0,0,12,0"/>
                                <Button x:Name="ExportLineItemsCsvBtn"
                                        Content="↓ Export CSV"
                                        Height="28" Padding="10,0" FontSize="11" FontWeight="SemiBold"
                                        Cursor="Hand" Visibility="Collapsed"
                                        Style="{StaticResource SecondaryButton}"
                                        Click="ExportLineItemsCsv_Click"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Placeholder shown when no transaction is selected -->
                    <Border x:Name="ItemsPlaceholder" Grid.Row="1" Background="{DynamicResource CardBg}">
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock Text="📋" FontSize="40" HorizontalAlignment="Center"
                                       Margin="0,0,0,12" Opacity="0.3"/>
                            <TextBlock Text="Select a transaction to view its line items"
                                       FontSize="14" Foreground="{DynamicResource HintFg}" HorizontalAlignment="Center"/>
                            <TextBlock Text="Click any row in the Transactions tab"
                                       FontSize="12" Foreground="{DynamicResource SeparatorFg}" HorizontalAlignment="Center"
                                       Margin="0,6,0,0"/>
                        </StackPanel>
                    </Border>

                    <!-- Disbursement entries grid (shown when a disbursement is fetched) -->
                    <DataGrid x:Name="DisbEntryGrid" Grid.Row="1" Visibility="Collapsed"
                              AutoGenerateColumns="False" IsReadOnly="True"
                              CanUserResizeColumns="True" GridLinesVisibility="Horizontal"
                              AlternatingRowBackground="{DynamicResource GridAltRowBg}" RowBackground="{DynamicResource GridRowBg}"
                              HeadersVisibility="Column" BorderThickness="0"
                              SelectionUnit="Cell" SelectionMode="Single"
                              HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto"
                              ContextMenu="{StaticResource GridContextMenu}"
                              ContextMenuOpening="Grid_ContextMenuOpening"
                              FontSize="12">
                        <DataGrid.ColumnHeaderStyle>
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="Background" Value="{DynamicResource GridHeaderBg}"/>
                                <Setter Property="Foreground" Value="{DynamicResource GridHeaderFg}"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                                <Setter Property="Padding" Value="10,8"/>
                                <Setter Property="BorderBrush" Value="{DynamicResource GridBorder}"/>
                                <Setter Property="BorderThickness" Value="0,0,1,1"/>
                            </Style>
                        </DataGrid.ColumnHeaderStyle>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Entry ID"      Binding="{Binding Id}"             Width="220"/>
                            <DataGridTextColumn Header="Transaction ID" Binding="{Binding EventId}"       Width="220"/>
                            <DataGridTextColumn Header="Disbursement"  Binding="{Binding Disbursement}"   Width="220"/>
                            <DataGridTextColumn Header="Created"       Binding="{Binding Created}"        Width="160"/>
                            <DataGridTextColumn Header="Description"   Binding="{Binding Description}"    Width="200"/>
                            <DataGridTextColumn Header="Amount"        Binding="{Binding AmountFormatted}" Width="110"/>
                            <DataGridTextColumn Header="Event Type"    Binding="{Binding Event}"          Width="90"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <DataGrid x:Name="ItemsGrid" Grid.Row="1" Visibility="Collapsed"
                              AutoGenerateColumns="False" IsReadOnly="True"
                              CanUserResizeColumns="True" GridLinesVisibility="Horizontal"
                              AlternatingRowBackground="{DynamicResource GridAltRowBg}" RowBackground="{DynamicResource GridRowBg}"
                              HeadersVisibility="Column" BorderThickness="0"
                              SelectionUnit="Cell" SelectionMode="Single"
                              HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto"
                              ContextMenu="{StaticResource GridContextMenu}"
                              ContextMenuOpening="Grid_ContextMenuOpening"
                              FontSize="12">
                        <DataGrid.ColumnHeaderStyle>
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="Background" Value="{DynamicResource GridHeaderBg}"/>
                                <Setter Property="Foreground" Value="{DynamicResource GridHeaderFg}"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                                <Setter Property="Padding" Value="10,8"/>
                                <Setter Property="BorderBrush" Value="{DynamicResource GridBorder}"/>
                                <Setter Property="BorderThickness" Value="0,0,1,1"/>
                            </Style>
                        </DataGrid.ColumnHeaderStyle>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Item ID" Binding="{Binding Id}" Width="220"/>
                            <DataGridTextColumn Header="Transaction ID" Binding="{Binding Txn}" Width="220"/>
                            <DataGridTextColumn Header="Created" Binding="{Binding Created}" Width="160"/>
                            <DataGridTextColumn Header="Item" Binding="{Binding Item}" Width="160"/>
                            <DataGridTextColumn Header="Description" Binding="{Binding Description}" Width="180"/>
                            <DataGridTextColumn Header="Qty" Binding="{Binding Quantity}" Width="60"/>
                            <DataGridTextColumn Header="Price" Binding="{Binding PriceFormatted}" Width="90"/>
                            <DataGridTextColumn Header="Total" Binding="{Binding TotalFormatted}" Width="90"/>
                            <DataGridTextColumn Header="Discount" Binding="{Binding Discount}" Width="80"/>
                            <DataGridTextColumn Header="UM" Binding="{Binding Um}" Width="70"/>
                            <DataGridTextColumn Header="Commodity Code" Binding="{Binding CommodityCode}" Width="130"/>
                            <DataGridTextColumn Header="Product Code" Binding="{Binding ProductCode}" Width="150"/>
                            <DataGridTextColumn Header="Discount Treatment" Binding="{Binding DiscountTreatment}" Width="140"/>
                            <DataGridTemplateColumn Header="Line Item Indicator" Width="170" SortMemberPath="LineItemDetailIndicator">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border CornerRadius="4" Padding="7,3"
                                                HorizontalAlignment="Left" Margin="2,3">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="#64748B"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding LineItemDetailIndicator}" Value="2">
                                                            <Setter Property="Background" Value="#17A34A"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding LineItemDetailIndicator}" Value="3">
                                                            <Setter Property="Background" Value="#17A34A"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding LineItemDetailIndicator}" Value="4">
                                                            <Setter Property="Background" Value="#7C3AED"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding LineItemDetailIndicator}" Value="5">
                                                            <Setter Property="Background" Value="#7C3AED"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <TextBlock Text="{Binding LineItemDetailIndicatorLabel}"
                                                       FontWeight="SemiBold" FontSize="11"
                                                       Foreground="White"/>
                                        </Border>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>

                    <!-- Grand total footer row -->
                    <Border x:Name="ItemsGrandTotalRow" Grid.Row="2"
                            Background="{DynamicResource KpiHeaderBg}" BorderThickness="0">
                        <Grid>
                            <!-- Columns mirror the DataGrid columns widths exactly -->
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="220"/>  <!-- Item ID -->
                                <ColumnDefinition Width="220"/>  <!-- Transaction ID -->
                                <ColumnDefinition Width="160"/>  <!-- Created -->
                                <ColumnDefinition Width="160"/>  <!-- Item -->
                                <ColumnDefinition Width="180"/>  <!-- Description -->
                                <ColumnDefinition Width="60"/>   <!-- Qty -->
                                <ColumnDefinition Width="90"/>   <!-- Price -->
                                <ColumnDefinition Width="90"/>   <!-- Total -->
                                <ColumnDefinition Width="*"/>    <!-- rest -->
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="4" Grid.ColumnSpan="2" Text="Grand Total"
                                       FontWeight="Bold" FontSize="12" Foreground="White"
                                       HorizontalAlignment="Right" VerticalAlignment="Center"
                                       Padding="0,6,8,6"/>

                            <TextBlock x:Name="GrandTotalPrice" Grid.Column="6"
                                       FontWeight="Bold" FontSize="12" Foreground="{DynamicResource KpiHeaderFg}"
                                       HorizontalAlignment="Right" VerticalAlignment="Center"
                                       Padding="0,6,10,6"/>

                            <TextBlock x:Name="GrandTotalAmount" Grid.Column="7"
                                       FontWeight="Bold" FontSize="13" Foreground="White"
                                       HorizontalAlignment="Right" VerticalAlignment="Center"
                                       Padding="0,6,10,6"/>
                        </Grid>
                    </Border>

                    <!-- Line Items summary bar -->
                    <Border x:Name="ItemsSummaryBar" Grid.Row="3"
                            Margin="0,0,0,0" Padding="14,10" BorderThickness="0,1,0,0"
                            BorderBrush="{DynamicResource CardBorder2}">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="{DynamicResource SummaryBarBg}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ElementName=ItemsMismatchIcon, Path=Visibility}"
                                                 Value="Visible">
                                        <Setter Property="Background" Value="{DynamicResource TestRowFailBg}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="30"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="30"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Orientation="Horizontal">
                                <TextBlock Text="Line Items Sum:" FontWeight="SemiBold" FontSize="12"
                                           Foreground="{DynamicResource LabelFg}" VerticalAlignment="Center"/>
                                <TextBlock x:Name="ItemsSumText" Text="$0.00" FontWeight="Bold"
                                           FontSize="13" Foreground="{DynamicResource KpiValueFg}"
                                           Margin="8,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>

                            <TextBlock Grid.Column="1" Text="vs" FontSize="12" Foreground="{DynamicResource HintFg}"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>

                            <StackPanel Grid.Column="2" Orientation="Horizontal">
                                <TextBlock Text="Transaction Approved:" FontWeight="SemiBold" FontSize="12"
                                           Foreground="{DynamicResource LabelFg}" VerticalAlignment="Center"/>
                                <TextBlock x:Name="ItemsTxnTotalText" Text="$0.00" FontWeight="Bold"
                                           FontSize="13" Foreground="{DynamicResource KpiValueFg}"
                                           Margin="8,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>

                            <TextBlock Grid.Column="3" Text="→" FontSize="12" Foreground="{DynamicResource HintFg}"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>

                            <!-- Match indicator -->
                            <StackPanel Grid.Column="4" Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock x:Name="ItemsMatchIcon" Text="✓ Match"
                                           FontWeight="Bold" FontSize="12" Foreground="#4C1D95"/>
                                <StackPanel x:Name="ItemsMismatchIcon" Orientation="Horizontal"
                                            Visibility="Collapsed">
                                    <TextBlock Text="⚠ Mismatch — difference: " FontWeight="Bold"
                                               FontSize="12" Foreground="#991B1B" VerticalAlignment="Center"/>
                                    <TextBlock x:Name="ItemsDiffText" FontWeight="Bold"
                                               FontSize="12" Foreground="#991B1B" VerticalAlignment="Center"/>
                                    <!-- Fix button: adjusts last line item Total to reconcile -->
                                    <Button x:Name="FixDiscrepancyBtn"
                                            Content="🔧 Fix" Height="26" Padding="10,0"
                                            FontSize="11" FontWeight="SemiBold" Cursor="Hand"
                                            Margin="10,0,0,0" BorderThickness="1"
                                            BorderBrush="#DC2626" Background="#FFF1F2"
                                            Foreground="#991B1B"
                                            Click="FixDiscrepancyBtn_Click"
                                            ToolTip="Auto-adjust the last line item's Total so the&#x0a;line items sum matches the transaction Approved amount">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                                        BorderBrush="{TemplateBinding BorderBrush}"
                                                        BorderThickness="{TemplateBinding BorderThickness}"
                                                        CornerRadius="4" Padding="{TemplateBinding Padding}">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="Bd" Property="Background" Value="#FEE2E2"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                    <TextBlock x:Name="FixDiscrepancyStatus"
                                               FontSize="11" Foreground="#4C1D95"
                                               VerticalAlignment="Center" Margin="8,0,0,0"/>
                                </StackPanel>
                            </StackPanel>

                            <TextBlock x:Name="ItemsCountText" Grid.Column="6"
                                       FontSize="11" Foreground="{DynamicResource HintFg}" VerticalAlignment="Center"/>
                        </Grid>
                    </Border>

                    <!-- lineItemDetailIndicator reference banner -->
                    <Border Grid.Row="4"
                            Background="{DynamicResource InfoBannerBg}"
                            BorderBrush="{DynamicResource InfoBannerBorder}"
                            BorderThickness="0,1,0,0" Padding="14,10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="16"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="lineItemDetailIndicator" FontFamily="Consolas"
                                           FontSize="11" FontWeight="Bold"
                                           Foreground="{DynamicResource InfoBannerTitleFg}"
                                           VerticalAlignment="Center"/>
                                <TextBlock Text=" — Worldpay CNP per-item field"
                                           FontSize="11" Foreground="{DynamicResource InfoBannerTextFg}"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                <Border Background="#64748B" CornerRadius="4" Padding="6,2" Margin="0,0,6,0">
                                    <TextBlock Text="0 — Normal" Foreground="White" FontSize="11" FontWeight="SemiBold"/>
                                </Border>
                                <Border Background="#64748B" CornerRadius="4" Padding="6,2" Margin="0,0,6,0">
                                    <TextBlock Text="1 — Normal (last)" Foreground="White" FontSize="11" FontWeight="SemiBold"/>
                                </Border>
                                <Border Background="#17A34A" CornerRadius="4" Padding="6,2" Margin="0,0,6,0">
                                    <TextBlock Text="2 — Credit" Foreground="White" FontSize="11" FontWeight="SemiBold"/>
                                </Border>
                                <Border Background="#17A34A" CornerRadius="4" Padding="6,2" Margin="0,0,6,0">
                                    <TextBlock Text="3 — Credit (last)" Foreground="White" FontSize="11" FontWeight="SemiBold"/>
                                </Border>
                                <Border Background="#7C3AED" CornerRadius="4" Padding="6,2" Margin="0,0,6,0">
                                    <TextBlock Text="4 — Payment" Foreground="White" FontSize="11" FontWeight="SemiBold"/>
                                </Border>
                                <Border Background="#7C3AED" CornerRadius="4" Padding="6,2">
                                    <TextBlock Text="5 — Payment (last)" Foreground="White" FontSize="11" FontWeight="SemiBold"/>
                                </Border>
                            </StackPanel>
                        </Grid>
                    </Border>

                    </Grid>
                </TabItem>


                <!-- Webhook Tests Tab -->
                                <!-- Webhook Tests - content in full-screen overlay -->
                <TabItem x:Name="TabItem3" Visibility="Collapsed">
                    <Grid/>
                </TabItem>

                <!-- Raw JSON Tab -->
                <TabItem x:Name="TabItem4" Header="Raw JSON">
                    <DockPanel Background="{DynamicResource CodeBg}">

                        <!-- Toolbar pinned to top -->
                        <Border DockPanel.Dock="Top" Background="#1E293B" Padding="10,6"
                                BorderBrush="#334155" BorderThickness="0,0,0,1">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Orientation="Horizontal">
                                    <Button Content="📋  Copy All" Click="RawJsonCopyAll_Click"
                                            Style="{StaticResource PrimaryButton}"
                                            Padding="12,5" FontSize="12" Margin="0,0,8,0"
                                            ToolTip="Copy entire Raw JSON to clipboard"/>
                                    <Button Content="📌  Paste JSON" Click="RawJsonPaste_Click"
                                            Style="{StaticResource SecondaryButton}"
                                            Padding="12,5" FontSize="12" Margin="0,0,8,0"
                                            ToolTip="Paste JSON from clipboard into this box"/>
                                    <Button Content="🗑️  Clear" Click="RawJsonClear_Click"
                                            Style="{StaticResource DangerButton}"
                                            Padding="12,5" FontSize="12" Margin="0,0,8,0"
                                            ToolTip="Clear the Raw JSON box"/>
                                    <Button Content="⎌  Undo" Click="RawJsonUndoBtn_Click"
                                            Style="{StaticResource SecondaryButton}"
                                            Padding="12,5" FontSize="12" Margin="0,0,8,0"
                                            ToolTip="Undo last change to Raw JSON (Ctrl+Z also works for typed text)"/>
                                    <Button Content="🔗  Share" Click="ShareRawJsonBtn_Click"
                                            Height="26" Padding="8,0" FontSize="11" Cursor="Hand" Margin="0,0,16,0"
                                            Background="#F0F9FF" Foreground="#7C3AED"
                                            BorderBrush="#BAE6FD" BorderThickness="1">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}"
                                                        BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True"><Setter Property="Background" Value="#E0F2FE"/></Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                    <TextBlock Text="Tip: Ctrl+A · Ctrl+C · Ctrl+H = Find/Replace"
                                               FontSize="11" Foreground="#475569" VerticalAlignment="Center"
                                               FontFamily="Consolas"/>
                                </StackPanel>
                                <!-- Find/Replace toggle -->
                                <Button Grid.Column="1" Content="🔍  Find / Replace"
                                        Click="RawJsonFindReplaceToggle_Click"
                                        Height="28" Padding="10,0" FontSize="11"
                                        Cursor="Hand" BorderThickness="1"
                                        BorderBrush="#475569" Background="#334155" Foreground="#94A3B8">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}"
                                                    BorderBrush="{TemplateBinding BorderBrush}"
                                                    BorderThickness="{TemplateBinding BorderThickness}"
                                                    CornerRadius="5" Padding="{TemplateBinding Padding}">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="#475569"/>
                                                    <Setter Property="Foreground" Value="#E2E8F0"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                            </Grid>
                        </Border>

                        <!-- Find & Replace bar (hidden by default, Ctrl+H or button to show) -->
                        <Border x:Name="RawJsonFindReplaceBar" DockPanel.Dock="Top"
                                Background="#162032" Padding="10,7"
                                BorderBrush="#334155" BorderThickness="0,0,0,1"
                                Visibility="Collapsed">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="220"/>
                                    <ColumnDefinition Width="12"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="220"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="4"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="4"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <!-- Find label + box -->
                                <TextBlock Grid.Column="0" Text="Find:" FontSize="11" FontWeight="SemiBold"
                                           Foreground="#94A3B8" VerticalAlignment="Center" Margin="0,0,7,0"/>
                                <TextBox x:Name="RawFindBox" Grid.Column="1" Height="26" Padding="7,0"
                                         Background="#1E293B" Foreground="#E2E8F0" CaretBrush="#E2E8F0"
                                         BorderBrush="#475569" BorderThickness="1"
                                         FontFamily="Consolas" FontSize="11" VerticalContentAlignment="Center"
                                         ToolTip="Text to search for (case-insensitive)"
                                         KeyDown="RawFindBox_KeyDown"/>

                                <!-- Replace label + box -->
                                <TextBlock Grid.Column="3" Text="Replace:" FontSize="11" FontWeight="SemiBold"
                                           Foreground="#94A3B8" VerticalAlignment="Center" Margin="0,0,7,0"/>
                                <TextBox x:Name="RawReplaceBox" Grid.Column="4" Height="26" Padding="7,0"
                                         Background="#1E293B" Foreground="#E2E8F0" CaretBrush="#E2E8F0"
                                         BorderBrush="#475569" BorderThickness="1"
                                         FontFamily="Consolas" FontSize="11" VerticalContentAlignment="Center"
                                         ToolTip="Replacement text"/>

                                <!-- Find Next -->
                                <Button Grid.Column="6" Content="🔍 Find Next" Height="26" Padding="10,0"
                                        FontSize="11" FontWeight="SemiBold" Cursor="Hand"
                                        BorderThickness="0" Background="#7C3AED" Foreground="White"
                                        Click="RawJsonFindNext_Click">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True"><Setter Property="Background" Value="#6D28D9"/></Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>

                                <!-- Replace (single) -->
                                <Button Grid.Column="8" Content="✏ Replace" Height="26" Padding="10,0"
                                        FontSize="11" FontWeight="SemiBold" Cursor="Hand"
                                        BorderThickness="0" Background="#059669" Foreground="White"
                                        Click="RawJsonReplace_Click">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True"><Setter Property="Background" Value="#047857"/></Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>

                                <!-- Replace All -->
                                <Button Grid.Column="10" Content="🔁 Replace All" Height="26" Padding="10,0"
                                        FontSize="11" FontWeight="SemiBold" Cursor="Hand"
                                        BorderThickness="0" Background="#D97706" Foreground="White"
                                        Click="RawJsonReplaceAll_Click">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True"><Setter Property="Background" Value="#B45309"/></Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>

                                <!-- Status text -->
                                <TextBlock x:Name="RawFindStatus" Grid.Column="11"
                                           FontSize="11" FontFamily="Consolas"
                                           Foreground="#64748B" VerticalAlignment="Center"
                                           Margin="12,0,0,0" Text=""/>

                                <!-- Close × -->
                                <Button Grid.Column="12" Content="✕" Height="22" Width="22" Padding="0"
                                        FontSize="12" Cursor="Hand" VerticalAlignment="Center"
                                        BorderThickness="0" Background="Transparent" Foreground="#64748B"
                                        Click="RawJsonFindReplaceClose_Click"
                                        ToolTip="Close Find/Replace bar">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Foreground" Value="#E2E8F0"/>
                                                    <Setter Property="Background" Value="#334155"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                            </Grid>
                        </Border>

                        <!-- Editable JSON area -->
                        <TextBox x:Name="RawJsonBox" FontFamily="Consolas" FontSize="12"
                                 VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                                 Background="{DynamicResource CodeBg}" Foreground="{DynamicResource CodeFg}"
                                 BorderThickness="0" Padding="16" TextWrapping="NoWrap"
                                 AcceptsReturn="True" AcceptsTab="True"
                                 PreviewKeyDown="RawJsonBox_PreviewKeyDown"/>
                    </DockPanel>
                </TabItem>

                <!-- JSON Tools Tab -->
                <TabItem x:Name="TabItem5" Header="🔧 JSON Tools">
                    <Grid Margin="16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- LEFT: JSON Formatter -->
                        <Border Grid.Column="0" Background="{DynamicResource CardBg}" CornerRadius="10" Padding="14">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="8" ShadowDepth="1" Opacity="0.07" Color="#64748B"/>
                            </Border.Effect>
                            <DockPanel>
                                <!-- Title row -->
                                <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,10">
                                    <TextBlock Text="{}{}" FontSize="16" FontWeight="Bold" Foreground="{DynamicResource DarkAccent}" Margin="0,0,8,0"/>
                                    <TextBlock Text="JSON Formatter" FontSize="14" FontWeight="Bold" Foreground="{DynamicResource PanelTitleFg}" VerticalAlignment="Center"/>
                                </StackPanel>
                                <!-- Input label -->
                                <TextBlock DockPanel.Dock="Top" Text="Paste JSON to format:" FontSize="11"
                                           Foreground="{DynamicResource SubLabelFg}" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                <!-- Input box -->
                                <TextBox DockPanel.Dock="Top" x:Name="FmtInputBox"
                                         AcceptsReturn="True" TextWrapping="NoWrap"
                                         VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                                         FontFamily="Consolas" FontSize="12" Height="180"
                                         Background="{DynamicResource JsonInputBg}" BorderBrush="{DynamicResource JsonInputBorder}" BorderThickness="1"
                                         Padding="10" ContextMenu="{StaticResource TextBoxContextMenu}"/>
                                <!-- Button row -->
                                <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,8,0,8">
                                    <Button Content="⚡ Format" Style="{StaticResource PrimaryButton}"
                                            Click="FormatJsonBtn_Click" Margin="0,0,8,0"/>
                                    <Button Content="🗑 Clear" Style="{StaticResource DangerButton}"
                                            Click="FmtClearBtn_Click"/>
                                </StackPanel>
                                <!-- Output label -->
                                <TextBlock DockPanel.Dock="Top" Text="Formatted output:" FontSize="11"
                                           Foreground="{DynamicResource SubLabelFg}" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                <!-- Output -->
                                <TextBox x:Name="FmtOutputBox"
                                         IsReadOnly="True" AcceptsReturn="True" TextWrapping="NoWrap"
                                         VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                                         FontFamily="Consolas" FontSize="12"
                                         Background="{DynamicResource JsonOutputGreenBg}" BorderBrush="{DynamicResource JsonOutputGreenBorder}" BorderThickness="1"
                                         Padding="10" ContextMenu="{StaticResource TextBoxContextMenu}"/>
                            </DockPanel>
                        </Border>

                        <!-- RIGHT: JSON Compare -->
                        <Border Grid.Column="2" Background="{DynamicResource CardBg}" CornerRadius="10" Padding="14">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="8" ShadowDepth="1" Opacity="0.07" Color="#64748B"/>
                            </Border.Effect>
                            <DockPanel>
                                <!-- Title -->
                                <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,10">
                                    <TextBlock Text="⇄" FontSize="16" FontWeight="Bold" Foreground="#059669" Margin="0,0,8,0"/>
                                    <TextBlock Text="JSON Compare" FontSize="14" FontWeight="Bold" Foreground="{DynamicResource PanelTitleFg}" VerticalAlignment="Center"/>
                                </StackPanel>
                                <!-- Two input boxes side by side -->
                                <Grid DockPanel.Dock="Top" Height="180" Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="8"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <DockPanel Grid.Column="0">
                                        <TextBlock DockPanel.Dock="Top" Text="Left JSON" FontSize="11"
                                                   Foreground="{DynamicResource SubLabelFg}" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                        <TextBox x:Name="CmpLeftBox"
                                                 AcceptsReturn="True" TextWrapping="NoWrap"
                                                 VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                                                 FontFamily="Consolas" FontSize="12"
                                                 Background="{DynamicResource JsonInputBg}" BorderBrush="{DynamicResource JsonInputBorder}" BorderThickness="1"
                                                 Padding="8" ContextMenu="{StaticResource TextBoxContextMenu}"/>
                                    </DockPanel>
                                    <DockPanel Grid.Column="2">
                                        <TextBlock DockPanel.Dock="Top" Text="Right JSON" FontSize="11"
                                                   Foreground="{DynamicResource SubLabelFg}" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                        <TextBox x:Name="CmpRightBox"
                                                 AcceptsReturn="True" TextWrapping="NoWrap"
                                                 VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                                                 FontFamily="Consolas" FontSize="12"
                                                 Background="{DynamicResource JsonInputBg}" BorderBrush="{DynamicResource JsonInputBorder}" BorderThickness="1"
                                                 Padding="8" ContextMenu="{StaticResource TextBoxContextMenu}"/>
                                    </DockPanel>
                                </Grid>
                                <!-- Buttons -->
                                <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,8">
                                    <Button Content="⇄ Compare" Style="{StaticResource SecondaryButton}"
                                            Click="CompareJsonBtn_Click" Margin="0,0,8,0"/>
                                    <Button Content="🗑 Clear" Style="{StaticResource DangerButton}"
                                            Click="CmpClearBtn_Click"/>
                                </StackPanel>
                                <!-- Diff result label -->
                                <TextBlock DockPanel.Dock="Top" Text="Differences:" FontSize="11"
                                           Foreground="{DynamicResource SubLabelFg}" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                <!-- Diff output -->
                                <TextBox x:Name="CmpResultBox"
                                         IsReadOnly="True" AcceptsReturn="True" TextWrapping="Wrap"
                                         VerticalScrollBarVisibility="Auto"
                                         FontFamily="Consolas" FontSize="12"
                                         Background="{DynamicResource JsonOutputYellowBg}" BorderBrush="{DynamicResource JsonOutputYellowBorder}" BorderThickness="1"
                                         Padding="10" ContextMenu="{StaticResource TextBoxContextMenu}"/>
                            </DockPanel>
                        </Border>
                    </Grid>
                </TabItem>

                <!-- Crypto Tab -->
                <TabItem x:Name="TabItem6" Header="🔐 Crypto">
                    <Grid Margin="16">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Header -->
                        <TextBlock Grid.Row="0" Text="BQE Encrypt / Decrypt  (DES / 3DES · auto-padding)"
                                   FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource KpiValueFg}"
                                   Margin="0,0,0,14"/>

                        <!-- Controls row -->
                        <Grid Grid.Row="1" Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="180"/>
                                <ColumnDefinition Width="20"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="76"/>
                                <ColumnDefinition Width="20"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="76"/>
                                <ColumnDefinition Width="20"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="90"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0" Text="Key:" FontWeight="SemiBold"
                                       VerticalAlignment="Center" FontSize="12"/>
                            <ComboBox x:Name="CryptoKeyBox" Grid.Column="2" Height="32"
                                      VerticalContentAlignment="Center" FontFamily="Consolas"
                                      FontSize="11" IsEditable="True"
                                      ToolTip="Select a preset key or type a custom 8-byte key">
                                <ComboBoxItem Content="C#E1b@$0" IsSelected="True"/>
                                <ComboBoxItem Content="E@a2b#$0"/>
                            </ComboBox>

                            <TextBlock Grid.Column="4" Text="Algo:" FontWeight="SemiBold"
                                       VerticalAlignment="Center" FontSize="12"
                                       ToolTip="DES = single DES (56-bit). 3DES = TripleDES with key repeated ×3 (112-bit effective). Auto-fallback tries the other if selected fails."/>
                            <ComboBox x:Name="CryptoAlgoBox" Grid.Column="6" Height="32"
                                      VerticalContentAlignment="Center" FontSize="12"
                                      SelectedIndex="0"
                                      ToolTip="DES = single DES. 3DES = TripleDES (8-byte key expanded ×3). Decrypt auto-falls back if selected fails.">
                                <ComboBoxItem Content="DES"/>
                                <ComboBoxItem Content="3DES"/>
                            </ComboBox>

                            <TextBlock Grid.Column="8" Text="Mode:" FontWeight="SemiBold"
                                       VerticalAlignment="Center" FontSize="12"/>
                            <ComboBox x:Name="CryptoModeBox" Grid.Column="10" Height="32"
                                      VerticalContentAlignment="Center" FontSize="12"
                                      SelectedIndex="0">
                                <ComboBoxItem Content="ECB"/>
                                <ComboBoxItem Content="CBC"/>
                            </ComboBox>

                            <TextBlock Grid.Column="12" Text="Output:" FontWeight="SemiBold"
                                       VerticalAlignment="Center" FontSize="12"/>
                            <ComboBox x:Name="CryptoOutFmtBox" Grid.Column="14" Height="32"
                                      VerticalContentAlignment="Center" FontSize="12"
                                      SelectedIndex="0">
                                <ComboBoxItem Content="Hex"/>
                                <ComboBoxItem Content="Base64"/>
                            </ComboBox>
                        </Grid>

                        <!-- Input / Output panels -->
                        <Grid Grid.Row="2" Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- Input -->
                            <Grid Grid.Column="0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="120"/>
                                </Grid.RowDefinitions>
                                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,4">
                                    <TextBlock Text="Input" FontWeight="SemiBold" FontSize="12"
                                               Foreground="{DynamicResource LabelFg}" VerticalAlignment="Center"/>
                                    <TextBlock Text="  (hex, Base64, or plain text)"
                                               FontSize="11" Foreground="{DynamicResource HintFg}" VerticalAlignment="Center"/>
                                    <Button Content="⧉ Paste" Height="22" Padding="8,0"
                                            FontSize="11" Cursor="Hand" Margin="10,0,0,0"
                                            BorderThickness="1" BorderBrush="{DynamicResource CopyBtnBorder}"
                                            Background="{DynamicResource CopyBtnBg}" Foreground="{DynamicResource LabelFg}"
                                            Click="CryptoPasteBtn_Click">
                                        <Button.Template><ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter Property="Background" Value="{DynamicResource DarkBtnBgHover}"/></Trigger></ControlTemplate.Triggers>
                                        </ControlTemplate></Button.Template>
                                    </Button>
                                    <Button Content="✕ Clear" Height="22" Padding="8,0"
                                            FontSize="11" Cursor="Hand" Margin="4,0,0,0"
                                            BorderThickness="1" BorderBrush="#FCA5A5"
                                            Background="#FFF5F5" Foreground="#B91C1C"
                                            Click="CryptoClearBtn_Click">
                                        <Button.Template><ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter Property="Background" Value="#FEE2E2"/></Trigger></ControlTemplate.Triggers>
                                        </ControlTemplate></Button.Template>
                                    </Button>
                                </StackPanel>
                                <TextBox x:Name="CryptoInputBox" Grid.Row="1"
                                         AcceptsReturn="True" TextWrapping="Wrap"
                                         FontFamily="Consolas" FontSize="11"
                                         VerticalScrollBarVisibility="Auto"
                                         BorderBrush="{DynamicResource InputBorder}" BorderThickness="1"
                                         Padding="8,6" Background="{DynamicResource InputBg}"
                                         ToolTip="Paste hex / Base64 cipher to decrypt, or plain text to encrypt"/>
                            </Grid>

                            <!-- Action buttons (middle) -->
                            <StackPanel Grid.Column="1" Orientation="Vertical"
                                        HorizontalAlignment="Center" VerticalAlignment="Center">

                                <!-- Manual DES/3DES -->
                                <TextBlock Text="MANUAL" FontSize="9" FontWeight="Bold"
                                           Foreground="#AEAEB2" HorizontalAlignment="Center"
                                           Margin="0,0,0,5"/>
                                <Button x:Name="DecryptBtn" Content="🔓  Decrypt  →"
                                        Height="34" Padding="12,0" FontSize="12"
                                        FontWeight="SemiBold" Cursor="Hand" Margin="0,0,0,6"
                                        BorderThickness="0" Background="#7C3AED" Foreground="White"
                                        Click="DecryptBtn_Click">
                                    <Button.Template><ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter Property="Background" Value="#6D28D9"/></Trigger></ControlTemplate.Triggers>
                                    </ControlTemplate></Button.Template>
                                </Button>
                                <Button x:Name="EncryptBtn" Content="🔒  Encrypt  →"
                                        Height="34" Padding="12,0" FontSize="12"
                                        FontWeight="SemiBold" Cursor="Hand" Margin="0,0,0,6"
                                        BorderThickness="0" Background="#0D9488" Foreground="White"
                                        Click="EncryptBtn_Click">
                                    <Button.Template><ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter Property="Background" Value="#0F766E"/></Trigger></ControlTemplate.Triggers>
                                    </ControlTemplate></Button.Template>
                                </Button>
                                <Button Content="🔄 Try All Keys"
                                        Height="34" Padding="12,0" FontSize="11"
                                        FontWeight="SemiBold" Cursor="Hand" Margin="0,0,0,14"
                                        BorderThickness="0" Background="#059669" Foreground="White"
                                        Click="TryAllKeysBtn_Click">
                                    <Button.Template><ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter Property="Background" Value="#047857"/></Trigger></ControlTemplate.Triggers>
                                    </ControlTemplate></Button.Template>
                                </Button>

                                <!-- BQE Native -->
                                <Border Height="1" Background="#E5E5EA" Margin="0,0,0,10"/>
                                <TextBlock Text="BQE NATIVE" FontSize="9" FontWeight="Bold"
                                           Foreground="#7C3AED" HorizontalAlignment="Center"
                                           Margin="0,0,0,5"
                                           ToolTip="Exact replica of BQECoreSharedLib.Encryption — DES-CBC, ASCII, 5-char length header, Base64"/>
                                <Button Content="🔓  BQE Decrypt"
                                        Height="34" Padding="10,0" FontSize="11"
                                        FontWeight="SemiBold" Cursor="Hand" Margin="0,0,0,6"
                                        BorderThickness="0" Background="#7C3AED" Foreground="White"
                                        Click="BqeDecryptBtn_Click"
                                        ToolTip="DES-CBC, Key=C#E1b@$0 / IV=E@a2b#$0 (V2), fallback to BQES2011 (V1). Strips 5-char length header.">
                                    <Button.Template><ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter Property="Background" Value="#7C3AED"/></Trigger></ControlTemplate.Triggers>
                                    </ControlTemplate></Button.Template>
                                </Button>
                                <Button Content="🔒  BQE Encrypt"
                                        Height="34" Padding="10,0" FontSize="11"
                                        FontWeight="SemiBold" Cursor="Hand" Margin="0,0,0,6"
                                        BorderThickness="0" Background="#5856D6" Foreground="White"
                                        Click="BqeEncryptBtn_Click"
                                        ToolTip="DES-CBC, Key=C#E1b@$0 / IV=E@a2b#$0 (V2). Prepends 5-char length header. Output: Base64.">
                                    <Button.Template><ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter Property="Background" Value="#4845C0"/></Trigger></ControlTemplate.Triggers>
                                    </ControlTemplate></Button.Template>
                                </Button>
                                <Button Content="🔑  BQE Pwd Encrypt"
                                        Height="34" Padding="10,0" FontSize="11"
                                        FontWeight="SemiBold" Cursor="Hand" Margin="0,0,0,14"
                                        BorderThickness="0" Background="#FF9500" Foreground="White"
                                        Click="BqePasswordEncryptBtn_Click"
                                        ToolTip="PasswordEncrypt — uses V1 key (BQES2011). Same format as BQE Encrypt but with the legacy key pair.">
                                    <Button.Template><ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter Property="Background" Value="#CC7800"/></Trigger></ControlTemplate.Triggers>
                                    </ControlTemplate></Button.Template>
                                </Button>

                                <!-- SHA-256 -->
                                <Border Height="1" Background="#E5E5EA" Margin="0,0,0,10"/>
                                <TextBlock Text="SHA-256" FontSize="9" FontWeight="Bold"
                                           Foreground="#A78BFA" HorizontalAlignment="Center"
                                           Margin="0,0,0,5"
                                           ToolTip="One-way hash — exact replica of Hashing.ComputeSha256Hash()"/>
                                <Button Content="# Hash (SHA-256)"
                                        Height="34" Padding="10,0" FontSize="11"
                                        FontWeight="SemiBold" Cursor="Hand" Margin="0,0,0,6"
                                        BorderThickness="0" Background="#A78BFA" Foreground="White"
                                        Click="Sha256HashBtn_Click"
                                        ToolTip="Computes SHA-256 of the input text. Matches Hashing.ComputeSha256Hash().">
                                    <Button.Template><ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter Property="Background" Value="#28A745"/></Trigger></ControlTemplate.Triggers>
                                    </ControlTemplate></Button.Template>
                                </Button>
                                <Button Content="✔ Verify Hash"
                                        Height="34" Padding="10,0" FontSize="11"
                                        FontWeight="SemiBold" Cursor="Hand"
                                        BorderThickness="0" Background="#636366" Foreground="White"
                                        Click="Sha256VerifyBtn_Click"
                                        ToolTip="Input = plaintext&#10;Output box = the hash to verify against&#10;Checks if SHA-256(input) matches the hash in the output box.">
                                    <Button.Template><ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter Property="Background" Value="#48484A"/></Trigger></ControlTemplate.Triggers>
                                    </ControlTemplate></Button.Template>
                                </Button>
                            </StackPanel>

                            <!-- Output -->
                            <Grid Grid.Column="2">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="120"/>
                                </Grid.RowDefinitions>
                                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,4">
                                    <TextBlock Text="Output" FontWeight="SemiBold" FontSize="12"
                                               Foreground="{DynamicResource LabelFg}" VerticalAlignment="Center"/>
                                    <Button Content="⧉ Copy" Height="22" Padding="8,0"
                                            FontSize="11" Cursor="Hand" Margin="10,0,0,0"
                                            BorderThickness="1" BorderBrush="{DynamicResource InfoStripGreenBorder}"
                                            Background="{DynamicResource InfoStripGreenBtnBg}" Foreground="{DynamicResource InfoStripGreenFg}"
                                            Click="CryptoCopyOutputBtn_Click">
                                        <Button.Template><ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter Property="Background" Value="{DynamicResource InfoStripGreenBtnHover}"/></Trigger></ControlTemplate.Triggers>
                                        </ControlTemplate></Button.Template>
                                    </Button>
                                    <Button Content="⇄ Swap" Height="22" Padding="8,0"
                                            FontSize="11" Cursor="Hand" Margin="4,0,0,0"
                                            BorderThickness="1" BorderBrush="{DynamicResource InfoStripBlueBorder}"
                                            Background="{DynamicResource QuickFetchCcBg}" Foreground="{DynamicResource QuickFetchCcFg}"
                                            Click="CryptoSwapBtn_Click"
                                            ToolTip="Move output back to input">
                                        <Button.Template><ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter Property="Background" Value="#E0F2FE"/></Trigger></ControlTemplate.Triggers>
                                        </ControlTemplate></Button.Template>
                                    </Button>
                                </StackPanel>
                                <TextBox x:Name="CryptoOutputBox" Grid.Row="1"
                                         AcceptsReturn="True" TextWrapping="Wrap"
                                         FontFamily="Consolas" FontSize="11"
                                         IsReadOnly="True"
                                         VerticalScrollBarVisibility="Auto"
                                         BorderBrush="{DynamicResource InfoStripGreenBorder}" BorderThickness="1"
                                         Padding="8,6" Background="{DynamicResource JsonOutputGreenBg}"/>
                            </Grid>
                        </Grid>

                        <!-- Status -->
                        <TextBlock x:Name="CryptoStatusText" Grid.Row="3"
                                   FontSize="11" Foreground="{DynamicResource SubLabelFg}"
                                   TextWrapping="Wrap" Margin="0,4,0,0" Text=""/>
                    </Grid>
                </TabItem>

                <!-- Payrix Portal Tab -->
                <TabItem x:Name="TabItem7" Header="🌐 Payrix Portal"
                         GotFocus="TabItem7_GotFocus">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Toolbar -->
                        <Border Grid.Row="0" Background="{DynamicResource CodeBg}" Padding="10,6">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="🔒" FontSize="13"
                                           VerticalAlignment="Center" Margin="0,0,6,0"
                                           Foreground="{DynamicResource SubText}"/>
                                <TextBox x:Name="PortalAddressBar" Grid.Column="1"
                                         FontFamily="Consolas" FontSize="12"
                                         Background="{DynamicResource InputBg}" Foreground="{DynamicResource InputFg}"
                                         BorderBrush="{DynamicResource InputBorder}" BorderThickness="1"
                                         Padding="8,4" Height="30" VerticalContentAlignment="Center"
                                         KeyDown="PortalAddressBar_KeyDown"/>
                                <Button Grid.Column="2" Content="Go" Style="{StaticResource PrimaryButton}"
                                        Padding="14,4" FontSize="12" Click="PortalGoBtn_Click"/>
                                <Button Grid.Column="4" Content="⟳ Reload" Style="{StaticResource PrimaryButton}"
                                        Padding="10,4" FontSize="12" Background="#475569"
                                        Click="PortalReloadBtn_Click"/>
                                <Button Grid.Column="6" Content="🔑 Login" Style="{StaticResource PrimaryButton}"
                                        Padding="10,4" FontSize="12" Background="#7C3AED"
                                        Click="PortalLoginBtn_Click"
                                        ToolTip="Auto-login to Payrix portal"/>
                            </Grid>
                        </Border>

                        <!-- Embedded browser -->
                        <wv2:WebView2 x:Name="PortalBrowser" Grid.Row="1"
                                      NavigationCompleted="PortalBrowser_NavigationCompleted"/>
                    </Grid>
                </TabItem>

                <!-- ═══════════════════════════════════════════════════════
                     TAB 8 — SETTINGS
                     ═══════════════════════════════════════════════════════ -->
                <TabItem x:Name="TabItem8" Header="⚙ Settings">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="28,24,28,28">
                        <StackPanel MaxWidth="700" HorizontalAlignment="Left">

                            <!-- Page header -->
                            <StackPanel Margin="0,0,0,24">
                                <TextBlock Text="Settings" FontSize="24" FontWeight="Bold"
                                           Foreground="{DynamicResource PrimaryText}"/>
                                <TextBlock Text="Manage your BQE Core account, appearance, and tool preferences."
                                           FontSize="13" Foreground="{DynamicResource SubText}" Margin="0,4,0,0"/>
                            </StackPanel>

                            <!-- ── Signed-in card (visible only when signed in) ─── -->
                            <Border x:Name="BqeSignedInBanner"
                                    Background="{DynamicResource CardBg}"
                                    BorderBrush="{DynamicResource CardBorder}" BorderThickness="1"
                                    CornerRadius="12" Padding="18,14" Margin="0,0,0,14"
                                    Visibility="Collapsed">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="14"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <!-- Green avatar pill -->
                                    <Border Width="42" Height="42" CornerRadius="21"
                                            Background="#7C3AED">
                                        <TextBlock Text="SV" FontSize="15" FontWeight="Bold"
                                                   Foreground="White"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="Signed in as " FontSize="13"
                                                       Foreground="{DynamicResource SubText}"/>
                                            <TextBlock x:Name="BqeSignedInUserText"
                                                       FontSize="13" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource PrimaryText}"/>
                                        </StackPanel>
                                        <TextBlock x:Name="BqeTokenPreviewText"
                                                   FontFamily="Consolas" FontSize="10.5"
                                                   Foreground="{DynamicResource HintFg}"
                                                   Margin="0,3,0,0" TextTrimming="CharacterEllipsis"/>
                                    </StackPanel>
                                    <Button x:Name="BqeSignOutBtn" Grid.Column="3"
                                            Content="Sign out" Height="32" Padding="16,0"
                                            FontSize="12" FontWeight="SemiBold" Cursor="Hand"
                                            Click="BqeSignOutBtn_Click"
                                            Background="{DynamicResource DarkBtnBg}"
                                            BorderBrush="{DynamicResource CardBorder}"
                                            Foreground="{DynamicResource PrimaryText}"
                                            BorderThickness="1" VerticalAlignment="Center">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}"
                                                        BorderBrush="{TemplateBinding BorderBrush}"
                                                        BorderThickness="{TemplateBinding BorderThickness}"
                                                        CornerRadius="8" Padding="{TemplateBinding Padding}">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                </Grid>
                            </Border>

                            <!-- ── BQE Core Account card ───────────────────────── -->
                            <Border x:Name="BqeAccountCard"
                                    Background="{DynamicResource CardBg}" CornerRadius="12"
                                    Padding="20,18" Margin="0,0,0,18"
                                    BorderBrush="{DynamicResource CardBorder}" BorderThickness="1">
                                <StackPanel>

                                    <!-- Section header -->
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                                        <Border Width="32" Height="32" CornerRadius="8" Background="{DynamicResource GreenIconBadgeBg}" Margin="0,0,10,0">
                                            <TextBlock Text="🔑" FontSize="15" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock Text="BQE Core Account" FontSize="14" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource PrimaryText}"/>
                                            <TextBlock Text="Sign in to access subscription management and company tools."
                                                       FontSize="11.5" Foreground="{DynamicResource SubText}"/>
                                        </StackPanel>
                                    </StackPanel>

                                    <Border Height="1" Background="{DynamicResource CardBorder}" Margin="0,0,0,16"/>

                                    <!-- BQE Core URL -->
                                    <Grid Margin="0,0,0,12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                                <TextBlock Text="BQE Core URL" FontSize="12" FontWeight="SemiBold"
                                                           Foreground="{DynamicResource SubLabelFg}"/>
                                                <Border Background="{DynamicResource GreenIconBadgeBg}" CornerRadius="10" Padding="5,1" Margin="8,0,0,0" VerticalAlignment="Center"
                                                        ToolTip="Host root URL — do NOT include /BQECoreWebApp or /BQECoreAdminPortalAPI&#x0a;Examples:&#x0a;  Local:   http://localhost&#x0a;  Staging: https://staging.bqecore.com">
                                                    <TextBlock Text="ℹ" FontSize="10" Foreground="#7C3AED"/>
                                                </Border>
                                            </StackPanel>
                                            <TextBox x:Name="BqeCoreUrlBox"
                                                     Height="36" Padding="10,0" FontSize="13"
                                                     VerticalContentAlignment="Center"
                                                     BorderBrush="{DynamicResource InputBorder}" BorderThickness="1"
                                                     Text="http://localhost"
                                                     LostFocus="BqeCoreUrlBox_LostFocus"/>
                                        </StackPanel>
                                    </Grid>

                                    <!-- Quick environment pills -->
                                    <StackPanel Margin="0,0,0,16">
                                        <TextBlock Text="Quick Environment" FontSize="11.5" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource SubLabelFg}" Margin="0,0,0,7"/>
                                        <StackPanel Orientation="Horizontal">
                                            <Button x:Name="BqeUrlLocalBtn" Content="Local" Height="28" Padding="14,0" FontSize="11.5"
                                                    Margin="0,0,6,0" Cursor="Hand"
                                                    Click="BqeUrlPreset_Click" Tag="http://localhost"
                                                    Background="{DynamicResource TabHoverBg}"
                                                    BorderBrush="{DynamicResource CardBorder}" BorderThickness="1"
                                                    Foreground="{DynamicResource PrimaryText}">
                                                <Button.Template>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border Background="{TemplateBinding Background}"
                                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                                CornerRadius="14" Padding="{TemplateBinding Padding}">
                                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>
                                                    </ControlTemplate>
                                                </Button.Template>
                                            </Button>
                                            <Button x:Name="BqeUrlStagingBtn" Content="Staging" Height="28" Padding="14,0" FontSize="11.5"
                                                    Margin="0,0,6,0" Cursor="Hand"
                                                    Click="BqeUrlPreset_Click" Tag="https://staging-admin.bqecore-np.com"
                                                    Background="{DynamicResource TabHoverBg}"
                                                    BorderBrush="{DynamicResource CardBorder}" BorderThickness="1"
                                                    Foreground="{DynamicResource PrimaryText}">
                                                <Button.Template>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border Background="{TemplateBinding Background}"
                                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                                CornerRadius="14" Padding="{TemplateBinding Padding}">
                                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>
                                                    </ControlTemplate>
                                                </Button.Template>
                                            </Button>
                                            <Button x:Name="BqeUrlSprintBtn" Content="Sprint" Height="28" Padding="14,0" FontSize="11.5"
                                                    Cursor="Hand"
                                                    Click="BqeUrlPreset_Click" Tag="https://sprint-admin.bqecore-np.com"
                                                    Background="{DynamicResource TabHoverBg}"
                                                    BorderBrush="{DynamicResource CardBorder}" BorderThickness="1"
                                                    Foreground="{DynamicResource PrimaryText}">
                                                <Button.Template>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border Background="{TemplateBinding Background}"
                                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                                CornerRadius="14" Padding="{TemplateBinding Padding}">
                                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>
                                                    </ControlTemplate>
                                                </Button.Template>
                                            </Button>
                                        </StackPanel>
                                    </StackPanel>

                                    <!-- Email with icon -->
                                    <StackPanel Margin="0,0,0,12">
                                        <TextBlock Text="Email" FontSize="12" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource SubLabelFg}" Margin="0,0,0,6"/>
                                        <Border BorderBrush="{DynamicResource InputBorder}" BorderThickness="1" CornerRadius="6">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <Border Background="{DynamicResource TabHoverBg}" CornerRadius="5,0,0,5" Width="36"
                                                        BorderBrush="{DynamicResource InputBorder}" BorderThickness="0,0,1,0">
                                                    <TextBlock Text="✉" FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center"
                                                               Foreground="{DynamicResource SubText}"/>
                                                </Border>
                                                <TextBox x:Name="BqeEmailBox" Grid.Column="1"
                                                         Height="36" Padding="10,0" FontSize="13"
                                                         VerticalContentAlignment="Center"
                                                         Background="Transparent"
                                                         BorderThickness="0"/>
                                            </Grid>
                                        </Border>
                                    </StackPanel>

                                    <!-- Password with icon + eye toggle -->
                                    <StackPanel Margin="0,0,0,16">
                                        <TextBlock FontSize="12" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource SubLabelFg}" Margin="0,0,0,6">
                                            Password <Run FontWeight="Normal" Foreground="{DynamicResource SubText}">(Outlook / Microsoft)</Run>
                                        </TextBlock>
                                        <Border BorderBrush="{DynamicResource InputBorder}" BorderThickness="1" CornerRadius="6">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <Border Background="{DynamicResource TabHoverBg}" CornerRadius="5,0,0,5" Width="36"
                                                        BorderBrush="{DynamicResource InputBorder}" BorderThickness="0,0,1,0">
                                                    <TextBlock Text="🔒" FontSize="13" HorizontalAlignment="Center" VerticalAlignment="Center"
                                                               Foreground="{DynamicResource SubText}"/>
                                                </Border>
                                                <PasswordBox x:Name="BqePasswordBox" Grid.Column="1"
                                                             Height="36" Padding="10,0" FontSize="13"
                                                             PasswordChar="●"
                                                             Background="Transparent"
                                                             BorderThickness="0"
                                                             PreviewKeyDown="BqePasswordBox_PreviewKeyDown"/>
                                                <Border Grid.Column="2" Background="{DynamicResource TabHoverBg}" CornerRadius="0,5,5,0" Width="36"
                                                        BorderBrush="{DynamicResource InputBorder}" BorderThickness="1,0,0,0"
                                                        Cursor="Hand">
                                                    <TextBlock Text="👁" FontSize="13" HorizontalAlignment="Center" VerticalAlignment="Center"
                                                               Foreground="{DynamicResource SubText}"/>
                                                </Border>
                                            </Grid>
                                        </Border>
                                    </StackPanel>

                                    <!-- Company picker (shown only when account has multiple companies) -->
                                    <StackPanel x:Name="BqeCompanyPickerRow"
                                                Visibility="Collapsed" Margin="0,0,0,14">
                                        <TextBlock Text="Company" FontSize="12" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource SubLabelFg}" Margin="0,0,0,6"/>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="10"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <ComboBox x:Name="BqeCompanyBox"
                                                      Height="36" FontSize="13"
                                                      VerticalContentAlignment="Center"
                                                      BorderBrush="{DynamicResource InputBorder}" BorderThickness="1"/>
                                            <Button x:Name="BqeCompanySignInBtn" Grid.Column="2"
                                                    Content="Select &amp; Sign In"
                                                    Height="36" Padding="14,0" FontSize="13" FontWeight="SemiBold"
                                                    Cursor="Hand" BorderThickness="0"
                                                    Background="{DynamicResource DarkAccent}" Foreground="White"
                                                    Click="BqeCompanySignInBtn_Click">
                                                <Button.Template>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border Background="{TemplateBinding Background}"
                                                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>
                                                    </ControlTemplate>
                                                </Button.Template>
                                            </Button>
                                        </Grid>
                                    </StackPanel>

                                    <!-- Sign in button (full width) + status -->
                                    <Button x:Name="BqeSignInBtn"
                                            Content="⬅  Sign in to BQE Core"
                                            Height="40" FontSize="13.5" FontWeight="SemiBold"
                                            Cursor="Hand" BorderThickness="0"
                                            HorizontalAlignment="Stretch"
                                            Background="#7C3AED" Foreground="White"
                                            Click="BqeSignInBtn_Click">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                                        CornerRadius="8" Padding="{TemplateBinding Padding}">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="Bd" Property="Background" Value="#6D28D9"/>
                                                    </Trigger>
                                                    <Trigger Property="IsEnabled" Value="False">
                                                        <Setter TargetName="Bd" Property="Background" Value="#93C5FD"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                    <TextBlock x:Name="BqeSignInStatus"
                                               FontSize="12" Margin="0,8,0,0"
                                               TextWrapping="Wrap"
                                               Foreground="{DynamicResource SubText}"/>

                                    <!-- Raw response (debug) -->
                                    <Border x:Name="BqeRawResponseCard"
                                            Visibility="Collapsed" Margin="0,12,0,0"
                                            Background="{DynamicResource CodeBg}"
                                            CornerRadius="4">
                                        <TextBox x:Name="BqeRawResponseBox"
                                                 IsReadOnly="True" TextWrapping="Wrap"
                                                 FontFamily="Consolas" FontSize="10"
                                                 Background="Transparent"
                                                 Foreground="{DynamicResource CodeFg}"
                                                 BorderThickness="0" Padding="8,6"
                                                 MaxHeight="160" VerticalScrollBarVisibility="Auto">
                                            <TextBox.Template>
                                                <ControlTemplate TargetType="TextBox">
                                                    <ScrollViewer x:Name="PART_ContentHost"
                                                                  Background="Transparent"
                                                                  Padding="{TemplateBinding Padding}"
                                                                  VerticalScrollBarVisibility="{TemplateBinding VerticalScrollBarVisibility}"/>
                                                </ControlTemplate>
                                            </TextBox.Template>
                                        </TextBox>
                                    </Border>

                                </StackPanel>
                            </Border>

                            <!-- ── Appearance card ──────────────────────────────── -->
                            <Border Background="{DynamicResource CardBg}" CornerRadius="12"
                                    Padding="20,18" Margin="0,0,0,18"
                                    BorderBrush="{DynamicResource CardBorder}" BorderThickness="1">
                                <StackPanel>
                                    <!-- Section header -->
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                                        <Border Width="32" Height="32" CornerRadius="8" Background="#FFF7ED" Margin="0,0,10,0">
                                            <TextBlock Text="🎨" FontSize="15" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock Text="Appearance" FontSize="14" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource PrimaryText}"/>
                                            <TextBlock Text="Choose your preferred theme for the application."
                                                       FontSize="11.5" Foreground="{DynamicResource SubText}"/>
                                        </StackPanel>
                                    </StackPanel>
                                    <Border Height="1" Background="{DynamicResource CardBorder}" Margin="0,0,0,14"/>

                                    <!-- 3-option theme selector -->
                                    <StackPanel Orientation="Horizontal">
                                        <Button x:Name="SettingsLightBtn"
                                                Height="34" Padding="16,0" FontSize="12" FontWeight="SemiBold"
                                                Margin="0,0,8,0" Cursor="Hand"
                                                Click="SettingsLightTheme_Click"
                                                ToolTip="Switch to light theme">
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <Border x:Name="Bd"
                                                            Background="{DynamicResource TabHoverBg}"
                                                            BorderBrush="{DynamicResource CardBorder}" BorderThickness="1"
                                                            CornerRadius="8" Padding="{TemplateBinding Padding}">
                                                        <StackPanel Orientation="Horizontal">
                                                            <TextBlock Text="☀" FontSize="13" Margin="0,0,5,0" VerticalAlignment="Center"/>
                                                            <TextBlock Text="Light Mode" FontSize="12" VerticalAlignment="Center"
                                                                       Foreground="{DynamicResource PrimaryText}"/>
                                                        </StackPanel>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="Bd" Property="BorderBrush" Value="#7C3AED"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Button.Template>
                                        </Button>
                                        <Button x:Name="SettingsDarkBtn"
                                                Height="34" Padding="16,0" FontSize="12" FontWeight="SemiBold"
                                                Margin="0,0,8,0" Cursor="Hand"
                                                Click="SettingsDarkTheme_Click"
                                                ToolTip="Switch to dark theme">
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <Border x:Name="Bd"
                                                            Background="{DynamicResource TabHoverBg}"
                                                            BorderBrush="{DynamicResource CardBorder}" BorderThickness="1"
                                                            CornerRadius="8" Padding="{TemplateBinding Padding}">
                                                        <StackPanel Orientation="Horizontal">
                                                            <TextBlock Text="🌙" FontSize="13" Margin="0,0,5,0" VerticalAlignment="Center"/>
                                                            <TextBlock Text="Dark Mode" FontSize="12" VerticalAlignment="Center"
                                                                       Foreground="{DynamicResource PrimaryText}"/>
                                                        </StackPanel>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="Bd" Property="BorderBrush" Value="#7C3AED"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Button.Template>
                                        </Button>
                                        <!-- Active badge -->
                                        <Border x:Name="ThemeActiveBadge"
                                                Background="{DynamicResource GreenIconBadgeBg}" BorderBrush="#7C3AED" BorderThickness="1"
                                                CornerRadius="8" Padding="12,0"
                                                VerticalAlignment="Center" Height="34">
                                            <TextBlock x:Name="ThemeActiveBadgeText"
                                                       Text="☀  Light Mode Active"
                                                       FontSize="12" FontWeight="SemiBold"
                                                       Foreground="#7C3AED"
                                                       VerticalAlignment="Center"/>
                                        </Border>
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <!-- ── Tab Visibility card ──────────────────────────── -->
                            <Border Background="{DynamicResource CardBg}" CornerRadius="12"
                                    Padding="20,18" Margin="0,0,0,18"
                                    BorderBrush="{DynamicResource CardBorder}" BorderThickness="1">
                                <StackPanel>
                                    <!-- Section header -->
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                                        <Border Width="32" Height="32" CornerRadius="8" Background="{DynamicResource GreenIconBadgeBg}" Margin="0,0,10,0">
                                            <TextBlock Text="📊" FontSize="15" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock Text="Tab Visibility" FontSize="14" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource PrimaryText}"/>
                                            <TextBlock Text="Choose which tabs appear in the sidebar. Overview and Settings are always visible."
                                                       FontSize="11.5" Foreground="{DynamicResource SubText}"/>
                                        </StackPanel>
                                    </StackPanel>
                                    <Border Height="1" Background="{DynamicResource CardBorder}" Margin="0,0,0,14"/>
                                    <UniformGrid Columns="2">
                                        <CheckBox x:Name="TabChk0"  Tag="0"  Content="📊  Overview"       IsEnabled="False" IsChecked="True"  Margin="0,0,16,10" FontSize="12" Foreground="{DynamicResource SubText}"  Checked="TabVisibility_Changed" Unchecked="TabVisibility_Changed"/>
                                        <CheckBox x:Name="TabChk1"  Tag="1"  Content="⊞  Transactions"    IsChecked="True"  Margin="0,0,16,10" FontSize="12" Foreground="{DynamicResource PrimaryText}" Checked="TabVisibility_Changed" Unchecked="TabVisibility_Changed"/>
                                        <CheckBox x:Name="TabChk2"  Tag="2"  Content="📋  Line Items"      IsChecked="True"  Margin="0,0,16,10" FontSize="12" Foreground="{DynamicResource PrimaryText}" Checked="TabVisibility_Changed" Unchecked="TabVisibility_Changed"/>
                                        <CheckBox x:Name="TabChk3"  Tag="3"  Content="⚡  Webhook Tests"   IsChecked="True"  Margin="0,0,16,10" FontSize="12" Foreground="{DynamicResource PrimaryText}" Checked="TabVisibility_Changed" Unchecked="TabVisibility_Changed"/>
                                        <CheckBox x:Name="TabChk4"  Tag="4"  Content="{}  Raw JSON"        IsChecked="True"  Margin="0,0,16,10" FontSize="12" Foreground="{DynamicResource PrimaryText}" Checked="TabVisibility_Changed" Unchecked="TabVisibility_Changed"/>
                                        <CheckBox x:Name="TabChk5"  Tag="5"  Content="🔧  JSON Tools"      IsChecked="True"  Margin="0,0,16,10" FontSize="12" Foreground="{DynamicResource PrimaryText}" Checked="TabVisibility_Changed" Unchecked="TabVisibility_Changed"/>
                                        <CheckBox x:Name="TabChk6"  Tag="6"  Content="🔐  Crypto"          IsChecked="True"  Margin="0,0,16,10" FontSize="12" Foreground="{DynamicResource PrimaryText}" Checked="TabVisibility_Changed" Unchecked="TabVisibility_Changed"/>
                                        <CheckBox x:Name="TabChk7"  Tag="7"  Content="⬡  Payrix Portal"    IsChecked="True"  Margin="0,0,16,10" FontSize="12" Foreground="{DynamicResource PrimaryText}" Checked="TabVisibility_Changed" Unchecked="TabVisibility_Changed"/>
                                        <CheckBox x:Name="TabChk9"  Tag="9"  Content="❓  Help &amp; Docs"  IsChecked="True"  Margin="0,0,16,10" FontSize="12" Foreground="{DynamicResource PrimaryText}" Checked="TabVisibility_Changed" Unchecked="TabVisibility_Changed"/>
                                        <CheckBox x:Name="TabChk10" Tag="10" Content="🏠  Dashboard"       IsChecked="True"  Margin="0,0,16,10" FontSize="12" Foreground="{DynamicResource PrimaryText}" Checked="TabVisibility_Changed" Unchecked="TabVisibility_Changed"/>
                                        <CheckBox x:Name="TabChk11" Tag="11" Content="💳  Disbursements"   IsChecked="True"  Margin="0,0,16,10" FontSize="12" Foreground="{DynamicResource PrimaryText}" Checked="TabVisibility_Changed" Unchecked="TabVisibility_Changed"/>
                                        <CheckBox x:Name="TabChk12" Tag="12" Content="🏦  Accounts"        IsChecked="True"  Margin="0,0,16,10" FontSize="12" Foreground="{DynamicResource PrimaryText}" Checked="TabVisibility_Changed" Unchecked="TabVisibility_Changed"/>
