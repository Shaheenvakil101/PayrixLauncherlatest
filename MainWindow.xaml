        <!-- Webhook Tests full-screen overlay -->
        <Grid x:Name="WebhookOverlay"
              Grid.Column="1"
              Panel.ZIndex="200"
              Visibility="Collapsed"
              Background="{DynamicResource WindowBg}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Overlay header -->
            <Border Grid.Row="0"
                    Background="{DynamicResource CardBg}"
                    BorderBrush="{DynamicResource CardBorder}"
                    BorderThickness="0,0,0,1"
                    Padding="18,10,18,10">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="8" ShadowDepth="0" Opacity="0.06" Color="#000000"/>
                </Border.Effect>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <Border Width="34" Height="34" CornerRadius="8"
                                Background="#7C3AED1A" BorderBrush="#7C3AED40" BorderThickness="1"
                                Margin="0,0,12,0">
                            <TextBlock Text="&#x26A1;" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#A78BFA"/>
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Webhook Tests" FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryText}"/>
                            <TextBlock Text="Send and verify Payrix webhook payloads" FontSize="11" Foreground="{DynamicResource SubText}" Margin="0,2,0,0"/>
                        </StackPanel>
                    </StackPanel>
                    <Button Grid.Column="2"
                            Height="32" Padding="14,0"
                            FontSize="12" FontWeight="SemiBold"
                            Cursor="Hand"
                            Click="WebhookOverlayClose_Click">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="&#x2190; " FontSize="13" VerticalAlignment="Center"/>
                            <TextBlock Text="Back" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </Grid>
            </Border>

            <!-- Webhook content -->
            <Grid Grid.Row="1">

                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/><!-- Row 0: POST panel -->
                            <RowDefinition Height="Auto"/><!-- Row 1: Configuration header -->
                            <RowDefinition Height="Auto"/><!-- Row 2: Transaction detail card -->
                            <RowDefinition Height="Auto"/><!-- Row 3: Controls -->
                            <RowDefinition Height="*"/>  <!-- Row 4: Results+Summary+Payload wrapper -->
                        </Grid.RowDefinitions>

                        <!-- ── Unified Webhook POST panel ────────────────────── -->
                        <ScrollViewer Grid.Row="0" HorizontalScrollBarVisibility="Auto"
                                      VerticalScrollBarVisibility="Disabled" Margin="0,0,0,8">
                        <Border x:Name="WebhookPostBorder"
                                Background="{DynamicResource CardBg}" BorderBrush="{DynamicResource CardBorder}"
                                BorderThickness="1" CornerRadius="8" Padding="10,4">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="6"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="4"/>
                                    <ColumnDefinition Width="130"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="4"/>
                                    <ColumnDefinition Width="150"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="4"/>
                                    <ColumnDefinition Width="72"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="6"/>
                                    <ColumnDefinition Width="Auto"/>   <!-- 16: Fetch -->
                                    <ColumnDefinition Width="6"/>
                                    <ColumnDefinition Width="Auto"/>   <!-- 18: Create Merchant -->
                                    <ColumnDefinition Width="Auto"/>   <!-- 19: Open Portal -->
                                    <ColumnDefinition Width="Auto" MinWidth="160"/>  <!-- 20: Status -->
                                </Grid.ColumnDefinitions>

                                <!-- Badge — updated by WebhookTypeBox_SelectionChanged -->
                                <Border x:Name="WebhookTypeBadge" Grid.Column="0" Background="#7C3AED"
                                        CornerRadius="4" Padding="8,4" VerticalAlignment="Center">
                                    <TextBlock x:Name="WebhookTypeBadgeText" Text="ACH FUNDED"
                                               Foreground="White" FontWeight="Bold" FontSize="11"/>
                                </Border>

                                <!-- Type dropdown -->
                                <TextBlock Grid.Column="2" Text="Type:" FontSize="12"
                                           FontWeight="SemiBold" VerticalAlignment="Center"
                                           Foreground="{DynamicResource LabelFg}"/>
                                <ComboBox x:Name="WebhookTypeBox" Grid.Column="4"
                                          Height="32" FontSize="12" VerticalContentAlignment="Center"
                                          SelectionChanged="WebhookTypeBox_SelectionChanged"
                                          SelectedIndex="0">
                                    <ComboBoxItem Content="ACH Funded"/>
                                    <ComboBoxItem Content="ACH Return"/>
                                    <ComboBoxItem Content="CC Refund"/>
                                    <ComboBoxItem Content="CC Return"/>
                                    <ComboBoxItem Content="Disbursement"/>
                                    <ComboBoxItem Content="Withdrawal"/>
                                    <ComboBoxItem Content="ACH Refund"/>
                                    <ComboBoxItem Content="Withdrawal Processed"/>
                                    <ComboBoxItem Content="Entities Created"/>
                                    <ComboBoxItem Content="Merchant Boarded"/>
                                    <ComboBoxItem Content="Withdrawal Pending"/>
                                    <ComboBoxItem Content="Withdrawal Scheduled"/>
                                </ComboBox>

                                <!-- txnId label — updated dynamically by WebhookTypeBox_SelectionChanged -->
                                <TextBlock x:Name="TxnIdLabel" Grid.Column="6" Text="txnId:" FontSize="12"
                                           FontWeight="SemiBold" VerticalAlignment="Center"
                                           Foreground="{DynamicResource LabelFg}"
                                           ToolTip="Paste any Payrix ID here — merchant ID, entity ID, transaction ID or disbursement ID. Auto-resolved based on webhook type."/>
                                <TextBox x:Name="AchTxnIdBox" Grid.Column="8"
                                         Height="32" Padding="8,0" FontFamily="Consolas"
                                         FontSize="11" VerticalContentAlignment="Center"
                                         BorderBrush="{DynamicResource InputBorder}" BorderThickness="1" Text=""
                                         LostFocus="AchTxnIdBox_LostFocus"
                                         ToolTip="ID depends on webhook type:&#x0a;• Types 0,1,2,3,6 → Transaction ID (t1_txn_...)&#x0a;• Types 4,5,7 → Disbursement ID (p1_dbm_...)&#x0a;• Type 8 → Entity ID (t1_ent_...)&#x0a;• Type 9 → Merchant ID (t1_mer_...) OR Entity ID — auto-resolved"/>

                                <!-- Amount -->
                                <TextBlock Grid.Column="10" Text="Amount:" FontSize="12"
                                           FontWeight="SemiBold" VerticalAlignment="Center"
                                           Foreground="{DynamicResource LabelFg}"/>
                                <TextBox x:Name="AchAmountBox" Grid.Column="12"
                                         Height="32" Padding="8,0" FontFamily="Consolas"
                                         FontSize="11" VerticalContentAlignment="Center"
                                         BorderBrush="{DynamicResource InputBorder}" BorderThickness="1" Text="898.00"
                                         LostFocus="AchAmountBox_LostFocus"/>

                                <!-- POST button -->
                                <Button x:Name="AchPostBtn" Grid.Column="14"
                                        Content="⚡  Send POST" Height="32" Padding="14,0"
                                        FontWeight="Bold" FontSize="12" Cursor="Hand"
                                        BorderThickness="0" Background="#7C3AED" Foreground="White"
                                        Click="AchPostBtn_Click">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}"
                                                    CornerRadius="6" Padding="{TemplateBinding Padding}">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="#6D28D9"/>
                                                </Trigger>
                                                <Trigger Property="IsEnabled" Value="False">
                                                    <Setter Property="Background" Value="#86EFAC"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>

                                <!-- Fetch from Payrix button -->
                                <Button x:Name="AchFetchBtn" Grid.Column="16"
                                        Content="📥  Fetch" Height="32" Padding="12,0"
                                        FontWeight="SemiBold" FontSize="12" Cursor="Hand"
                                        BorderThickness="0" Background="#7C3AED" Foreground="White"
                                        Click="AchFetchBtn_Click"
                                        ToolTip="Fetch the most recent matching transaction from Payrix for the selected type and build the webhook payload">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}"
                                                    CornerRadius="6" Padding="{TemplateBinding Padding}">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="#6D28D9"/>
                                                </Trigger>
                                                <Trigger Property="IsEnabled" Value="False">
                                                    <Setter Property="Background" Value="#DDD6FE"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>

                                <!-- Create Merchant in Payrix button (Entities Created / Merchant Boarded types) -->
                                <Button x:Name="CreateMerchantInPayrixBtn" Grid.Column="18"
                                        Content="🏪  Create in Payrix" Height="32" Padding="12,0"
                                        FontWeight="SemiBold" FontSize="12" Cursor="Hand"
                                        BorderThickness="0" Background="#DB2777" Foreground="White"
                                        Margin="6,0,0,0"
                                        Click="CreateMerchantInPayrixBtn_Click"
                                        Visibility="Collapsed"
                                        ToolTip="POST entity data directly to Payrix /entities endpoint to create a new merchant&#x0a;(Only available for Entities Created / Merchant Boarded types)">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}"
                                                    CornerRadius="6" Padding="{TemplateBinding Padding}">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="#BE185D"/>
                                                </Trigger>
                                                <Trigger Property="IsEnabled" Value="False">
                                                    <Setter Property="Background" Value="#FBCFE8"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>

                                <!-- Open Payrix Portal (same flow as BQE Core UI) -->
                                <Button x:Name="OpenPayrixPortalBtn" Grid.Column="19"
                                        Content="🚀  Open Payrix Portal" Height="32" Padding="12,0"
                                        FontWeight="SemiBold" FontSize="12" Cursor="Hand"
                                        BorderThickness="0" Background="#4C1D95" Foreground="White"
                                        Margin="6,0,0,0"
                                        Click="OpenPayrixPortalBtn_Click"
                                        Visibility="Collapsed"
                                        ToolTip="Fetch company + owner info from BQE Core, then open the pre-filled Payrix signup portal (same flow as Settings → ePayments → Get Started)">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}"
                                                    CornerRadius="6" Padding="{TemplateBinding Padding}">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="#6D28D9"/>
                                                </Trigger>
                                                <Trigger Property="IsEnabled" Value="False">
                                                    <Setter Property="Background" Value="#BAE6FD"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>

                                <!-- Status text — fills remaining space -->
                                <TextBlock x:Name="AchPostStatus" Grid.Column="20"
                                           FontSize="12" VerticalAlignment="Center"
                                           Foreground="{DynamicResource LabelFg}"
                                           TextWrapping="NoWrap" TextTrimming="CharacterEllipsis"
                                           Text="← select type &amp; environment, then Send POST or Fetch from Payrix"
                                           ToolTip="{Binding Text, RelativeSource={RelativeSource Self}}"/>
                                <!-- Hidden name alias so code-behind x:Name refs still compile -->
                                <TextBlock x:Name="WebhookConfigToggleText" Visibility="Collapsed"/>

                                <!-- ── Date filter row ── -->
                                <StackPanel x:Name="WebhookDateFilterPanel"
                                            Grid.Row="1" Grid.ColumnSpan="21"
                                            Orientation="Horizontal" Margin="0,3,0,0"
                                            Visibility="Visible">
                                    <TextBlock Text="From:" FontSize="11" Foreground="{DynamicResource SubLabelFg}"
                                               VerticalAlignment="Center" Margin="0,0,4,0"
                                               ToolTip="Filter Fetch results by transaction created date"/>
                                    <DatePicker x:Name="FetchFromDatePicker"
                                                Width="110" Height="26" FontSize="11"
                                                VerticalContentAlignment="Center"
                                                SelectedDateFormat="Short"
                                                ToolTip="Start of date range (inclusive) — leave blank for no lower bound"/>
                                    <TextBlock Text="To:" FontSize="11" Foreground="{DynamicResource SubLabelFg}"
                                               VerticalAlignment="Center" Margin="8,0,4,0"/>
                                    <DatePicker x:Name="FetchToDatePicker"
                                                Width="110" Height="26" FontSize="11"
                                                VerticalContentAlignment="Center"
                                                SelectedDateFormat="Short"
                                                ToolTip="End of date range (inclusive) — leave blank for no upper bound"/>
                                    <Button x:Name="FetchClearDatesBtn"
                                            Content="✕" Height="26" Padding="8,0"
                                            FontSize="11" Cursor="Hand" Margin="6,0,0,0"
                                            BorderThickness="1" BorderBrush="{DynamicResource InputBorder}"
                                            Background="{DynamicResource CopyBtnBg}" Foreground="{DynamicResource SubLabelFg}"
                                            Click="FetchClearDatesBtn_Click"
                                            ToolTip="Clear date filter">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}"
                                                        BorderBrush="{TemplateBinding BorderBrush}"
                                                        BorderThickness="{TemplateBinding BorderThickness}"
                                                        CornerRadius="4" Padding="{TemplateBinding Padding}">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="{DynamicResource DarkBtnBgHover}"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                    <TextBlock x:Name="DateFilterHintText" Visibility="Collapsed"
                                               FontSize="11" Foreground="{DynamicResource HintFg}"
                                               VerticalAlignment="Center" Margin="12,0,0,0"
                                               Text="(optional — narrows Fetch results by created date)"/>

                                    <!-- Search all webhooks by TxnID -->
                                    <Button x:Name="SearchAllWebhooksBtn"
                                            Content="🔍 Search All Webhooks" Height="28" Padding="10,0"
                                            FontSize="11" Cursor="Hand" Margin="16,0,0,0"
                                            BorderThickness="1" BorderBrush="#FDE68A"
                                            Background="#FFFBEB" Foreground="#92400E"
                                            Click="SearchAllWebhooksBtn_Click"
                                            ToolTip="Fetch the transaction/disbursement in txnId and build ALL webhook payloads from it">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}"
                                                        BorderBrush="{TemplateBinding BorderBrush}"
                                                        BorderThickness="{TemplateBinding BorderThickness}"
                                                        CornerRadius="4" Padding="{TemplateBinding Padding}">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="#FEF3C7"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>

                                    <TextBlock x:Name="SearchAllStatusText"
                                               FontSize="11" Foreground="{DynamicResource SubLabelFg}"
                                               VerticalAlignment="Center" Margin="10,0,0,0"
                                               Text=""/>

                                    <!-- Open log file -->
                                    <Button x:Name="OpenLogBtn"
                                            Content="📋 Open Log" Height="28" Padding="10,0"
                                            FontSize="11" Cursor="Hand" Margin="16,0,0,0"
                                            BorderThickness="1" BorderBrush="{DynamicResource InfoStripBlueBorder}"
                                            Background="{DynamicResource QuickFetchCcBg}" Foreground="{DynamicResource QuickFetchCcFg}"
                                            Click="OpenLogBtn_Click"
                                            ToolTip="Open today's webhook log file in Notepad">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}"
                                                        BorderBrush="{TemplateBinding BorderBrush}"
                                                        BorderThickness="{TemplateBinding BorderThickness}"
                                                        CornerRadius="4" Padding="{TemplateBinding Padding}">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="#E0F2FE"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                </StackPanel>

                                <!-- ── Entity Custom Field (Row 2) — for Onboarding webhooks ── -->
                                <StackPanel x:Name="WebhookEntityCustomPanel"
                                            Grid.Row="2" Grid.ColumnSpan="21"
                                            Orientation="Horizontal" Margin="0,6,0,0"
                                            Visibility="Visible">
                                    <Border Background="{DynamicResource OrangePanelBg}" BorderBrush="{DynamicResource OrangePanelBorder}"
                                            BorderThickness="1" CornerRadius="5" Padding="8,5">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="🏢" FontSize="12" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                            <TextBlock Text="Entity Custom:" FontSize="12" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource OrangePanelFg}" VerticalAlignment="Center" Margin="0,0,8,0"
                                                       ToolTip="Used in Entities Created &amp; Merchant Boarded webhook payloads&#x0a;Format: AccountID,CompanyID  (comma-separated)"/>
                                            <ComboBox x:Name="EntityCustomBox"
                                                      IsEditable="True"
                                                      Width="380" Height="28" Padding="6,0"
                                                      FontFamily="Consolas" FontSize="11"
                                                      VerticalContentAlignment="Center"
                                                      BorderBrush="#FED7AA" BorderThickness="1"
                                                      LostFocus="EntityCustomBox_LostFocus"
                                                      ToolTip="AccountID,CompanyID — e.g. 5F523389-...,672209C4-...&#x0a;When multiple companies are found, use the dropdown to switch between them."/>
                                            <Button x:Name="UseDbIdsForCustomBtn"
                                                    Content="⟵ Use DB IDs" Height="28" Padding="10,0"
                                                    FontSize="11" Cursor="Hand" Margin="6,0,0,0"
                                                    BorderThickness="1" BorderBrush="#FED7AA"
                                                    Background="#FFFBEB" Foreground="#92400E"
                                                    Click="UseDbIdsForCustomBtn_Click"
                                                    ToolTip="Auto-fill from the AccountID + CompanyID shown in the Core DB strip">
                                                <Button.Template>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}"
                                                                BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter Property="Background" Value="#FEF3C7"/>
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Button.Template>
                                            </Button>
                                            <!-- Fetch AccountID+CompanyID directly from host DB by email -->
                                            <Button x:Name="FetchEntityCustomFromDbBtn"
                                                    Content="🔍 Fetch from DB" Height="28" Padding="10,0"
                                                    FontSize="11" Cursor="Hand" Margin="6,0,0,0"
                                                    BorderThickness="1" BorderBrush="#FED7AA"
                                                    Background="#FFF7ED" Foreground="#92400E"
                                                    Click="FetchEntityCustomFromDbBtn_Click"
                                                    ToolTip="Fetch AccountID + CompanyID from Local BQECoreHost DB using the Email in the DB config panel, then fill this box">
                                                <Button.Template>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}"
                                                                BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter Property="Background" Value="#FEF3C7"/>
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Button.Template>
                                            </Button>
                                            <TextBlock x:Name="EntityCustomHint"
                                                       FontSize="11" Foreground="{DynamicResource HintFg}"
                                                       VerticalAlignment="Center" Margin="10,0,0,0"
                                                       Text="← used in Entities Created &amp; Merchant Boarded payloads"/>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>

                                <!-- ── Host DB connection strings (Row 3) ── -->
                                <ScrollViewer x:Name="WebhookDbConfigPanel"
                                              Grid.Row="3" Grid.ColumnSpan="21"
                                              Margin="0,8,0,0"
                                              Visibility="Visible"
                                              HorizontalScrollBarVisibility="Auto"
                                              VerticalScrollBarVisibility="Auto"
                                              MaxHeight="160">
                                    <StackPanel Orientation="Vertical" VerticalAlignment="Top">
                                        <!-- Hidden — kept for code-behind compatibility -->
                                        <TextBlock x:Name="AutoDetectStatusText" Visibility="Collapsed" Height="0"/>

                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Top">

                                        <!-- Payment Service DB -->
                                        <Border BorderBrush="{DynamicResource DbConfigBorder}" BorderThickness="1"
                                                CornerRadius="6" Padding="10,6" Margin="0,0,12,0"
                                                Background="{DynamicResource DbConfigBg}">
                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                </Grid.RowDefinitions>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="64"/>
                                                    <ColumnDefinition Width="4"/>
                                                    <ColumnDefinition Width="380"/>
                                                    <ColumnDefinition Width="4"/>
                                                    <ColumnDefinition Width="22"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Row="0" Grid.ColumnSpan="5"
                                                           Text="🗄  Payment Service DB  (CompanyID)"
                                                           FontSize="11" FontWeight="SemiBold"
                                                           Foreground="{DynamicResource LabelFg}" Margin="0,0,0,4"/>
                                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Local"
                                                           FontSize="11" Foreground="{DynamicResource SubLabelFg}" VerticalAlignment="Center"/>
                                                <TextBox x:Name="LocalHostDbBox" Grid.Row="1" Grid.Column="2"
                                                         Height="22" Padding="5,0" FontFamily="Consolas" FontSize="10"
                                                         VerticalContentAlignment="Center" Margin="0,2,0,2"
                                                         BorderBrush="{DynamicResource InputBorder}" BorderThickness="1"
                                                         ToolTip="Local BQECorePaymentService DB"/>
                                                <Button Grid.Row="1" Grid.Column="4" Content="⧉" Height="22" Width="22"
                                                        Padding="0" FontSize="10" Cursor="Hand" VerticalAlignment="Center"
                                                        BorderThickness="1" BorderBrush="{DynamicResource CopyBtnBorder}" Background="{DynamicResource CopyBtnBg}"
                                                        ToolTip="Copy Local Payment Service DB connection string"
                                                        Click="CopyLocalHostDbBtn_Click">
                                                    <Button.Template><ControlTemplate TargetType="Button">
                                                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="3" Padding="{TemplateBinding Padding}">
                                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>
                                                        <ControlTemplate.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter Property="Background" Value="{DynamicResource DarkBtnBgHover}"/></Trigger></ControlTemplate.Triggers>
                                                    </ControlTemplate></Button.Template>
                                                </Button>
                                                <TextBlock Grid.Row="2" Grid.Column="0" Text="Staging"
                                                           FontSize="11" Foreground="{DynamicResource SubLabelFg}" VerticalAlignment="Center"/>
                                                <TextBox x:Name="StagingHostDbBox" Grid.Row="2" Grid.Column="2"
                                                         Height="22" Padding="5,0" FontFamily="Consolas" FontSize="10"
                                                         VerticalContentAlignment="Center" Margin="0,2,0,2"
                                                         BorderBrush="{DynamicResource InputBorder}" BorderThickness="1"
                                                         ToolTip="Staging BQECorePaymentService DB"/>
                                                <Button Grid.Row="2" Grid.Column="4" Content="⧉" Height="22" Width="22"
                                                        Padding="0" FontSize="10" Cursor="Hand" VerticalAlignment="Center"
                                                        BorderThickness="1" BorderBrush="{DynamicResource CopyBtnBorder}" Background="{DynamicResource CopyBtnBg}"
                                                        ToolTip="Copy Staging Payment Service DB connection string"
                                                        Click="CopyStagingHostDbBtn_Click">
                                                    <Button.Template><ControlTemplate TargetType="Button">
                                                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="3" Padding="{TemplateBinding Padding}">
                                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>
                                                        <ControlTemplate.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter Property="Background" Value="{DynamicResource DarkBtnBgHover}"/></Trigger></ControlTemplate.Triggers>
                                                    </ControlTemplate></Button.Template>
                                                </Button>
                                                <TextBlock Grid.Row="3" Grid.Column="0" Text="Sprint"
                                                           FontSize="11" Foreground="{DynamicResource SubLabelFg}" VerticalAlignment="Center"/>
                                                <TextBox x:Name="SprintHostDbBox" Grid.Row="3" Grid.Column="2"
                                                         Height="22" Padding="5,0" FontFamily="Consolas" FontSize="10"
                                                         VerticalContentAlignment="Center" Margin="0,2,0,2"
                                                         BorderBrush="{DynamicResource InputBorder}" BorderThickness="1"
                                                         ToolTip="Sprint BQECorePaymentService DB"/>
                                                <Button Grid.Row="3" Grid.Column="4" Content="⧉" Height="22" Width="22"
                                                        Padding="0" FontSize="10" Cursor="Hand" VerticalAlignment="Center"
                                                        BorderThickness="1" BorderBrush="{DynamicResource CopyBtnBorder}" Background="{DynamicResource CopyBtnBg}"
                                                        ToolTip="Copy Sprint Payment Service DB connection string"
                                                        Click="CopySprintHostDbBtn_Click">
                                                    <Button.Template><ControlTemplate TargetType="Button">
                                                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="3" Padding="{TemplateBinding Padding}">
                                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>
                                                        <ControlTemplate.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter Property="Background" Value="{DynamicResource DarkBtnBgHover}"/></Trigger></ControlTemplate.Triggers>
                                                    </ControlTemplate></Button.Template>
                                                </Button>
                                                <TextBlock Grid.Row="4" Grid.Column="0" Text="Production"
                                                           FontSize="11" Foreground="{DynamicResource SubLabelFg}" VerticalAlignment="Center"/>
                                                <TextBox x:Name="ProductionHostDbBox" Grid.Row="4" Grid.Column="2"
                                                         Height="22" Padding="5,0" FontFamily="Consolas" FontSize="10"
                                                         VerticalContentAlignment="Center" Margin="0,2,0,2"
                                                         BorderBrush="{DynamicResource InputBorder}" BorderThickness="1"
                                                         ToolTip="Production BQECorePaymentService DB"/>
                                                <Button Grid.Row="4" Grid.Column="4" Content="⧉" Height="22" Width="22"
                                                        Padding="0" FontSize="10" Cursor="Hand" VerticalAlignment="Center"
                                                        BorderThickness="1" BorderBrush="{DynamicResource CopyBtnBorder}" Background="{DynamicResource CopyBtnBg}"
                                                        ToolTip="Copy Production Payment Service DB connection string"
                                                        Click="CopyProductionHostDbBtn_Click">
                                                    <Button.Template><ControlTemplate TargetType="Button">
                                                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="3" Padding="{TemplateBinding Padding}">
                                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>
                                                        <ControlTemplate.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter Property="Background" Value="{DynamicResource DarkBtnBgHover}"/></Trigger></ControlTemplate.Triggers>
                                                    </ControlTemplate></Button.Template>
                                                </Button>
                                            </Grid>
                                        </Border>

                                        <!-- Main Host DB -->
                                        <Border BorderBrush="{DynamicResource DbConfigBlueBorder}" BorderThickness="1"
                                                CornerRadius="6" Padding="10,6"
                                                Background="{DynamicResource DbConfigBlueBg}">
                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                </Grid.RowDefinitions>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="64"/>
                                                    <ColumnDefinition Width="4"/>
                                                    <ColumnDefinition Width="380"/>
                                                    <ColumnDefinition Width="4"/>
                                                    <ColumnDefinition Width="22"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Row="0" Grid.ColumnSpan="5"
                                                           Text="🗄  Main Host DB  (AccountID)"
                                                           FontSize="11" FontWeight="SemiBold"
                                                           Foreground="{DynamicResource InfoStripBlueFg}" Margin="0,0,0,4"/>
                                                <!-- Core Account Email for Account.Email lookup -->
                                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Email"
                                                           FontSize="11" Foreground="{DynamicResource SubLabelFg}" VerticalAlignment="Center"/>
                                                <TextBox x:Name="CoreAccountEmailBox" Grid.Row="1" Grid.Column="2"
                                                         Height="22" Padding="5,0" FontSize="11"
                                                         VerticalContentAlignment="Center" Margin="0,2,0,4"
                                                         BorderBrush="{DynamicResource InputBorder}" BorderThickness="1"
                                                         ToolTip="Email in Account table — used to look up AccountID (e.g. Shaheen@bqe.com)"
                                                         Text="Shaheen@bqe.com"/>
                                                <!-- Fetch button — queries main DB by email, shows AccountID + CompanyID -->
                                                <Button x:Name="FetchIdsByEmailBtn"
                                                        Grid.Row="1" Grid.Column="4"
                                                        Content="▶" Height="22" Width="22"
                                                        Padding="0" FontSize="10" Cursor="Hand" VerticalAlignment="Center"
                                                        BorderThickness="1" BorderBrush="{DynamicResource InfoStripBlueBorder}"
                                                        Background="{DynamicResource InfoStripBlueBtnBg}"
                                                        Foreground="{DynamicResource InfoStripBlueFg}"
                                                        ToolTip="Fetch AccountID and CompanyID for this email — tries active env first, then all configured environments"
                                                        Click="FetchIdsByEmailBtn_Click">
                                                    <Button.Template><ControlTemplate TargetType="Button">
                                                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="3" Padding="{TemplateBinding Padding}">
                                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>
                                                        <ControlTemplate.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter Property="Background" Value="{DynamicResource InfoStripBlueBtnHover}"/></Trigger></ControlTemplate.Triggers>
                                                    </ControlTemplate></Button.Template>
                                                </Button>
                                                <TextBlock Grid.Row="2" Grid.Column="0" Text="Local"
                                                           FontSize="11" Foreground="{DynamicResource SubLabelFg}" VerticalAlignment="Center"/>
                                                <TextBox x:Name="LocalMainDbBox" Grid.Row="2" Grid.Column="2"
                                                         Height="22" Padding="5,0" FontFamily="Consolas" FontSize="10"
                                                         VerticalContentAlignment="Center" Margin="0,2,0,2"
                                                         BorderBrush="{DynamicResource InputBorder}" BorderThickness="1"
                                                         ToolTip="Local BQECoreHost main DB"/>
                                                <Button Grid.Row="2" Grid.Column="4" Content="⧉" Height="22" Width="22"
                                                        Padding="0" FontSize="10" Cursor="Hand" VerticalAlignment="Center"
                                                        BorderThickness="1" BorderBrush="{DynamicResource InfoStripBlueBorder}" Background="{DynamicResource CopyBtnBg}"
                                                        ToolTip="Copy Local Main DB connection string"
                                                        Click="CopyLocalMainDbBtn_Click">
                                                    <Button.Template><ControlTemplate TargetType="Button">
