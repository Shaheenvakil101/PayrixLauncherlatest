                            <!-- ══════════════════════════════════════════════════
                                 SECTION A — BQE Core API Reference
                                 ══════════════════════════════════════════════════ -->
                            <TextBlock Text="🔌  BQE Core API Reference" FontSize="15" FontWeight="Bold"
                                       Foreground="{DynamicResource PrimaryText}" Margin="0,0,0,10"/>

                            <!-- A1: Authentication -->
                            <Border Background="{DynamicResource CardBg}" CornerRadius="14" Padding="22,18" Margin="0,0,0,12" BorderBrush="{DynamicResource CardBorder}" BorderThickness="1">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                        <Border Width="32" Height="32" CornerRadius="8" Margin="0,0,12,0">
                                            <Border.Background><SolidColorBrush Color="#F59E0B" Opacity="0.2"/></Border.Background>
                                            <TextBlock Text="🔑" FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <TextBlock Text="Authentication" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryText}" VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <Border Height="1" Background="{DynamicResource CardBorder}" Margin="0,0,0,12"/>
                                    <Grid Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions><ColumnDefinition Width="140"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                        <TextBlock Text="Header name" FontWeight="SemiBold" Foreground="#FCD34D" FontSize="12"/>
                                        <TextBlock Grid.Column="1" Text="Authorization: Bearer {token}" FontSize="12" Foreground="{DynamicResource SubText}" FontFamily="Cascadia Code, Consolas, Courier New"/>
                                    </Grid>
                                    <Grid Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions><ColumnDefinition Width="140"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                        <TextBlock Text="Token source" FontWeight="SemiBold" Foreground="#FCD34D" FontSize="12"/>
                                        <TextBlock Grid.Column="1" Text="POST /api/token — body: { UserName, Password, CompanyId, grant_type: &quot;password&quot; }" FontSize="12" Foreground="{DynamicResource SubText}" TextWrapping="Wrap" FontFamily="Cascadia Code, Consolas, Courier New"/>
                                    </Grid>
                                    <Grid Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions><ColumnDefinition Width="140"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                        <TextBlock Text="Token lifetime" FontWeight="SemiBold" Foreground="#FCD34D" FontSize="12"/>
                                        <TextBlock Grid.Column="1" Text="14 days (refresh by re-authenticating)" FontSize="12" Foreground="{DynamicResource SubText}"/>
                                    </Grid>
                                    <Grid>
                                        <Grid.ColumnDefinitions><ColumnDefinition Width="140"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                        <TextBlock Text="Content-Type" FontWeight="SemiBold" Foreground="#FCD34D" FontSize="12"/>
                                        <TextBlock Grid.Column="1" Text="application/json  (all requests)" FontSize="12" Foreground="{DynamicResource SubText}"/>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <!-- A2: Route convention -->
                            <Border Background="{DynamicResource CardBg}" CornerRadius="14" Padding="22,18" Margin="0,0,0,12" BorderBrush="{DynamicResource CardBorder}" BorderThickness="1">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                        <Border Width="32" Height="32" CornerRadius="8" Margin="0,0,12,0">
                                            <Border.Background><SolidColorBrush Color="#7C3AED" Opacity="0.2"/></Border.Background>
                                            <TextBlock Text="🛣" FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <TextBlock Text="Route Convention" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryText}" VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <Border Height="1" Background="{DynamicResource CardBorder}" Margin="0,0,0,12"/>
                                    <Border Background="{DynamicResource DbConfigBg}" CornerRadius="8" Padding="14,10" BorderBrush="{DynamicResource DbConfigBorder}" BorderThickness="1" Margin="0,0,0,10">
                                        <TextBlock FontSize="12" FontFamily="Cascadia Code, Consolas, Courier New" Foreground="#A78BFA" TextWrapping="Wrap">
                                            {baseUrl}/api/{Controller}/{Action}/{id?}
                                        </TextBlock>
                                    </Border>
                                    <Grid Margin="0,0,0,6">
                                        <Grid.ColumnDefinitions><ColumnDefinition Width="120"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                        <TextBlock Text="List endpoints" FontWeight="SemiBold" FontSize="12" Foreground="#4ADE80"/>
                                        <TextBlock Grid.Column="1" Text="POST  /api/Budget/BudgetList  — body: BQEParameters JSON" FontSize="12" Foreground="{DynamicResource SubText}" FontFamily="Cascadia Code, Consolas, Courier New" TextWrapping="Wrap"/>
                                    </Grid>
                                    <Grid Margin="0,0,0,6">
                                        <Grid.ColumnDefinitions><ColumnDefinition Width="120"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                        <TextBlock Text="Get by ID" FontWeight="SemiBold" FontSize="12" Foreground="#4ADE80"/>
                                        <TextBlock Grid.Column="1" Text="GET   /api/Budget/GetBudget/{id}" FontSize="12" Foreground="{DynamicResource SubText}" FontFamily="Cascadia Code, Consolas, Courier New"/>
                                    </Grid>
                                    <Grid Margin="0,0,0,6">
                                        <Grid.ColumnDefinitions><ColumnDefinition Width="120"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                        <TextBlock Text="Create" FontWeight="SemiBold" FontSize="12" Foreground="#FCD34D"/>
                                        <TextBlock Grid.Column="1" Text="POST  /api/Budget/PostBudget  — body: entity JSON" FontSize="12" Foreground="{DynamicResource SubText}" FontFamily="Cascadia Code, Consolas, Courier New"/>
                                    </Grid>
                                    <Grid Margin="0,0,0,6">
                                        <Grid.ColumnDefinitions><ColumnDefinition Width="120"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                        <TextBlock Text="Update" FontWeight="SemiBold" FontSize="12" Foreground="#7C3AED"/>
                                        <TextBlock Grid.Column="1" Text="PUT   /api/Budget/PutBudget  — body: entity JSON" FontSize="12" Foreground="{DynamicResource SubText}" FontFamily="Cascadia Code, Consolas, Courier New"/>
                                    </Grid>
                                    <Grid>
                                        <Grid.ColumnDefinitions><ColumnDefinition Width="120"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                        <TextBlock Text="Delete" FontWeight="SemiBold" FontSize="12" Foreground="#F87171"/>
                                        <TextBlock Grid.Column="1" Text="DELETE /api/Budget/DeleteBudget/{id}" FontSize="12" Foreground="{DynamicResource SubText}" FontFamily="Cascadia Code, Consolas, Courier New"/>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <!-- A3: BQEParameters -->
                            <Border Background="{DynamicResource CardBg}" CornerRadius="14" Padding="22,18" Margin="0,0,0,12" BorderBrush="{DynamicResource CardBorder}" BorderThickness="1">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                        <Border Width="32" Height="32" CornerRadius="8" Margin="0,0,12,0">
                                            <Border.Background><SolidColorBrush Color="#7C3AED" Opacity="0.2"/></Border.Background>
                                            <TextBlock Text="📦" FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <TextBlock Text="BQEParameters — Request Body Format" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryText}" VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <Border Height="1" Background="{DynamicResource CardBorder}" Margin="0,0,0,12"/>
                                    <TextBlock Text="All list/search POST endpoints expect this JSON body:" FontSize="12" Foreground="{DynamicResource SubText}" Margin="0,0,0,8"/>
                                    <Border Background="{DynamicResource DbConfigBg}" CornerRadius="8" Padding="14,12" BorderBrush="{DynamicResource DbConfigBorder}" BorderThickness="1" Margin="0,0,0,12">
                                        <TextBlock FontSize="11.5" FontFamily="Cascadia Code, Consolas, Courier New" Foreground="#A78BFA" TextWrapping="Wrap" xml:space="preserve">{
  "PageInfo": {
    "PageNumber": 0,    ← 0 = first 500 rows (OFFSET 0)
    "PageSize":   500   ← max rows per page
  },
  "FilterList": [
    {
      "Field":      "Status",
      "Operator":   0,        ← 0 = equals
      "StartValue": "1"
    }
  ],
  "SortList": [
    { "OrderBy": "Name", "OrderType": 1 }  ← 1=ASC, 2=DESC
  ]
}</TextBlock>
                                    </Border>
                                    <!-- PageNumber table -->
                                    <TextBlock Text="PageNumber values:" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryText}" Margin="0,0,0,6"/>
                                    <Grid Margin="0,0,0,4"><Grid.ColumnDefinitions><ColumnDefinition Width="50"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                        <TextBlock Text="0" FontWeight="Bold" Foreground="#4ADE80" FontSize="12"/><TextBlock Grid.Column="1" Text="First page — OFFSET 0 FETCH NEXT 500  (always use this for first load)" FontSize="12" Foreground="{DynamicResource SubText}"/>
                                    </Grid>
                                    <Grid Margin="0,0,0,4"><Grid.ColumnDefinitions><ColumnDefinition Width="50"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                        <TextBlock Text="1" FontWeight="Bold" Foreground="#FBBF24" FontSize="12"/><TextBlock Grid.Column="1" Text="Second page — OFFSET 500 (skips first 500 rows)" FontSize="12" Foreground="{DynamicResource SubText}"/>
                                    </Grid>
                                    <Grid Margin="0,0,0,10"><Grid.ColumnDefinitions><ColumnDefinition Width="50"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                        <TextBlock Text="-1" FontWeight="Bold" Foreground="#F87171" FontSize="12"/><TextBlock Grid.Column="1" Text="Unpaginated — returns null on some controllers (ProjectList). Avoid." FontSize="12" Foreground="{DynamicResource SubText}"/>
                                    </Grid>
                                    <!-- Operator table -->
                                    <TextBlock Text="FilterList Operator values:" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryText}" Margin="0,0,0,6"/>
                                    <UniformGrid Columns="2">
                                        <Grid Margin="0,0,0,4"><Grid.ColumnDefinitions><ColumnDefinition Width="30"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                            <TextBlock Text="0" FontWeight="Bold" Foreground="#A78BFA" FontSize="12"/><TextBlock Grid.Column="1" Text="Equals (=)" FontSize="12" Foreground="{DynamicResource SubText}"/>
                                        </Grid>
                                        <Grid Margin="0,0,0,4"><Grid.ColumnDefinitions><ColumnDefinition Width="30"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                            <TextBlock Text="1" FontWeight="Bold" Foreground="#A78BFA" FontSize="12"/><TextBlock Grid.Column="1" Text="Not equals (!=)" FontSize="12" Foreground="{DynamicResource SubText}"/>
                                        </Grid>
                                        <Grid Margin="0,0,0,4"><Grid.ColumnDefinitions><ColumnDefinition Width="30"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                            <TextBlock Text="2" FontWeight="Bold" Foreground="#A78BFA" FontSize="12"/><TextBlock Grid.Column="1" Text="Greater than (&gt;)" FontSize="12" Foreground="{DynamicResource SubText}"/>
                                        </Grid>
                                        <Grid Margin="0,0,0,4"><Grid.ColumnDefinitions><ColumnDefinition Width="30"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                            <TextBlock Text="3" FontWeight="Bold" Foreground="#A78BFA" FontSize="12"/><TextBlock Grid.Column="1" Text="Less than (&lt;)" FontSize="12" Foreground="{DynamicResource SubText}"/>
                                        </Grid>
                                        <Grid Margin="0,0,0,4"><Grid.ColumnDefinitions><ColumnDefinition Width="30"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                            <TextBlock Text="4" FontWeight="Bold" Foreground="#A78BFA" FontSize="12"/><TextBlock Grid.Column="1" Text="Greater or equal (&gt;=)" FontSize="12" Foreground="{DynamicResource SubText}"/>
                                        </Grid>
                                        <Grid Margin="0,0,0,4"><Grid.ColumnDefinitions><ColumnDefinition Width="30"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                            <TextBlock Text="5" FontWeight="Bold" Foreground="#A78BFA" FontSize="12"/><TextBlock Grid.Column="1" Text="Less or equal (&lt;=)" FontSize="12" Foreground="{DynamicResource SubText}"/>
                                        </Grid>
                                        <Grid Margin="0,0,0,4"><Grid.ColumnDefinitions><ColumnDefinition Width="30"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                            <TextBlock Text="6" FontWeight="Bold" Foreground="#A78BFA" FontSize="12"/><TextBlock Grid.Column="1" Text="Contains (LIKE %x%)" FontSize="12" Foreground="{DynamicResource SubText}"/>
                                        </Grid>
