<Window x:Class="PayrixLauncher.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="460" Height="680"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">

    <Border Background="#FFFFFF" CornerRadius="20">
        <Border.Effect>
            <DropShadowEffect BlurRadius="48" Opacity="0.22" Color="#000000" ShadowDepth="0"/>
        </Border.Effect>

        <Grid>
            <!-- Close button -->
            <TextBlock x:Name="CloseBtn" Text="✕" FontSize="14"
                       Foreground="#AEAEB2" HorizontalAlignment="Right" VerticalAlignment="Top"
                       Margin="0,16,18,0" Cursor="Hand"
                       MouseLeftButtonDown="CloseBtn_MouseLeftButtonDown">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="#FF3B30"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>

            <StackPanel>
                <!-- Top accent bar -->
                <Border Height="3" CornerRadius="20,20,0,0">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="#007AFF" Offset="0"/>
                            <GradientStop Color="#5856D6" Offset="0.5"/>
                            <GradientStop Color="#AF52DE" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                </Border>

                <!-- Logo — drag handle -->
                <StackPanel Margin="36,28,36,0" HorizontalAlignment="Center"
                            MouseLeftButtonDown="DragHandle_MouseLeftButtonDown"
                            Background="Transparent">
                    <Border Width="56" Height="56" CornerRadius="14" HorizontalAlignment="Center">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#007AFF" Offset="0"/>
                                <GradientStop Color="#5856D6" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="18" ShadowDepth="0" Opacity="0.32" Color="#007AFF"/>
                        </Border.Effect>
                        <TextBlock Text="⚡" FontSize="26" Foreground="White"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="Payrix Tools" FontSize="22" FontWeight="Bold"
                               Foreground="#1D1D1F"
                               FontFamily="Segoe UI Variable Text, Segoe UI, Inter"
                               HorizontalAlignment="Center" Margin="0,12,0,0"/>
                    <TextBlock Text="Sign in to your account" FontSize="12.5" Foreground="#6E6E73"
                               FontFamily="Segoe UI Variable Text, Segoe UI, Inter"
                               HorizontalAlignment="Center" Margin="0,4,0,0"/>
                </StackPanel>

                <!-- Form -->
                <StackPanel Margin="36,22,36,0">

                    <!-- Email -->
                    <TextBlock Text="Email" FontSize="11.5" FontWeight="Medium" Foreground="#6E6E73"
                               FontFamily="Segoe UI Variable Text, Segoe UI, Inter" Margin="0,0,0,6"/>
                    <TextBox x:Name="ManualEmailBox" Height="44" Padding="14,0"
                             Background="#FFFFFF" Foreground="#1D1D1F"
                             BorderBrush="#D2D2D7" BorderThickness="1.5"
                             VerticalContentAlignment="Center" FontSize="13"
                             CaretBrush="#007AFF"
                             FontFamily="Segoe UI Variable Text, Segoe UI, Inter"
                             TextChanged="EmailBox_TextChanged" KeyDown="Email_KeyDown">
                        <TextBox.Template>
                            <ControlTemplate TargetType="TextBox">
                                <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                        BorderBrush="{TemplateBinding BorderBrush}"
                                        BorderThickness="{TemplateBinding BorderThickness}"
                                        CornerRadius="10" Padding="{TemplateBinding Padding}">
                                    <ScrollViewer x:Name="PART_ContentHost" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsFocused" Value="True">
                                        <Setter TargetName="Bd" Property="BorderBrush" Value="#007AFF"/>
                                    </Trigger>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bd" Property="BorderBrush" Value="#AEAEB2"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </TextBox.Template>
                    </TextBox>

                    <!-- Password header row -->
                    <Grid Margin="0,14,0,6">
                        <TextBlock Text="Password" FontSize="11.5" FontWeight="Medium" Foreground="#6E6E73"
                                   FontFamily="Segoe UI Variable Text, Segoe UI, Inter"
                                   HorizontalAlignment="Left" VerticalAlignment="Center"/>
                        <TextBlock Text="Forgot password?" FontSize="11" Foreground="#007AFF"
                                   FontFamily="Segoe UI Variable Text, Segoe UI, Inter"
                                   HorizontalAlignment="Right" VerticalAlignment="Center"
                                   Cursor="Hand" MouseLeftButtonDown="ForgotPassword_Click">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="TextDecorations" Value="Underline"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>

                    <!-- Password field -->
                    <Grid>
                        <PasswordBox x:Name="WinPasswordBox" Height="44" Padding="14,0,46,0"
                                     Background="#FFFFFF" Foreground="#1D1D1F"
                                     BorderBrush="#D2D2D7" BorderThickness="1.5"
                                     VerticalContentAlignment="Center" FontSize="13"
                                     CaretBrush="#007AFF"
                                     FontFamily="Segoe UI Variable Text, Segoe UI, Inter"
                                     PasswordChanged="WinPasswordBox_PasswordChanged"
                                     KeyDown="Password_KeyDown">
                            <PasswordBox.Template>
                                <ControlTemplate TargetType="PasswordBox">
                                    <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                            BorderBrush="{TemplateBinding BorderBrush}"
                                            BorderThickness="{TemplateBinding BorderThickness}"
                                            CornerRadius="10" Padding="{TemplateBinding Padding}">
                                        <ScrollViewer x:Name="PART_ContentHost" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsFocused" Value="True">
                                            <Setter TargetName="Bd" Property="BorderBrush" Value="#007AFF"/>
                                        </Trigger>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Bd" Property="BorderBrush" Value="#AEAEB2"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </PasswordBox.Template>
                        </PasswordBox>
                        <TextBox x:Name="WinPasswordPlainBox" Height="44" Padding="14,0,46,0"
                                 Background="#FFFFFF" Foreground="#1D1D1F"
                                 BorderBrush="#007AFF" BorderThickness="1.5"
                                 VerticalContentAlignment="Center" FontSize="13"
                                 CaretBrush="#007AFF"
                                 FontFamily="Segoe UI Variable Text, Segoe UI, Inter"
                                 Visibility="Collapsed" KeyDown="Password_KeyDown">
                            <TextBox.Template>
                                <ControlTemplate TargetType="TextBox">
                                    <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                            BorderBrush="{TemplateBinding BorderBrush}"
                                            BorderThickness="{TemplateBinding BorderThickness}"
                                            CornerRadius="10" Padding="{TemplateBinding Padding}">
                                        <ScrollViewer x:Name="PART_ContentHost" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </TextBox.Template>
                        </TextBox>
                        <TextBlock x:Name="EyeToggle" Text="👁" FontSize="16"
                                   HorizontalAlignment="Right" VerticalAlignment="Center"
                                   Margin="0,0,14,0" Cursor="Hand" Foreground="#AEAEB2"
                                   MouseLeftButtonDown="EyeToggle_MouseLeftButtonDown">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Foreground" Value="#007AFF"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>

                    <!-- Info / Error message -->
                    <TextBlock x:Name="AuthErrorText" Text="" FontSize="11" Foreground="#FF3B30"
                               FontFamily="Segoe UI Variable Text, Segoe UI, Inter"
                               Margin="0,7,0,0" Visibility="Collapsed" TextWrapping="Wrap"/>

                    <!-- Sign In button -->
                    <Button x:Name="SsoSignInBtn" Height="46" Margin="0,14,0,0"
                            Click="SsoSignIn_Click" BorderThickness="0" Cursor="Hand" IsEnabled="False">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="BtnBorder" CornerRadius="12">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                            <GradientStop Color="#007AFF" Offset="0"/>
                                            <GradientStop Color="#5856D6" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                    <Border.Effect>
                                        <DropShadowEffect BlurRadius="14" ShadowDepth="0" Opacity="0.28" Color="#007AFF"/>
                                    </Border.Effect>
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="BtnBorder" Property="Background">
                                            <Setter.Value>
                                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                    <GradientStop Color="#0066DD" Offset="0"/>
                                                    <GradientStop Color="#4845C0" Offset="1"/>
                                                </LinearGradientBrush>
                                            </Setter.Value>
                                        </Setter>
                                    </Trigger>
                                    <Trigger Property="IsEnabled" Value="False">
                                        <Setter TargetName="BtnBorder" Property="Opacity" Value="0.45"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                        <TextBlock x:Name="SignInBtnText" Text="Sign In"
                                   Foreground="White" FontWeight="SemiBold" FontSize="14"
                                   FontFamily="Segoe UI Variable Text, Segoe UI, Inter"/>
                    </Button>
                </StackPanel>

                <!-- Divider -->
                <Grid Margin="36,18,36,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Height="1" Background="#E5E5EA" VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="1" Text="or sign in with"
                               Foreground="#AEAEB2" FontSize="11"
                               FontFamily="Segoe UI Variable Text, Segoe UI, Inter"
                               Margin="12,0"/>
                    <Border Grid.Column="2" Height="1" Background="#E5E5EA" VerticalAlignment="Center"/>
                </Grid>

                <!-- Social buttons -->
                <Grid Margin="36,14,36,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Google -->
                    <Button Grid.Column="0" Height="42" Cursor="Hand"
                            Click="GoogleLogin_Click"
                            Background="#FFFFFF" BorderBrush="#E5E5EA" BorderThickness="1.5">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                        BorderBrush="{TemplateBinding BorderBrush}"
                                        BorderThickness="{TemplateBinding BorderThickness}"
                                        CornerRadius="10">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bd" Property="Background" Value="#F5F5F7"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <TextBlock Text="G" FontSize="15" FontWeight="Bold"
                                       VerticalAlignment="Center" Margin="0,0,6,0">
                                <TextBlock.Foreground>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                        <GradientStop Color="#4285F4" Offset="0"/>
                                        <GradientStop Color="#EA4335" Offset="1"/>
                                    </LinearGradientBrush>
                                </TextBlock.Foreground>
                            </TextBlock>
                            <TextBlock Text="Google" FontSize="12" FontWeight="Medium"
                                       Foreground="#1D1D1F" VerticalAlignment="Center"
                                       FontFamily="Segoe UI Variable Text, Segoe UI, Inter"/>
                        </StackPanel>
                    </Button>

                    <!-- Microsoft -->
                    <Button Grid.Column="2" Height="42" Cursor="Hand"
                            Click="MicrosoftLogin_Click"
                            Background="#FFFFFF" BorderBrush="#E5E5EA" BorderThickness="1.5">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                        BorderBrush="{TemplateBinding BorderBrush}"
                                        BorderThickness="{TemplateBinding BorderThickness}"
                                        CornerRadius="10">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bd" Property="Background" Value="#F5F5F7"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <Grid Width="16" Height="16" Margin="0,0,6,0" VerticalAlignment="Center">
                                <Rectangle Fill="#F25022" Width="7" Height="7" HorizontalAlignment="Left" VerticalAlignment="Top"/>
                                <Rectangle Fill="#7FBA00" Width="7" Height="7" HorizontalAlignment="Right" VerticalAlignment="Top"/>
                                <Rectangle Fill="#00A4EF" Width="7" Height="7" HorizontalAlignment="Left" VerticalAlignment="Bottom"/>
                                <Rectangle Fill="#FFB900" Width="7" Height="7" HorizontalAlignment="Right" VerticalAlignment="Bottom"/>
                            </Grid>
                            <TextBlock Text="Microsoft" FontSize="12" FontWeight="Medium"
                                       Foreground="#1D1D1F" VerticalAlignment="Center"
                                       FontFamily="Segoe UI Variable Text, Segoe UI, Inter"/>
                        </StackPanel>
                    </Button>

                    <!-- Apple -->
                    <Button Grid.Column="4" Height="42" Cursor="Hand"
                            Click="AppleLogin_Click"
                            Background="#FFFFFF" BorderBrush="#E5E5EA" BorderThickness="1.5">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                        BorderBrush="{TemplateBinding BorderBrush}"
                                        BorderThickness="{TemplateBinding BorderThickness}"
                                        CornerRadius="10">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bd" Property="Background" Value="#F5F5F7"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <TextBlock Text="" FontSize="15" VerticalAlignment="Center"
                                       Foreground="#1D1D1F" Margin="0,0,6,0"
                                       FontFamily="Segoe UI Variable Text, Segoe UI, Inter"/>
                            <TextBlock Text="Apple" FontSize="12" FontWeight="Medium"
                                       Foreground="#1D1D1F" VerticalAlignment="Center"
                                       FontFamily="Segoe UI Variable Text, Segoe UI, Inter"/>
                        </StackPanel>
                    </Button>
                </Grid>

                <!-- Footer -->
                <TextBlock Text="BQE Software — Internal Tool"
                           FontSize="10.5" Foreground="#AEAEB2"
                           FontFamily="Segoe UI Variable Text, Segoe UI, Inter"
                           HorizontalAlignment="Center" Margin="0,20,0,24"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
